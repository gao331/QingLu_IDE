        如果 (标准值 == "")
        {
            返回
        }
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 目标数组.取成员数 ())
            {
                跳出循环 ()
            }
            如果 (到小写 (目标数组.取成员 (索引)) == 到小写 (标准值))
            {
                返回
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 目标数组.取成员数 ())
        目标数组.加入成员 (标准值)
    }

    方法 取JSON字符串值 <类型 = 文本型>
    参数 JSON文本 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    {
        变量 键标记 <类型 = 文本型>
        键标记 = "\"" + 键名称 + "\""
        变量 键位置 <类型 = 整数>
        键位置 = 文本类.寻找文本 (JSON文本, 键标记, 0, 真)
        如果 (键位置 < 0)
        {
            返回 ("")
        }
        变量 冒号位置 <类型 = 整数>
        冒号位置 = 文本类.寻找文本 (JSON文本, ":", 键位置 + 文本类.取文本长度 (键标记), 真)
        如果 (冒号位置 < 0)
        {
            返回 ("")
        }
        变量 起始位置 <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        起始位置 = 冒号位置 + 1
        判断循环 (起始位置 < 文本类.取文本长度 (JSON文本))
        {
            当前字符 = 文本类.取文本中间 (JSON文本, 起始位置, 1)
            如果 (当前字符 == "\"")
            {
                起始位置 = 起始位置 + 1
                跳出循环 ()
            }
            起始位置 = 起始位置 + 1
        }
        如果 (起始位置 >= 文本类.取文本长度 (JSON文本))
        {
            返回 ("")
        }
        变量 结束位置 <类型 = 整数>
        结束位置 = 起始位置
        判断循环 (结束位置 < 文本类.取文本长度 (JSON文本))
        {
            当前字符 = 文本类.取文本中间 (JSON文本, 结束位置, 1)
            如果 (当前字符 == "\"")
            {
                返回 (文本类.取文本中间 (JSON文本, 起始位置, 结束位置 - 起始位置))
            }
            结束位置 = 结束位置 + 1
        }
        返回 ("")
    }

    方法 取JSON字符串数组 <类型 = 文本数组类>
    参数 JSON文本 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    {
        变量 结果组 <类型 = 文本数组类>
        变量 键标记 <类型 = 文本型>
        键标记 = "\"" + 键名称 + "\""
        变量 键位置 <类型 = 整数>
        键位置 = 文本类.寻找文本 (JSON文本, 键标记, 0, 真)
        如果 (键位置 < 0)
        {
            返回 (结果组)
        }
        变量 左括号位置 <类型 = 整数>
        左括号位置 = 文本类.寻找文本 (JSON文本, "[", 键位置 + 文本类.取文本长度 (键标记), 真)
        如果 (左括号位置 < 0)
        {
            返回 (结果组)
        }
        变量 IC <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        IC = 左括号位置 + 1
        判断循环 (IC < 文本类.取文本长度 (JSON文本))
        {
            当前字符 = 文本类.取文本中间 (JSON文本, IC, 1)
            如果 (当前字符 == "]")
            {
                跳出循环 ()
            }
            如果 (当前字符 == "\"")
            {
                变量 起始位置 <类型 = 整数>
                变量 结束位置 <类型 = 整数>
                起始位置 = IC + 1
                结束位置 = 起始位置
                判断循环 (结束位置 < 文本类.取文本长度 (JSON文本))
                {
                    如果 (文本类.取文本中间 (JSON文本, 结束位置, 1) == "\"")
                    {
                        结果组.加入成员 (文本类.取文本中间 (JSON文本, 起始位置, 结束位置 - 起始位置))
                        IC = 结束位置
                        跳出循环 ()
                    }
                    结束位置 = 结束位置 + 1
                }
            }
            IC = IC + 1
        }
        返回 (结果组)
    }

    方法 标准化模块路径 <类型 = 文本型>
    参数 模块目录 <类型 = 文本型>
    参数 原路径 <类型 = 文本型>
    {
