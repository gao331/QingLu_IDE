        如果 (点位置 < 0)
        {
            返回 ("")
        }
        变量 根目录 <类型 = 文本型>
        变量 相对目录 <类型 = 文本型>
        根目录 = 文本类.取文本左边 (模块标识, 点位置)
        相对目录 = 文本类.取文本右边 (模块标识, 文本类.取文本长度 (模块标识) - 点位置 - 1)
        相对目录 = 替换全部文本 (相对目录, ".", "\\")
        返回 (去除末尾反斜杠 (项目目录) + "\\modules\\" + 根目录 + "\\" + 相对目录)
    }

    方法 提取接口映射文本 <类型 = 文本型>
    参数 接口JSON文本 <类型 = 文本型>
    {
        变量 结果文本 <类型 = 文本型>
        变量 查找位置 <类型 = 整数>
        查找位置 = 0
        循环判断首 ()
        {
            变量 中文键位置 <类型 = 整数>
            变量 显示键位置 <类型 = 整数>
            变量 当前键位置 <类型 = 整数>
            变量 当前键名 <类型 = 文本型>
            中文键位置 = 文本类.寻找文本 (接口JSON文本, "\"中文名称\"", 查找位置, 真)
            显示键位置 = 文本类.寻找文本 (接口JSON文本, "\"显示名称\"", 查找位置, 真)
            当前键位置 = -1
            当前键名 = ""
            如果 (中文键位置 >= 0 && (显示键位置 < 0 || 中文键位置 < 显示键位置))
            {
                当前键位置 = 中文键位置
                当前键名 = "中文名称"
            }
            否则 (显示键位置 >= 0)
            {
                当前键位置 = 显示键位置
                当前键名 = "显示名称"
            }
            如果 (当前键位置 < 0)
            {
                跳出循环 ()
            }
            变量 原生键位置 <类型 = 整数>
            原生键位置 = 文本类.寻找文本 (接口JSON文本, "\"原生名称\"", 当前键位置, 真)
            如果 (原生键位置 < 0)
            {
                跳出循环 ()
            }
            变量 显示名 <类型 = 文本型>
            变量 原生名 <类型 = 文本型>
            显示名 = 取JSON字符串值 (文本类.取文本右边 (接口JSON文本, 文本类.取文本长度 (接口JSON文本) - 当前键位置), 当前键名)
            原生名 = 取JSON字符串值 (文本类.取文本右边 (接口JSON文本, 文本类.取文本长度 (接口JSON文本) - 原生键位置), "原生名称")
            如果 (显示名 != "" && 原生名 != "")
            {
                结果文本 = 结果文本 + 显示名 + "	" + 原生名 + "\n"
            }
            查找位置 = 原生键位置 + 1
        }
        循环判断尾 (真)
        返回 (结果文本)
    }

    方法 加载项目模块 <公开>
    参数 项目目录 <类型 = 文本型>
    参数 输出回调 <类型 = 构建输出回调类>
    参数 源文件列表 <类型 = 文本数组类>
    {
        变量 模块列表 <类型 = 文本数组类>
        变量 临时列表 <类型 = 文本数组类>
        变量 索引 <类型 = 整数>
        临时列表 = 拆分列表文本 (成员_核心模块文本)
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 临时列表.取成员数 ())
            {
                跳出循环 ()
            }
            附加唯一文本 (模块列表, 临时列表.取成员 (索引))
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 临时列表.取成员数 ())
        临时列表 = 拆分列表文本 (成员_用户模块文本)
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 临时列表.取成员数 ())
            {
                跳出循环 ()
            }
            附加唯一文本 (模块列表, 临时列表.取成员 (索引))
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 临时列表.取成员数 ())
        如果 (模块列表.取成员数 () == 0)
        {
            返回
        }
        输出回调.输出文本 ("--- 模块装载阶段 ---")
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 模块列表.取成员数 ())
            {
                跳出循环 ()
            }
            变量 模块标识 <类型 = 文本型>
            变量 模块目录 <类型 = 文本型>
            变量 模块JSON路径 <类型 = 文本型>
            变量 接口JSON路径 <类型 = 文本型>
            模块标识 = 模块列表.取成员 (索引)
            模块目录 = 取模块目录路径 (项目目录, 模块标识)
            模块JSON路径 = 模块目录 + "\\模块.json"
            接口JSON路径 = 模块目录 + "\\接口.json"
            如果 (内部_文件是否存在 (模块JSON路径) == 假)
            {
                输出回调.输出文本 ("警告: 未找到模块.json -> " + 模块标识)
            }
            否则
            {
                变量 模块JSON文本 <类型 = 文本型>
                模块JSON文本 = 内部_读入文本文件 (模块JSON路径)
                变量 包含目录组 <类型 = 文本数组类>
                变量 库目录组 <类型 = 文本数组类>
                变量 链接库组 <类型 = 文本数组类>
                变量 源码文件组 <类型 = 文本数组类>
                变量 子索引 <类型 = 整数>
                包含目录组 = 取JSON字符串数组 (模块JSON文本, "包含目录")
                子索引 = 0
                循环判断首 ()
                {
                    如果 (子索引 >= 包含目录组.取成员数 ())
                    {
                        跳出循环 ()
                    }
                    附加唯一文本 (成员_包含目录, 标准化模块路径 (模块目录, 包含目录组.取成员 (子索引)))
                    子索引 = 子索引 + 1
                }
                循环判断尾 (子索引 < 包含目录组.取成员数 ())
                库目录组 = 取JSON字符串数组 (模块JSON文本, "库目录")
                子索引 = 0
                循环判断首 ()
                {
                    如果 (子索引 >= 库目录组.取成员数 ())
                    {
                        跳出循环 ()
                    }
                    附加唯一文本 (成员_库目录, 标准化模块路径 (模块目录, 库目录组.取成员 (子索引)))
                    子索引 = 子索引 + 1
                }
                循环判断尾 (子索引 < 库目录组.取成员数 ())
                链接库组 = 取JSON字符串数组 (模块JSON文本, "链接库")
                子索引 = 0
                循环判断首 ()
                {
                    如果 (子索引 >= 链接库组.取成员数 ())
                    {
                        跳出循环 ()
                    }
                    附加唯一文本 (成员_链接库, 标准化链接库名称 (链接库组.取成员 (子索引)))
                    子索引 = 子索引 + 1
                }
                循环判断尾 (子索引 < 链接库组.取成员数 ())
                源码文件组 = 取JSON字符串数组 (模块JSON文本, "源码文件")
                子索引 = 0
                循环判断首 ()
                {
                    如果 (子索引 >= 源码文件组.取成员数 ())
                    {
                        跳出循环 ()
                    }
                    附加唯一文本 (源文件列表, 标准化模块路径 (模块目录, 源码文件组.取成员 (子索引)))
                    子索引 = 子索引 + 1
                }
                循环判断尾 (子索引 < 源码文件组.取成员数 ())
                如果 (内部_文件是否存在 (接口JSON路径))
                {
                    成员_接口映射文本 = 成员_接口映射文本 + 提取接口映射文本 (内部_读入文本文件 (接口JSON路径))
                }
                输出回调.输出文本 ("模块已装载: " + 模块标识)
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 模块列表.取成员数 ())
    }

    方法 转换火山表格代码为C加加 <公开 类型 = 文本型 @禁止流程检查 = 真>
    参数 源码 <类型 = 文本型>
    参数 项目名称 <类型 = 文本型>
