    {
        @ struct SMethodInfo
        @ {
        @     CString nsName;
        @     CString nsCpp;
        @     CString className;
        @     CString classCpp;
        @     CString methodName;
        @     CString methodCpp;
        @     CString retType;
        @     CString params;
        @     CString paramOrigList;
        @     CString paramCppList;
        @     CString localOrigList;
        @     CString localCppList;
        @     CString body;
        @     BOOL isStatic;
        @     INT localCount;
        @ };
        @ struct SClassInfo
        @ {
        @     CString nsName;
        @     CString nsCpp;
        @     CString className;
        @     CString classCpp;
        @ };
        @ struct STableCodeGen
        @ {
        @     CStringArray lines;
        @     CArray<SClassInfo, SClassInfo&> classes;
        @     CArray<SMethodInfo, SMethodInfo&> methods;
        @     CString mainNs;
        @     CString mainNsCpp;
