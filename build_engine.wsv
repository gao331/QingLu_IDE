<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 构建引擎 <公开>
{
    变量 成员_编译器路径 <公开 类型 = 文本型>
    变量 成员_链接器路径 <公开 类型 = 文本型>
    变量 成员_包含目录 <公开 类型 = 文本数组类>
    变量 成员_库目录 <公开 类型 = 文本数组类>
    变量 成员_链接库 <公开 类型 = 文本数组类>
    变量 成员_预定义 <公开 类型 = 文本数组类>
    变量 成员_平台 <公开 类型 = 文本型 值 = "x64">
    变量 成员_配置 <公开 类型 = 文本型 值 = "Debug">
    变量 成员_输出类型 <公开 类型 = 文本型 值 = "exe">
    变量 成员_项目类型 <公开 类型 = 文本型 值 = "console">
    变量 成员_编译器类型 <公开 类型 = 文本型 值 = "gcc">
    变量 成员_最后输出路径 <公开 类型 = 文本型>
    变量 成员_构建耗时 <公开 类型 = 长整数>
    变量 成员_输出目录 <公开 类型 = 文本型>
    变量 成员_核心模块文本 <公开 类型 = 文本型>
    变量 成员_用户模块文本 <公开 类型 = 文本型>
    变量 成员_接口映射文本 <公开 类型 = 文本型>

    方法 初始化 <公开>
    {
        加载配置 ()
        如果 (成员_编译器路径 == "")
        {
            成员_编译器路径 = 自动查找编译器 ()
        }
    }

    方法 自动查找编译器 <公开 类型 = 文本型>
    {
        变量 运行目录 <类型 = 文本型>
        运行目录 = 环境存取类.取运行目录 ()
        变量 候选路径 <类型 = 文本型>
        候选路径 = 运行目录 + "\\huanjing\\mingw64\\bin\\g++.exe"
        如果 (内部_文件是否存在 (候选路径))
        {
            成员_编译器类型 = "gcc"
            返回 (候选路径)
        }
        候选路径 = 运行目录 + "\\mingw64\\bin\\g++.exe"
        如果 (内部_文件是否存在 (候选路径))
        {
            成员_编译器类型 = "gcc"
            返回 (候选路径)
        }
        候选路径 = "C:\\msys64\\mingw64\\bin\\g++.exe"
        如果 (内部_文件是否存在 (候选路径))
        {
            成员_编译器类型 = "gcc"
            返回 (候选路径)
        }
        候选路径 = "D:\\msys64\\mingw64\\bin\\g++.exe"
        如果 (内部_文件是否存在 (候选路径))
        {
            成员_编译器类型 = "gcc"
            返回 (候选路径)
        }
        变量 盘符组 <类型 = 文本数组类>
        盘符组.加入成员 ("C")
        盘符组.加入成员 ("D")
        盘符组.加入成员 ("E")
        盘符组.加入成员 ("F")
        变量 盘符索引 <类型 = 整数>
        盘符索引 = 0
        循环判断首 ()
        {
            如果 (盘符索引 >= 盘符组.取成员数 ())
            {
                跳出循环 ()
            }
            变量 当前盘符 <类型 = 文本型>
            当前盘符 = 盘符组.取成员 (盘符索引)
            候选路径 = 当前盘符 + ":\\Program Files\\mingw64\\bin\\g++.exe"
            如果 (内部_文件是否存在 (候选路径))
            {
                成员_编译器类型 = "gcc"
                返回 (候选路径)
            }
            候选路径 = 当前盘符 + ":\\mingw64\\bin\\g++.exe"
            如果 (内部_文件是否存在 (候选路径))
            {
                成员_编译器类型 = "gcc"
                返回 (候选路径)
            }
            盘符索引 = 盘符索引 + 1
        }
        循环判断尾 (盘符索引 < 盘符组.取成员数 ())
        变量 MSVC路径 <类型 = 文本型>
        MSVC路径 = 查找MSVC编译器 ()
        如果 (MSVC路径 != "")
        {
            成员_编译器类型 = "msvc"
            返回 (MSVC路径)
        }
        返回 ("")
    }

    方法 查找MSVC编译器 <公开 类型 = 文本型>
    {
        变量 版本组 <类型 = 文本数组类>
        版本组.加入成员 ("2022")
        版本组.加入成员 ("2019")
        版本组.加入成员 ("2017")
        变量 版本变体组 <类型 = 文本数组类>
        版本变体组.加入成员 ("Community")
        版本变体组.加入成员 ("Professional")
        版本变体组.加入成员 ("Enterprise")
        版本变体组.加入成员 ("BuildTools")
        变量 盘符组2 <类型 = 文本数组类>
        盘符组2.加入成员 ("C")
        盘符组2.加入成员 ("D")
        盘符组2.加入成员 ("E")
        变量 版本索引 <类型 = 整数>
        版本索引 = 0
        循环判断首 ()
        {
            如果 (版本索引 >= 版本组.取成员数 ())
            {
                跳出循环 ()
            }
            变量 版本目录 <类型 = 文本型>
            版本目录 = 版本组.取成员 (版本索引)
            变量 变体索引 <类型 = 整数>
            变体索引 = 0
            循环判断首 ()
            {
                如果 (变体索引 >= 版本变体组.取成员数 ())
                {
                    跳出循环 ()
                }
                变量 变体名 <类型 = 文本型>
                变体名 = 版本变体组.取成员 (变体索引)
                变量 盘符索引2 <类型 = 整数>
                盘符索引2 = 0
                循环判断首 ()
                {
                    如果 (盘符索引2 >= 盘符组2.取成员数 ())
                    {
                        跳出循环 ()
                    }
                    变量 当前盘 <类型 = 文本型>
                    当前盘 = 盘符组2.取成员 (盘符索引2)
                    变量 基础路径 <类型 = 文本型>
                    基础路径 = 当前盘 + ":\\Program Files\\Microsoft Visual Studio\\" + 版本目录 + "\\" + 变体名
                    变量 MSVC工具目录 <类型 = 文本型>
                    MSVC工具目录 = 基础路径 + "\\VC\\Tools\\MSVC"
                    变量 CL路径 <类型 = 文本型>
                    CL路径 = 在MSVC工具目录中查找CL (MSVC工具目录)
                    如果 (CL路径 != "")
                    {
                        返回 (CL路径)
                    }
                    基础路径 = 当前盘 + ":\\Program Files (x86)\\Microsoft Visual Studio\\" + 版本目录 + "\\" + 变体名
                    MSVC工具目录 = 基础路径 + "\\VC\\Tools\\MSVC"
                    CL路径 = 在MSVC工具目录中查找CL (MSVC工具目录)
                    如果 (CL路径 != "")
                    {
                        返回 (CL路径)
                    }
                    盘符索引2 = 盘符索引2 + 1
                }
                循环判断尾 (盘符索引2 < 盘符组2.取成员数 ())
                变体索引 = 变体索引 + 1
            }
            循环判断尾 (变体索引 < 版本变体组.取成员数 ())
            版本索引 = 版本索引 + 1
        }
        循环判断尾 (版本索引 < 版本组.取成员数 ())
        返回 ("")
    }

    方法 在MSVC工具目录中查找CL <类型 = 文本型>
    参数 工具目录 <类型 = 文本型>
    {
        如果 (磁盘操作类.取文件属性 (工具目录) == -1)
        {
            返回 ("")
        }
        变量 候选 <类型 = 文本型>
        候选 = 工具目录 + "\\bin\\Hostx64\\x64\\cl.exe"
        如果 (内部_文件是否存在 (候选))
        {
            返回 (候选)
        }
        候选 = 工具目录 + "\\bin\\Hostx86\\x86\\cl.exe"
        如果 (内部_文件是否存在 (候选))
        {
            返回 (候选)
        }
        返回 ("")
    }

    方法 构建项目 <公开 类型 = 逻辑型>
    参数 项目目录 <类型 = 文本型>
    参数 项目名称 <类型 = 文本型>
    参数 源文件列表 <类型 = 文本数组类>
    参数 输出回调 <类型 = 构建输出回调类>
    {
        成员_最后输出路径 = ""
        变量 开始时间 <类型 = 长整数>
        开始时间 = 常用功能类.取启动时间 ()
        变量 错误数 <类型 = 整数>
        错误数 = 0
        成员_包含目录.删除所有成员 ()
        成员_库目录.删除所有成员 ()
        成员_链接库.删除所有成员 ()
        成员_接口映射文本 = ""

        输出回调.输出文本 ("=== 构建项目: " + 项目名称 + " ===")
        输出回调.输出文本 ("源文件数: " + 到文本 (源文件列表.取成员数 ()))
        输出回调.输出文本 ("编译器: " + 成员_编译器类型 + " (" + 成员_编译器路径 + ")")
        输出回调.输出文本 ("平台: " + 成员_平台 + " | 配置: " + 成员_配置 + " | 项目类型: " + 成员_项目类型)

        如果 (成员_编译器路径 == "")
        {
            输出回调.输出文本 ("错误: 未找到编译器，请在设置中配置编译器路径。")
            返回 (假)
        }

        变量 构建目录 <类型 = 文本型>
        如果 (成员_输出目录 != "")
        {
            构建目录 = 去除末尾反斜杠 (成员_输出目录)
        }
        否则
        {
            构建目录 = 去除末尾反斜杠 (项目目录) + "\\build\\" + 成员_平台 + "\\" + 成员_配置
        }
        内部_创建目录树 (构建目录)
        输出回调.输出文本 ("输出目录: " + 构建目录)

        如果 (成员_项目类型 == "console")
        {
            准备控制台核心模块 (项目目录, 输出回调)
        }
        加载项目模块 (项目目录, 输出回调, 源文件列表)

        输出回调.输出文本 ("")
        输出回调.输出文本 ("--- 中文编译阶段 ---")
        变量 编译器 <类型 = 中文编译器>
        编译器.初始化 ()
        变量 C加加文件组 <类型 = 文本数组类>
        变量 表格源码合集 <类型 = 文本型>
        表格源码合集 = ""
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 源文件列表.取成员数 ())
            {
                跳出循环 ()
            }
            变量 源文件 <类型 = 文本型>
            源文件 = 源文件列表.取成员 (索引)
            变量 源路径 <类型 = 文本型>
            如果 (文本类.寻找文本 (源文件, ":\\", 0, 真) >= 0)
            {
                源路径 = 源文件
            }
            否则
            {
                源路径 = 项目目录 + "\\" + 源文件
            }
            如果 (内部_文件是否存在 (源路径) == 假)
            {
                输出回调.输出文本 ("错误: 源文件不存在 " + 源文件)
                错误数 = 错误数 + 1
            }
            否则
            {
                变量 源码内容 <类型 = 文本型>
                源码内容 = 内部_读入文本文件 (源路径)
                如果 (是否火山表格代码 (源码内容))
                {
                    表格源码合集 = 表格源码合集 + "\n\n# 源文件: " + 源路径 + "\n" + 源码内容
                    输出回调.输出文本 (源文件 + " -> 已加入表格代码生成队列")
                }
                否则
                {
                    变量 C加加代码 <类型 = 文本型>
                    C加加代码 = 编译器.中文转C加加 (源码内容)
                    变量 基名 <类型 = 文本型>
                    基名 = 磁盘操作类.取文件名无路径部分 (源路径)
                    变量 点位置 <类型 = 整数>
                    点位置 = 文本类.寻找文本 (基名, ".", 0, 真)
                    如果 (点位置 >= 0)
                    {
                        基名 = 文本类.取文本左边 (基名, 点位置)
                    }
                    变量 输出文件 <类型 = 文本型>
                    输出文件 = 构建目录 + "\\" + 基名 + ".cpp"
                    内部_写出文本文件 (输出文件, C加加代码)
                    C加加文件组.加入成员 (输出文件)
                    输出回调.输出文本 (源文件 + " -> " + 基名 + ".cpp")
                    输出回调.输出文本 ("转换后代码: " + C加加代码)
                }
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 源文件列表.取成员数 ())

        如果 (表格源码合集 != "")
        {
            变量 表格C加加代码 <类型 = 文本型>
            表格C加加代码 = 转换火山表格代码为C加加 (表格源码合集, 项目名称, 成员_接口映射文本)
            如果 (表格C加加代码 == "")
            {
                输出回调.输出文本 ("错误: 表格代码生成C++失败")
                返回 (假)
            }
            变量 表格输出文件 <类型 = 文本型>
            表格输出文件 = 构建目录 + "\\" + 项目名称 + "_table.cpp"
            内部_写出文本文件 (表格输出文件, 表格C加加代码)
            C加加文件组.加入成员 (表格输出文件)
            输出回调.输出文本 ("表格代码 -> " + 项目名称 + "_table.cpp")
            输出回调.输出文本 ("表格代码已生成对应C++源文件。")
        }

        如果 (错误数 > 0)
        {
            输出回调.输出文本 ("编译失败，共 " + 到文本 (错误数) + " 个错误")
            返回 (假)
        }

        如果 (C加加文件组.取成员数 () == 0)
        {
            输出回调.输出文本 ("错误: 没有可编译的源文件")
            返回 (假)
        }

        输出回调.输出文本 ("")
        输出回调.输出文本 ("--- C++ 编译阶段 ---")
        变量 目标文件组 <类型 = 文本数组类>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= C加加文件组.取成员数 ())
            {
                跳出循环 ()
            }
            变量 当前文件 <类型 = 文本型>
            当前文件 = C加加文件组.取成员 (索引)
            变量 当前基名 <类型 = 文本型>
            当前基名 = 磁盘操作类.取文件名无路径部分 (当前文件)
            变量 当前点位置 <类型 = 整数>
            当前点位置 = 文本类.寻找文本 (当前基名, ".", 0, 真)
            如果 (当前点位置 >= 0)
            {
                当前基名 = 文本类.取文本左边 (当前基名, 当前点位置)
            }
            变量 目标文件 <类型 = 文本型>
            目标文件 = 构建目录 + "\\" + 当前基名 + ".o"
            变量 编译命令 <类型 = 文本型>
            编译命令 = 构建编译命令 (当前文件, 目标文件, 项目目录, 构建目录)
            输出回调.输出文本 ("> " + 编译命令)
            变量 编译输出 <类型 = 文本型>
            变量 编译错误 <类型 = 文本型>
            变量 编译退出码 <类型 = 整数类>
            常用功能类.运行 (编译命令, 真, 程序窗口显示方式.隐藏窗口, 编译退出码, 编译输出, 编译错误, 假)
            如果 (编译输出 != "")
            {
                输出回调.输出文本 (编译输出)
            }
            如果 (编译错误 != "")
            {
                输出回调.输出错误 (编译错误)
            }
            如果 (编译退出码.值 != 0)
            {
                输出回调.输出文本 ("编译失败: " + 当前基名 + ".cpp")
                如果 (编译输出 == "" && 编译错误 == "")
                {
                    输出回调.输出文本 ("(无编译器输出)")
                }
                错误数 = 错误数 + 1
            }
            否则
            {
                目标文件组.加入成员 (目标文件)
                输出回调.输出文本 (当前基名 + ".cpp -> " + 当前基名 + ".o")
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < C加加文件组.取成员数 ())

        如果 (错误数 > 0)
        {
            返回 (假)
        }

        输出回调.输出文本 ("")
        输出回调.输出文本 ("--- 链接阶段 ---")
        变量 链接命令 <类型 = 文本型>
        链接命令 = 构建链接命令 (目标文件组, 构建目录, 项目名称)
        输出回调.输出文本 ("> " + 链接命令)
        变量 链接输出 <类型 = 文本型>
        变量 链接错误 <类型 = 文本型>
        变量 链接退出码 <类型 = 整数类>
        常用功能类.运行 (链接命令, 真, 程序窗口显示方式.隐藏窗口, 链接退出码, 链接输出, 链接错误, 假)
        如果 (链接输出 != "")
        {
            输出回调.输出文本 (链接输出)
        }
        如果 (链接错误 != "")
        {
            输出回调.输出错误 (链接错误)
        }
        如果 (链接退出码.值 != 0)
        {
            输出回调.输出文本 ("链接失败")
            返回 (假)
        }

        成员_最后输出路径 = 构建目录 + "\\" + 项目名称 + ".exe"
        成员_构建耗时 = 常用功能类.取启动时间 () - 开始时间
        输出回调.输出文本 ("")
        输出回调.输出文本 ("构建成功: " + 成员_最后输出路径)
        输出回调.输出文本 ("  耗时: " + 到文本 (成员_构建耗时) + "ms")
        返回 (真)
    }

    方法 是否火山表格代码 <公开 类型 = 逻辑型>
    参数 源码 <类型 = 文本型>
    {
        如果 (文本类.寻找文本 (源码, "包 ", 0, 真) >= 0 && 文本类.寻找文本 (源码, "类 ", 0, 真) >= 0 && 文本类.寻找文本 (源码, "方法 ", 0, 真) >= 0)
        {
            返回 (真)
        }
        如果 (文本类.寻找文本 (源码, "命名空间", 0, 真) >= 0 && 文本类.寻找文本 (源码, "类名", 0, 真) >= 0 && 文本类.寻找文本 (源码, "方法名", 0, 真) >= 0)
        {
            返回 (真)
        }
        如果 (文本类.寻找文本 (源码, "1310", 0, 真) >= 0 && 文本类.寻找文本 (源码, "返回值类型", 0, 真) >= 0)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 取裁剪文本 <公开 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 起始 <类型 = 整数>
        变量 结束 <类型 = 整数>
        变量 长度 <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        长度 = 文本类.取文本长度 (原文本)
        如果 (长度 <= 0)
        {
            返回 ("")
        }
        起始 = 0
        如果 (长度 >= 3 && 无符号字符到整数 (取字符 (原文本, 0)) == 239 && 无符号字符到整数 (取字符 (原文本, 1)) == 187 && 无符号字符到整数 (取字符 (原文本, 2)) == 191)
        {
            起始 = 3
        }
        判断循环 (起始 < 长度)
        {
            当前字符 = 文本类.取文本中间 (原文本, 起始, 1)
            如果 (当前字符 != " " && 当前字符 != "\t")
            {
                跳出循环
            }
            起始 = 起始 + 1
        }
        如果 (起始 >= 长度)
        {
            返回 ("")
        }
        结束 = 长度 - 1
        判断循环 (结束 >= 起始)
        {
            当前字符 = 文本类.取文本中间 (原文本, 结束, 1)
            如果 (当前字符 != " " && 当前字符 != "\t")
            {
                跳出循环
            }
            结束 = 结束 - 1
        }
        返回 (文本类.取文本中间 (原文本, 起始, 结束 - 起始 + 1))
    }

    方法 准备控制台核心模块 <类型 = 文本型>
