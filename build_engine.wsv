        @         if (s == _T ("滤")) return _T ("Lv");
        @         if (s == _T ("拖")) return _T ("Tuo");
        @         if (s == _T ("横")) return _T ("Heng");
        @         if (s == _T ("纵")) return _T ("Zong");
        @         if (s == _T ("向")) return _T ("Xiang");
        @         if (s == _T ("宽")) return _T ("Kuan");
        @         if (s == _T ("高")) return _T ("Gao");
        @         if (s == _T ("允")) return _T ("Yun");
        @         if (s == _T ("许")) return _T ("Xu");
        @         return _T ("");
        @     }
        @     static CString MakeNamePart (CString s)
        @     {
        @         s.Trim ();
        @         CString known = KnownNamePart (s);
        @         if (!known.IsEmpty ()) return known;
        @         CString out;
        @         for (INT i = 0; i < s.GetLength (); ++i)
        @         {
        @             TCHAR ch = s.GetAt (i);
        @             if (IsAsciiIdentChar (ch))
        @             {
        @                 out += ch;
        @             }
        @             else
        @             {
        @                 CString part = KnownCharPart (ch);
        @                 if (!part.IsEmpty ())
        @                 {
        @                     out += part;
        @                 }
        @                 else if (ch != _T (' ') && ch != _T ('\t') && ch != _T ('.'))
        @                 {
        @                     CString code;
        @                     code.Format (_T ("U%04X"), (UINT)ch);
        @                     out += code;
        @                 }
        @             }
        @         }
        @         if (out.IsEmpty ()) out = _T ("item");
        @         if (out.GetAt (0) >= _T ('0') && out.GetAt (0) <= _T ('9'))
        @             out = _T ("n_") + out;
        @         return out;
        @     }
        @     static CString MakeCppName (CString s)
        @     {
        @         return MakeNamePart (s);
        @     }
        @     static CString MakeCppNamespace (CString ns)
        @     {
        @         ns.Trim ();
        @         if (ns == _T ("火山.程序")) return _T ("volcano_app");
        @         if (ns == _T ("火山.基础")) return _T ("volcano_base");
        @         if (ns == _T ("火山.MFC界面基本类")) return _T ("volcano_MFCJieMian_base");
        @         if (ns == _T ("火山.视窗界面基本类")) return _T ("volcano_ShiChuangJieMian_base");
        @         if (ns == _T ("控制台.程序")) return _T ("KongZhiTai_app");
        @         CString out;
        @         INT start = 0;
        @         while (start <= ns.GetLength ())
        @         {
        @             INT pos = ns.Find (_T ('.'), start);
        @             CString seg = (pos < 0 ? ns.Mid (start) : ns.Mid (start, pos - start));
        @             seg.Trim ();
        @             if (!seg.IsEmpty ())
        @             {
        @                 if (!out.IsEmpty ()) out += _T ("_");
        @                 out += MakeNamePart (seg);
        @             }
        @             if (pos < 0) break;
        @             start = pos + 1;
        @         }
        @         if (out.IsEmpty ()) out = _T ("user_app");
        @         return out;
        @     }
        @     static CString IndexName (LPCTSTR prefix, INT index)
        @     {
        @         CString s;
        @         s.Format (_T ("%s%d"), prefix, index);
        @         return s;
        @     }
        @     CString GetNsCpp (const CString& ns)
        @     {
        @         for (INT i = 0; i < nsOrig.GetSize (); ++i)
        @         {
        @             if (nsOrig [i] == ns)
        @                 return nsCpp [i];
        @         }
        @         CString code = MakeCppNamespace (ns);
        @         nsOrig.Add (ns);
        @         nsCpp.Add (code);
        @         return code;
        @     }
        @     CString GetClassCpp (const CString& ns, const CString& cls)
        @     {
        @         for (INT i = 0; i < classes.GetSize (); ++i)
        @         {
        @             if (classes [i].nsName == ns && classes [i].className == cls)
        @                 return classes [i].classCpp;
        @         }
        @         return _T ("");
        @     }
        @     static CString ListItem (const CString& list, INT index)
        @     {
        @         INT start = 0;
        @         INT cur = 0;
        @         while (start <= list.GetLength ())
        @         {
        @             INT pos = list.Find (_T ('\n'), start);
        @             CString item = (pos < 0 ? list.Mid (start) : list.Mid (start, pos - start));
        @             if (cur == index)
        @                 return item;
        @             if (pos < 0)
        @                 break;
        @             start = pos + 1;
        @             cur++;
        @         }
        @         return _T ("");
        @     }
        @     static void AppendListPair (CString& origList, CString& cppList, const CString& orig, const CString& cpp)
        @     {
        @         if (!origList.IsEmpty ())
        @         {
        @             origList += _T ("\n");
        @             cppList += _T ("\n");
        @         }
        @         origList += orig;
        @         cppList += cpp;
        @     }
        @     static CString ReplaceKnownNames (CString text, const SMethodInfo& mi)
        @     {
        @         INT index = 0;
        @         while (TRUE)
        @         {
        @             CString orig = ListItem (mi.paramOrigList, index);
        @             CString cpp = ListItem (mi.paramCppList, index);
        @             if (orig.IsEmpty ())
        @                 break;
        @             text.Replace (orig, cpp);
        @             index++;
        @         }
        @         index = 0;
        @         while (TRUE)
        @         {
        @             CString orig = ListItem (mi.localOrigList, index);
        @             CString cpp = ListItem (mi.localCppList, index);
        @             if (orig.IsEmpty ())
        @                 break;
        @             text.Replace (orig, cpp);
        @             index++;
        @         }
        @         return text;
        @     }
        @     CString ReplaceModuleNames (CString text)
        @     {
        @         INT index = 0;
        @         while (TRUE)
        @         {
        @             CString orig = ListItem (moduleOrigList, index);
        @             CString cpp = ListItem (moduleCppList, index);
        @             if (orig.IsEmpty ())
        @                 break;
        @             text.Replace (orig, cpp);
        @             index++;
        @         }
        @         return text;
        @     }
        @     static void AddSemiIfNeeded (CString& s)
        @     {
        @         CString t = s;
        @         t.Trim ();
        @         if (t.IsEmpty ()) return;
        @         CString r = t.Right (1);
        @         if (r != _T (";") && r != _T ("{") && r != _T ("}") && r != _T (":"))
        @             s += _T (";");
        @     }
        @     static void SplitTableTokens (CString src, CStringArray& tokens)
        @     {
        @         src.Replace (_T ("\r\n"), _T ("\n"));
        @         src.Replace (_T ("\r"), _T ("\n"));
        @         src.Replace (_T ("1310"), _T ("\n"));
        @         INT start = 0;
        @         while (start <= src.GetLength ())
        @         {
        @             INT pos = src.Find (_T ('\n'), start);
        @             CString line = (pos < 0 ? src.Mid (start) : src.Mid (start, pos - start));
        @             INT colStart = 0;
        @             while (colStart <= line.GetLength ())
        @             {
        @                 while (colStart < line.GetLength () && (line.GetAt (colStart) == _T (' ') || line.GetAt (colStart) == _T ('\t')))
        @                     colStart++;
        @                 if (colStart >= line.GetLength ())
        @                     break;
        @                 INT colEnd = colStart;
        @                 INT spaceRun = 0;
        @                 while (colEnd < line.GetLength ())
        @                 {
        @                     TCHAR ch = line.GetAt (colEnd);
        @                     if (ch == _T ('\t'))
        @                         break;
        @                     if (ch == _T (' '))
        @                     {
        @                         spaceRun++;
        @                         if (spaceRun >= 2)
        @                             break;
        @                     }
        @                     else
        @                     {
        @                         spaceRun = 0;
        @                     }
        @                     colEnd++;
        @                 }
        @                 CString token = line.Mid (colStart, colEnd - colStart);
        @                 token.Trim ();
        @                 if (!token.IsEmpty ())
        @                     tokens.Add (token);
        @                 colStart = colEnd;
        @             }
        @             if (pos < 0)
        @                 break;
        @             start = pos + 1;
        @         }
        @     }
        @     static CString NormalizeSavedTableText (CString src)
        @     {
        @         if (src.Find (_T ("包 ")) >= 0 && src.Find (_T ("类 ")) >= 0 && src.Find (_T ("方法 ")) >= 0)
        @             return src;
        @         if (src.Find (_T ("命名空间")) < 0 || src.Find (_T ("类名")) < 0 || src.Find (_T ("方法名")) < 0)
        @             return src;
        @         CStringArray tokens;
        @         SplitTableTokens (src, tokens);
        @         CString ns = _T ("控制台.程序");
        @         CString cls = _T ("程序启动类");
        @         CString method = _T ("主程序函数");
        @         CString retType = _T ("整数");
        @         BOOL methodStatic = FALSE;
        @         CString body;
        @         for (INT i = 0; i < tokens.GetSize (); ++i)
        @         {
        @             CString t = Trim (tokens [i]);
        @             if (t == _T ("命名空间"))
        @             {
        @                 INT p = i + 1;
        @                 CString v = NextValueToken (tokens, p);
        @                 if (!v.IsEmpty ()) ns = v;
        @             }
        @             else if (t == _T ("类名"))
        @             {
        @                 INT p = i + 1;
        @                 CString v = NextValueToken (tokens, p);
        @                 if (!v.IsEmpty ()) cls = v;
        @             }
        @             else if (t == _T ("方法名"))
        @             {
        @                 INT p = i + 1;
        @                 CString v = NextValueToken (tokens, p);
        @                 if (!v.IsEmpty ()) method = v;
        @             }
        @             else if (t == _T ("返回值类型:") || t == _T ("返回值类型"))
        @             {
        @                 INT p = i + 1;
        @                 CString v = NextValueToken (tokens, p);
        @                 if (!v.IsEmpty ()) retType = v;
        @             }
        @             else if ((IsReturnStatement (t) || StartsWith (t, _T ("如果")) || StartsWith (t, _T ("否则")) || StartsWith (t, _T ("变量 "))) && !IsHeaderToken (t))
        @             {
        @                 if (!body.IsEmpty ()) body += _T ("\n");
        @                 body += _T ("        ") + t;
        @             }
        @         }
        @         if (body.IsEmpty ())
        @             body = _T ("        返回 (0)");
        @         CString out;
        @         out += _T ("包 ") + ns + _T ("\n\n");
        @         out += _T ("类 ") + cls + _T (" <公开>\n{\n");
        @         out += _T ("    方法 ") + method + _T (" <公开 ");
        @         if (methodStatic)
        @             out += _T ("静态 ");
        @         out += _T ("类型 = ") + retType + _T (">\n    {\n");
        @         out += body + _T ("\n");
        @         out += _T ("    }\n}\n");
        @         return out;
        @     }
        @     CString ConvertBodyLine (CString line, SMethodInfo& mi)
        @     {
        @         CString indent;
        @         INT n = 0;
        @         while (n < line.GetLength () && (line.GetAt (n) == _T (' ') || line.GetAt (n) == _T ('\t')))
        @         {
        @             indent += line.GetAt (n);
        @             n++;
        @         }
        @         CString t = line.Mid (n);
        @         t.TrimRight ();
        @         CString tt = t;
        @         tt.Trim ();
        @         if (tt.IsEmpty ()) return _T ("");
        @         if (IsReturnStatement (tt))
        @         {
        @             tt = CString (_T ("return")) + tt.Mid (2);
        @         }
        @         else if (StartsWith (tt, _T ("如果")))
        @         {
        @             tt = CString (_T ("if")) + tt.Mid (2);
        @         }
        @         else if (StartsWith (tt, _T ("否则")))
        @         {
        @             CString rest = tt.Mid (2);
        @             rest.TrimLeft ();
        @             if (StartsWith (rest, _T ("(")))
        @                 tt = CString (_T ("else if ")) + rest;
        @             else
        @                 tt = CString (_T ("else")) + (rest.IsEmpty () ? CString (_T ("")) : CString (_T (" ")) + rest);
        @         }
        @         else if (StartsWith (tt, _T ("变量 ")))
        @         {
        @             CString name = TokenAfter (tt, _T ("变量 "));
        @             CString typeName = MapType (GetAttr (tt, _T ("类型"), _T ("整数")));
        @             CString localCpp = MakeCppName (name);
        @             mi.localCount++;
        @             AppendListPair (mi.localOrigList, mi.localCppList, name, localCpp);
        @             tt = typeName + _T (" ") + localCpp;
        @             AddSemiIfNeeded (tt);
        @             return indent + tt;
        @         }
        @         tt = ReplaceKnownNames (tt, mi);
        @         tt = ReplaceModuleNames (tt);
        @         tt.Replace (_T ("."), _T ("::"));
        @         AddSemiIfNeeded (tt);
        @         return indent + tt;
        @     }
        @     void LoadModuleMap (CString text)
        @     {
        @         text.Replace (_T ("\r\n"), _T ("\n"));
        @         text.Replace (_T ("\r"), _T ("\n"));
        @         INT start = 0;
        @         while (start <= text.GetLength ())
        @         {
        @             INT pos = text.Find (_T ('\n'), start);
        @             CString line = (pos < 0 ? text.Mid (start) : text.Mid (start, pos - start));
        @             line.Trim ();
        @             if (!line.IsEmpty ())
        @             {
        @                 INT tabPos = line.Find (_T ('\t'));
        @                 if (tabPos > 0 && tabPos < line.GetLength () - 1)
        @                 {
        @                     CString orig = line.Left (tabPos);
        @                     CString cpp = line.Mid (tabPos + 1);
        @                     orig.Trim ();
        @                     cpp.Trim ();
        @                     if (!orig.IsEmpty () && !cpp.IsEmpty ())
        @                         AppendListPair (moduleOrigList, moduleCppList, orig, cpp);
        @                 }
        @             }
        @             if (pos < 0)
        @                 break;
        @             start = pos + 1;
        @         }
        @     }
        @     void SplitLines (CString src)
        @     {
        @         src = NormalizeSavedTableText (src);
        @         src.Replace (_T ("\r\n"), _T ("\n"));
        @         src.Replace (_T ("\r"), _T ("\n"));
        @         INT start = 0;
        @         while (start <= src.GetLength ())
        @         {
        @             INT pos = src.Find (_T ('\n'), start);
        @             CString line = (pos < 0 ? src.Mid (start) : src.Mid (start, pos - start));
        @             lines.Add (line);
        @             if (pos < 0) break;
        @             start = pos + 1;
        @         }
        @     }
        @     BOOL HasClass (const CString& ns, const CString& cls)
        @     {
        @         for (INT i = 0; i < classes.GetSize (); ++i)
        @             if (classes [i].nsName == ns && classes [i].className == cls) return TRUE;
        @         return FALSE;
        @     }
        @     void AddClass (const CString& ns, const CString& cls)
        @     {
        @         if (cls.IsEmpty () || HasClass (ns, cls)) return;
        @         SClassInfo ci;
        @         ci.nsName = ns;
        @         ci.nsCpp = GetNsCpp (ns);
        @         ci.className = cls;
        @         ci.classCpp = MakeCppName (cls);
        @         classes.Add (ci);
        @     }
        @     void Parse (CString src)
        @     {
        @         SplitLines (src);
        @         CString curNs = _T ("user_app");
        @         CString curClass;
        @         mainIsStatic = FALSE;
        @         mainMethodIndex = -1;
        @         for (INT i = 0; i < lines.GetSize (); ++i)
        @         {
        @             CString raw = lines [i];
        @             CString t = Trim (raw);
        @             if (StartsWith (t, _T ("#"))) continue;
        @             if (StartsWith (t, _T ("包 ")))
        @             {
        @                 curNs = NsFromPackage (TokenAfter (t, _T ("包 ")));
        @             }
        @             else if (StartsWith (t, _T ("类 ")))
        @             {
        @                 curClass = TokenAfter (t, _T ("类 "));
        @                 AddClass (curNs, curClass);
        @             }
        @             else if (StartsWith (t, _T ("方法 ")) && !curClass.IsEmpty ())
        @             {
        @                 SMethodInfo mi;
        @                 mi.nsName = curNs;
        @                 mi.nsCpp = GetNsCpp (curNs);
        @                 mi.className = curClass;
        @                 mi.classCpp = GetClassCpp (curNs, curClass);
        @                 mi.methodName = TokenAfter (t, _T ("方法 "));
        @                 mi.methodCpp = MakeCppName (mi.methodName);
        @                 mi.retType = MapType (GetAttr (t, _T ("类型"), _T ("空")));
        @                 mi.params = _T ("");
        @                 mi.paramOrigList = _T ("");
        @                 mi.paramCppList = _T ("");
        @                 mi.localOrigList = _T ("");
        @                 mi.localCppList = _T ("");
        @                 mi.body = _T ("");
        @                 mi.isStatic = (t.Find (_T ("静态")) >= 0);
        @                 mi.localCount = 0;
        @                 BOOL inBody = FALSE;
        @                 INT braceDepth = 0;
        @                 for (++i; i < lines.GetSize (); ++i)
        @                 {
        @                     CString l = lines [i];
        @                     CString lt = Trim (l);
        @                     if (!inBody && StartsWith (lt, _T ("参数 ")))
        @                     {
        @                         CString pn = TokenAfter (lt, _T ("参数 "));
        @                         CString pt = MapType (GetAttr (lt, _T ("类型"), _T ("整数")));
        @                         CString pc;
        @                         INT paramIndex = (mi.paramOrigList.IsEmpty () ? 1 : 2);
        @                         for (INT pi = 0; pi < mi.paramOrigList.GetLength (); ++pi)
        @                         {
        @                             if (mi.paramOrigList.GetAt (pi) == _T ('\n')) paramIndex++;
        @                         }
        @                         pc = MakeCppName (pn);
        @                         if (!mi.params.IsEmpty ()) mi.params += _T (", ");
        @                         mi.params += pt + _T (" ") + pc;
        @                         AppendListPair (mi.paramOrigList, mi.paramCppList, pn, pc);
        @                         continue;
        @                     }
        @                     if (!inBody)
        @                     {
        @                         if (lt.Find (_T ("{")) >= 0)
        @                         {
        @                             inBody = TRUE;
        @                             braceDepth = 1;
        @                         }
        @                         continue;
        @                     }
        @                     INT opens = 0;
        @                     INT closes = 0;
        @                     for (INT c = 0; c < l.GetLength (); ++c)
        @                     {
        @                         if (l.GetAt (c) == _T ('{')) opens++;
        @                         else if (l.GetAt (c) == _T ('}')) closes++;
        @                     }
        @                     if (braceDepth == 1 && closes > opens && lt == _T ("}"))
        @                         break;
        @                     mi.body += CString (_T ("    ")) + ConvertBodyLine (l, mi) + _T ("\n");
        @                     braceDepth += opens - closes;
        @                     if (braceDepth <= 0)
        @                         break;
        @                 }
        @                 methods.Add (mi);
        @                 if (IsEntryMethodName (mi.methodName) && mainMethod.IsEmpty ())
        @                 {
        @                     mainNs = mi.nsName;
        @                     mainNsCpp = mi.nsCpp;
        @                     mainClass = mi.className;
        @                     mainClassCpp = mi.classCpp;
        @                     mainMethod = mi.methodName;
        @                     mainMethodCpp = mi.methodCpp;
        @                     mainIsStatic = mi.isStatic;
        @                     mainMethodIndex = methods.GetSize () - 1;
        @                 }
        @             }
        @         }
        @     }
        @     void ResolveMethodCalls ()
        @     {
        @         for (INT i = 0; i < methods.GetSize (); ++i)
        @         {
        @             for (INT j = 0; j < methods.GetSize (); ++j)
        @             {
        @                 CString from = methods [j].className + _T ("::") + methods [j].methodName;
        @                 CString to = methods [j].nsCpp + _T ("::") + methods [j].classCpp + _T ("::") + methods [j].methodCpp;
        @                 methods [i].body.Replace (from, to);
        @             }
        @         }
        @     }
        @     CString Generate ()
        @     {
        @         ResolveMethodCalls ();
        @         CString out;
        @         out += _T ("// Generated by cc开发IDE table-code compiler\r\n");
        @         out += _T ("#include <iostream>\r\n#include <string>\r\n\r\n");
        @         for (INT c = 0; c < classes.GetSize (); ++c)
        @         {
        @             out += CString (_T ("namespace ")) + classes [c].nsCpp + _T (" {\r\n");
        @             out += CString (_T ("class ")) + classes [c].classCpp + _T ("\r\n{\r\npublic:\r\n");
        @             for (INT m = 0; m < methods.GetSize (); ++m)
        @             {
        @                 if (methods [m].nsName == classes [c].nsName && methods [m].className == classes [c].className)
        @                 {
        @                     if (m == mainMethodIndex)
        @                         continue;
        @                     out += _T ("    ");
        @                     if (methods [m].isStatic) out += _T ("static ");
        @                     out += methods [m].retType + _T (" ") + methods [m].methodCpp + _T ("(") + methods [m].params + _T (");\r\n");
        @                 }
        @             }
        @             out += _T ("};\r\n}\r\n\r\n");
        @         }
        @         for (INT m2 = 0; m2 < methods.GetSize (); ++m2)
        @         {
        @             if (m2 == mainMethodIndex)
        @                 continue;
        @             out += methods [m2].retType + _T (" ") + methods [m2].nsCpp + _T ("::") + methods [m2].classCpp + _T ("::") + methods [m2].methodCpp + _T ("(") + methods [m2].params + _T (")\r\n{\r\n");
        @             out += methods [m2].body;
        @             out += _T ("}\r\n\r\n");
        @         }
        @         if (mainMethodIndex >= 0 && mainMethodIndex < methods.GetSize ())
        @         {
        @             out += _T ("int main()\r\n{\r\n");
        @             out += methods [mainMethodIndex].body;
        @             out += _T ("}\r\n");
        @         }
        @         return out;
        @     }
        @ };
        @ STableCodeGen gen;
        @ gen.LoadModuleMap (@<接口映射文本>.GetText ());
        @ gen.Parse (@<源码>.GetText ());
        @ CVolString result;
        @ result.SetText (gen.Generate ());
        @ return result;
    }

    方法 构建编译命令 <公开 类型 = 文本型>
    参数 源文件 <类型 = 文本型>
    参数 目标文件 <类型 = 文本型>
    参数 项目目录 <类型 = 文本型>
    参数 构建目录 <类型 = 文本型>
    {
        变量 清理项目目录 <类型 = 文本型>
        清理项目目录 = 去除末尾反斜杠 (项目目录)
        变量 清理构建目录 <类型 = 文本型>
        清理构建目录 = 去除末尾反斜杠 (构建目录)
        变量 命令 <类型 = 文本型>
        如果 (成员_编译器类型 == "msvc")
        {
            命令 = "\"" + 成员_编译器路径 + "\""
            命令 = 命令 + " /nologo /EHsc /std:c++17 /utf-8 /c"
            如果 (成员_配置 == "Debug")
            {
                命令 = 命令 + " /Zi /Od /DDEBUG"
            }
            否则
            {
                命令 = 命令 + " /O2 /DNDEBUG"
            }
            命令 = 命令 + " /I\"" + 清理项目目录 + "\""
            命令 = 命令 + " /I\"" + 清理构建目录 + "\""
            变量 MSVC包含索引 <类型 = 整数>
            MSVC包含索引 = 0
            循环判断首 ()
            {
                如果 (MSVC包含索引 >= 成员_包含目录.取成员数 ())
                {
                    跳出循环 ()
                }
                命令 = 命令 + " /I\"" + 去除末尾反斜杠 (成员_包含目录.取成员 (MSVC包含索引)) + "\""
                MSVC包含索引 = MSVC包含索引 + 1
            }
            循环判断尾 (MSVC包含索引 < 成员_包含目录.取成员数 ())
            变量 MSVC预定义索引 <类型 = 整数>
            MSVC预定义索引 = 0
            循环判断首 ()
            {
                如果 (MSVC预定义索引 >= 成员_预定义.取成员数 ())
                {
                    跳出循环 ()
                }
                命令 = 命令 + " /D" + 成员_预定义.取成员 (MSVC预定义索引)
                MSVC预定义索引 = MSVC预定义索引 + 1
            }
            循环判断尾 (MSVC预定义索引 < 成员_预定义.取成员数 ())
            命令 = 命令 + " \"" + 源文件 + "\""
            命令 = 命令 + " /Fo\"" + 目标文件 + "\""
            返回 (命令)
        }
        命令 = "\"" + 成员_编译器路径 + "\""
        命令 = 命令 + " -c"
        如果 (成员_平台 == "x64")
        {
            命令 = 命令 + " -m64"
        }
        否则
        {
            命令 = 命令 + " -m32"
        }
        如果 (成员_配置 == "Debug")
        {
            命令 = 命令 + " -g -O0 -Wall -DDEBUG"
        }
        否则
        {
            命令 = 命令 + " -O2 -DNDEBUG"
        }
        命令 = 命令 + " -I\"" + 清理项目目录 + "\""
        命令 = 命令 + " -I\"" + 清理构建目录 + "\""
        变量 包含索引 <类型 = 整数>
        包含索引 = 0
        循环判断首 ()
        {
            如果 (包含索引 >= 成员_包含目录.取成员数 ())
            {
                跳出循环 ()
            }
            命令 = 命令 + " -I\"" + 去除末尾反斜杠 (成员_包含目录.取成员 (包含索引)) + "\""
            包含索引 = 包含索引 + 1
        }
        循环判断尾 (包含索引 < 成员_包含目录.取成员数 ())
        变量 预定义索引 <类型 = 整数>
        预定义索引 = 0
        循环判断首 ()
        {
            如果 (预定义索引 >= 成员_预定义.取成员数 ())
            {
                跳出循环 ()
            }
            命令 = 命令 + " -D" + 成员_预定义.取成员 (预定义索引)
            预定义索引 = 预定义索引 + 1
        }
        循环判断尾 (预定义索引 < 成员_预定义.取成员数 ())
        命令 = 命令 + " -std=c++17 -finput-charset=UTF-8"
        命令 = 命令 + " \"" + 源文件 + "\""
        命令 = 命令 + " -o \"" + 目标文件 + "\""
        返回 (命令)
    }

    方法 构建链接命令 <公开 类型 = 文本型>
    参数 目标文件组 <类型 = 文本数组类>
    参数 构建目录 <类型 = 文本型>
    参数 项目名称 <类型 = 文本型>
    {
        变量 清理构建目录2 <类型 = 文本型>
        清理构建目录2 = 去除末尾反斜杠 (构建目录)
        变量 命令 <类型 = 文本型>
        变量 输出扩展 <类型 = 文本型>
        如果 (成员_输出类型 == "dll")
        {
            输出扩展 = ".dll"
        }
        否则 (成员_输出类型 == "lib")
        {
            输出扩展 = ".a"
        }
        否则
        {
            输出扩展 = ".exe"
        }
        如果 (成员_编译器类型 == "msvc")
        {
            命令 = "\"" + 成员_编译器路径 + "\" /nologo"
            如果 (成员_输出类型 == "dll")
            {
                命令 = 命令 + " /LD"
            }
            变量 MSVC目标索引 <类型 = 整数>
            MSVC目标索引 = 0
            循环判断首 ()
            {
                如果 (MSVC目标索引 >= 目标文件组.取成员数 ())
                {
                    跳出循环 ()
                }
                命令 = 命令 + " \"" + 目标文件组.取成员 (MSVC目标索引) + "\""
                MSVC目标索引 = MSVC目标索引 + 1
            }
            循环判断尾 (MSVC目标索引 < 目标文件组.取成员数 ())
            命令 = 命令 + " /Fe\"" + 清理构建目录2 + "\\" + 项目名称 + 输出扩展 + "\""
            命令 = 命令 + " /link"
            变量 MSVC库目录索引 <类型 = 整数>
            MSVC库目录索引 = 0
            循环判断首 ()
            {
                如果 (MSVC库目录索引 >= 成员_库目录.取成员数 ())
                {
                    跳出循环 ()
                }
                命令 = 命令 + " /LIBPATH:\"" + 去除末尾反斜杠 (成员_库目录.取成员 (MSVC库目录索引)) + "\""
                MSVC库目录索引 = MSVC库目录索引 + 1
            }
            循环判断尾 (MSVC库目录索引 < 成员_库目录.取成员数 ())
            变量 MSVC链接库索引 <类型 = 整数>
            MSVC链接库索引 = 0
            循环判断首 ()
            {
                如果 (MSVC链接库索引 >= 成员_链接库.取成员数 ())
                {
                    跳出循环 ()
                }
                命令 = 命令 + " " + 成员_链接库.取成员 (MSVC链接库索引)
                MSVC链接库索引 = MSVC链接库索引 + 1
            }
            循环判断尾 (MSVC链接库索引 < 成员_链接库.取成员数 ())
            如果 (成员_项目类型 == "window")
            {
                命令 = 命令 + " /SUBSYSTEM:WINDOWS"
            }
            否则
            {
                命令 = 命令 + " /SUBSYSTEM:CONSOLE"
            }
            返回 (命令)
        }
        命令 = "\"" + 成员_编译器路径 + "\""
        如果 (成员_平台 == "x64")
        {
            命令 = 命令 + " -m64"
        }
        否则
        {
            命令 = 命令 + " -m32"
        }
        如果 (成员_输出类型 == "dll")
        {
            命令 = 命令 + " -shared"
        }
        否则
        {
            命令 = 命令 + " -static"
        }
        如果 (成员_项目类型 == "window")
        {
            命令 = 命令 + " -mwindows"
        }
        变量 目标索引 <类型 = 整数>
        目标索引 = 0
        循环判断首 ()
        {
            如果 (目标索引 >= 目标文件组.取成员数 ())
            {
                跳出循环 ()
            }
            命令 = 命令 + " \"" + 目标文件组.取成员 (目标索引) + "\""
            目标索引 = 目标索引 + 1
        }
        循环判断尾 (目标索引 < 目标文件组.取成员数 ())
        变量 库目录索引 <类型 = 整数>
        库目录索引 = 0
        循环判断首 ()
        {
            如果 (库目录索引 >= 成员_库目录.取成员数 ())
            {
                跳出循环 ()
            }
            命令 = 命令 + " -L\"" + 去除末尾反斜杠 (成员_库目录.取成员 (库目录索引)) + "\""
            库目录索引 = 库目录索引 + 1
        }
        循环判断尾 (库目录索引 < 成员_库目录.取成员数 ())
        变量 链接库索引 <类型 = 整数>
        链接库索引 = 0
        循环判断首 ()
        {
            如果 (链接库索引 >= 成员_链接库.取成员数 ())
            {
                跳出循环 ()
            }
            命令 = 命令 + " -l" + 成员_链接库.取成员 (链接库索引)
            链接库索引 = 链接库索引 + 1
        }
        循环判断尾 (链接库索引 < 成员_链接库.取成员数 ())
        命令 = 命令 + " -o \"" + 清理构建目录2 + "\\" + 项目名称 + 输出扩展 + "\""
        返回 (命令)
    }

    方法 运行程序 <公开 类型 = 逻辑型>
    参数 输出回调 <类型 = 构建输出回调类>
    {
        如果 (成员_最后输出路径 == "" || 内部_文件是否存在 (成员_最后输出路径) == 假)
        {
            输出回调.输出文本 ("错误: 没有可运行的程序，请先编译。")
            返回 (假)
        }
        输出回调.输出文本 ("")
        输出回调.输出文本 ("--- 运行程序 ---")
        输出回调.输出文本 ("> " + 成员_最后输出路径)
        变量 运行输出 <类型 = 文本型>
        变量 运行错误 <类型 = 文本型>
        变量 运行退出码 <类型 = 整数类>
        如果 (成员_项目类型 == "window")
        {
            常用功能类.运行 ("\"" + 成员_最后输出路径 + "\"", 真, 程序窗口显示方式.普通激活, 运行退出码, 运行输出, 运行错误, 假)
        }
        否则
        {
            常用功能类.运行 ("\"" + 成员_最后输出路径 + "\"", 真, 程序窗口显示方式.隐藏窗口, 运行退出码, 运行输出, 运行错误, 假)
        }
        如果 (运行输出 != "")
        {
            输出回调.输出文本 (运行输出)
        }
        如果 (运行错误 != "")
        {
            输出回调.输出错误 (运行错误)
        }
        输出回调.输出文本 ("程序退出码: " + 到文本 (运行退出码.值))
        返回 (运行退出码.值 == 0)
    }

    方法 加载配置 <公开>
    {
        变量 配置路径 <类型 = 文本型>
        配置路径 = 环境存取类.取运行目录 () + "\\ide_config.ini"
        成员_编译器路径 = 常用功能类.读配置项 (配置路径, "编译器", "路径", "")
        变量 类型文本 <类型 = 文本型>
        类型文本 = 常用功能类.读配置项 (配置路径, "编译器", "类型", "gcc")
        如果 (类型文本 == "msvc")
        {
            成员_编译器类型 = "msvc"
        }
        否则
        {
            成员_编译器类型 = "gcc"
        }
        成员_平台 = 常用功能类.读配置项 (配置路径, "构建", "平台", "x64")
        成员_配置 = 常用功能类.读配置项 (配置路径, "构建", "配置", "Debug")
        成员_输出类型 = 常用功能类.读配置项 (配置路径, "构建", "输出类型", "exe")
        成员_输出目录 = 常用功能类.读配置项 (配置路径, "构建", "输出目录", "")
    }

    方法 保存配置 <公开>
    {
        变量 配置路径 <类型 = 文本型>
        配置路径 = 环境存取类.取运行目录 () + "\\ide_config.ini"
        常用功能类.写配置项 (配置路径, "编译器", "路径", 成员_编译器路径)
        常用功能类.写配置项 (配置路径, "编译器", "类型", 成员_编译器类型)
        常用功能类.写配置项 (配置路径, "构建", "平台", 成员_平台)
        常用功能类.写配置项 (配置路径, "构建", "配置", 成员_配置)
        常用功能类.写配置项 (配置路径, "构建", "输出类型", 成员_输出类型)
        常用功能类.写配置项 (配置路径, "构建", "输出目录", 成员_输出目录)
    }

    方法 取编译器信息 <公开 类型 = 文本型>
    {
        如果 (成员_编译器路径 == "")
        {
            返回 ("未配置编译器")
        }
        返回 (成员_编译器类型 + ": " + 成员_编译器路径)
    }

    方法 内部_文件是否存在 <类型 = 逻辑型>
    参数 文件路径 <类型 = 文本型>
    {
        返回 (磁盘操作类.取文件属性 (文件路径) != -1)
    }

    方法 内部_读入文本文件 <类型 = 文本型>
    参数 文件路径 <类型 = 文本型>
    {
        变量 结果 <类型 = 文本型>
        结果 = ""
        变量 文件读写 <类型 = 文件读写类>
        如果 (文件读写.打开文件 (文件路径, 文件打开方式.读入))
        {
            结果 = 文件读写.读入文本 (-1, 文本编码类型.UTF8)
            文件读写.关闭文件 ()
        }
        返回 (结果)
    }

    方法 内部_写出文本文件 <类型 = 逻辑型>
    参数 文件路径 <类型 = 文本型>
    参数 内容 <类型 = 文本型>
    {
        返回 (写出文本文件 (内容, 文件路径, -1, 文本编码类型.UTF8))
    }

    方法 内部_创建目录树 <类型 = 逻辑型>
    参数 目录路径 <类型 = 文本型>
    {
        如果 (磁盘操作类.取文件属性 (目录路径) != -1)
        {
            返回 (真)
        }
        返回 (磁盘操作类.创建目录 (目录路径))
    }

    方法 去除末尾反斜杠 <公开 类型 = 文本型>
    参数 路径 <类型 = 文本型>
    {
        变量 局结果 <类型 = 文本型>
        局结果 = 路径
        如果 (取文本长度 (局结果) > 3)
        {
            如果 (文本类.寻找文本 (局结果, "\\", 取文本长度 (局结果) - 1, 真) >= 0)
            {
                局结果 = 文本类.取文本左边 (局结果, 取文本长度 (局结果) - 1)
            }
        }
        返回 (局结果)
    }
}

类 构建输出回调类 <公开>
{
    方法 输出文本 <公开 @虚拟方法 = 可覆盖 类型 = 整数>
    参数 文本 <类型 = 文本型>
    {
        返回 (0)
    }

    方法 输出错误 <公开 @虚拟方法 = 可覆盖 类型 = 整数>
    参数 文本 <类型 = 文本型>
    {
        返回 (输出文本 (文本))
    }
}
