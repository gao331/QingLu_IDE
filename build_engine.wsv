    方法 拆分列表文本 <公开 类型 = 文本数组类>
    参数 原文本 <类型 = 文本型>
    {
        变量 结果组 <类型 = 文本数组类>
        变量 当前项 <类型 = 文本型>
        变量 当前字符 <类型 = 文本型>
        变量 IC <类型 = 整数>
        当前项 = ""
        IC = 0
        判断循环 (IC < 文本类.取文本长度 (原文本))
        {
            当前字符 = 文本类.取文本中间 (原文本, IC, 1)
            如果 (当前字符 == "|" || 当前字符 == "," || 当前字符 == "，" || 当前字符 == ";" || 当前字符 == "；" || 当前字符 == "\n" || 当前字符 == "\r")
            {
                当前项 = 去除末尾反斜杠 (取裁剪文本 (当前项))
                如果 (当前项 != "")
                {
                    结果组.加入成员 (当前项)
                }
                当前项 = ""
            }
            否则
            {
                当前项 = 当前项 + 当前字符
            }
            IC = IC + 1
        }
        当前项 = 去除末尾反斜杠 (取裁剪文本 (当前项))
        如果 (当前项 != "")
        {
            结果组.加入成员 (当前项)
        }
        返回 (结果组)
    }

    方法 替换全部文本 <类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    参数 查找文本 <类型 = 文本型>
    参数 替换文本 <类型 = 文本型>
    {
        如果 (查找文本 == "")
        {
            返回 (原文本)
        }
        变量 结果文本 <类型 = 文本型>
        变量 剩余文本 <类型 = 文本型>
        变量 位置 <类型 = 整数>
        结果文本 = ""
        剩余文本 = 原文本
        循环判断首 ()
        {
            位置 = 文本类.寻找文本 (剩余文本, 查找文本, 0, 真)
            如果 (位置 < 0)
            {
                结果文本 = 结果文本 + 剩余文本
                跳出循环 ()
            }
            结果文本 = 结果文本 + 文本类.取文本左边 (剩余文本, 位置) + 替换文本
            剩余文本 = 文本类.取文本右边 (剩余文本, 文本类.取文本长度 (剩余文本) - 位置 - 文本类.取文本长度 (查找文本))
        }
        循环判断尾 (真)
        返回 (结果文本)
    }

    方法 附加唯一文本 <公开>
    参数 目标数组 <类型 = 文本数组类>
    参数 文本值 <类型 = 文本型>
    {
