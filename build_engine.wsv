        @     CString moduleCppList;
        @
        @     static CString Trim (CString s) { s.Trim (); return s; }
        @     static BOOL StartsWith (const CString& s, LPCTSTR p) { return s.Left ((INT)_tcslen (p)) == p; }
        @     static BOOL IsBlankToken (const CString& s)
        @     {
        @         CString t = s;
        @         t.Trim ();
        @         return t.IsEmpty ();
        @     }
        @     static BOOL IsHeaderToken (const CString& t)
        @     {
        @         return t == _T ("命名空间") || t == _T ("备注") || t == _T ("类名") || t == _T ("基础类") ||
        @             t == _T ("公开") || t == _T ("静态") || t == _T ("方法名") || t == _T ("返回值类型:") ||
        @             t == _T ("返回值类型") || t == _T ("返回值备注:") || t == _T ("返回值备注") ||
        @             t == _T ("成员变量名") || t == _T ("局部变量名") || t == _T ("参数名") ||
        @             t == _T ("类型") || t == _T ("初始值");
        @     }
        @     static BOOL IsReturnStatement (const CString& t)
        @     {
        @         return t == _T ("返回") || StartsWith (t, _T ("返回 ")) || StartsWith (t, _T ("返回(")) || StartsWith (t, _T ("返回（"));
        @     }
        @     static BOOL IsEntryMethodName (const CString& s)
        @     {
        @         return s == _T ("项目入口") || s == _T ("主程序函数") || s == _T ("启动方法");
        @     }
        @     static CString NextValueToken (CStringArray& tokens, INT& pos)
        @     {
        @         while (pos < tokens.GetSize ())
        @         {
        @             CString t = Trim (tokens [pos++]);
        @             if (IsBlankToken (t) || IsHeaderToken (t))
        @                 continue;
        @             return t;
        @         }
        @         return _T ("");
        @     }
        @     static CString TokenAfter (const CString& s, LPCTSTR p)
        @     {
        @         CString t = s.Mid ((INT)_tcslen (p));
        @         t.Trim ();
        @         INT nEnd = t.Find (_T (' '));
        @         INT nAttr = t.Find (_T ('<'));
        @         if (nEnd < 0 || (nAttr >= 0 && nAttr < nEnd)) nEnd = nAttr;
        @         if (nEnd >= 0) t = t.Left (nEnd);
        @         t.Trim ();
        @         return t;
        @     }
        @     static CString GetAttr (const CString& s, LPCTSTR key, LPCTSTR defValue)
        @     {
        @         INT n = s.Find (key);
        @         if (n < 0) return defValue;
        @         CString t = s.Mid (n + (INT)_tcslen (key));
        @         t.Trim ();
        @         if (StartsWith (t, _T ("=")))
        @         {
        @             t = t.Mid (1);
        @             t.Trim ();
        @         }
        @         INT nEnd = t.Find (_T ('>'));
        @         INT nSpace = t.Find (_T (' '));
        @         if (nEnd < 0 || (nSpace >= 0 && nSpace < nEnd)) nEnd = nSpace;
        @         if (nEnd >= 0) t = t.Left (nEnd);
        @         t.Trim ();
        @         return (t.IsEmpty () ? CString (defValue) : t);
        @     }
        @     static CString MapType (CString t)
        @     {
        @         t.Trim ();
        @         if (t == _T ("整数")) return _T ("int");
        @         if (t == _T ("长整数")) return _T ("long long");
        @         if (t == _T ("小数") || t == _T ("双精度小数")) return _T ("double");
        @         if (t == _T ("逻辑型")) return _T ("bool");
        @         if (t == _T ("文本型")) return _T ("std::string");
        @         if (t == _T ("字符")) return _T ("char");
        @         if (t == _T ("空") || t == _T ("无")) return _T ("void");
        @         return _T ("auto");
        @     }
        @     static CString NsFromPackage (CString pkg)
        @     {
        @         pkg.Trim ();
        @         if (pkg.IsEmpty ()) pkg = _T ("user_app");
        @         return pkg;
        @     }
        @     static BOOL IsAsciiIdentChar (TCHAR ch)
        @     {
        @         return (ch >= _T ('a') && ch <= _T ('z')) || (ch >= _T ('A') && ch <= _T ('Z')) || (ch >= _T ('0') && ch <= _T ('9')) || ch == _T ('_');
        @     }
