        路径文本 = 取裁剪文本 (原路径)
        路径文本 = 替换全部文本 (路径文本, "${平台}", 成员_平台)
        路径文本 = 替换全部文本 (路径文本, "${配置}", 成员_配置)
        路径文本 = 替换全部文本 (路径文本, "/", "\\")
        如果 (文本类.寻找文本 (路径文本, ":\\", 0, 真) >= 0)
        {
            返回 (路径文本)
        }
        如果 (文本类.取文本左边 (路径文本, 1) == "\\")
        {
            返回 (路径文本)
        }
        返回 (去除末尾反斜杠 (模块目录) + "\\" + 路径文本)
    }

    方法 标准化链接库名称 <类型 = 文本型>
    参数 原名称 <类型 = 文本型>
    {
        变量 结果文本 <类型 = 文本型>
        结果文本 = 取裁剪文本 (原名称)
        如果 (成员_编译器类型 == "gcc")
        {
            如果 (文本类.取文本右边 (到小写 (结果文本), 4) == ".lib")
            {
                结果文本 = 文本类.取文本左边 (结果文本, 文本类.取文本长度 (结果文本) - 4)
            }
            否则 (文本类.取文本右边 (到小写 (结果文本), 2) == ".a")
            {
                结果文本 = 文本类.取文本左边 (结果文本, 文本类.取文本长度 (结果文本) - 2)
            }
            如果 (文本类.取文本左边 (到小写 (结果文本), 3) == "lib" && 文本类.取文本长度 (结果文本) > 3)
            {
                结果文本 = 文本类.取文本右边 (结果文本, 文本类.取文本长度 (结果文本) - 3)
            }
        }
        返回 (结果文本)
    }

