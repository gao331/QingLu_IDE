    方法 计算匹配分数 <公开 类型 = 整数>
    参数 候选索引 <类型 = 整数>
    参数 查询文本 <类型 = 文本型>
    参数 宽松查询文本 <类型 = 文本型>
    {
        变量 名称 <类型 = 文本型>
        变量 名称小写 <类型 = 文本型>
        变量 全拼索引 <类型 = 文本型>
        变量 首拼索引 <类型 = 文本型>
        变量 混合索引 <类型 = 文本型>
        变量 额外索引 <类型 = 文本型>
        变量 基础分 <类型 = 整数>
        变量 名称差值 <类型 = 整数>
        名称 = 候选名称组.取成员 (候选索引)
        名称小写 = 文本类.到小写 (名称)
        全拼索引 = 候选全拼索引组.取成员 (候选索引)
        首拼索引 = 候选首拼索引组.取成员 (候选索引)
        混合索引 = 候选混合索引组.取成员 (候选索引)
        额外索引 = 候选额外索引组.取成员 (候选索引)
        如果 (查询文本 == "")
        {
            基础分 = 400
        }
        否则 (名称小写 == 查询文本)
        {
            基础分 = 1200
        }
        否则 (文本类.取文本左边 (名称小写, 文本类.取文本长度 (查询文本)) == 查询文本)
        {
            名称差值 = 文本类.取文本长度 (名称小写) - 文本类.取文本长度 (查询文本)
            如果 (名称差值 > 80)
            {
                名称差值 = 80
            }
            基础分 = 1120 - 名称差值
        }
        否则 (索引文本含前缀 (全拼索引, 查询文本) || 索引文本含前缀 (全拼索引, 宽松查询文本))
        {
            基础分 = 1010
        }
        否则 (索引文本含前缀 (首拼索引, 查询文本))
        {
            基础分 = 980
        }
        否则 (索引文本含前缀 (混合索引, 查询文本))
        {
            基础分 = 950
        }
        否则 (索引文本含前缀 (额外索引, 查询文本))
        {
            基础分 = 920
        }
        否则 (文本类.寻找文本 (名称小写, 查询文本, 0, 假) >= 0)
        {
            基础分 = 760
        }
        否则 (索引文本含片段 (全拼索引, 查询文本) || 索引文本含片段 (首拼索引, 查询文本) || 索引文本含片段 (混合索引, 查询文本) || 索引文本含片段 (额外索引, 查询文本))
        {
            基础分 = 680
        }
        如果 (基础分 <= 0)
        {
            返回 (0)
        }
        返回 (基础分 + 取候选作用域加分 (候选索引) + 取候选使用加分 (候选索引))
    }

    方法 输出排序结果 <公开>
    参数 临时索引组 <类型 = 整数数组类>
    参数 临时分数组 <类型 = 整数数组类>
    参数 最大数量 <类型 = 整数>
    参数 结果索引组 <类型 = 整数数组类>
    参数 结果分数组 <类型 = 整数数组类>
    {
        变量 已用组 <类型 = 整数数组类>
        变量 输出数量 <类型 = 整数>
        变量 最佳位置 <类型 = 整数>
        变量 最佳分数 <类型 = 整数>
        变量 IC <类型 = 整数>
        变量 当前更优 <类型 = 逻辑型>
        如果 (最大数量 <= 0)
        {
            最大数量 = 20
        }
        判断循环 (输出数量 < 最大数量)
        {
            最佳位置 = -1
            最佳分数 = -1
            IC = 0
            判断循环 (IC < 临时索引组.取成员数 ())
            {
                当前更优 = 假
                如果 (是否整数已存在 (已用组, IC) == 假)
                {
                    如果 (临时分数组.取成员 (IC) > 最佳分数)
                    {
                        当前更优 = 真
                    }
                    否则 (临时分数组.取成员 (IC) == 最佳分数 && 最佳位置 >= 0 && 文本类.取文本长度 (候选名称组.取成员 (临时索引组.取成员 (IC))) < 文本类.取文本长度 (候选名称组.取成员 (临时索引组.取成员 (最佳位置))))
                    {
                        当前更优 = 真
                    }
                }
                如果 (当前更优)
                {
                    最佳位置 = IC
                    最佳分数 = 临时分数组.取成员 (IC)
                }
                IC = IC + 1
            }
            如果 (最佳位置 < 0)
            {
                跳出循环
            }
            已用组.加入成员 (最佳位置)
            结果索引组.加入成员 (临时索引组.取成员 (最佳位置))
            结果分数组.加入成员 (临时分数组.取成员 (最佳位置))
            输出数量 = 输出数量 + 1
        }
    }

