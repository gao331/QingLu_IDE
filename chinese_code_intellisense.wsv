    }

    方法 加入唯一文本 <公开>
    参数 文本组 <类型 = 文本数组类>
    参数 文本值 <类型 = 文本型>
    {
        如果 (文本值 == "")
        {
            返回
        }
        如果 (是否文本已存在 (文本组, 文本值) == 假)
        {
            文本组.加入成员 (文本值)
        }
    }

    方法 是否文本已存在 <公开 类型 = 逻辑型>
    参数 文本组 <类型 = 文本数组类>
    参数 文本值 <类型 = 文本型>
    {
        变量 IC <类型 = 整数>
        IC = 0
        判断循环 (IC < 文本组.取成员数 ())
        {
            如果 (文本组.取成员 (IC) == 文本值)
            {
                返回 (真)
            }
            IC = IC + 1
        }
        返回 (假)
    }

    方法 是否整数已存在 <公开 类型 = 逻辑型>
    参数 整数组 <类型 = 整数数组类>
    参数 整数值 <类型 = 整数>
    {
        变量 IC <类型 = 整数>
        IC = 0
        判断循环 (IC < 整数组.取成员数 ())
        {
            如果 (整数组.取成员 (IC) == 整数值)
            {
                返回 (真)
            }
            IC = IC + 1
        }
        返回 (假)
    }

    方法 是否英文数字下划线 <公开 类型 = 逻辑型>
    参数 待判字符 <类型 = 文本型>
    {
        如果 (待判字符 == "")
        {
            返回 (假)
        }
        如果 (文本类.寻找文本 ("0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz_", 待判字符, 0, 假) >= 0)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 合并路径 <公开 类型 = 文本型>
    参数 目录 <类型 = 文本型>
    参数 子路径 <类型 = 文本型>
    {
        如果 (目录 == "")
        {
            返回 (子路径)
        }
        如果 (文本类.取文本右边 (目录, 1) == "\\" || 文本类.取文本右边 (目录, 1) == "/")
        {
            返回 (目录 + 子路径)
        }
        返回 (目录 + "\\" + 子路径)
    }

    方法 取裁剪文本 <公开 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 起始 <类型 = 整数>
        变量 结束 <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        起始 = 0
        结束 = 文本类.取文本长度 (原文本) - 1
        判断循环 (起始 <= 结束)
        {
            当前字符 = 文本类.取文本中间 (原文本, 起始, 1)
            如果 (当前字符 != " " && 当前字符 != "\t")
            {
                跳出循环
            }
            起始 = 起始 + 1
        }
        判断循环 (结束 >= 起始)
        {
            当前字符 = 文本类.取文本中间 (原文本, 结束, 1)
            如果 (当前字符 != " " && 当前字符 != "\t")
            {
                跳出循环
            }
            结束 = 结束 - 1
        }
        如果 (结束 < 起始)
        {
            返回 ("")
        }
        返回 (文本类.取文本中间 (原文本, 起始, 结束 - 起始 + 1))
    }

    方法 取列文本 <公开 类型 = 文本型>
    参数 列组 <类型 = 文本数组类>
    参数 索引 <类型 = 整数>
    {
        如果 (索引 < 0 || 索引 >= 列组.取成员数 ())
        {
            返回 ("")
        }
        返回 (取裁剪文本 (列组.取成员 (索引)))
    }

    方法 取候选类型值 <公开 类型 = 整数>
    参数 类型文本 <类型 = 文本型>
    {
        变量 文本 <类型 = 文本型>
        文本 = 取裁剪文本 (类型文本)
        如果 (文本 == "关键字")
        {
            返回 (中文智能提示候选类型.关键字项)
        }
        否则 (文本 == "类")
        {
            返回 (中文智能提示候选类型.类项)
        }
        否则 (文本 == "方法")
        {
            返回 (中文智能提示候选类型.方法项)
        }
        否则 (文本 == "变量")
        {
            返回 (中文智能提示候选类型.变量项)
        }
        否则 (文本 == "常量")
        {
            返回 (中文智能提示候选类型.常量项)
        }
        否则 (文本 == "参数")
        {
            返回 (中文智能提示候选类型.参数项)
        }
        否则 (文本 == "属性")
        {
            返回 (中文智能提示候选类型.属性项)
        }
        否则 (文本 == "片段")
        {
            返回 (中文智能提示候选类型.片段项)
        }
        返回 (中文智能提示候选类型.变量项)
    }
}
