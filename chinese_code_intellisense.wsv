    方法 载入候选词库文本 <公开 类型 = 整数>
    参数 词库文本 <类型 = 文本型>
    {
        变量 行组 <类型 = 文本数组类>
        变量 列组 <类型 = 文本数组类>
        变量 IC <类型 = 整数>
        变量 行文本 <类型 = 文本型>
        变量 类型值 <类型 = 整数>
        变量 数量 <类型 = 整数>
        拆分文本为行 (词库文本, 行组)
        IC = 0
        判断循环 (IC < 行组.取成员数 ())
        {
            行文本 = 取裁剪文本 (行组.取成员 (IC))
            如果 (行文本 != "" && 文本类.取文本左边 (行文本, 1) != "#")
            {
                拆分文本 (行文本, "|", 列组)
                如果 (列组.取成员数 () >= 1)
                {
                    类型值 = 中文智能提示候选类型.变量项
                    如果 (列组.取成员数 () >= 2)
                    {
                        类型值 = 取候选类型值 (列组.取成员 (1))
                    }
                    加入候选 (取列文本 (列组, 0), 类型值, 取列文本 (列组, 2), 取列文本 (列组, 3), 取列文本 (列组, 4), 取列文本 (列组, 5), 取列文本 (列组, 6))
                    数量 = 数量 + 1
                }
            }
            IC = IC + 1
        }
        返回 (数量)
    }

