    方法 记录候选使用 <公开>
    参数 候选索引 <类型 = 整数>
    {
        变量 名称小写 <类型 = 文本型>
        变量 类型值 <类型 = 整数>
        变量 IC <类型 = 整数>
        如果 (候选索引 < 0 || 候选索引 >= 候选名称组.取成员数 ())
        {
            返回
        }
        名称小写 = 文本类.到小写 (候选名称组.取成员 (候选索引))
        类型值 = 候选类型组.取成员 (候选索引)
        当前使用序号 = 当前使用序号 + 1
        IC = 0
        判断循环 (IC < 使用候选名称组.取成员数 ())
        {
            如果 (使用候选名称组.取成员 (IC) == 名称小写 && 使用候选类型组.取成员 (IC) == 类型值)
            {
                使用次数组.置成员值 (IC, 使用次数组.取成员 (IC) + 1)
                最近使用序号组.置成员值 (IC, 当前使用序号)
                返回
            }
            IC = IC + 1
        }
        使用候选名称组.加入成员 (名称小写)
        使用候选类型组.加入成员 (类型值)
        使用次数组.加入成员 (1)
        最近使用序号组.加入成员 (当前使用序号)
    }

    方法 取候选使用加分 <公开 类型 = 整数>
    参数 候选索引 <类型 = 整数>
    {
        变量 名称小写 <类型 = 文本型>
        变量 类型值 <类型 = 整数>
        变量 IC <类型 = 整数>
        变量 使用加分 <类型 = 整数>
        如果 (候选索引 < 0 || 候选索引 >= 候选名称组.取成员数 ())
        {
            返回 (0)
        }
        名称小写 = 文本类.到小写 (候选名称组.取成员 (候选索引))
        类型值 = 候选类型组.取成员 (候选索引)
        IC = 0
        判断循环 (IC < 使用候选名称组.取成员数 ())
        {
            如果 (使用候选名称组.取成员 (IC) == 名称小写 && 使用候选类型组.取成员 (IC) == 类型值)
            {
                使用加分 = 使用次数组.取成员 (IC) * 8
                如果 (使用加分 > 64)
                {
                    使用加分 = 64
                }
                如果 (当前使用序号 - 最近使用序号组.取成员 (IC) <= 5)
                {
                    使用加分 = 使用加分 + 24
                }
                返回 (使用加分)
            }
            IC = IC + 1
        }
        返回 (0)
    }

    方法 载入拼音词库文本 <公开 类型 = 整数>
    参数 词库文本 <类型 = 文本型>
    {
        变量 行组 <类型 = 文本数组类>
        变量 IC <类型 = 整数>
        变量 行文本 <类型 = 文本型>
        变量 等号位置 <类型 = 整数>
        变量 汉字文本 <类型 = 文本型>
        变量 拼音文本 <类型 = 文本型>
        变量 数量 <类型 = 整数>
        拆分文本为行 (词库文本, 行组)
        IC = 0
        判断循环 (IC < 行组.取成员数 ())
        {
            行文本 = 取裁剪文本 (行组.取成员 (IC))
            如果 (行文本 != "" && 文本类.取文本左边 (行文本, 1) != "#")
            {
                等号位置 = 文本类.寻找文本 (行文本, "=", 0, 真)
                如果 (等号位置 > 0)
                {
                    汉字文本 = 取裁剪文本 (文本类.取文本左边 (行文本, 等号位置))
                    拼音文本 = 取裁剪文本 (文本类.取文本右边 (行文本, 文本类.取文本长度 (行文本) - 等号位置 - 1))
                    如果 (汉字文本 != "" && 拼音文本 != "")
                    {
                        加入拼音映射 (汉字文本, 拼音文本)
                        数量 = 数量 + 1
                    }
                }
            }
            IC = IC + 1
        }
        返回 (数量)
    }

    方法 载入指定拼音词库文件 <公开 类型 = 整数>
    参数 文件路径 <类型 = 文本型>
    {
        变量 词库文本 <类型 = 文本型>
        如果 (文件路径 == "" || 磁盘操作类.取文件属性 (文件路径) == -1)
        {
            返回 (0)
        }
        如果 (读入文本文件2 (词库文本, 文件路径, -1, 文本编码类型.UTF8) == 假)
        {
            返回 (0)
        }
        返回 (载入拼音词库文本 (词库文本))
    }

