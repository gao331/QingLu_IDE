    方法 初始化 <公开>
    {
        清空 ()
        拼音快速索引组.重置数组 (65536, 真)
        初始化基础拼音 ()
    }

    方法 清空 <公开>
    {
        清空候选 ()
        拼音汉字组.删除所有成员 ()
        拼音候选组.删除所有成员 ()
        拼音快速索引组.删除所有成员 ()
        使用候选名称组.删除所有成员 ()
        使用候选类型组.删除所有成员 ()
        使用次数组.删除所有成员 ()
        最近使用序号组.删除所有成员 ()
        当前使用序号 = 0
    }

    方法 清空候选 <公开>
    {
        候选名称组.删除所有成员 ()
        候选类型组.删除所有成员 ()
        候选插入文本组.删除所有成员 ()
        候选说明组.删除所有成员 ()
        候选参数签名组.删除所有成员 ()
        候选来源组.删除所有成员 ()
        候选额外索引组.删除所有成员 ()
        候选全拼索引组.删除所有成员 ()
        候选首拼索引组.删除所有成员 ()
        候选混合索引组.删除所有成员 ()
    }

    方法 加入候选 <公开 类型 = 整数>
    参数 名称 <类型 = 文本型>
    参数 类型值 <类型 = 整数>
    参数 插入文本 <类型 = 文本型>
    参数 说明 <类型 = 文本型>
    参数 参数签名 <类型 = 文本型>
    参数 来源 <类型 = 文本型>
    参数 额外索引 <类型 = 文本型>
    {
        变量 新索引 <类型 = 整数>
        新索引 = 候选名称组.加入成员 (名称)
        候选类型组.加入成员 (类型值)
        如果 (插入文本 == "")
        {
            候选插入文本组.加入成员 (名称)
        }
        否则
        {
            候选插入文本组.加入成员 (插入文本)
        }
        候选说明组.加入成员 (说明)
        候选参数签名组.加入成员 (参数签名)
        候选来源组.加入成员 (来源)
        候选额外索引组.加入成员 (规范索引列表文本 (文本类.到小写 (额外索引)))
        候选全拼索引组.加入成员 (取全拼索引文本 (名称))
        候选首拼索引组.加入成员 (取首拼索引文本 (名称))
        候选混合索引组.加入成员 (取混合索引文本 (名称))
        返回 (新索引)
    }

    方法 查询候选 <公开 类型 = 整数>
    参数 输入文本 <类型 = 文本型>
    参数 最大数量 <类型 = 整数>
    参数 结果索引组 <类型 = 整数数组类>
    参数 结果分数组 <类型 = 整数数组类>
    {
        变量 查询文本 <类型 = 文本型>
        变量 查询文本2 <类型 = 文本型>
        变量 临时索引组 <类型 = 整数数组类>
        变量 临时分数组 <类型 = 整数数组类>
        变量 IC <类型 = 整数>
        变量 分数 <类型 = 整数>
        结果索引组.删除所有成员 ()
        结果分数组.删除所有成员 ()
        查询文本 = 规范查询文本 (输入文本)
        查询文本2 = 取宽松拼音查询文本 (查询文本)
        IC = 0
        判断循环 (IC < 候选名称组.取成员数 ())
        {
            分数 = 计算匹配分数 (IC, 查询文本, 查询文本2)
            如果 (分数 > 0)
            {
                临时索引组.加入成员 (IC)
                临时分数组.加入成员 (分数)
            }
            IC = IC + 1
        }
        输出排序结果 (临时索引组, 临时分数组, 最大数量, 结果索引组, 结果分数组)
        返回 (结果索引组.取成员数 ())
    }

