    方法 加入拼音映射 <公开>
    参数 汉字 <类型 = 文本型>
    参数 拼音列表 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        变量 规范拼音 <类型 = 文本型>
        变量 字符代码 <类型 = 整数>
        如果 (汉字 == "" || 拼音列表 == "")
        {
            返回
        }
        规范拼音 = 取零声母兼容拼音文本 (文本类.到小写 (拼音列表))
        索引 = 查找拼音索引 (汉字)
        如果 (索引 >= 0)
        {
            拼音候选组.置成员值 (索引, 合并索引文本 (拼音候选组.取成员 (索引), 规范拼音))
        }
        否则
        {
            索引 = 拼音汉字组.加入成员 (汉字)
            拼音候选组.加入成员 (规范拼音)
            如果 (文本类.取文本长度 (汉字) == 1 && 拼音快速索引组.取成员数 () >= 65536)
            {
                字符代码 = 无符号字符到整数 (取字符 (汉字, 0))
                如果 (字符代码 >= 0 && 字符代码 < 65536)
                {
                    拼音快速索引组.置成员值 (字符代码, 索引 + 1)
                }
            }
        }
    }

    方法 取零声母兼容拼音文本 <公开 类型 = 文本型>
    参数 拼音列表 <类型 = 文本型>
    {
        变量 原组 <类型 = 文本数组类>
        变量 结果组 <类型 = 文本数组类>
        变量 IC <类型 = 整数>
        变量 拼音文本 <类型 = 文本型>
        变量 首字母 <类型 = 文本型>
        变量 末字母 <类型 = 文本型>
        拆分索引文本 (规范索引列表文本 (拼音列表), 原组)
        IC = 0
        判断循环 (IC < 原组.取成员数 ())
        {
            拼音文本 = 原组.取成员 (IC)
            如果 (拼音文本 != "")
            {
                加入唯一文本 (结果组, 拼音文本)
                首字母 = 文本类.取文本左边 (拼音文本, 1)
                如果 (首字母 == "a" || 首字母 == "e" || 首字母 == "o")
                {
                    加入唯一文本 (结果组, 首字母)
                    末字母 = 文本类.取文本右边 (拼音文本, 1)
                    如果 (末字母 == "n")
                    {
                        加入唯一文本 (结果组, 拼音文本 + "n")
                    }
                }
            }
            IC = IC + 1
        }
        返回 (数组到索引文本 (结果组))
    }

    方法 取全拼索引文本 <公开 类型 = 文本型>
    参数 名称 <类型 = 文本型>
    {
        变量 组合组 <类型 = 文本数组类>
        变量 拼音组 <类型 = 文本数组类>
        变量 IC <类型 = 整数>
        变量 IA <类型 = 整数>
        变量 IB <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        变量 新组合组 <类型 = 文本数组类>
        组合组.加入成员 ("")
        IC = 0
        判断循环 (IC < 文本类.取文本长度 (名称))
        {
            当前字符 = 文本类.取文本中间 (名称, IC, 1)
            取字符索引候选 (当前字符, 拼音组)
            新组合组.删除所有成员 ()
            IA = 0
            判断循环 (IA < 组合组.取成员数 ())
            {
                IB = 0
                判断循环 (IB < 拼音组.取成员数 ())
                {
                    如果 (新组合组.取成员数 () < 32)
                    {
