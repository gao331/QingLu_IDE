<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 启动类 <公开 基础类 = 窗口程序类>
{
    变量 主窗口对象 <类型 = IDE主窗口>

    方法 启动方法 <公开 类型 = 整数>
    {
        主窗口对象.皮肤类型 = 窗口皮肤类型.淡蓝
        主窗口对象.选择夹类型 = 文档选择夹类型.三维
        主窗口对象.创建MDI主窗口 ("清律IDE", IDE编辑文档, IDE编辑视图, IDE主菜单, "源码\nIDE源码\n项目源码文件(*.n)\n.n\nCCIDE.Doc\nIDE源码", 空资源.空图标, "清律IDE", 真, 4)
        返回 (1)
    }
}

类 IDE编辑文档 <基础类 = MDI文档类>
{
    变量 文档内容 <公开 类型 = 文本型>

    方法 MDI文档类_将新建文档 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = MDI文档类>
    参数 标记值 <类型 = 整数>
    {
        文档内容 = ""
        被修改 = 假
        返回 (1)
    }

    方法 MDI文档类_将打开文档 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = MDI文档类>
    参数 标记值 <类型 = 整数>
    参数 文档文件名 <类型 = 文本型>
    {
        返回 (1)
    }

    方法 MDI文档类_将保存文档 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = MDI文档类>
    参数 标记值 <类型 = 整数>
    参数 文档文件名 <类型 = 文本型>
    {
        变量 保存内容 <类型 = 文本型>
        保存内容 = 文档内容
        变量 编辑内容 <类型 = 文本型>
        编辑内容 = 文档内容
        变量 视图包装 <类型 = 对象包装类>
        如果 (取视图 (视图包装))
        {
            编辑内容 = 视图包装.对象 (IDE编辑视图).页面编辑器.取内容文本 ()
            保存内容 = 编辑内容
        }
        变量 后缀 <类型 = 文本型>
        后缀 = 取文件名后缀 (文档文件名)
        如果 (后缀 == "cpp" || 后缀 == "h")
        {
            变量 局部转换器 <类型 = 中文编译器>
            局部转换器.初始化 ()
            保存内容 = 局部转换器.中文转C加加 (保存内容)
        }
        如果 (写出文本文件 (保存内容, 文档文件名, -1, 文本编码类型.UTF8))
        {
            文档内容 = 编辑内容
            如果 (取视图 (视图包装))
            {
                视图包装.对象 (IDE编辑视图).页面编辑器.置为保存点 ()
            }
            被修改 = 假
            返回 (1)
        }
        返回 (0)
    }
}

类 IDE编辑视图 <基础类 = MDI视图类 @视窗.布局 = "client_size = \"800, 600\"">
{
    变量 页面编辑器 <公开 类型 = 代码表格编辑器 @视窗.布局 = "id = 201\r\npos = \"0, 0, 800, 600\"">

    方法 IDE编辑视图_初始化 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE编辑视图>
    参数 标记值 <类型 = 整数>
    {
        页面编辑器.缩放系数 = 0
        返回 (0)
    }

    方法 IDE编辑视图_尺寸被改变 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE编辑视图>
    参数 标记值 <类型 = 整数>
    {
        页面编辑器.宽度 = 宽度
        页面编辑器.高度 = 高度
        返回 (0)
    }

    方法 IDE编辑视图_被更新 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE编辑视图>
    参数 标记值 <类型 = 整数>
    {
        变量 文档包装 <类型 = 对象包装类>
        如果 (取文档 (文档包装))
        {
            页面编辑器.置内容文本 (文档包装.对象 (IDE编辑文档).文档内容)
            页面编辑器.置为保存点 ()
        }
        返回 (0)
    }
}

