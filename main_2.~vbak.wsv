            模式说明标签.标题 = "注: 可以在“解决方案”工作夹中对项目显示名称重新命名。"
        }
        更新模板说明 ()
    }

    方法 隐藏标题栏图标 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pWnd = GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd == NULL || pWnd->m_hWnd == NULL)
        @     return;
        @ HWND hWnd = pWnd->m_hWnd;
        @ static HICON hBlankSmall = NULL;
        @ static HICON hBlankBig = NULL;
        @ if (hBlankSmall == NULL)
        @ {
        @     const int w = 16, h = 16;
        @     const int bytes = (((w + 31) / 32) * 4) * h;
        @     BYTE* andBits = new BYTE[bytes];
        @     BYTE* xorBits = new BYTE[bytes];
        @     ::FillMemory (andBits, bytes, 0xFF);
        @     ::ZeroMemory (xorBits, bytes);
        @     hBlankSmall = ::CreateIcon (AfxGetInstanceHandle (), w, h, 1, 1, andBits, xorBits);
        @     delete[] andBits;
        @     delete[] xorBits;
        @ }
        @ if (hBlankBig == NULL)
        @ {
        @     const int w = 32, h = 32;
        @     const int bytes = (((w + 31) / 32) * 4) * h;
        @     BYTE* andBits = new BYTE[bytes];
        @     BYTE* xorBits = new BYTE[bytes];
        @     ::FillMemory (andBits, bytes, 0xFF);
        @     ::ZeroMemory (xorBits, bytes);
        @     hBlankBig = ::CreateIcon (AfxGetInstanceHandle (), w, h, 1, 1, andBits, xorBits);
        @     delete[] andBits;
        @     delete[] xorBits;
        @ }
        @ if (hBlankBig != NULL)
        @ {
        @     pWnd->SetIcon (hBlankBig, TRUE);
        @     ::SendMessage (hWnd, WM_SETICON, ICON_BIG, (LPARAM)hBlankBig);
        @     ::SetClassLongPtr (hWnd, GCLP_HICON, (LONG_PTR)hBlankBig);
        @ }
        @ if (hBlankSmall != NULL)
        @ {
        @     pWnd->SetIcon (hBlankSmall, FALSE);
        @     ::SendMessage (hWnd, WM_SETICON, ICON_SMALL, (LPARAM)hBlankSmall);
        @     ::SetClassLongPtr (hWnd, GCLP_HICONSM, (LONG_PTR)hBlankSmall);
        @ }
        @ LONG_PTR exStyle = ::GetWindowLongPtr (hWnd, GWL_EXSTYLE);
        @ exStyle |= WS_EX_DLGMODALFRAME;
        @ ::SetWindowLongPtr (hWnd, GWL_EXSTYLE, exStyle);
        @ ::SetWindowPos (hWnd, NULL, 0, 0, 0, 0,
        @     SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_FRAMECHANGED);
    }

    方法 新建项目对话框_创建完毕 <接收事件 类型 = 整数>
