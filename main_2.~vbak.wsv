    方法 取裁剪文本 <公开 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 起始 <类型 = 整数>
        变量 结束 <类型 = 整数>
        变量 长度 <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        长度 = 文本类.取文本长度 (原文本)
        如果 (长度 <= 0)
        {
            返回 ("")
        }
        起始 = 0
        如果 (长度 >= 3 && 无符号字符到整数 (取字符 (原文本, 0)) == 239 && 无符号字符到整数 (取字符 (原文本, 1)) == 187 && 无符号字符到整数 (取字符 (原文本, 2)) == 191)
        {
            起始 = 3
        }
        判断循环 (起始 < 长度)
        {
            当前字符 = 文本类.取文本中间 (原文本, 起始, 1)
            如果 (当前字符 != " " && 当前字符 != "\t")
            {
                跳出循环
            }
            起始 = 起始 + 1
        }
        如果 (起始 >= 长度)
        {
            返回 ("")
        }
        结束 = 长度 - 1
        判断循环 (结束 >= 起始)
        {
            当前字符 = 文本类.取文本中间 (原文本, 结束, 1)
            如果 (当前字符 != " " && 当前字符 != "\t")
            {
                跳出循环
            }
            结束 = 结束 - 1
        }
        返回 (文本类.取文本中间 (原文本, 起始, 结束 - 起始 + 1))
    }

    方法 拆分解决方案文本为行 <公开>
    参数 原文本 <类型 = 文本型>
    参数 结果数组 <类型 = 文本数组类>
    {
        变量 当前文本 <类型 = 文本型>
        变量 当前字符 <类型 = 文本型>
        变量 IC <类型 = 整数>
        结果数组.删除所有成员 ()
        当前文本 = ""
        IC = 0
        判断循环 (IC < 文本类.取文本长度 (原文本))
        {
            当前字符 = 文本类.取文本中间 (原文本, IC, 1)
            如果 (当前字符 == "\r")
            {
                结果数组.加入成员 (当前文本)
                当前文本 = ""
                如果 (IC + 1 < 文本类.取文本长度 (原文本) && 文本类.取文本中间 (原文本, IC + 1, 1) == "\n")
                {
                    IC = IC + 1
                }
            }
            否则 (当前字符 == "\n")
            {
                结果数组.加入成员 (当前文本)
                当前文本 = ""
            }
            否则
            {
                当前文本 = 当前文本 + 当前字符
            }
            IC = IC + 1
        }
        结果数组.加入成员 (当前文本)
    }

    方法 取解决方案配置值 <公开 类型 = 文本型>
    参数 配置文本 <类型 = 文本型>
    参数 节名称 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    {
        变量 行数组 <类型 = 文本数组类>
        变量 当前节 <类型 = 文本型>
        变量 行文本 <类型 = 文本型>
        变量 等号位置 <类型 = 整数>
        变量 键文本 <类型 = 文本型>
        变量 IC <类型 = 整数>
        拆分解决方案文本为行 (配置文本, 行数组)
        计次循环 (行数组.取成员数 ())
        {
            IC = 取循环索引 () + 1
            行文本 = 取裁剪文本 (行数组.取成员 (IC - 1))
            如果 (行文本 == "")
            否则 (文本类.取文本左边 (行文本, 1) == ";" || 文本类.取文本左边 (行文本, 1) == "#")
            否则 (文本类.寻找文本 (行文本, "[", 0, 真) >= 0 && 文本类.寻找文本 (行文本, "]", 0, 真) > 0)
            {
                变量 左括 <类型 = 整数>
                变量 右括 <类型 = 整数>
                左括 = 文本类.寻找文本 (行文本, "[", 0, 真)
                右括 = 文本类.寻找文本 (行文本, "]", 0, 真)
                当前节 = 文本类.取文本中间 (行文本, 左括 + 1, 右括 - 左括 - 1)
            }
            否则 (当前节 == 节名称)
            {
                等号位置 = 文本类.寻找文本 (行文本, "=", 0, 真)
                如果 (等号位置 >= 0)
                {
                    键文本 = 取裁剪文本 (文本类.取文本左边 (行文本, 等号位置))
                    如果 (键文本 == 键名称)
                    {
                        返回 (取裁剪文本 (文本类.取文本右边 (行文本, 文本类.取文本长度 (行文本) - 等号位置 - 1)))
                    }
                }
            }
        }
        返回 ("")
    }

    方法 规范模块列表文本 <公开 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 结果文本 <类型 = 文本型>
        变量 当前项 <类型 = 文本型>
        变量 当前字符 <类型 = 文本型>
        变量 IC <类型 = 整数>
        结果文本 = ""
        当前项 = ""
        IC = 0
        判断循环 (IC < 文本类.取文本长度 (原文本))
        {
            当前字符 = 文本类.取文本中间 (原文本, IC, 1)
            如果 (当前字符 == "|" || 当前字符 == "," || 当前字符 == "，" || 当前字符 == ";" || 当前字符 == "；" || 当前字符 == "\n" || 当前字符 == "\r")
            {
                当前项 = 取裁剪文本 (当前项)
                如果 (当前项 != "")
                {
                    如果 (结果文本 != "")
                    {
                        结果文本 = 结果文本 + "|"
                    }
                    结果文本 = 结果文本 + 当前项
                }
                当前项 = ""
            }
            否则
            {
                当前项 = 当前项 + 当前字符
            }
            IC = IC + 1
        }
        当前项 = 取裁剪文本 (当前项)
        如果 (当前项 != "")
        {
            如果 (结果文本 != "")
            {
                结果文本 = 结果文本 + "|"
            }
            结果文本 = 结果文本 + 当前项
        }
        返回 (结果文本)
    }

