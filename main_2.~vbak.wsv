    方法 取项目索引_按文件路径 <公开 类型 = 整数>
    参数 文件路径 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目目录组.取成员数 ())
            {
                跳出循环
            }
            如果 (文本类.寻找文本 (文件路径, 项目目录组.取成员 (索引), 0, 真) == 0)
            {
                返回 (索引)
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目目录组.取成员数 ())
        返回 (-1)
    }

