    {
        隐藏标题栏图标 ()
        模板画板已创建 = 真
        绘制模板区域 ()
        返回 (0)
    }

    方法 选择模板 <公开>
    参数 模板索引 <类型 = 整数>
    {
        当前模板索引 = 模板索引
        模板选择框.现行选中项 = 模板索引
        更新模板说明 ()
        如果 (模板画板已创建)
        {
            绘制模板区域 ()
        }
    }

    方法 更新模板说明 <公开>
    {
        如果 (当前模板索引 == 1)
        {
            结果项目类型 = "window"
        }
        否则 (当前模板索引 == 2)
        {
            结果项目类型 = "empty"
        }
        否则 (当前模板索引 == 3)
        {
            结果项目类型 = "dll"
        }
        否则
        {
            结果项目类型 = "console"
        }
    }

    方法 取当前模板标题 <类型 = 文本型>
    {
        如果 (当前模板索引 == 1)
        {
            返回 ("空白视窗项目")
        }
        否则 (当前模板索引 == 2)
        {
            返回 ("空项目")
        }
        否则 (当前模板索引 == 3)
        {
            返回 ("动态链接库")
        }
        返回 ("控制台程序")
    }

    方法 取当前模板说明 <类型 = 文本型>
    {
        如果 (当前模板索引 == 1)
        {
            返回 ("建立默认的空白视窗项目，适合创建带界面的火山视窗程序。")
        }
        否则 (当前模板索引 == 2)
        {
            返回 ("只创建包和空启动类，适合手动组织目录、模块和入口。")
        }
        否则 (当前模板索引 == 3)
        {
            返回 ("创建导出类入口，适合封装库、模块或可复用组件。")
        }
        返回 ("创建火山控制台程序表格代码模板，适合命令行工具和快速测试。")
    }

    方法 绘制模板行 <公开>
    参数 模板索引 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 图标文本 <类型 = 文本型>
    参数 标题文本 <类型 = 文本型>
    参数 说明文本 <类型 = 文本型>
    {
        变量 选中 <类型 = 逻辑型>
        选中 = 当前模板索引 == 模板索引
        如果 (选中)
        {
            模板画板.画笔颜色 = 0x00D77800
            模板画板.刷子颜色 = 0x00D77800
            模板画板.画矩形 (186, 顶边, 726, 顶边 + 42)
            模板画板.文本颜色 = 颜色类.白色
            模板画板.文本背景颜色 = 0x00D77800
        }
        否则
        {
            模板画板.画笔颜色 = 颜色类.白色
            模板画板.刷子颜色 = 颜色类.白色
            模板画板.画矩形 (186, 顶边, 726, 顶边 + 42)
            模板画板.文本颜色 = 颜色类.黑色
            模板画板.文本背景颜色 = 颜色类.白色
        }
        模板画板.画笔颜色 = 0x00A0A0A0
        模板画板.刷子颜色 = 0x00F5F5F5
        模板画板.画矩形 (194, 顶边 + 8, 224, 顶边 + 36)
        模板画板.定位写出 (200, 顶边 + 14, 图标文本)
        如果 (选中)
        {
            模板画板.文本颜色 = 颜色类.白色
            模板画板.文本背景颜色 = 0x00D77800
        }
        否则
        {
            模板画板.文本颜色 = 颜色类.黑色
            模板画板.文本背景颜色 = 颜色类.白色
        }
        模板画板.定位写出 (234, 顶边 + 8, 标题文本)
        如果 (选中)
        {
            模板画板.文本颜色 = 颜色类.白色
            模板画板.文本背景颜色 = 0x00D77800
        }
        否则
        {
            模板画板.文本颜色 = 0x00808080
            模板画板.文本背景颜色 = 颜色类.白色
        }
        模板画板.定位写出 (234, 顶边 + 25, 说明文本)
    }

    方法 绘制模板区域 <公开>
    {
        模板画板.清除 (0, 0, 模板画板.画板宽度, 模板画板.画板高度)
        模板画板.画笔颜色 = 0x00A0A0A0
        模板画板.刷子颜色 = 颜色类.白色
        模板画板.画矩形 (0, 0, 170, 358)
        模板画板.画矩形 (178, 0, 736, 220)
        模板画板.画矩形 (178, 224, 736, 358)
        模板画板.文本背景颜色 = 颜色类.白色
        模板画板.文本颜色 = 颜色类.黑色
        模板画板.定位写出 (8, 8, "已安装项目模板")
        模板画板.画笔颜色 = 0x00D77800
        模板画板.刷子颜色 = 0x00D77800
        模板画板.画矩形 (8, 38, 160, 66)
        模板画板.文本颜色 = 颜色类.白色
        模板画板.文本背景颜色 = 0x00D77800
        模板画板.定位写出 (28, 45, "视窗")
        绘制模板行 (1, 8, "APP", "空白视窗项目", "建立默认的空白视窗工程")
        绘制模板行 (3, 54, "DLL", "动态链接库", "生成导出类与库项目入口")
        绘制模板行 (0, 100, ">_", "控制台程序", "创建中文项目入口与命令行模板")
        绘制模板行 (2, 146, "...", "空项目", "只创建最小包与启动类")
        模板画板.画笔颜色 = 0x00A0A0A0
        模板画板.刷子颜色 = 颜色类.白色
        模板画板.画矩形 (720, 16, 728, 104)
        模板画板.刷子颜色 = 0x00808080
        模板画板.画矩形 (721, 22, 727, 70)
        模板画板.文本背景颜色 = 颜色类.白色
        模板画板.文本颜色 = 颜色类.黑色
        模板画板.定位写出 (186, 234, 取当前模板标题 ())
        模板画板.文本颜色 = 0x00555555
        模板画板.定位写出 (186, 260, 取当前模板说明 ())
    }

    方法 组合框_列表项被选择 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 组合框>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 模板选择框)
        {
            选择模板 (模板选择框.现行选中项)
        }
        否则 (来源对象 == 解决方案模式框)
        {
            如果 (已关联解决方案)
            {
                解决方案模式框.现行选中项 = 0
            }
            否则
            {
                解决方案模式框.现行选中项 = 1
            }
        }
        返回 (0)
    }

    方法 画板_鼠标左键被按下 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 模板画板)
        {
            如果 (横向位置 >= 8 && 横向位置 <= 160 && 纵向位置 >= 38 && 纵向位置 <= 66)
            {
                当前平台索引 = 0
                绘制模板区域 ()
            }
            否则 (横向位置 >= 186 && 横向位置 <= 726)
            {
                如果 (纵向位置 >= 8 && 纵向位置 <= 50)
                {
                    选择模板 (1)
                }
                否则 (纵向位置 >= 54 && 纵向位置 <= 96)
                {
                    选择模板 (3)
                }
                否则 (纵向位置 >= 100 && 纵向位置 <= 142)
                {
                    选择模板 (0)
                }
                否则 (纵向位置 >= 146 && 纵向位置 <= 188)
                {
                    选择模板 (2)
                }
            }
        }
        返回 (0)
    }

    方法 按钮_被单击 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 浏览路径按钮)
        {
            变量 新路径 <类型 = 文本型>
            新路径 = 快速文件对话框.选择目录 (本对象, "选择解决方案保存位置", 保存路径编辑框.内容)
            如果 (新路径 != "")
            {
                保存路径编辑框.内容 = 新路径
            }
        }
        否则 (来源对象 == 确定按钮)
        {
            如果 (项目名称编辑框.内容 == "")
            {
                警告信息框 ("请输入项目名称。", "新建项目")
                返回 (0)
            }
            如果 (已关联解决方案 == 假 && 解决方案名称编辑框.内容 == "")
            {
                警告信息框 ("请输入解决方案名称。", "新建项目")
                返回 (0)
            }
            如果 (已关联解决方案 == 假 && 保存路径编辑框.内容 == "")
            {
                警告信息框 ("请选择解决方案保存位置。", "新建项目")
                返回 (0)
            }
            结果项目名称 = 项目名称编辑框.内容
            结果解决方案名称 = 解决方案名称编辑框.内容
            结果方案根目录 = 保存路径编辑框.内容
            更新模板说明 ()
            关闭窗口 (1)
        }
        否则 (来源对象 == 取消按钮)
        {
            关闭窗口 (0)
        }
        返回 (0)
    }
}

