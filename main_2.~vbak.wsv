        {
            返回 (-1)
        }
        返回 (取节点项目索引 (解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)))
    }

    方法 执行打开所在文件夹 <公开>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回
        }
        变量 节点值 <类型 = 整数>
        节点值 = 解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)
        变量 路径 <类型 = 文本型>
        路径 = 取节点路径 (节点值)
        变量 节点类型 <类型 = 文本型>
        节点类型 = 取节点类型 (节点值)
        如果 (路径 == "")
        {
            返回
        }
        如果 (节点类型 == "file" || 节点类型 == "solution")
        {
            常用功能类.打开指定网址 ("browse://" + 路径)
        }
        否则
        {
            常用功能类.打开指定网址 ("file://" + 路径)
        }
    }

    方法 执行删除文件 <公开>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回
        }
        变量 节点值 <类型 = 整数>
        节点值 = 解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)
        变量 路径 <类型 = 文本型>
        路径 = 取节点路径 (节点值)
        变量 节点类型 <类型 = 文本型>
        节点类型 = 取节点类型 (节点值)
        变量 项目索引 <类型 = 整数>
        项目索引 = 取节点项目索引 (节点值)
        如果 (路径 == "" || 节点类型 == "solution")
        {
            返回
        }
        如果 (信息框 ("确定要删除文件/文件夹吗？\n" + 路径, 信息框按钮.是否钮, "确认删除") != 返回按钮类型.是钮)
        {
            返回
        }
        如果 (节点类型 == "project")
        {
            如果 (磁盘操作类.删除目录 (路径, 目录删除模式.全部删除))
            {
                解决方案项目文件组.删除成员 (项目索引, 1)
                项目名称组.删除成员 (项目索引, 1)
                项目目录组.删除成员 (项目索引, 1)
                项目文件组.删除成员 (项目索引, 1)
                项目类型组.删除成员 (项目索引, 1)
                项目主文件组.删除成员 (项目索引, 1)
                项目核心模块组.删除成员 (项目索引, 1)
                项目用户模块组.删除成员 (项目索引, 1)
                如果 (启动项目索引 == 项目索引)
                {
                    如果 (项目名称组.取成员数 () > 0)
                    {
                        启动项目索引 = 0
                    }
                    否则
                    {
                        启动项目索引 = -1
                    }
                }
                否则 (启动项目索引 > 项目索引)
                {
                    启动项目索引 = 启动项目索引 - 1
                }
                保存解决方案 ()
                重建文件树 ()
            }
            返回
        }
        如果 (位与 (磁盘操作类.取文件属性 (路径), 文件属性.子目录) != 0)
        {
            如果 (磁盘操作类.删除目录 (路径, 目录删除模式.全部删除))
            {
                重建文件树 ()
            }
        }
        否则
        {
            如果 (磁盘操作类.删除文件 (路径))
            {
                重建文件树 ()
            }
        }
    }

    方法 记录节点 <公开 类型 = 整数>
    参数 路径 <类型 = 文本型>
    参数 节点类型 <类型 = 文本型>
    参数 项目索引 <类型 = 整数>
    {
        变量 节点索引 <类型 = 整数>
        节点索引 = 节点路径组.加入成员 (路径)
        节点类型组.加入成员 (节点类型)
        节点项目索引组.加入成员 (项目索引)
        返回 (节点索引)
    }

    方法 重建文件树 <公开>
    {
        节点路径组.删除所有成员 ()
        节点类型组.删除所有成员 ()
        节点项目索引组.删除所有成员 ()
        解决方案窗口.文件树.清空 ()
        如果 (解决方案名称 == "")
        {
            解决方案窗口.文件树.加入项目 (-1, "未打开解决方案", 2, -1, 0, 假)
            解决方案窗口.文件树.加入项目 (-1, "双击工具栏「新项目」或「打开方案」开始", 2, -1, 0, 假)
            刷新解决方案辅助页 ()
            返回
        }
        变量 根节点索引 <类型 = 整数>
        根节点索引 = 记录节点 (解决方案路径, "solution", -1)
        变量 根项目句柄 <类型 = 变整数>
        根项目句柄 = 解决方案窗口.文件树.加入项目 (-1, "解决方案“" + 解决方案名称 + "”（" + 到文本 (项目名称组.取成员数 ()) + " 个项目）", 0, 1, 根节点索引 + 1, 真)
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目名称组.取成员数 ())
            {
                跳出循环
            }
            变量 项目标题 <类型 = 文本型>
            项目标题 = 项目名称组.取成员 (索引)
            如果 (索引 == 启动项目索引)
            {
                项目标题 = 项目标题 + " [启动]"
            }
            变量 项目节点索引 <类型 = 整数>
            项目节点索引 = 记录节点 (项目目录组.取成员 (索引), "project", 索引)
            变量 项目句柄 <类型 = 变整数>
            项目句柄 = 解决方案窗口.文件树.加入项目 (根项目句柄, 项目标题, 4, 4, 项目节点索引 + 1, 真)

            变量 模块夹句柄 <类型 = 变整数>
            变量 模块夹节点索引 <类型 = 整数>
            模块夹节点索引 = 记录节点 (项目目录组.取成员 (索引) + "\\modules", "modules_folder", 索引)
            模块夹句柄 = 解决方案窗口.文件树.加入项目 (项目句柄, "模块", 5, 5, 模块夹节点索引 + 1, 假)

            如果 (索引 < 项目核心模块组.取成员数 () && 项目核心模块组.取成员 (索引) != "")
            {
                变量 核心列表 <类型 = 文本数组类>
                核心列表 = 主构建引擎.拆分列表文本 (项目核心模块组.取成员 (索引))
                变量 核心索引 <类型 = 整数>
                核心索引 = 0
                循环判断首 ()
                {
                    如果 (核心索引 >= 核心列表.取成员数 ())
                    {
                        跳出循环
                    }
                    变量 核心名 <类型 = 文本型>
                    核心名 = 核心列表.取成员 (核心索引)
                    变量 核心节点索引 <类型 = 整数>
                    核心节点索引 = 记录节点 (项目目录组.取成员 (索引) + "\\modules\\" + 核心名, "module", 索引)
                    解决方案窗口.文件树.加入项目 (模块夹句柄, 核心名, 6, 6, 核心节点索引 + 1, 假)
                    核心索引 = 核心索引 + 1
                }
                循环判断尾 (核心索引 < 核心列表.取成员数 ())
            }
            如果 (索引 < 项目用户模块组.取成员数 () && 项目用户模块组.取成员 (索引) != "")
            {
                变量 用户列表 <类型 = 文本数组类>
                用户列表 = 主构建引擎.拆分列表文本 (项目用户模块组.取成员 (索引))
                变量 用户索引 <类型 = 整数>
                用户索引 = 0
                循环判断首 ()
                {
                    如果 (用户索引 >= 用户列表.取成员数 ())
                    {
                        跳出循环
                    }
                    变量 用户名 <类型 = 文本型>
                    用户名 = 用户列表.取成员 (用户索引)
                    变量 用户节点索引 <类型 = 整数>
                    用户节点索引 = 记录节点 (项目目录组.取成员 (索引) + "\\modules\\" + 用户名, "module", 索引)
                    解决方案窗口.文件树.加入项目 (模块夹句柄, 用户名, 6, 6, 用户节点索引 + 1, 假)
                    用户索引 = 用户索引 + 1
                }
                循环判断尾 (用户索引 < 用户列表.取成员数 ())
            }

            变量 项目文件路径 <类型 = 文本型>
            项目文件路径 = 项目文件组.取成员 (索引)
            变量 文件节点索引 <类型 = 整数>
            文件节点索引 = 记录节点 (项目文件路径, "file", 索引)
            解决方案窗口.文件树.加入项目 (项目句柄, 取文件名无路径部分 (项目文件路径), 2, 2, 文件节点索引 + 1, 假)
            如果 (项目主文件组.取成员 (索引) != 项目文件路径 && 项目主文件组.取成员 (索引) != "")
            {
                变量 附加文件节点索引 <类型 = 整数>
                附加文件节点索引 = 记录节点 (项目主文件组.取成员 (索引), "file", 索引)
                解决方案窗口.文件树.加入项目 (项目句柄, 取文件名无路径部分 (项目主文件组.取成员 (索引)), 2, 2, 附加文件节点索引 + 1, 假)
            }

            解决方案窗口.文件树.扩展 (项目句柄)
            解决方案窗口.文件树.收缩 (模块夹句柄)
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目名称组.取成员数 ())
        解决方案窗口.文件树.扩展 (根项目句柄)
        刷新解决方案辅助页 ()
    }

    方法 刷新解决方案辅助页 <公开>
    {
        支持库窗口.支持库树.清空 ()
        项目信息窗口.项目树.清空 ()
        如果 (解决方案名称 == "")
        {
            支持库窗口.支持库树.加入项目 (-1, "未打开解决方案", 2, -1, 0, 假)
            支持库窗口.支持库树.加入项目 (-1, "打开或新建解决方案后显示支持库", 2, -1, 0, 假)
            项目信息窗口.项目树.加入项目 (-1, "未打开解决方案", 2, -1, 0, 假)
            项目信息窗口.项目树.加入项目 (-1, "打开或新建解决方案后显示项目", 2, -1, 0, 假)
            属性窗口.属性编辑框.内容 = "属性\n\n未打开解决方案。"
            刷新输出辅助页 ()
            返回
        }

        变量 支持库根 <类型 = 变整数>
        支持库根 = 支持库窗口.支持库树.加入项目 (-1, "支持库（" + 到文本 (项目名称组.取成员数 ()) + " 个项目）", 5, 5, 0, 真)
        变量 项目根 <类型 = 变整数>
        项目根 = 项目信息窗口.项目树.加入项目 (-1, "项目（" + 到文本 (项目名称组.取成员数 ()) + "）", 4, 4, 0, 真)

        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目名称组.取成员数 ())
            {
                跳出循环
            }

            变量 项目标题 <类型 = 文本型>
            项目标题 = 项目名称组.取成员 (索引)
            如果 (索引 == 启动项目索引)
            {
                项目标题 = 项目标题 + " [启动]"
            }

            变量 支持库项目 <类型 = 变整数>
            支持库项目 = 支持库窗口.支持库树.加入项目 (支持库根, 项目标题, 4, 4, 0, 真)
            变量 核心夹 <类型 = 变整数>
            核心夹 = 支持库窗口.支持库树.加入项目 (支持库项目, "核心支持库", 5, 5, 0, 真)
            变量 用户夹 <类型 = 变整数>
            用户夹 = 支持库窗口.支持库树.加入项目 (支持库项目, "项目支持库", 5, 5, 0, 真)

            变量 核心列表 <类型 = 文本数组类>
            如果 (索引 < 项目核心模块组.取成员数 ())
            {
                核心列表 = 主构建引擎.拆分列表文本 (项目核心模块组.取成员 (索引))
            }
            如果 (核心列表.取成员数 () == 0)
            {
                支持库窗口.支持库树.加入项目 (核心夹, "未配置核心支持库", 2, 2, 0, 假)
            }
            否则
            {
                变量 核心索引 <类型 = 整数>
                核心索引 = 0
                循环判断首 ()
                {
                    如果 (核心索引 >= 核心列表.取成员数 ())
                    {
                        跳出循环
                    }
                    支持库窗口.支持库树.加入项目 (核心夹, 核心列表.取成员 (核心索引), 6, 6, 0, 假)
                    核心索引 = 核心索引 + 1
                }
                循环判断尾 (核心索引 < 核心列表.取成员数 ())
            }

            变量 用户列表 <类型 = 文本数组类>
            如果 (索引 < 项目用户模块组.取成员数 ())
            {
                用户列表 = 主构建引擎.拆分列表文本 (项目用户模块组.取成员 (索引))
            }
            如果 (用户列表.取成员数 () == 0)
            {
                支持库窗口.支持库树.加入项目 (用户夹, "未添加项目支持库", 2, 2, 0, 假)
            }
            否则
            {
                变量 用户索引 <类型 = 整数>
                用户索引 = 0
                循环判断首 ()
                {
                    如果 (用户索引 >= 用户列表.取成员数 ())
                    {
                        跳出循环
                    }
                    支持库窗口.支持库树.加入项目 (用户夹, 用户列表.取成员 (用户索引), 6, 6, 0, 假)
                    用户索引 = 用户索引 + 1
                }
                循环判断尾 (用户索引 < 用户列表.取成员数 ())
            }

            变量 项目句柄 <类型 = 变整数>
            项目句柄 = 项目信息窗口.项目树.加入项目 (项目根, 项目标题, 4, 4, 0, 真)
            项目信息窗口.项目树.加入项目 (项目句柄, "类型: " + 项目类型组.取成员 (索引), 2, 2, 0, 假)
            项目信息窗口.项目树.加入项目 (项目句柄, "目录: " + 项目目录组.取成员 (索引), 2, 2, 0, 假)
            项目信息窗口.项目树.加入项目 (项目句柄, "主文件: " + 取文件名无路径部分 (项目主文件组.取成员 (索引)), 2, 2, 0, 假)

            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目名称组.取成员数 ())

        支持库窗口.支持库树.扩展 (支持库根)
        项目信息窗口.项目树.扩展 (项目根)
        刷新解决方案属性页 ()
        刷新输出辅助页 ()
    }

    方法 刷新解决方案属性页 <公开>
    {
        变量 属性文本 <类型 = 文本型>
        属性文本 = "解决方案: " + 解决方案名称 + "\n"
        属性文本 = 属性文本 + "路径: " + 解决方案路径 + "\n"
        属性文本 = 属性文本 + "目录: " + 解决方案目录 + "\n"
        属性文本 = 属性文本 + "项目数: " + 到文本 (项目名称组.取成员数 ()) + "\n"
        属性文本 = 属性文本 + "平台: " + 主构建引擎.成员_平台 + "\n"
        属性文本 = 属性文本 + "配置: " + 主构建引擎.成员_配置 + "\n"
        如果 (启动项目索引 >= 0 && 启动项目索引 < 项目名称组.取成员数 ())
        {
            属性文本 = 属性文本 + "启动项目: " + 项目名称组.取成员 (启动项目索引) + "\n"
        }
        否则
        {
            属性文本 = 属性文本 + "启动项目: 未设置\n"
        }
        属性文本 = 属性文本 + "\n项目明细\n"

        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目名称组.取成员数 ())
            {
                跳出循环
            }
            属性文本 = 属性文本 + "\n[" + 到文本 (索引 + 1) + "] " + 项目名称组.取成员 (索引) + "\n"
            属性文本 = 属性文本 + "类型: " + 项目类型组.取成员 (索引) + "\n"
            属性文本 = 属性文本 + "项目文件: " + 项目文件组.取成员 (索引) + "\n"
            属性文本 = 属性文本 + "核心支持库: " + 选择 (索引 < 项目核心模块组.取成员数 () && 项目核心模块组.取成员 (索引) != "", 项目核心模块组.取成员 (索引), "无") + "\n"
            属性文本 = 属性文本 + "项目支持库: " + 选择 (索引 < 项目用户模块组.取成员数 () && 项目用户模块组.取成员 (索引) != "", 项目用户模块组.取成员 (索引), "无") + "\n"
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目名称组.取成员数 ())
        属性窗口.属性编辑框.内容 = 属性文本
    }

    方法 刷新输出辅助页 <公开>
    {
        变量 提示文本 <类型 = 文本型>
        提示文本 = "提示\n\n"
        如果 (解决方案名称 == "")
        {
            提示文本 = 提示文本 + "未打开解决方案。\n"
            提示文本 = 提示文本 + "可通过“新建项目”或“打开解决方案”开始。"
        }
        否则
        {
            提示文本 = 提示文本 + "当前解决方案: " + 解决方案名称 + "\n"
            提示文本 = 提示文本 + "项目数: " + 到文本 (项目名称组.取成员数 ()) + "\n"
            提示文本 = 提示文本 + "平台/配置: " + 主构建引擎.成员_平台 + " / " + 主构建引擎.成员_配置 + "\n"
            如果 (启动项目索引 >= 0 && 启动项目索引 < 项目名称组.取成员数 ())
            {
                提示文本 = 提示文本 + "启动项目: " + 项目名称组.取成员 (启动项目索引) + "\n"
            }
            否则
            {
                提示文本 = 提示文本 + "启动项目: 未设置\n"
            }
            提示文本 = 提示文本 + "\n生成日志会写入“输出”页。"
        }
        提示窗口.提示编辑框.内容 = 提示文本
        如果 (输出窗口.输出编辑框.取文本长度 () <= 0)
        {
            输出窗口.输出编辑框.内容 = "输出面板已就绪，请先新建项目或打开解决方案。"
        }
    }

    方法 取节点路径 <公开 类型 = 文本型>
    参数 项目数值 <类型 = 整数>
    {
        如果 (项目数值 == 0)
        {
            返回 ("")
        }
        变量 实际索引 <类型 = 整数>
        实际索引 = 项目数值 - 1
        如果 (实际索引 < 0 || 实际索引 >= 节点路径组.取成员数 ())
        {
            返回 ("")
        }
        返回 (节点路径组.取成员 (实际索引))
    }

    方法 取节点类型 <公开 类型 = 文本型>
    参数 项目数值 <类型 = 整数>
    {
        变量 实际索引 <类型 = 整数>
        实际索引 = 项目数值 - 1
        如果 (实际索引 < 0 || 实际索引 >= 节点类型组.取成员数 ())
        {
            返回 ("")
        }
        返回 (节点类型组.取成员 (实际索引))
    }

    方法 取节点项目索引 <公开 类型 = 整数>
    参数 项目数值 <类型 = 整数>
    {
        变量 实际索引 <类型 = 整数>
        实际索引 = 项目数值 - 1
        如果 (实际索引 < 0 || 实际索引 >= 节点路径组.取成员数 ())
        {
            返回 (-1)
        }
        返回 (节点项目索引组.取成员 (实际索引))
    }
}

类 IDE输出回调 <基础类 = 构建输出回调类>
{
    变量 目标编辑框 <类型 = 超级编辑框>

    方法 初始化 <公开>
    参数 编辑框 <类型 = 超级编辑框>
    {
        目标编辑框 = 编辑框
    }

    方法 输出文本 <公开 类型 = 整数 @虚拟方法 = 可覆盖>
    参数 文本 <类型 = 文本型>
    {
        如果 (目标编辑框.取文本长度 () > 0)
        {
            目标编辑框.加入文本行 (文本)
        }
        否则
        {
            目标编辑框.内容 = 文本 + "\n"
        }
        返回 (0)
    }

    方法 输出错误 <公开 类型 = 整数 @虚拟方法 = 可覆盖>
    参数 文本 <类型 = 文本型>
    {
        如果 (目标编辑框.取文本长度 () > 0)
        {
            目标编辑框.加入文本行 ("[错误] " + 文本)
        }
        否则
        {
            目标编辑框.内容 = "[错误] " + 文本 + "\n"
        }
        返回 (0)
    }
}
