            模板源码 = 模板源码 + "        主窗口对象.创建主窗口 ()" + 换行文本
            模板源码 = 模板源码 + "        返回 (1)" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
            模板源码 = 模板源码 + 换行文本
            模板源码 = 模板源码 + "类 主窗口类 <基础类 = 窗口 标题 = \"窗口程序\">" + 换行文本
            模板源码 = 模板源码 + "{" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
