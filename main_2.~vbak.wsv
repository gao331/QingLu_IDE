    方法 关闭同侧文档 <公开>
    参数 是否关闭左侧 <类型 = 逻辑型>
    {
        变量 活动文档 <类型 = 对象包装类>
        如果 (取活动文档 (活动文档) == 假)
        {
            返回
        }
        变量 活动路径 <类型 = 文本型>
        变量 活动标题 <类型 = 文本型>
        活动路径 = 活动文档.对象 (IDE编辑文档).文件名
        活动标题 = 活动文档.对象 (IDE编辑文档).标题
        变量 文档数组 <类型 = 对象包装数组类>
        变量 文档数 <类型 = 整数>
        文档数 = 取所有文档 (文档数组)
        变量 当前索引 <类型 = 整数>
        变量 索引 <类型 = 整数>
        当前索引 = -1
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 文档数)
            {
                跳出循环
            }
            如果 (活动路径 != "" && 文档数组.取成员 (索引).对象 (IDE编辑文档).文件名 == 活动路径 || 活动路径 == "" && 文档数组.取成员 (索引).对象 (IDE编辑文档).标题 == 活动标题)
            {
                当前索引 = 索引
                跳出循环
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 文档数)
        如果 (当前索引 < 0)
        {
            返回
        }
        如果 (是否关闭左侧)
        {
            索引 = 当前索引 - 1
            循环判断首 ()
            {
                如果 (索引 < 0)
                {
                    跳出循环
                }
                文档数组.取成员 (索引).对象 (IDE编辑文档).关闭 ()
                索引 = 索引 - 1
            }
            循环判断尾 (索引 >= 0)
        }
        否则
        {
            索引 = 文档数 - 1
            循环判断首 ()
            {
                如果 (索引 <= 当前索引)
                {
                    跳出循环
                }
                文档数组.取成员 (索引).对象 (IDE编辑文档).关闭 ()
                索引 = 索引 - 1
            }
            循环判断尾 (索引 > 当前索引)
        }
    }

