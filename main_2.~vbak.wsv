    方法 选择编译器路径 <公开>
    {
        变量 选中文件 <类型 = 文本型>
        选中文件 = 快速文件对话框.选择文件 (本对象, "选择编译器可执行文件", "可执行文件(*.exe)|*.exe|所有文件(*.*)|*.*", "exe", 取对话框初始目录 (), 假, 真, 假)
        如果 (选中文件 != "")
        {
            主构建引擎.成员_编译器路径 = 选中文件
            变量 选中路径 <类型 = 文本型>
            选中路径 = 选中文件
            如果 (文本类.寻找文本 (选中路径, "cl.exe", 0, 真) >= 0)
            {
                主构建引擎.成员_编译器类型 = "msvc"
            }
            否则 (文本类.寻找文本 (选中路径, "g++", 0, 真) >= 0 || 文本类.寻找文本 (选中路径, "gcc", 0, 真) >= 0)
            {
                主构建引擎.成员_编译器类型 = "gcc"
            }
            否则 (文本类.寻找文本 (选中路径, "clang++", 0, 真) >= 0 || 文本类.寻找文本 (选中路径, "clang", 0, 真) >= 0)
            {
                主构建引擎.成员_编译器类型 = "gcc"
            }
            主构建引擎.保存配置 ()
            置状态文本 ("编译器已设置: " + 主构建引擎.取编译器信息 ())
        }
    }

