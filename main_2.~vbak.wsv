    方法 执行生成指定项目 <公开>
    参数 项目索引 <类型 = 整数>
    {
        如果 (主构建引擎.成员_编译器路径 == "")
        {
            信息框 ("未找到编译器，请选择编译器可执行文件（如 g++.exe 或 cl.exe）。", 信息框按钮.确认钮, "编译器设置")
            选择编译器路径 ()
            如果 (主构建引擎.成员_编译器路径 == "")
            {
                返回
            }
        }
        如果 (项目索引 < 0 || 项目索引 >= 项目名称组.取成员数 ())
        {
            输出窗口.输出编辑框.内容 = "请先新建项目或打开解决方案。"
            返回
        }
        保存当前编辑页 ()
        输出窗口.输出编辑框.内容 = ""
        变量 源文件组 <类型 = 文本数组类>
        源文件组 = 收集项目源文件 (项目索引)
        主构建引擎.成员_项目类型 = 项目类型组.取成员 (项目索引)
        如果 (项目索引 < 项目核心模块组.取成员数 ())
        {
            主构建引擎.成员_核心模块文本 = 项目核心模块组.取成员 (项目索引)
        }
        否则
        {
            主构建引擎.成员_核心模块文本 = 取默认核心模块列表文本 (项目类型组.取成员 (项目索引))
        }
        如果 (项目索引 < 项目用户模块组.取成员数 ())
        {
            主构建引擎.成员_用户模块文本 = 项目用户模块组.取成员 (项目索引)
        }
        否则
        {
            主构建引擎.成员_用户模块文本 = ""
        }
        变量 成功 <类型 = 逻辑型>
        成功 = 主构建引擎.构建项目 (项目目录组.取成员 (项目索引), 项目名称组.取成员 (项目索引), 源文件组, 输出回调)
        如果 (成功)
        {
            置状态文本 ("生成成功: " + 项目名称组.取成员 (项目索引))
        }
        否则
        {
            置状态文本 ("生成失败: " + 项目名称组.取成员 (项目索引))
        }
    }

