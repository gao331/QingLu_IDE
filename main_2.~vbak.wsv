            模板源码 = 模板源码 + "    {" + 换行文本
            模板源码 = 模板源码 + "        返回 (1)" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
            返回 (模板源码)
        }
        模板源码 = "包 控制台.程序" + 换行文本
        模板源码 = 模板源码 + "类 程序入口类 <公开>" + 换行文本
