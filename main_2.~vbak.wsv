    {
        调整当前编辑器尺寸 ()
    }

    方法 调整当前编辑器尺寸 <公开>
    {
        变量 视图包装 <类型 = 对象包装类>
        如果 (取活动视图 (视图包装))
        {
            视图包装.对象 (IDE编辑视图).页面编辑器.宽度 = 视图包装.对象 (IDE编辑视图).宽度
            视图包装.对象 (IDE编辑视图).页面编辑器.高度 = 视图包装.对象 (IDE编辑视图).高度
        }
    }

    方法 消息过滤 <公开 类型 = 逻辑型 @虚拟方法 = 可覆盖>
    参数 窗口句柄 <类型 = 变整数>
    参数 消息值 <类型 = 整数>
    参数 消息参数1 <类型 = 变整数>
    参数 消息参数2 <类型 = 变整数>
    参数 消息地址 <类型 = 变整数>
    {
        变量 视图包装 <类型 = 对象包装类>
        如果 (取活动视图 (视图包装))
        {
            如果 (消息值 == 256 || 消息值 == 260)
            {
                如果 ((整数)消息参数1 == 17 || (整数)消息参数1 == 162 || (整数)消息参数1 == 163)
                {
                    Ctrl键按下 = 真
                }
                否则 (Ctrl键按下)
                {
                    如果 (视图包装.对象 (IDE编辑视图).页面编辑器.处理编辑快捷键 ((整数)消息参数1, 2) != 0)
                    {
                        返回 (假)
                    }
                }
                如果 (视图包装.对象 (IDE编辑视图).页面编辑器.处理导航按键 ((整数)消息参数1, 0) != 0)
                {
                    返回 (假)
                }
            }
            否则 (消息值 == 257 || 消息值 == 261)
            {
                如果 ((整数)消息参数1 == 17 || (整数)消息参数1 == 162 || (整数)消息参数1 == 163)
                {
                    Ctrl键按下 = 假
                }
            }
        }
        返回 (真)
    }

    方法 IDE主窗口_接收到命令 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE主窗口>
    参数 标记值 <类型 = 整数>
    参数 命令代码 <类型 = 整数>
    {
        变量 视图包装 <类型 = 对象包装类>
        如果 (取活动视图 (视图包装))
        {
            如果 (视图包装.对象 (IDE编辑视图).页面编辑器.处理右键菜单命令 (命令代码) != 0)
            {
                返回 (1)
            }
        }
        如果 (命令代码 == 文档页右键菜单.保存)
        {
            保存文件 ()
        }
        否则 (命令代码 == 文档页右键菜单.关闭)
        {
            关闭当前文档 ()
        }
        否则 (命令代码 == 文档页右键菜单.关闭左侧文档)
        {
            关闭同侧文档 (真)
        }
        否则 (命令代码 == 文档页右键菜单.关闭右侧文档)
        {
            关闭同侧文档 (假)
        }
        否则 (命令代码 == 文档页右键菜单.全部关闭)
        {
            关闭所有文档 ()
        }
        否则 (命令代码 == 文档页右键菜单.除此之外全部关闭)
        {
            关闭所有文档 (真)
        }
        否则 (命令代码 == 文档页右键菜单.复制完整路径)
        {
            复制当前文档完整路径 ()
        }
        否则 (命令代码 == 文档页右键菜单.打开所在的文件夹)
        {
            打开当前文档所在文件夹 ()
        }
        否则 (命令代码 == IDE主菜单.新建文件)
        {
            新建文件 ()
        }
        否则 (命令代码 == IDE主菜单.打开文件)
        {
            打开文件 ()
        }
        否则 (命令代码 == IDE主菜单.保存)
        {
            保存文件 ()
        }
        否则 (命令代码 == IDE主菜单.另存为)
        {
            另存文件 ()
        }
        否则 (命令代码 == IDE主菜单.保存全部)
        {
            保存全部 ()
        }
        否则 (命令代码 == IDE主菜单.关闭解决方案)
        {
            关闭当前解决方案 ()
        }
        否则 (命令代码 == IDE主菜单.退出)
        {
            关闭窗口 ()
        }
        否则 (命令代码 == IDE主菜单.撤销)
        {
            如果 (取活动视图 (视图包装))
            {
                视图包装.对象 (IDE编辑视图).页面编辑器.撤销 ()
            }
        }
        否则 (命令代码 == IDE主菜单.重做)
        {
            如果 (取活动视图 (视图包装))
            {
                视图包装.对象 (IDE编辑视图).页面编辑器.重做 ()
            }
        }
        否则 (命令代码 == IDE主菜单.剪切)
        {
            如果 (取活动视图 (视图包装))
            {
                视图包装.对象 (IDE编辑视图).页面编辑器.剪切选择内容 ()
            }
        }
        否则 (命令代码 == IDE主菜单.复制)
        {
            如果 (取活动视图 (视图包装))
            {
                视图包装.对象 (IDE编辑视图).页面编辑器.复制内容 ()
            }
        }
        否则 (命令代码 == IDE主菜单.粘贴)
        {
            如果 (取活动视图 (视图包装))
            {
                视图包装.对象 (IDE编辑视图).页面编辑器.粘贴内容 ()
            }
        }
        否则 (命令代码 == IDE主菜单.放大字体)
        {
            放大字体 ()
        }
        否则 (命令代码 == IDE主菜单.缩小字体)
        {
            缩小字体 ()
        }
        否则 (命令代码 == IDE主菜单.生成项目)
        {
            执行生成指定项目 (取当前项目索引 ())
        }
        否则 (命令代码 == IDE主菜单.设为启动项目)
        {
            执行设为启动项目 ()
        }
        否则 (命令代码 == IDE主菜单.编译)
        {
            执行编译 ()
        }
        否则 (命令代码 == IDE主菜单.运行)
        {
            执行编译运行 ()
        }
        否则 (命令代码 == IDE主菜单.中文转C加加)
        {
            执行中文转C加加 ()
        }
        否则 (命令代码 == IDE主菜单.C加加转中文)
        {
            执行C加加转中文 ()
        }
        否则 (命令代码 == IDE主菜单.关于)
        {
            显示关于对话框 ()
        }
        否则 (命令代码 == IDE主菜单.编译器设置)
        {
            选择编译器路径 ()
        }
        否则 (命令代码 == IDE主菜单.设置输出目录)
        {
            选择输出目录 ()
        }
        否则 (命令代码 == IDE主菜单.新建项目)
        {
            新建项目 ()
        }
        否则 (命令代码 == IDE主菜单.打开解决方案)
        {
            打开解决方案 ()
        }
        否则 (命令代码 == IDE主菜单.平台x64)
        {
            主构建引擎.成员_平台 = "x64"
            置状态文本 ("平台: x64")
            刷新解决方案辅助页 ()
            刷新输出辅助页 ()
        }
        否则 (命令代码 == IDE主菜单.平台x86)
        {
            主构建引擎.成员_平台 = "x86"
            置状态文本 ("平台: x86")
            刷新解决方案辅助页 ()
            刷新输出辅助页 ()
        }
        否则 (命令代码 == IDE主菜单.配置Debug)
        {
            主构建引擎.成员_配置 = "Debug"
            置状态文本 ("配置: Debug")
            刷新解决方案辅助页 ()
            刷新输出辅助页 ()
        }
        否则 (命令代码 == IDE主菜单.配置Release)
        {
            主构建引擎.成员_配置 = "Release"
            置状态文本 ("配置: Release")
            刷新解决方案辅助页 ()
            刷新输出辅助页 ()
        }
        否则 (命令代码 == 文件树右键菜单.刷新)
        {
            重建文件树 ()
        }
        否则 (命令代码 == 文件树右键菜单.生成项目)
        {
            执行右键生成项目 ()
        }
        否则 (命令代码 == 文件树右键菜单.设为启动项目)
        {
            执行设为启动项目 ()
        }
        否则 (命令代码 == 文件树右键菜单.打开所在文件夹)
        {
            执行打开所在文件夹 ()
        }
        否则 (命令代码 == 文件树右键菜单.删除)
        {
            执行删除文件 ()
        }
        返回 (1)
    }

    方法 IDE主窗口_更新命令状态 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE主窗口>
    参数 标记值 <类型 = 整数>
    参数 命令代码 <类型 = 整数>
    参数 命令状态 <类型 = 命令状态类>
    {
        如果 (命令代码 == IDE主菜单.平台x64 && 主构建引擎.成员_平台 == "x64" || 命令代码 == IDE主菜单.平台x86 && 主构建引擎.成员_平台 == "x86" || 命令代码 == IDE主菜单.配置Debug && 主构建引擎.成员_配置 == "Debug" || 命令代码 == IDE主菜单.配置Release && 主构建引擎.成员_配置 == "Release")
        {
            命令状态.状态 = 命令状态类.选中
        }
        否则 (解决方案路径 == "" && 命令代码 != IDE主菜单.文件 && 命令代码 != IDE主菜单.编辑 && 命令代码 != IDE主菜单.视图 && 命令代码 != IDE主菜单.帮助 && 命令代码 != IDE主菜单.新建项目 && 命令代码 != IDE主菜单.打开解决方案 && 命令代码 != IDE主菜单.打开文件 && 命令代码 != IDE主菜单.编译器设置 && 命令代码 != IDE主菜单.设置输出目录 && 命令代码 != IDE主菜单.关于 && 命令代码 != IDE主菜单.退出 && 命令代码 != IDE主菜单.平台x64 && 命令代码 != IDE主菜单.平台x86 && 命令代码 != IDE主菜单.配置Debug && 命令代码 != IDE主菜单.配置Release)
        {
            命令状态.状态 = 命令状态类.禁止
        }
        否则
        {
            命令状态.状态 = 命令状态类.未选中
        }
        返回 (1)
    }

