    方法 打开指定文件 <公开>
    参数 文件路径 <类型 = 文本型>
    {
        变量 文档包装 <类型 = 对象包装类>
        如果 (查找文档 (文件路径, 文档包装))
        {
            文档包装.对象 (IDE编辑文档).激活 ()
            当前文件路径 = 文件路径
            变量 已打开视图 <类型 = 对象包装类>
            如果 (取活动视图 (已打开视图))
            {
                已打开视图.对象 (IDE编辑视图).页面编辑器.聚焦编辑区 ()
            }
            更新状态栏 ()
            返回
        }
        变量 文件内容 <类型 = 文本型>
        如果 (读入文本文件2 (文件内容, 文件路径, -1, 文本编码类型.UTF8) == 假)
        {
            信息框 ("无法打开文件: " + 文件路径, 信息框按钮.确认钮, "错误")
            返回
        }
        变量 文件名 <类型 = 文本型>
        文件名 = 取文件名无路径部分 (文件路径)
        变量 后缀 <类型 = 文本型>
        后缀 = 取文件名后缀 (文件路径)
        如果 (后缀 == "cpp" || 后缀 == "h")
        {
            变量 局部转换器 <类型 = 中文编译器>
            局部转换器.初始化 ()
            文件内容 = 局部转换器.C加加转中文 (文件内容)
            文件名 = 文件名 + " [中文视图]"
        }
        如果 (新建文档 () == 假)
        {
            返回
        }
        如果 (取活动文档 (文档包装))
        {
            文档包装.对象 (IDE编辑文档).文件名 = 文件路径
            文档包装.对象 (IDE编辑文档).标题 = 文件名
            文档包装.对象 (IDE编辑文档).文档内容 = 文件内容
            文档包装.对象 (IDE编辑文档).被修改 = 假
        }
        变量 视图包装 <类型 = 对象包装类>
        如果 (取活动视图 (视图包装) == 假)
        {
            返回
        }
        如果 (后缀 == "cpp" || 后缀 == "h")
        {
            如果 (取活动文档 (文档包装))
            {
                文档包装.对象 (IDE编辑文档).标题 = 文件名
            }
        }
        如果 (后缀 == "n" && 视图包装.对象 (IDE编辑视图).页面编辑器.是否控制台默认模板 (文件内容))
        {
            视图包装.对象 (IDE编辑视图).页面编辑器.载入控制台默认模板 ()
        }
        否则 (后缀 == "n" && 视图包装.对象 (IDE编辑视图).页面编辑器.是否窗口默认模板 (文件内容))
        {
            视图包装.对象 (IDE编辑视图).页面编辑器.载入窗口默认模板 ()
        }
        否则
        {
            视图包装.对象 (IDE编辑视图).页面编辑器.置内容文本 (文件内容)
        }
        视图包装.对象 (IDE编辑视图).页面编辑器.置为保存点 ()
        视图包装.对象 (IDE编辑视图).页面编辑器.聚焦编辑区 ()
        当前文件路径 = 文件路径
        如果 (取活动文档 (文档包装))
        {
            文档包装.对象 (IDE编辑文档).文档内容 = 视图包装.对象 (IDE编辑视图).页面编辑器.取内容文本 ()
            文档包装.对象 (IDE编辑文档).被修改 = 假
        }
        更新状态栏 ()
    }

    方法 IDE主窗口_取状态栏文本 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE主窗口>
    参数 标记值 <类型 = 整数>
    参数 状态栏索引位置 <类型 = 整数>
    参数 状态栏内容 <类型 = 文本型>
    {
        如果 (状态栏索引位置 == 0)
        {
            状态栏内容 = 主构建引擎.成员_平台 + "  " + 主构建引擎.成员_配置
        }
        否则 (状态栏索引位置 == 1)
        {
            如果 (取当前编辑器行号 () > 0)
            {
                状态栏内容 = "行: " + 到文本 (取当前编辑器行号 ())
            }
            否则
            {
                状态栏内容 = "行: -"
            }
        }
        否则 (状态栏索引位置 == 2)
        {
            如果 (取当前编辑器列号 () > 0)
            {
                状态栏内容 = "列: " + 到文本 (取当前编辑器列号 ())
            }
            否则
            {
                状态栏内容 = "列: -"
            }
        }
        否则 (状态栏索引位置 == 3)
        {
            状态栏内容 = "UTF-8  |  中文C++"
        }
        返回 (1)
    }

