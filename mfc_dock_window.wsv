类 日志提示停靠窗口 <公开 基础类 = VS扩展停靠窗口 注释 = "IDE底部提示停靠页" @视窗.布局 = "client_size = \"800, 220\"">
{
    变量 提示编辑框 <公开 类型 = 超级编辑框
            @视窗.布局 = "id = 1111\r\npos = \"0, 0, 800, 220\"\r\n是否允许多行 = 真\r\n只读 = 真\r\n纯文本模式 = 真\r\n自动换行 = 真"
            背景颜色 = 0x00111827 字体 = "微软雅黑, 10">

    方法 设置面板颜色 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pEdit = @<提示编辑框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pEdit != NULL && pEdit->m_hWnd != NULL)
        @ {
        @     ::SendMessage (pEdit->m_hWnd, EM_SETBKGNDCOLOR, 0, RGB (17, 24, 39));
        @     CHARFORMAT2 cf;
        @     ZeroMemory (&cf, sizeof (cf));
        @     cf.cbSize = sizeof (cf);
        @     cf.dwMask = CFM_COLOR;
        @     cf.crTextColor = RGB (226, 232, 240);
        @     ::SendMessage (pEdit->m_hWnd, EM_SETCHARFORMAT, SCF_ALL, (LPARAM)&cf);
        @     ::SendMessage (pEdit->m_hWnd, EM_SETCHARFORMAT, SCF_DEFAULT, (LPARAM)&cf);
        @     ::InvalidateRect (pEdit->m_hWnd, NULL, TRUE);
        @ }
    }

    方法 调整内部布局 <公开>
    参数 宽度2 <类型 = 整数>
    参数 高度2 <类型 = 整数>
    {
        如果 (宽度2 < 1)
        {
            宽度2 = 1
        }
        如果 (高度2 < 1)
        {
            高度2 = 1
        }
        提示编辑框.移动 (0, 0, 宽度2, 高度2)
    }

