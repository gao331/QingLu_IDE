# @         {
# @             ::RemoveProp (GetSafeHwnd (), _T ("ccide_dock_pane_user_wnd"));
# @             ::RemoveProp (GetSafeHwnd (), _T ("ccide_solution_pane_native_last_popup"));
# @             Notify (CCIDE_DOCK_EVT_DESTROYING, 0, 0, 0, 0);
# @         }
# @         else if (message == WM_MOUSEACTIVATE)
# @         {
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_PANE_MOUSEACTIVATE"));
# @             return MA_ACTIVATE;
# @         }
# @         else if ((message == WM_CONTEXTMENU || message == WM_RBUTTONUP) && m_hUserWnd != NULL)
# @         {
# @             POINT ptScreen;
# @             if (message == WM_CONTEXTMENU && lParam != (LPARAM)-1)
# @             {
# @                 ptScreen.x = GET_X_LPARAM (lParam);
# @                 ptScreen.y = GET_Y_LPARAM (lParam);
# @             }
# @             else
# @             {
# @                 ::GetCursorPos (&ptScreen);
# @             }
# @             RECT rcUser;
# @             ::GetWindowRect (m_hUserWnd, &rcUser);
# @             if (::PtInRect (&rcUser, ptScreen))
# @             {
# @                 if (PopupSolutionTreeNativeMenu (ptScreen))
# @                     return 0;
# @                 POINT ptUser = ptScreen;
# @                 ::ScreenToClient (m_hUserWnd, &ptUser);
# @                 if (CCcIdeDockUserWndHook::ForwardMouse (m_hUserWnd, message, wParam, MAKELPARAM (ptUser.x, ptUser.y)))
# @                     return 0;
# @                 return 0;
# @             }
# @         }
# @         else if ((message == WM_LBUTTONDOWN || message == WM_LBUTTONDBLCLK || message == WM_RBUTTONDOWN) && m_hUserWnd != NULL)
# @         {
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_PANE_MOUSE"));
# @             DebugTrace (FALSE, 0, 0, _T ("n"), (INT)message);
# @             POINT pt;
# @             pt.x = GET_X_LPARAM (lParam);
# @             pt.y = GET_Y_LPARAM (lParam);
# @             ::MapWindowPoints (GetSafeHwnd (), m_hUserWnd, &pt, 1);
# @             if (CCcIdeDockUserWndHook::ForwardMouse (m_hUserWnd, message, wParam, MAKELPARAM (pt.x, pt.y)))
# @                 return 0;
# @         }
# @
# @         LRESULT lResult = CDockablePane::WindowProc (message, wParam, lParam);
# @
# @         switch (message)
# @         {
# @         case WM_SIZE:
# @             AdjustLayout ();
# @             Notify (CCIDE_DOCK_EVT_SIZE_CHANGED, LOWORD (lParam), HIWORD (lParam), (INT)wParam, 0);
# @             break;
# @         case WM_SETFOCUS:
# @             if (m_hUserWnd != NULL)
# @                 ::SetFocus (m_hUserWnd);
# @             Notify (CCIDE_DOCK_EVT_FOCUS, 0, 0, 0, 0);
# @             break;
# @         case WM_SHOWWINDOW:
# @             CheckStateChange ();
# @             break;
# @         case WM_WINDOWPOSCHANGED:
# @             Notify (CCIDE_DOCK_EVT_POSITION_CHANGED, 0, 0, 0, 0);
# @             CheckStateChange ();
# @             break;
# @         case WM_SETTEXT:
# @             Notify (CCIDE_DOCK_EVT_TITLE_CHANGED, 0, 0, 0, 0);
# @             break;
# @         }
# @
# @         return lResult;
# @     }
# @
# @     void AdjustLayout ()
# @     {
# @         if (m_hUserWnd == NULL)
# @             return;
# @
# @         CRect rectClient;
# @         GetClientRect (rectClient);
# @         ::SetWindowPos (m_hUserWnd, NULL, rectClient.left, rectClient.top,
# @             rectClient.Width (), rectClient.Height (), SWP_NOACTIVATE | SWP_NOZORDER);
# @     }
# @
# @     void Notify (INT nEvent, INT nValue1, INT nValue2, INT nValue3, INT nValue4)
# @     {
# @         if (m_pSink != NULL)
# @             m_pSink->OnDockPaneEvent (nEvent, nValue1, nValue2, nValue3, nValue4);
# @     }
# @
# @     void RememberState ()
# @     {
# @         m_blpLastVisible = IsVisible ();
# @         m_blpLastFloating = IsFloating ();
# @         m_blpLastAutoHide = IsAutoHideMode ();
# @         m_dwLastAlignment = GetCurrentAlignment ();
# @     }
# @
# @     void CheckStateChange ()
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return;
# @
# @         const BOOL blpVisible = IsVisible ();
# @         const BOOL blpFloating = IsFloating ();
# @         const BOOL blpAutoHide = IsAutoHideMode ();
# @         const DWORD dwAlignment = GetCurrentAlignment ();
# @
# @         if (blpVisible != m_blpLastVisible)
# @             Notify (CCIDE_DOCK_EVT_VISIBLE_CHANGED, blpVisible, 0, 0, 0);
# @         if (blpFloating != m_blpLastFloating)
# @             Notify (CCIDE_DOCK_EVT_FLOAT_CHANGED, blpFloating, 0, 0, 0);
# @         if (blpAutoHide != m_blpLastAutoHide)
# @             Notify (CCIDE_DOCK_EVT_AUTO_HIDE_CHANGED, blpAutoHide, 0, 0, 0);
# @         if (dwAlignment != m_dwLastAlignment)
# @             Notify (CCIDE_DOCK_EVT_DOCK_ALIGN_CHANGED, (INT)dwAlignment, 0, 0, 0);
# @
# @         m_blpLastVisible = blpVisible;
# @         m_blpLastFloating = blpFloating;
# @         m_blpLastAutoHide = blpAutoHide;
# @         m_dwLastAlignment = dwAlignment;
# @     }
# @
# @ protected:
# @     ICcIdeDockPaneSink* m_pSink;
# @     HWND m_hUserWnd;
# @     BOOL m_blpLastVisible;
# @     BOOL m_blpLastFloating;
# @     BOOL m_blpLastAutoHide;
# @     BOOL m_blpHasGripper;
# @     DWORD m_dwLastAlignment;
# @ };
# @ </include>
# @ </global>

类 停靠窗口位置 <公开 注释 = "停靠窗口在父窗口客户区中的停靠位置." @常量类 = 整数>
{
    常量 左边 <公开 值 = 1>
    常量 顶边 <公开 值 = 2>
    常量 右边 <公开 值 = 3>
    常量 底边 <公开 值 = 4>
    常量 充满 <公开 值 = 5>
}

类 停靠窗口管理器 <公开 注释 = "管理一组已创建的MFC窗口组件,按左/上/右/下/充满顺序自动排列到父窗口客户区内.">
{

    # @ @m<DECLARE_REF_OBJECT_CLASS_WITH_DATA> (CCcIdeDockLayoutManager)

    方法 初始化 <公开 类型 = 逻辑型 注释 = "绑定父窗口.通常在主窗口创建完毕后调用一次." @禁止流程检查 = 真>
    参数 父窗口 <类型 = 窗口组件 注释 = "提供承载停靠布局的父窗口组件,例如IDE主窗口.">
    {
        @ return data ().Init (@<父窗口>.GetMfcWndPtrWithValidHWnd ());
    }

    方法 清空 <公开 注释 = "清空已经加入的停靠窗口记录,不会销毁窗口本身." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().Clear ()
    }

    方法 添加窗口 <公开 类型 = 整数 注释 = "加入一个已经创建的窗口组件到停靠布局中.返回停靠窗口ID,失败返回0." @禁止流程检查 = 真>
    参数 欲停靠窗口 <类型 = 窗口组件 注释 = "提供已经创建的窗口组件.">
    参数 停靠位置 <类型 = 停靠窗口位置 注释 = "提供停靠位置.">
    参数 初始尺寸 <类型 = 整数 注释 = "左/右停靠时表示宽度,上/下停靠时表示高度,充满时忽略." @默认值 = 200>
    参数 最小尺寸 <类型 = 整数 注释 = "用于防止布局区域过小时尺寸小于该值." @默认值 = 40>
    参数 是否显示 <类型 = 逻辑型 注释 = "是否立即显示该停靠窗口." @默认值 = 真>
    {
        @ return data ().AddPane (@<欲停靠窗口>.GetMfcWndPtrWithValidHWnd (), @<停靠位置>, @<初始尺寸>, @<最小尺寸>, @<是否显示>);
    }

    方法 设置窗口可视 <公开 类型 = 逻辑型 注释 = "设置指定停靠窗口是否显示.返回是否成功." @禁止流程检查 = 真>
    参数 停靠窗口ID <类型 = 整数 注释 = "添加窗口方法返回的ID.">
    参数 是否显示 <类型 = 逻辑型>
    {
        @ return data ().SetPaneVisible (@<停靠窗口ID>, @<是否显示>);
    }

    方法 设置窗口尺寸 <公开 类型 = 逻辑型 注释 = "修改指定停靠窗口的停靠尺寸.返回是否成功." @禁止流程检查 = 真>
    参数 停靠窗口ID <类型 = 整数 注释 = "添加窗口方法返回的ID.">
    参数 新尺寸 <类型 = 整数 注释 = "左/右停靠时表示宽度,上/下停靠时表示高度.">
    {
        @ return data ().SetPaneSize (@<停靠窗口ID>, @<新尺寸>);
    }

    方法 更新布局 <公开 类型 = 逻辑型 注释 = "按已加入窗口的顺序更新布局.宽度或高度小于等于0时使用父窗口完整客户区." @禁止流程检查 = 真>
    参数 左边 <类型 = 整数 注释 = "布局区域左边坐标." @默认值 = 0>
    参数 顶边 <类型 = 整数 注释 = "布局区域顶边坐标." @默认值 = 0>
    参数 宽度 <类型 = 整数 注释 = "布局区域宽度.小于等于0时使用父窗口完整客户区." @默认值 = -1>
    参数 高度 <类型 = 整数 注释 = "布局区域高度.小于等于0时使用父窗口完整客户区." @默认值 = -1>
    {
        @ return data ().Layout (@<左边>, @<顶边>, @<宽度>, @<高度>);
    }

    方法 取窗口数 <公开 类型 = 整数 注释 = "返回当前已加入的停靠窗口数量." @嵌入式方法 = "">
    {
        @ @sn<this>.data ().GetPaneCount ()
    }
}

# ===

类 VS滚动容器 <公开 基础类 = 组件布局器 注释 = "当前项目专用的MFC滚动容器.外层窗口提供横向/纵向滚动条,内层承载火山子控件."
        @视窗.后缀文本 = "public ICcIdeScrollContainerSink">
{
    变量 内部虚拟宽度 <类型 = 整数>
    变量 内部虚拟高度 <类型 = 整数>
    变量 内部横向滚动 <类型 = 逻辑型>
    变量 内部纵向滚动 <类型 = 逻辑型>

    方法 VS滚动容器创建完毕 <公开 定义事件 类型 = 整数 注释 = "调用创建VS滚动容器成功后发送.">

    方法 VS滚动位置被改变 <公开 定义事件 类型 = 整数 注释 = "滚动位置改变后发送.来源:1横向滚动条,2纵向滚动条,3鼠标滚轮,4程序设置.">
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 来源 <类型 = 整数>

    方法 VS滚动内容尺寸被改变 <公开 定义事件 类型 = 整数 注释 = "虚拟内容尺寸改变后发送.">
    参数 内容宽度 <类型 = 整数>
    参数 内容高度 <类型 = 整数>

    方法 VS滚动可视尺寸被改变 <公开 定义事件 类型 = 整数 注释 = "容器可视客户区尺寸改变后发送.">
    参数 可视宽度 <类型 = 整数>
    参数 可视高度 <类型 = 整数>
    参数 调整类型 <类型 = 整数>

    方法 VS鼠标滚轮 <公开 定义事件 类型 = 整数 注释 = "滚动容器收到鼠标滚轮后发送.">
    参数 滚轮增量 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>

    方法 VS滚动容器将被销毁 <公开 定义事件 类型 = 整数 注释 = "底层滚动容器销毁前发送.">

    方法 创建VS滚动容器 <公开 类型 = 逻辑型 注释 = "创建滚动容器.父窗口可为停靠窗口、普通窗口或其它窗口组件." @禁止流程检查 = 真>
    参数 父窗口 <类型 = 窗口组件 注释 = "承载滚动容器的父窗口.">
    参数 ID值 <类型 = 整数 注释 = "窗口ID,同一父窗口内应唯一.">
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数>
    参数 高度 <类型 = 整数>
    参数 虚拟宽度 <类型 = 整数 注释 = "内容虚拟宽度.大于可视宽度时出现横向滚动条." @默认值 = 800>
    参数 虚拟高度 <类型 = 整数 注释 = "内容虚拟高度.大于可视高度时出现纵向滚动条." @默认值 = 600>
    参数 启用横向滚动 <类型 = 逻辑型 @默认值 = 真>
    参数 启用纵向滚动 <类型 = 逻辑型 @默认值 = 真>
    {
        @ if (GetMfcWndHandle () != NULL || data ().m_hWnd != NULL)
        @     return FALSE;
        @ CWnd* pwndParent = @<父窗口>.GetMfcWndPtrWithValidHWnd ();
        @ if (pwndParent == NULL || data ().CreateContainer (this, pwndParent,
        @         CMRect (@<左边>, @<顶边>, @<左边> + @<宽度>, @<顶边> + @<高度>), @<ID值>,
        @         @<虚拟宽度>, @<虚拟高度>, @<启用横向滚动>, @<启用纵向滚动>) == FALSE)
        @     return FALSE;
        内部虚拟宽度 = 虚拟宽度
        内部虚拟高度 = 虚拟高度
        内部横向滚动 = 启用横向滚动
        内部纵向滚动 = 启用纵向滚动
        VS滚动容器创建完毕 ()
        返回 (真)
    }

    方法 虚拟宽度 <公开 属性读 类型 = 整数 注释 = "返回虚拟内容宽度.">
    {
