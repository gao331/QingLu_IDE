    方法 设置面板颜色 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pTree = @<文件树>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTree != NULL && pTree->m_hWnd != NULL)
        @ {
        @     ::SendMessage (pTree->m_hWnd, TVM_SETBKCOLOR, 0, RGB (248, 250, 252));
        @     ::SendMessage (pTree->m_hWnd, TVM_SETTEXTCOLOR, 0, RGB (31, 41, 55));
        @     ::SendMessage (pTree->m_hWnd, TVM_SETLINECOLOR, 0, RGB (203, 213, 225));
        @     ::InvalidateRect (pTree->m_hWnd, NULL, TRUE);
        @ }
        @ pTree = @<支持库树>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTree != NULL && pTree->m_hWnd != NULL)
        @ {
        @     ::SendMessage (pTree->m_hWnd, TVM_SETBKCOLOR, 0, RGB (248, 250, 252));
        @     ::SendMessage (pTree->m_hWnd, TVM_SETTEXTCOLOR, 0, RGB (31, 41, 55));
        @     ::SendMessage (pTree->m_hWnd, TVM_SETLINECOLOR, 0, RGB (203, 213, 225));
        @     ::InvalidateRect (pTree->m_hWnd, NULL, TRUE);
        @ }
        @ pTree = @<项目树>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTree != NULL && pTree->m_hWnd != NULL)
        @ {
        @     ::SendMessage (pTree->m_hWnd, TVM_SETBKCOLOR, 0, RGB (248, 250, 252));
        @     ::SendMessage (pTree->m_hWnd, TVM_SETTEXTCOLOR, 0, RGB (31, 41, 55));
        @     ::SendMessage (pTree->m_hWnd, TVM_SETLINECOLOR, 0, RGB (203, 213, 225));
        @     ::InvalidateRect (pTree->m_hWnd, NULL, TRUE);
        @ }
    }

