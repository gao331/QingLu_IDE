    方法 应用页签位置 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pTab = @<方案选择夹>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTab != NULL && pTab->m_hWnd != NULL)
        @ {
        @     LONG_PTR style = ::GetWindowLongPtr (pTab->m_hWnd, GWL_STYLE);
        @     style &= ~(TCS_BOTTOM | TCS_VERTICAL);
        @     switch (@<内部页签位置>)
        @     {
        @     case 1: style |= TCS_BOTTOM; break;
        @     case 2: style |= TCS_VERTICAL; break;
        @     case 3: style |= TCS_BOTTOM | TCS_VERTICAL; break;
        @     default: break;
        @     }
        @     ::SetWindowLongPtr (pTab->m_hWnd, GWL_STYLE, style);
        @     ::SetWindowPos (pTab->m_hWnd, NULL, 0, 0, 0, 0,
        @         SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED);
        @     pTab->Invalidate ();
        @ }
    }

    方法 应用页签样式 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pTab = @<方案选择夹>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTab != NULL && pTab->m_hWnd != NULL)
        @ {
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_solution_tab_style"), (HANDLE)(DWORD_PTR)(@<内部页签样式> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_solution_tab_bg"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签背景颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_solution_tab_sel_bg"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签选中背景颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_solution_tab_text"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签文字颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_solution_tab_sel_text"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签选中文字颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_solution_tab_hi"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签高亮颜色> + 1));
        @     LONG_PTR nStyle = ::GetWindowLongPtr (pTab->m_hWnd, GWL_STYLE);
        @     if ((nStyle & TCS_FIXEDWIDTH) == 0)
        @         ::SetWindowLongPtr (pTab->m_hWnd, GWL_STYLE, nStyle | TCS_FIXEDWIDTH);
        @     ::SendMessage (pTab->m_hWnd, TCM_SETITEMSIZE, 0, MAKELPARAM (76, 26));
        @     ::SetWindowPos (pTab->m_hWnd, NULL, 0, 0, 0, 0,
        @         SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED);
        @     ::InvalidateRect (pTab->m_hWnd, NULL, TRUE);
        @ }
    }

    方法 安装页签原生切换 <公开 @禁止流程检查 = 真>
    {
        @ static const TCHAR* kOldProcProp = _T ("ccide_solution_tab_old_proc");
        @ static const TCHAR* kDocWndProp = _T ("ccide_solution_tab_doc");
        @ static const TCHAR* kLibWndProp = _T ("ccide_solution_tab_lib");
        @ static const TCHAR* kPropWndProp = _T ("ccide_solution_tab_prop");
        @ static const TCHAR* kTabWndProp = _T ("ccide_solution_tab_hwnd");
        @ static const TCHAR* kLastSwitchTickProp = _T ("ccide_solution_tab_last_switch_tick");
        @ static const TCHAR* kTabStyleProp = _T ("ccide_solution_tab_style");
        @ static const TCHAR* kTabBgProp = _T ("ccide_solution_tab_bg");
        @ static const TCHAR* kTabSelBgProp = _T ("ccide_solution_tab_sel_bg");
        @ static const TCHAR* kTabTextProp = _T ("ccide_solution_tab_text");
        @ static const TCHAR* kTabSelTextProp = _T ("ccide_solution_tab_sel_text");
        @ static const TCHAR* kTabHiProp = _T ("ccide_solution_tab_hi");
        @ struct CSolutionTabSwitchHook
        @ {
        @     static INT GetIntProp (HWND hWnd, const TCHAR* name, INT defValue)
        @     {
        @         DWORD_PTR v = (DWORD_PTR)::GetProp (hWnd, name);
        @         return v == 0 ? defValue : (INT)(v - 1);
        @     }
        @     static COLORREF GetColorProp (HWND hWnd, const TCHAR* name, COLORREF defValue)
        @     {
        @         DWORD_PTR v = (DWORD_PTR)::GetProp (hWnd, name);
        @         return v == 0 ? defValue : (COLORREF)(v - 1);
        @     }
        @     static void DrawTabs (HWND hTab)
        @     {
        @         if (!::IsWindow (hTab) || GetIntProp (hTab, kTabStyleProp, 1) <= 0)
        @             return;
        @         HDC hdc = ::GetDC (hTab);
        @         if (hdc == NULL)
        @             return;
        @         const INT nCount = (INT)::SendMessage (hTab, TCM_GETITEMCOUNT, 0, 0);
        @         const INT nCur = (INT)::SendMessage (hTab, TCM_GETCURSEL, 0, 0);
        @         COLORREF clrBg = GetColorProp (hTab, kTabBgProp, RGB (248, 250, 252));
        @         COLORREF clrSelBg = GetColorProp (hTab, kTabSelBgProp, RGB (255, 255, 255));
        @         COLORREF clrText = GetColorProp (hTab, kTabTextProp, RGB (75, 85, 99));
        @         COLORREF clrSelText = GetColorProp (hTab, kTabSelTextProp, RGB (15, 23, 42));
        @         COLORREF clrHi = GetColorProp (hTab, kTabHiProp, RGB (14, 165, 233));
        @         COLORREF clrBorder = RGB (203, 213, 225);
        @         HIMAGELIST hImages = (HIMAGELIST)::SendMessage (hTab, TCM_GETIMAGELIST, 0, 0);
        @         HFONT hFont = (HFONT)::SendMessage (hTab, WM_GETFONT, 0, 0);
        @         HFONT hOldFont = hFont == NULL ? NULL : (HFONT)::SelectObject (hdc, hFont);
        @         ::SetBkMode (hdc, TRANSPARENT);
        @         for (INT i = 0; i < nCount; ++i)
        @         {
        @             RECT rcItem;
        @             ZeroMemory (&rcItem, sizeof (rcItem));
        @             if (!::SendMessage (hTab, TCM_GETITEMRECT, i, (LPARAM)&rcItem))
        @                 continue;
        @             const BOOL bSel = (i == nCur);
        @             RECT rcFill = rcItem;
        @             ::InflateRect (&rcFill, 1, 2);
        @             HBRUSH hBrush = ::CreateSolidBrush (bSel ? clrSelBg : clrBg);
        @             ::FillRect (hdc, &rcFill, hBrush);
        @             ::DeleteObject (hBrush);
        @             HPEN hPen = ::CreatePen (PS_SOLID, 1, clrBorder);
        @             HPEN hOldPen = (HPEN)::SelectObject (hdc, hPen);
        @             ::MoveToEx (hdc, rcFill.left, rcFill.top, NULL);
        @             ::LineTo (hdc, rcFill.right, rcFill.top);
        @             ::MoveToEx (hdc, rcFill.left, rcFill.bottom - 1, NULL);
        @             ::LineTo (hdc, rcFill.right, rcFill.bottom - 1);
        @             ::SelectObject (hdc, hOldPen);
        @             ::DeleteObject (hPen);
        @             if (bSel)
        @             {
        @                 RECT rcHi = rcFill;
        @                 if ((::GetWindowLongPtr (hTab, GWL_STYLE) & TCS_BOTTOM) != 0)
        @                     rcHi.top = rcHi.bottom - 3;
        @                 else
        @                     rcHi.bottom = rcHi.top + 3;
        @                 HBRUSH hHi = ::CreateSolidBrush (clrHi);
        @                 ::FillRect (hdc, &rcHi, hHi);
        @                 ::DeleteObject (hHi);
        @             }
        @             TCHAR text[128];
        @             TC_ITEM item;
        @             ZeroMemory (&item, sizeof (item));
        @             ZeroMemory (text, sizeof (text));
        @             item.mask = TCIF_TEXT | TCIF_IMAGE;
        @             item.pszText = text;
        @             item.cchTextMax = 127;
        @             item.iImage = -1;
        @             ::SendMessage (hTab, TCM_GETITEM, i, (LPARAM)&item);
        @             RECT rcText = rcItem;
        @             rcText.left += 8;
        @             rcText.right -= 8;
        @             SIZE szText;
        @             szText.cx = 0;
        @             szText.cy = 0;
        @             ::GetTextExtentPoint32 (hdc, text, lstrlen (text), &szText);
        @             BOOL bDrawImage = hImages != NULL && item.iImage >= 0 && (rcText.right - rcText.left) >= (szText.cx + 20);
        @             if (bDrawImage)
        @             {
        @                 ::ImageList_Draw (hImages, item.iImage, hdc, rcText.left, rcText.top + ((rcText.bottom - rcText.top - 16) / 2), ILD_TRANSPARENT);
        @                 rcText.left += 20;
        @             }
        @             ::SetTextColor (hdc, bSel ? clrSelText : clrText);
        @             ::DrawText (hdc, text, -1, &rcText, (bDrawImage ? DT_LEFT : DT_CENTER) | DT_VCENTER | DT_SINGLELINE | DT_END_ELLIPSIS);
        @         }
        @         if (hOldFont != NULL)
        @             ::SelectObject (hdc, hOldFont);
        @         ::ReleaseDC (hTab, hdc);
        @     }
        @     static void ShowPage (HWND hWnd, INT nIndex)
        @     {
        @         HWND hDoc = (HWND)::GetProp (hWnd, kDocWndProp);
        @         HWND hLib = (HWND)::GetProp (hWnd, kLibWndProp);
        @         HWND hProp = (HWND)::GetProp (hWnd, kPropWndProp);
        @         if (::IsWindow (hDoc)) ::ShowWindow (hDoc, nIndex == 0 ? SW_SHOW : SW_HIDE);
        @         if (::IsWindow (hLib)) ::ShowWindow (hLib, nIndex == 1 ? SW_SHOW : SW_HIDE);
        @         if (::IsWindow (hProp)) ::ShowWindow (hProp, nIndex == 2 ? SW_SHOW : SW_HIDE);
        @     }
        @     static INT HitPage (HWND hWnd, HWND hTab, LPARAM lParam)
        @     {
        @         POINT pt;
        @         pt.x = GET_X_LPARAM (lParam);
        @         pt.y = GET_Y_LPARAM (lParam);
        @         if (::IsWindow (hTab))
        @         {
        @             POINT ptTab = pt;
        @             ::ClientToScreen (hWnd, &ptTab);
        @             ::ScreenToClient (hTab, &ptTab);
        @             RECT rcTab;
        @             if (!::GetClientRect (hTab, &rcTab))
        @                 return -1;
        @             if (ptTab.x < 0 || ptTab.x >= rcTab.right || ptTab.y < 0 || ptTab.y >= rcTab.bottom)
        @                 return -1;
        @             TCHITTESTINFO hit;
        @             ZeroMemory (&hit, sizeof (hit));
        @             hit.pt = ptTab;
        @             INT nIndex = (INT)::SendMessage (hTab, TCM_HITTEST, 0, (LPARAM)&hit);
        @             if (nIndex >= 0)
        @             {
        @                 RECT rcHitItem;
        @                 ZeroMemory (&rcHitItem, sizeof (rcHitItem));
        @                 if (::SendMessage (hTab, TCM_GETITEMRECT, nIndex, (LPARAM)&rcHitItem))
        @                 {
        @                     ::InflateRect (&rcHitItem, 8, 8);
        @                     if (ptTab.x >= rcHitItem.left && ptTab.x < rcHitItem.right && ptTab.y >= rcHitItem.top && ptTab.y < rcHitItem.bottom)
        @                         return nIndex;
        @                 }
        @             }
        @             if (ptTab.y < rcTab.bottom - 42 || ptTab.y >= rcTab.bottom)
        @                 return -1;
        @             INT nCount = (INT)::SendMessage (hTab, TCM_GETITEMCOUNT, 0, 0);
        @             for (INT i = 0; i < nCount; ++i)
        @             {
        @                 RECT rcItem;
        @                 ZeroMemory (&rcItem, sizeof (rcItem));
        @                 if (::SendMessage (hTab, TCM_GETITEMRECT, i, (LPARAM)&rcItem))
        @                 {
        @                     ::InflateRect (&rcItem, 8, 8);
        @                     if (ptTab.x >= rcItem.left && ptTab.x < rcItem.right && ptTab.y >= rcItem.top && ptTab.y < rcItem.bottom)
        @                         return i;
        @                 }
        @             }
        @             return -1;
        @         }
        @         return -1;
        @     }
        @     static void HookWindow (HWND hTarget, HWND hTab)
        @     {
        @         if (hTarget == NULL || !::IsWindow (hTarget))
        @             return;
        @         ::SetProp (hTarget, kTabWndProp, (HANDLE)hTab);
        @         if (::GetProp (hTarget, kOldProcProp) == NULL)
        @         {
        @             WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (hTarget, GWLP_WNDPROC, (LONG_PTR)CSolutionTabSwitchHook::Proc);
        @             if (oldProc != NULL)
        @                 ::SetProp (hTarget, kOldProcProp, (HANDLE)oldProc);
        @         }
        @     }
        @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
        @     {
        @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, kOldProcProp);
        @         if (uMsg == WM_PAINT)
        @         {
        @             LRESULT lr = oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam);
        @             HWND hTab = (HWND)::GetProp (hWnd, kTabWndProp);
        @             if (hTab == NULL)
        @                 hTab = hWnd;
        @             if (hWnd == hTab)
        @                 DrawTabs (hTab);
        @             return lr;
        @         }
        @         const BOOL bParentNotify = (uMsg == WM_PARENTNOTIFY && LOWORD (wParam) == WM_LBUTTONDOWN);
        @         if (uMsg == WM_LBUTTONDOWN || bParentNotify)
        @         {
        @             HWND hTab = (HWND)::GetProp (hWnd, kTabWndProp);
        @             if (hTab == NULL)
        @                 hTab = hWnd;
        @             INT nIndex = HitPage (hWnd, hTab, lParam);
        @             if (nIndex < 0)
        @                 return (oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam));
        @             if (nIndex >= 0)
        @             {
        @                 DWORD dwNow = ::GetTickCount ();
        @                 DWORD_PTR npLastSwitch = (DWORD_PTR)::GetProp (hTab, kLastSwitchTickProp);
        @                 if (npLastSwitch != 0 && dwNow - (DWORD)npLastSwitch < 120)
        @                 {
        @                     return 0;
        @                 }
        @                 ::SetProp (hTab, kLastSwitchTickProp, (HANDLE)(DWORD_PTR)dwNow);
        @                 ::SendMessage (hTab, TCM_SETCURSEL, nIndex, 0);
        @                 ShowPage (hTab, nIndex);
        @                 ::InvalidateRect (hTab, NULL, TRUE);
        @                 if (hWnd != hTab)
        @                     ::InvalidateRect (hWnd, NULL, TRUE);
        @                 return 0;
        @             }
        @         }
        @         if (uMsg == WM_NCDESTROY)
        @         {
        @             if (oldProc != NULL)
        @             {
        @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
        @                 ::RemoveProp (hWnd, kOldProcProp);
        @                 ::RemoveProp (hWnd, kDocWndProp);
        @                 ::RemoveProp (hWnd, kLibWndProp);
        @                 ::RemoveProp (hWnd, kPropWndProp);
        @                 ::RemoveProp (hWnd, kTabWndProp);
        @                 ::RemoveProp (hWnd, kLastSwitchTickProp);
        @                 ::RemoveProp (hWnd, kTabStyleProp);
        @                 ::RemoveProp (hWnd, kTabBgProp);
        @                 ::RemoveProp (hWnd, kTabSelBgProp);
        @                 ::RemoveProp (hWnd, kTabTextProp);
        @                 ::RemoveProp (hWnd, kTabSelTextProp);
        @                 ::RemoveProp (hWnd, kTabHiProp);
        @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
        @             }
        @         }
        @         return (oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam));
        @     }
        @ };
        @ CWnd* pTab = @<方案选择夹>.GetMfcWndPtrWithValidHWnd ();
        @ CWnd* pDoc = @<文件树>.GetMfcWndPtrWithValidHWnd ();
        @ CWnd* pLib = @<支持库树>.GetMfcWndPtrWithValidHWnd ();
        @ CWnd* pProp = @<属性编辑框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTab != NULL && pTab->m_hWnd != NULL)
        @ {
        @     if (pDoc != NULL) ::SetProp (pTab->m_hWnd, kDocWndProp, (HANDLE)pDoc->m_hWnd);
        @     if (pLib != NULL) ::SetProp (pTab->m_hWnd, kLibWndProp, (HANDLE)pLib->m_hWnd);
        @     if (pProp != NULL) ::SetProp (pTab->m_hWnd, kPropWndProp, (HANDLE)pProp->m_hWnd);
        @     if (::GetProp (pTab->m_hWnd, kOldProcProp) == NULL)
        @     {
        @         WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (pTab->m_hWnd, GWLP_WNDPROC, (LONG_PTR)CSolutionTabSwitchHook::Proc);
        @         if (oldProc != NULL)
        @             ::SetProp (pTab->m_hWnd, kOldProcProp, (HANDLE)oldProc);
        @     }
        @ }
        @ HWND pageWnds[3] = {
        @     pDoc == NULL ? NULL : pDoc->m_hWnd,
        @     pLib == NULL ? NULL : pLib->m_hWnd,
        @     pProp == NULL ? NULL : pProp->m_hWnd
        @ };
        @ for (int i = 0; i < 3 && pTab != NULL && pTab->m_hWnd != NULL; ++i)
        @ {
        @     HWND hPage = pageWnds[i];
        @     if (hPage == NULL || !::IsWindow (hPage))
        @         continue;
        @     CSolutionTabSwitchHook::HookWindow (hPage, pTab->m_hWnd);
        @ }
        @ HWND hAncestor = pTab == NULL ? NULL : ::GetParent (pTab->m_hWnd);
        @ for (int i = 0; i < 8 && hAncestor != NULL && ::IsWindow (hAncestor); ++i)
        @ {
        @     CSolutionTabSwitchHook::HookWindow (hAncestor, pTab->m_hWnd);
        @     hAncestor = ::GetParent (hAncestor);
        @ }
    }

    方法 安装文件树右键拦截 <公开 @禁止流程检查 = 真>
    {
        @ static const TCHAR* kOldProcProp = _T ("ccide_solution_tree_context_old_proc");
        @ static const TCHAR* kLastPopupTickProp = _T ("ccide_solution_tree_context_last_tick");
        @ static const UINT kPopupTreeMenuCommand = 30012;
        @ struct CSolutionTreeContextHook
        @ {
        @     static void SelectHitItem (HWND hWnd, LPARAM lParam)
        @     {
        @         POINT pt;
        @         if (lParam != (LPARAM)-1)
        @         {
        @             pt.x = GET_X_LPARAM (lParam);
        @             pt.y = GET_Y_LPARAM (lParam);
        @             ::ScreenToClient (hWnd, &pt);
        @         }
        @         else
        @         {
        @             ::GetCursorPos (&pt);
        @             ::ScreenToClient (hWnd, &pt);
        @         }
        @         TVHITTESTINFO hit;
        @         ZeroMemory (&hit, sizeof (hit));
        @         hit.pt = pt;
        @         HTREEITEM hItem = (HTREEITEM)::SendMessage (hWnd, TVM_HITTEST, 0, (LPARAM)&hit);
        @         if (hItem != NULL)
        @             ::SendMessage (hWnd, TVM_SELECTITEM, TVGN_CARET, (LPARAM)hItem);
        @     }
        @     static void NotifyMainWindow (HWND hWnd)
        @     {
        @         DWORD dwNow = ::GetTickCount ();
        @         DWORD_PTR npLastTick = (DWORD_PTR)::GetProp (hWnd, kLastPopupTickProp);
        @         if (npLastTick != 0 && dwNow - (DWORD)npLastTick < 200)
        @             return;
        @         ::SetProp (hWnd, kLastPopupTickProp, (HANDLE)(DWORD_PTR)dwNow);
        @         CWnd* pMain = AfxGetMainWnd ();
        @         HWND hTarget = (pMain != NULL && pMain->GetSafeHwnd () != NULL) ? pMain->GetSafeHwnd () : ::GetAncestor (hWnd, GA_ROOT);
        @         if (hTarget != NULL && ::IsWindow (hTarget))
        @             ::PostMessage (hTarget, WM_COMMAND, MAKEWPARAM (kPopupTreeMenuCommand, 0), (LPARAM)hWnd);
        @     }
        @     static void SendMenuCommand (HWND hWnd, UINT nCmd)
        @     {
        @         if (nCmd == 0)
        @             return;
        @         CWnd* pMain = AfxGetMainWnd ();
        @         HWND hTarget = (pMain != NULL && pMain->GetSafeHwnd () != NULL) ? pMain->GetSafeHwnd () : ::GetAncestor (hWnd, GA_ROOT);
        @         if (hTarget != NULL && ::IsWindow (hTarget))
        @             ::SendMessage (hTarget, WM_COMMAND, MAKEWPARAM (nCmd, 0), (LPARAM)hWnd);
        @     }
        @     static void PopupNativeMenu (HWND hWnd, LPARAM lParam)
        @     {
        @         DWORD dwNow = ::GetTickCount ();
        @         DWORD_PTR npLastTick = (DWORD_PTR)::GetProp (hWnd, kLastPopupTickProp);
        @         if (npLastTick != 0 && dwNow - (DWORD)npLastTick < 200)
        @             return;
        @         ::SetProp (hWnd, kLastPopupTickProp, (HANDLE)(DWORD_PTR)dwNow);
        @         POINT pt;
        @         if (lParam != (LPARAM)-1)
        @         {
        @             pt.x = GET_X_LPARAM (lParam);
        @             pt.y = GET_Y_LPARAM (lParam);
        @         }
        @         else
        @         {
        @             ::GetCursorPos (&pt);
        @         }
        @         HMENU hMenu = ::CreatePopupMenu ();
        @         if (hMenu == NULL)
        @         {
        @             NotifyMainWindow (hWnd);
        @             return;
        @         }
        @         ::AppendMenu (hMenu, MF_STRING, 30001, _T ("刷新"));
        @         ::AppendMenu (hMenu, MF_SEPARATOR, 0, NULL);
        @         ::AppendMenu (hMenu, MF_STRING, 30006, _T ("新建窗口"));
        @         ::AppendMenu (hMenu, MF_STRING, 30008, _T ("创建模块"));
        @         ::AppendMenu (hMenu, MF_STRING, 30009, _T ("配置项目模块"));
        @         ::AppendMenu (hMenu, MF_STRING, 30010, _T ("重新引入模块"));
        @         ::AppendMenu (hMenu, MF_STRING, 30011, _T ("位置调整"));
        @         ::AppendMenu (hMenu, MF_SEPARATOR, 0, NULL);
        @         ::AppendMenu (hMenu, MF_STRING, 30004, _T ("生成项目"));
        @         ::AppendMenu (hMenu, MF_STRING, 30005, _T ("设为启动项目"));
        @         ::AppendMenu (hMenu, MF_STRING, 30007, _T ("重命名"));
        @         ::AppendMenu (hMenu, MF_STRING, 30002, _T ("打开所在文件夹"));
        @         ::AppendMenu (hMenu, MF_STRING, 30003, _T ("删除"));
        @         UINT nCmd = ::TrackPopupMenu (hMenu, TPM_RETURNCMD | TPM_RIGHTBUTTON, pt.x, pt.y, 0, hWnd, NULL);
        @         ::DestroyMenu (hMenu);
        @         SendMenuCommand (hWnd, nCmd);
        @     }
        @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
        @     {
        @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, kOldProcProp);
        @         if (uMsg == WM_RBUTTONUP || uMsg == WM_CONTEXTMENU)
        @         {
        @             SelectHitItem (hWnd, uMsg == WM_CONTEXTMENU ? lParam : (LPARAM)-1);
        @             PopupNativeMenu (hWnd, uMsg == WM_CONTEXTMENU ? lParam : (LPARAM)-1);
        @             return 0;
        @         }
        @         if (uMsg == WM_NCDESTROY)
        @         {
        @             if (oldProc != NULL)
        @             {
        @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
        @                 ::RemoveProp (hWnd, kOldProcProp);
        @                 ::RemoveProp (hWnd, kLastPopupTickProp);
        @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
        @             }
        @         }
        @         return (oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam));
        @     }
        @ };
        @ CWnd* pTree = @<文件树>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTree != NULL && pTree->m_hWnd != NULL && ::GetProp (pTree->m_hWnd, kOldProcProp) == NULL)
        @ {
        @     WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (pTree->m_hWnd, GWLP_WNDPROC, (LONG_PTR)CSolutionTreeContextHook::Proc);
        @     if (oldProc != NULL)
        @         ::SetProp (pTree->m_hWnd, kOldProcProp, (HANDLE)oldProc);
        @ }
    }

