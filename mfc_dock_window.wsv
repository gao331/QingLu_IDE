    }

    方法 浮动显示 <公开 类型 = 逻辑型 注释 = "将停靠窗口切换为浮动窗口并设置浮动矩形." @禁止流程检查 = 真>
    参数 左边 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 宽度 <类型 = 整数 注释 = "小于等于0时使用默认宽度." @默认值 = 320>
    参数 高度 <类型 = 整数 注释 = "小于等于0时使用默认高度." @默认值 = 240>
    {
        @ return data ().FloatAt (@<左边>, @<顶边>, @<宽度>, @<高度>);
    }

    方法 停靠到主窗口 <公开 类型 = 逻辑型 注释 = "将窗口重新停靠到MDI主窗口指定方向." @禁止流程检查 = 真>
    参数 父窗口 <类型 = MDI主窗口>
    参数 停靠方向 <类型 = 整数 注释 = "使用组件允许停靠位置中的某一边.">
    {
        @ return data ().DockToFrame ((CMDIFrameWndEx*)@<父窗口>.GetMfcWndPtrWithValidHWnd (), @<停靠方向>);
    }

    方法 移动浮动窗口 <公开 类型 = 逻辑型 注释 = "移动/调整浮动状态下的停靠窗口矩形." @禁止流程检查 = 真>
