# @         ::AppendMenu (hMenu, MF_STRING, 30006, _T ("新建窗口"));
# @         ::AppendMenu (hMenu, MF_STRING, 30008, _T ("创建模块"));
# @         ::AppendMenu (hMenu, MF_STRING, 30009, _T ("配置项目模块"));
# @         ::AppendMenu (hMenu, MF_STRING, 30010, _T ("重新引入模块"));
# @         ::AppendMenu (hMenu, MF_STRING, 30011, _T ("位置调整"));
# @         ::AppendMenu (hMenu, MF_SEPARATOR, 0, NULL);
# @         ::AppendMenu (hMenu, MF_STRING, 30004, _T ("生成项目"));
# @         ::AppendMenu (hMenu, MF_STRING, 30005, _T ("设为启动项目"));
# @         ::AppendMenu (hMenu, MF_STRING, 30007, _T ("重命名"));
# @         ::AppendMenu (hMenu, MF_STRING, 30002, _T ("打开所在文件夹"));
# @         ::AppendMenu (hMenu, MF_STRING, 30003, _T ("删除"));
# @
# @         UINT nCmd = ::TrackPopupMenu (hMenu, TPM_RETURNCMD | TPM_RIGHTBUTTON, ptScreen.x, ptScreen.y, 0, GetSafeHwnd (), NULL);
# @         ::DestroyMenu (hMenu);
# @         if (nCmd != 0)
# @         {
# @             CWnd* pMain = AfxGetMainWnd ();
# @             HWND hTarget = (pMain != NULL && pMain->GetSafeHwnd () != NULL) ? pMain->GetSafeHwnd () : ::GetAncestor (GetSafeHwnd (), GA_ROOT);
# @             if (hTarget != NULL && ::IsWindow (hTarget))
# @                 ::SendMessage (hTarget, WM_COMMAND, MAKEWPARAM (nCmd, 0), (LPARAM)GetSafeHwnd ());
# @         }
# @         return TRUE;
# @     }
# @
# @     virtual void OnContextMenu (CWnd* pWnd, CPoint point)
# @     {
# @         if (m_hUserWnd != NULL && ::IsWindow (m_hUserWnd))
# @         {
# @             if (PopupSolutionTreeNativeMenu (point))
# @                 return;
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_SUPPRESS_CONTEXT_MENU"));
# @             return;
# @         }
# @         CDockablePane::OnContextMenu (pWnd, point);
# @     }
# @
# @     virtual LRESULT WindowProc (UINT message, WPARAM wParam, LPARAM lParam) override
# @     {
# @         if (message == WM_CLOSE)
# @             Notify (CCIDE_DOCK_EVT_CLOSING, 0, 0, 0, 0);
