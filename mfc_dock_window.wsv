类 解决方案管理停靠窗口 <公开 基础类 = VS扩展停靠窗口 注释 = "IDE左侧解决方案管理器停靠窗" @视窗.布局 = "client_size = \"260, 600\"">
{
    变量 方案选择夹 <公开 类型 = 选择夹
            @视窗.布局 = "id = 1004\r\npos = \"0, 0, 260, 600\""
            子夹项目 = "解决方案\n0\n支持库\n1\n属性\n2"
            图片组 = "..\\Assets\\dock_solution_tabs.bmp">

    变量 文件树 <公开 类型 = 增强树形框
            @视窗.布局 = "id = 1005\r\npos = \"0, 28, 260, 572\""
            显示加减框 = 真 显示连线 = 真 显示根部线 = 真 始终显示选择项 = 真
            图片组文件 = "..\\Assets\\tree_icons.bmp"
            字体 = "微软雅黑, 10">

    变量 支持库树 <公开 类型 = 增强树形框
            @视窗.布局 = "id = 1006\r\npos = \"0, 28, 260, 572\""
            显示加减框 = 真 显示连线 = 真 显示根部线 = 真 始终显示选择项 = 真
            图片组文件 = "..\\Assets\\tree_icons.bmp"
            字体 = "微软雅黑, 10">

    变量 项目树 <公开 类型 = 增强树形框
            @视窗.布局 = "id = 1007\r\npos = \"0, 28, 260, 572\""
            显示加减框 = 真 显示连线 = 真 显示根部线 = 真 始终显示选择项 = 真
            图片组文件 = "..\\Assets\\tree_icons.bmp"
            字体 = "微软雅黑, 10">

    变量 属性编辑框 <公开 类型 = 超级编辑框
            @视窗.布局 = "id = 1008\r\npos = \"0, 28, 260, 572\"\r\n是否允许多行 = 真\r\n只读 = 真\r\n纯文本模式 = 真\r\n自动换行 = 真"
            背景颜色 = 0x00F8FAFC 字体 = "微软雅黑, 10">

