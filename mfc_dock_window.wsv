    }

    方法 脱离停靠窗口 <公开 类型 = 逻辑型 注释 = "从当前停靠/标签容器中脱离,通常配合浮动显示或重新停靠使用." @禁止流程检查 = 真>
    参数 是否延迟 <类型 = 逻辑型 @默认值 = 假>
    {
        @ return data ().UndockFromFrame (@<是否延迟>);
    }

    方法 保存停靠状态 <公开 类型 = 逻辑型 注释 = "保存当前停靠窗口状态到MFC配置项.配置名称为空时使用MFC默认配置." @禁止流程检查 = 真>
    参数 配置名称 <类型 = 文本型 @默认值 = "">
    参数 索引 <类型 = 整数 @默认值 = -1>
    参数 ID值 <类型 = 整数 @默认值 = -1>
    {
        @ return data ().SavePaneState (@<配置名称>.GetText (), @<索引>, (UINT)@<ID值>);
    }

    方法 读取停靠状态 <公开 类型 = 逻辑型 注释 = "从MFC配置项读取当前停靠窗口状态.配置名称为空时使用MFC默认配置." @禁止流程检查 = 真>
    参数 配置名称 <类型 = 文本型 @默认值 = "">
    参数 索引 <类型 = 整数 @默认值 = -1>
    参数 ID值 <类型 = 整数 @默认值 = -1>
    {
        @ return data ().LoadPaneState (@<配置名称>.GetText (), @<索引>, (UINT)@<ID值>);
    }

    方法 激活停靠窗口 <公开 注释 = "显示并激活停靠窗口.">
    {
        @ data ().ActivatePaneTab ();
    }

    方法 销毁停靠窗口 <公开 类型 = 逻辑型 注释 = "销毁底层CDockablePane窗口.成功发起销毁返回真,窗口不存在返回假." @禁止流程检查 = 真>
    {
        @ return (data ().GetSafeHwnd () != NULL ? data ().DestroyWindow () : FALSE);
    }

    方法 重画停靠窗口 <公开 注释 = "重画停靠窗内部用户窗口.">
    {
        @ data ().Redraw ();
    }

    方法 组合VS停靠选择夹 <公开 静态 注释 = "将多个VS扩展停靠窗口组合成标签停靠窗口.所有窗口必须已经创建." @嵌入式方法 = "">
    参数 所组合窗口 <类型 = VS扩展停靠窗口 注释 = "提供欲组合到同一标签组的停靠窗口" @可扩展 = "d_text = \".pdata (), \"">
    {
        @ CCcIdeWndBarEx::sDockControls (NUM_CHARS_OF_TEXT (@sn<pm_types>), @<所组合窗口>.pdata ())
    }

    方法 应用最小尺寸 <注释 = "将最小宽高应用到底层MFC pane.">
    {
        @ data ().SetMinTrackSize (@<内部最小宽度>, @<内部最小高度>);
    }

