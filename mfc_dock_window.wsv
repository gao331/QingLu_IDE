    方法 页签高亮颜色 <公开 属性写 注释 = "设置选中页签顶部/底部强调线颜色.">
    参数 颜色值 <类型 = 整数>
    {
        内部页签高亮颜色 = 颜色值
        应用页签样式 ()
    }

    方法 应用页签位置 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pTab = @<输出选择夹>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTab != NULL && pTab->m_hWnd != NULL)
        @ {
        @     LONG_PTR style = ::GetWindowLongPtr (pTab->m_hWnd, GWL_STYLE);
        @     style &= ~(TCS_BOTTOM | TCS_VERTICAL);
        @     switch (@<内部页签位置>)
        @     {
        @     case 1: style |= TCS_BOTTOM; break;
        @     case 2: style |= TCS_VERTICAL; break;
        @     case 3: style |= TCS_BOTTOM | TCS_VERTICAL; break;
        @     default: break;
        @     }
        @     ::SetWindowLongPtr (pTab->m_hWnd, GWL_STYLE, style);
        @     ::SetWindowPos (pTab->m_hWnd, NULL, 0, 0, 0, 0,
        @         SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED);
        @     pTab->Invalidate ();
        @ }
    }

    方法 应用页签样式 <公开 @禁止流程检查 = 真>
    {
        @ CWnd* pTab = @<输出选择夹>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTab != NULL && pTab->m_hWnd != NULL)
        @ {
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_output_tab_style"), (HANDLE)(DWORD_PTR)(@<内部页签样式> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_output_tab_bg"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签背景颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_output_tab_sel_bg"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签选中背景颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_output_tab_text"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签文字颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_output_tab_sel_text"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签选中文字颜色> + 1));
        @     ::SetProp (pTab->m_hWnd, _T ("ccide_output_tab_hi"), (HANDLE)(DWORD_PTR)((COLORREF)@<内部页签高亮颜色> + 1));
        @     LONG_PTR nStyle = ::GetWindowLongPtr (pTab->m_hWnd, GWL_STYLE);
        @     if ((nStyle & TCS_FIXEDWIDTH) == 0)
        @         ::SetWindowLongPtr (pTab->m_hWnd, GWL_STYLE, nStyle | TCS_FIXEDWIDTH);
        @     ::SendMessage (pTab->m_hWnd, TCM_SETITEMSIZE, 0, MAKELPARAM (84, 26));
        @     ::SetWindowPos (pTab->m_hWnd, NULL, 0, 0, 0, 0,
        @         SWP_NOMOVE | SWP_NOSIZE | SWP_NOZORDER | SWP_NOACTIVATE | SWP_FRAMECHANGED);
        @     ::InvalidateRect (pTab->m_hWnd, NULL, TRUE);
        @ }
    }

    方法 安装页签原生切换 <公开 @禁止流程检查 = 真>
    {
        @ static const TCHAR* kOldProcProp = _T ("ccide_output_tab_old_proc");
        @ static const TCHAR* kTipWndProp = _T ("ccide_output_tab_tip");
        @ static const TCHAR* kOutputWndProp = _T ("ccide_output_tab_output");
        @ static const TCHAR* kTabWndProp = _T ("ccide_output_tab_hwnd");
        @ static const TCHAR* kLastSwitchTickProp = _T ("ccide_output_tab_last_switch_tick");
        @ static const TCHAR* kTabStyleProp = _T ("ccide_output_tab_style");
        @ static const TCHAR* kTabBgProp = _T ("ccide_output_tab_bg");
        @ static const TCHAR* kTabSelBgProp = _T ("ccide_output_tab_sel_bg");
        @ static const TCHAR* kTabTextProp = _T ("ccide_output_tab_text");
        @ static const TCHAR* kTabSelTextProp = _T ("ccide_output_tab_sel_text");
        @ static const TCHAR* kTabHiProp = _T ("ccide_output_tab_hi");
        @ struct COutputTabSwitchHook
        @ {
        @     static INT GetIntProp (HWND hWnd, const TCHAR* name, INT defValue)
        @     {
        @         DWORD_PTR v = (DWORD_PTR)::GetProp (hWnd, name);
        @         return v == 0 ? defValue : (INT)(v - 1);
        @     }
        @     static COLORREF GetColorProp (HWND hWnd, const TCHAR* name, COLORREF defValue)
        @     {
        @         DWORD_PTR v = (DWORD_PTR)::GetProp (hWnd, name);
        @         return v == 0 ? defValue : (COLORREF)(v - 1);
        @     }
        @     static void DrawTabs (HWND hTab)
        @     {
        @         if (!::IsWindow (hTab) || GetIntProp (hTab, kTabStyleProp, 1) <= 0)
        @             return;
        @         HDC hdc = ::GetDC (hTab);
        @         if (hdc == NULL)
        @             return;
        @         const INT nCount = (INT)::SendMessage (hTab, TCM_GETITEMCOUNT, 0, 0);
        @         const INT nCur = (INT)::SendMessage (hTab, TCM_GETCURSEL, 0, 0);
        @         COLORREF clrBg = GetColorProp (hTab, kTabBgProp, RGB (17, 24, 39));
        @         COLORREF clrSelBg = GetColorProp (hTab, kTabSelBgProp, RGB (30, 64, 175));
        @         COLORREF clrText = GetColorProp (hTab, kTabTextProp, RGB (148, 163, 184));
        @         COLORREF clrSelText = GetColorProp (hTab, kTabSelTextProp, RGB (248, 250, 252));
        @         COLORREF clrHi = GetColorProp (hTab, kTabHiProp, RGB (56, 189, 248));
        @         COLORREF clrBorder = RGB (51, 65, 85);
        @         HIMAGELIST hImages = (HIMAGELIST)::SendMessage (hTab, TCM_GETIMAGELIST, 0, 0);
        @         HFONT hFont = (HFONT)::SendMessage (hTab, WM_GETFONT, 0, 0);
        @         HFONT hOldFont = hFont == NULL ? NULL : (HFONT)::SelectObject (hdc, hFont);
        @         ::SetBkMode (hdc, TRANSPARENT);
        @         for (INT i = 0; i < nCount; ++i)
        @         {
        @             RECT rcItem;
        @             ZeroMemory (&rcItem, sizeof (rcItem));
        @             if (!::SendMessage (hTab, TCM_GETITEMRECT, i, (LPARAM)&rcItem))
        @                 continue;
        @             const BOOL bSel = (i == nCur);
        @             RECT rcFill = rcItem;
        @             ::InflateRect (&rcFill, 1, 2);
        @             HBRUSH hBrush = ::CreateSolidBrush (bSel ? clrSelBg : clrBg);
        @             ::FillRect (hdc, &rcFill, hBrush);
        @             ::DeleteObject (hBrush);
        @             HPEN hPen = ::CreatePen (PS_SOLID, 1, clrBorder);
        @             HPEN hOldPen = (HPEN)::SelectObject (hdc, hPen);
        @             ::MoveToEx (hdc, rcFill.left, rcFill.top, NULL);
        @             ::LineTo (hdc, rcFill.right, rcFill.top);
        @             ::MoveToEx (hdc, rcFill.left, rcFill.bottom - 1, NULL);
        @             ::LineTo (hdc, rcFill.right, rcFill.bottom - 1);
        @             ::SelectObject (hdc, hOldPen);
        @             ::DeleteObject (hPen);
        @             if (bSel)
        @             {
        @                 RECT rcHi = rcFill;
        @                 if ((::GetWindowLongPtr (hTab, GWL_STYLE) & TCS_BOTTOM) != 0)
        @                     rcHi.top = rcHi.bottom - 3;
        @                 else
        @                     rcHi.bottom = rcHi.top + 3;
        @                 HBRUSH hHi = ::CreateSolidBrush (clrHi);
        @                 ::FillRect (hdc, &rcHi, hHi);
        @                 ::DeleteObject (hHi);
        @             }
        @             TCHAR text[128];
        @             TC_ITEM item;
        @             ZeroMemory (&item, sizeof (item));
        @             ZeroMemory (text, sizeof (text));
        @             item.mask = TCIF_TEXT | TCIF_IMAGE;
        @             item.pszText = text;
        @             item.cchTextMax = 127;
        @             item.iImage = -1;
        @             ::SendMessage (hTab, TCM_GETITEM, i, (LPARAM)&item);
        @             RECT rcText = rcItem;
        @             rcText.left += 8;
        @             rcText.right -= 8;
        @             SIZE szText;
        @             szText.cx = 0;
        @             szText.cy = 0;
        @             ::GetTextExtentPoint32 (hdc, text, lstrlen (text), &szText);
        @             BOOL bDrawImage = hImages != NULL && item.iImage >= 0 && (rcText.right - rcText.left) >= (szText.cx + 20);
        @             if (bDrawImage)
        @             {
        @                 ::ImageList_Draw (hImages, item.iImage, hdc, rcText.left, rcText.top + ((rcText.bottom - rcText.top - 16) / 2), ILD_TRANSPARENT);
        @                 rcText.left += 20;
        @             }
        @             ::SetTextColor (hdc, bSel ? clrSelText : clrText);
        @             ::DrawText (hdc, text, -1, &rcText, (bDrawImage ? DT_LEFT : DT_CENTER) | DT_VCENTER | DT_SINGLELINE | DT_END_ELLIPSIS);
        @         }
        @         if (hOldFont != NULL)
        @             ::SelectObject (hdc, hOldFont);
        @         ::ReleaseDC (hTab, hdc);
        @     }
        @     static void ShowPage (HWND hWnd, INT nIndex)
        @     {
        @         HWND hTip = (HWND)::GetProp (hWnd, kTipWndProp);
        @         HWND hOutput = (HWND)::GetProp (hWnd, kOutputWndProp);
        @         if (::IsWindow (hTip)) ::ShowWindow (hTip, nIndex == 0 ? SW_SHOW : SW_HIDE);
        @         if (::IsWindow (hOutput)) ::ShowWindow (hOutput, nIndex == 1 ? SW_SHOW : SW_HIDE);
        @     }
        @     static INT HitPage (HWND hWnd, HWND hTab, LPARAM lParam)
        @     {
        @         POINT pt;
        @         pt.x = GET_X_LPARAM (lParam);
        @         pt.y = GET_Y_LPARAM (lParam);
        @         if (::IsWindow (hTab))
        @         {
        @             POINT ptTab = pt;
        @             ::ClientToScreen (hWnd, &ptTab);
        @             ::ScreenToClient (hTab, &ptTab);
        @             RECT rcTab;
        @             if (!::GetClientRect (hTab, &rcTab))
        @                 return -1;
        @             if (ptTab.x < 0 || ptTab.x >= rcTab.right || ptTab.y < 0 || ptTab.y >= rcTab.bottom)
        @                 return -1;
        @             TCHITTESTINFO hit;
        @             ZeroMemory (&hit, sizeof (hit));
        @             hit.pt = ptTab;
        @             INT nIndex = (INT)::SendMessage (hTab, TCM_HITTEST, 0, (LPARAM)&hit);
        @             if (nIndex >= 0)
        @             {
        @                 RECT rcHitItem;
        @                 ZeroMemory (&rcHitItem, sizeof (rcHitItem));
        @                 if (::SendMessage (hTab, TCM_GETITEMRECT, nIndex, (LPARAM)&rcHitItem))
        @                 {
        @                     ::InflateRect (&rcHitItem, 8, 8);
        @                     if (ptTab.x >= rcHitItem.left && ptTab.x < rcHitItem.right && ptTab.y >= rcHitItem.top && ptTab.y < rcHitItem.bottom)
        @                         return nIndex;
        @                 }
        @             }
        @             if (ptTab.y < rcTab.bottom - 42 || ptTab.y >= rcTab.bottom)
        @                 return -1;
        @             INT nCount = (INT)::SendMessage (hTab, TCM_GETITEMCOUNT, 0, 0);
        @             for (INT i = 0; i < nCount; ++i)
        @             {
        @                 RECT rcItem;
        @                 ZeroMemory (&rcItem, sizeof (rcItem));
        @                 if (::SendMessage (hTab, TCM_GETITEMRECT, i, (LPARAM)&rcItem))
        @                 {
        @                     ::InflateRect (&rcItem, 8, 8);
        @                     if (ptTab.x >= rcItem.left && ptTab.x < rcItem.right && ptTab.y >= rcItem.top && ptTab.y < rcItem.bottom)
        @                         return i;
        @                 }
        @             }
        @             return -1;
        @         }
        @         return -1;
        @     }
        @     static void HookWindow (HWND hTarget, HWND hTab)
        @     {
        @         if (hTarget == NULL || !::IsWindow (hTarget))
        @             return;
        @         ::SetProp (hTarget, kTabWndProp, (HANDLE)hTab);
        @         if (::GetProp (hTarget, kOldProcProp) == NULL)
        @         {
        @             WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (hTarget, GWLP_WNDPROC, (LONG_PTR)COutputTabSwitchHook::Proc);
        @             if (oldProc != NULL)
        @                 ::SetProp (hTarget, kOldProcProp, (HANDLE)oldProc);
        @         }
        @     }
        @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
        @     {
        @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, kOldProcProp);
        @         if (uMsg == WM_PAINT)
        @         {
        @             LRESULT lr = oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam);
        @             HWND hTab = (HWND)::GetProp (hWnd, kTabWndProp);
        @             if (hTab == NULL)
        @                 hTab = hWnd;
        @             if (hWnd == hTab)
        @                 DrawTabs (hTab);
        @             return lr;
        @         }
        @         const BOOL bParentNotify = (uMsg == WM_PARENTNOTIFY && LOWORD (wParam) == WM_LBUTTONDOWN);
        @         if (uMsg == WM_LBUTTONDOWN || bParentNotify)
        @         {
        @             HWND hTab = (HWND)::GetProp (hWnd, kTabWndProp);
        @             if (hTab == NULL)
        @                 hTab = hWnd;
        @             INT nIndex = HitPage (hWnd, hTab, lParam);
        @             if (nIndex < 0)
        @                 return (oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam));
        @             if (nIndex >= 0)
        @             {
        @                 DWORD dwNow = ::GetTickCount ();
        @                 DWORD_PTR npLastSwitch = (DWORD_PTR)::GetProp (hTab, kLastSwitchTickProp);
        @                 if (npLastSwitch != 0 && dwNow - (DWORD)npLastSwitch < 120)
        @                 {
        @                     return 0;
        @                 }
        @                 ::SetProp (hTab, kLastSwitchTickProp, (HANDLE)(DWORD_PTR)dwNow);
        @                 ::SendMessage (hTab, TCM_SETCURSEL, nIndex, 0);
        @                 ShowPage (hTab, nIndex);
        @                 ::InvalidateRect (hTab, NULL, TRUE);
        @                 if (hWnd != hTab)
        @                     ::InvalidateRect (hWnd, NULL, TRUE);
        @                 return 0;
        @             }
        @         }
        @         if (uMsg == WM_NCDESTROY)
        @         {
        @             if (oldProc != NULL)
        @             {
        @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
        @                 ::RemoveProp (hWnd, kOldProcProp);
        @                 ::RemoveProp (hWnd, kTipWndProp);
        @                 ::RemoveProp (hWnd, kOutputWndProp);
        @                 ::RemoveProp (hWnd, kTabWndProp);
        @                 ::RemoveProp (hWnd, kLastSwitchTickProp);
        @                 ::RemoveProp (hWnd, kTabStyleProp);
        @                 ::RemoveProp (hWnd, kTabBgProp);
        @                 ::RemoveProp (hWnd, kTabSelBgProp);
        @                 ::RemoveProp (hWnd, kTabTextProp);
        @                 ::RemoveProp (hWnd, kTabSelTextProp);
        @                 ::RemoveProp (hWnd, kTabHiProp);
        @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
        @             }
        @         }
        @         return (oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam));
        @     }
        @ };
        @ CWnd* pTab = @<输出选择夹>.GetMfcWndPtrWithValidHWnd ();
        @ CWnd* pTip = @<提示编辑框>.GetMfcWndPtrWithValidHWnd ();
        @ CWnd* pOutput = @<输出编辑框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pTab != NULL && pTab->m_hWnd != NULL)
        @ {
        @     if (pTip != NULL) ::SetProp (pTab->m_hWnd, kTipWndProp, (HANDLE)pTip->m_hWnd);
        @     if (pOutput != NULL) ::SetProp (pTab->m_hWnd, kOutputWndProp, (HANDLE)pOutput->m_hWnd);
        @     if (::GetProp (pTab->m_hWnd, kOldProcProp) == NULL)
        @     {
        @         WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (pTab->m_hWnd, GWLP_WNDPROC, (LONG_PTR)COutputTabSwitchHook::Proc);
        @         if (oldProc != NULL)
        @             ::SetProp (pTab->m_hWnd, kOldProcProp, (HANDLE)oldProc);
        @     }
        @ }
        @ HWND pageWnds[2] = {
        @     pTip == NULL ? NULL : pTip->m_hWnd,
        @     pOutput == NULL ? NULL : pOutput->m_hWnd
        @ };
        @ for (int i = 0; i < 2 && pTab != NULL && pTab->m_hWnd != NULL; ++i)
        @ {
        @     HWND hPage = pageWnds[i];
        @     if (hPage == NULL || !::IsWindow (hPage))
        @         continue;
        @     COutputTabSwitchHook::HookWindow (hPage, pTab->m_hWnd);
        @ }
        @ HWND hAncestor = pTab == NULL ? NULL : ::GetParent (pTab->m_hWnd);
        @ for (int i = 0; i < 8 && hAncestor != NULL && ::IsWindow (hAncestor); ++i)
        @ {
        @     COutputTabSwitchHook::HookWindow (hAncestor, pTab->m_hWnd);
        @     hAncestor = ::GetParent (hAncestor);
        @ }
    }

    方法 置提示页图标 <公开>
    参数 图标索引 <类型 = 整数>
    {
        输出选择夹.置子夹图标索引 (0, 图标索引)
    }

    方法 置输出页图标 <公开>
    参数 图标索引 <类型 = 整数>
    {
        输出选择夹.置子夹图标索引 (1, 图标索引)
    }

    方法 当前页 <公开 属性读 类型 = 整数>
    {
        返回 (输出选择夹.现行子夹)
    }

    方法 当前页 <公开 属性写>
    参数 页索引 <类型 = 整数>
    {
        输出选择夹.现行子夹 = 页索引
        刷新页可视状态 ()
    }

    方法 刷新页可视状态 <公开>
    {
        输出选择夹.可视 = 假
        提示编辑框.可视 = (输出选择夹.现行子夹 == 0)
        输出编辑框.可视 = (输出选择夹.现行子夹 == 1)
    }

    方法 调整内部布局 <公开>
    参数 宽度2 <类型 = 整数>
    参数 高度2 <类型 = 整数>
    {
        如果 (宽度2 < 1)
        {
            宽度2 = 1
        }
        如果 (高度2 < 1)
        {
            高度2 = 1
        }
        输出选择夹.可视 = 假
        提示编辑框.移动 (0, 0, 宽度2, 高度2)
        输出编辑框.移动 (0, 0, 宽度2, 高度2)
        刷新页可视状态 ()
    }

    方法 安装原生菜单 <公开 @禁止流程检查 = 真>
    {
        @ static const TCHAR* kOldProcProp = _T ("ccide_output_old_proc");
        @ static const TCHAR* kSelectingProp = _T ("ccide_output_selecting");
        @ static const TCHAR* kSelectAnchorProp = _T ("ccide_output_select_anchor");
        @ static const TCHAR* kSkipRButtonProp = _T ("ccide_output_skip_rbutton");
        @ static const UINT kCopyId = 41001;
        @ static const UINT kCopyAllId = 41002;
        @ static const UINT kClearId = 41003;
        @ struct COutputRichEditMenuHook
        @ {
        @     static void SetSelectionRange (HWND hWnd, LONG nAnchor, LONG nChar)
        @     {
        @         CHARRANGE cr;
        @         ZERO_MEM (&cr, sizeof (cr));
        @         if (nAnchor <= nChar)
        @         {
        @             cr.cpMin = nAnchor;
        @             cr.cpMax = nChar;
        @         }
        @         else
        @         {
        @             cr.cpMin = nChar;
        @             cr.cpMax = nAnchor;
        @         }
        @         if (cr.cpMax > cr.cpMin)
        @             cr.cpMax++;
        @         ::SetFocus (hWnd);
        @         ::SendMessage (hWnd, EM_EXSETSEL, 0, (LPARAM)&cr);
        @         ::SendMessage (hWnd, EM_HIDESELECTION, FALSE, 0);
        @         ::RedrawWindow (hWnd, NULL, NULL, RDW_INVALIDATE | RDW_UPDATENOW);
        @     }
        @
        @     static LONG CharFromClientPoint (HWND hWnd, LPARAM lParam)
        @     {
        @         POINTL pt;
        @         pt.x = GET_X_LPARAM (lParam);
        @         pt.y = GET_Y_LPARAM (lParam);
        @         LRESULT result = ::SendMessage (hWnd, EM_CHARFROMPOS, 0, (LPARAM)&pt);
        @         if (result < 0)
        @             result = 0;
        @         return (LONG)result;
        @     }
        @
        @     static BOOL IsPointInTextArea (HWND hWnd, LPARAM lParam)
        @     {
        @         RECT rcText;
        @         ZERO_MEM (&rcText, sizeof (rcText));
        @         ::SendMessage (hWnd, EM_GETRECT, 0, (LPARAM)&rcText);
        @         if (rcText.right <= rcText.left || rcText.bottom <= rcText.top)
        @             ::GetClientRect (hWnd, &rcText);
        @         POINT pt;
        @         pt.x = GET_X_LPARAM (lParam);
        @         pt.y = GET_Y_LPARAM (lParam);
        @         return ::PtInRect (&rcText, pt);
        @     }
        @
        @     static BOOL HandleSelectionDrag (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
        @     {
        @         if (uMsg == WM_LBUTTONDOWN)
        @         {
        @             if (!IsPointInTextArea (hWnd, lParam))
        @             {
        @                 DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_SELECT_SKIP_SCROLL"));
        @                 return FALSE;
        @             }
        @             LONG nChar = CharFromClientPoint (hWnd, lParam);
        @             ::SetProp (hWnd, kSelectingProp, (HANDLE)1);
        @             ::SetProp (hWnd, kSelectAnchorProp, (HANDLE)(INT_PTR)(nChar + 1));
        @             ::SetFocus (hWnd);
        @             ::SetCapture (hWnd);
        @             SetSelectionRange (hWnd, nChar, nChar);
        @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_SELECT_START"));
        @             DebugTrace (FALSE, 0, 0, _T ("n"), nChar);
        @             return TRUE;
        @         }
        @         if (uMsg == WM_MOUSEMOVE && (wParam & MK_LBUTTON) != 0 && ::GetProp (hWnd, kSelectingProp) != NULL)
        @         {
        @             LONG nAnchor = (LONG)((INT_PTR)::GetProp (hWnd, kSelectAnchorProp) - 1);
        @             LONG nChar = CharFromClientPoint (hWnd, lParam);
        @             if (nAnchor < 0)
        @                 nAnchor = nChar;
        @             SetSelectionRange (hWnd, nAnchor, nChar);
        @             return TRUE;
        @         }
        @         if (uMsg == WM_LBUTTONUP && ::GetProp (hWnd, kSelectingProp) != NULL)
        @         {
        @             LONG nAnchor = (LONG)((INT_PTR)::GetProp (hWnd, kSelectAnchorProp) - 1);
        @             LONG nChar = CharFromClientPoint (hWnd, lParam);
        @             if (nAnchor >= 0)
        @                 SetSelectionRange (hWnd, nAnchor, nChar);
        @             ::RemoveProp (hWnd, kSelectingProp);
        @             ::RemoveProp (hWnd, kSelectAnchorProp);
        @             if (::GetCapture () == hWnd)
        @                 ::ReleaseCapture ();
        @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_SELECT_END"));
        @             DebugTrace (FALSE, 0, 0, _T ("n"), nChar);
        @             return TRUE;
        @         }
        @         return FALSE;
        @     }
        @
        @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
        @     {
        @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, kOldProcProp);
        @         if (uMsg == WM_MOUSEACTIVATE)
        @         {
        @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_EDIT_MOUSEACTIVATE"));
        @             return MA_ACTIVATE;
        @         }
        @         if (uMsg == WM_LBUTTONDOWN || uMsg == WM_LBUTTONDBLCLK || uMsg == WM_RBUTTONDOWN)
        @         {
        @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_EDIT_MOUSE"));
        @             DebugTrace (FALSE, 0, 0, _T ("n"), (INT)uMsg);
        @             DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
        @             ::SetFocus (hWnd);
        @         }
        @         if (uMsg == WM_LBUTTONDOWN && HandleSelectionDrag (hWnd, uMsg, wParam, lParam))
        @             return 0;
        @         if ((uMsg == WM_RBUTTONUP || uMsg == WM_CONTEXTMENU) && ::GetProp (hWnd, kSkipRButtonProp) != NULL)
        @         {
        @             ::RemoveProp (hWnd, kSkipRButtonProp);
        @             return 0;
        @         }
        @         if ((uMsg == WM_RBUTTONDOWN && IsPointInTextArea (hWnd, lParam)) || uMsg == WM_CONTEXTMENU || uMsg == WM_RBUTTONUP)
        @         {
        @             if (uMsg == WM_RBUTTONDOWN)
        @                 ::SetProp (hWnd, kSkipRButtonProp, (HANDLE)1);
        @             POINT pt;
        @             if (uMsg == WM_CONTEXTMENU && lParam != (LPARAM)-1)
        @             {
        @                 pt.x = GET_X_LPARAM (lParam);
        @                 pt.y = GET_Y_LPARAM (lParam);
        @             }
        @             else
        @             {
        @                 ::GetCursorPos (&pt);
        @             }
        @             HMENU hMenu = ::CreatePopupMenu ();
        @             if (hMenu != NULL)
        @             {
        @                 CHARRANGE crOld;
        @                 ZERO_MEM (&crOld, sizeof (crOld));
        @                 ::SendMessage (hWnd, EM_EXGETSEL, 0, (LPARAM)&crOld);
        @                 ::AppendMenu (hMenu, MF_STRING | (crOld.cpMin == crOld.cpMax ? MF_GRAYED : 0), kCopyId, _T ("复制"));
        @                 ::AppendMenu (hMenu, MF_STRING, kCopyAllId, _T ("全部复制"));
        @                 ::AppendMenu (hMenu, MF_STRING, kClearId, _T ("清空"));
        @                 UINT nCmd = ::TrackPopupMenu (hMenu, TPM_RETURNCMD | TPM_RIGHTBUTTON, pt.x, pt.y, 0, hWnd, NULL);
        @                 ::DestroyMenu (hMenu);
        @                 if (nCmd == kCopyId)
        @                 {
        @                     ::SendMessage (hWnd, WM_COPY, 0, 0);
        @                     return 0;
        @                 }
        @                 if (nCmd == kCopyAllId)
        @                 {
        @                     ::SendMessage (hWnd, EM_SETSEL, 0, -1);
        @                     ::SendMessage (hWnd, WM_COPY, 0, 0);
        @                     ::SendMessage (hWnd, EM_EXSETSEL, 0, (LPARAM)&crOld);
        @                     return 0;
        @                 }
        @                 if (nCmd == kClearId)
        @                 {
        @                     LONG_PTR nStyle = ::GetWindowLongPtr (hWnd, GWL_STYLE);
        @                     if ((nStyle & ES_READONLY) != 0)
        @                         ::SendMessage (hWnd, EM_SETREADONLY, FALSE, 0);
        @                     ::SetWindowText (hWnd, _T (""));
        @                     if ((nStyle & ES_READONLY) != 0)
        @                         ::SendMessage (hWnd, EM_SETREADONLY, TRUE, 0);
        @                     return 0;
        @                 }
        @             }
        @             return 0;
        @         }
        @         if (uMsg == WM_NCDESTROY)
        @         {
        @             if (oldProc != NULL)
        @             {
        @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
        @                 ::RemoveProp (hWnd, kOldProcProp);
        @                 ::RemoveProp (hWnd, kSelectingProp);
        @                 ::RemoveProp (hWnd, kSelectAnchorProp);
        @                 ::RemoveProp (hWnd, kSkipRButtonProp);
        @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
        @             }
        @         }
        @         return (oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam));
        @     }
        @ };
        @ CWnd* pWnd = @<提示编辑框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->m_hWnd != NULL && ::GetProp (pWnd->m_hWnd, kOldProcProp) == NULL)
        @ {
        @     LONG_PTR nStyle = ::GetWindowLongPtr (pWnd->m_hWnd, GWL_STYLE);
        @     ::SetWindowLongPtr (pWnd->m_hWnd, GWL_STYLE, nStyle | ES_NOHIDESEL);
        @     ::SendMessage (pWnd->m_hWnd, EM_SETOPTIONS, ECOOP_OR, ECO_NOHIDESEL);
        @     ::SendMessage (pWnd->m_hWnd, EM_HIDESELECTION, FALSE, 0);
        @     WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (pWnd->m_hWnd, GWLP_WNDPROC, (LONG_PTR)COutputRichEditMenuHook::Proc);
        @     if (oldProc != NULL)
        @         ::SetProp (pWnd->m_hWnd, kOldProcProp, (HANDLE)oldProc);
        @ }
        @ pWnd = @<输出编辑框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pWnd != NULL && pWnd->m_hWnd != NULL && ::GetProp (pWnd->m_hWnd, kOldProcProp) == NULL)
        @ {
        @     LONG_PTR nStyle = ::GetWindowLongPtr (pWnd->m_hWnd, GWL_STYLE);
        @     ::SetWindowLongPtr (pWnd->m_hWnd, GWL_STYLE, nStyle | ES_NOHIDESEL);
        @     ::SendMessage (pWnd->m_hWnd, EM_SETOPTIONS, ECOOP_OR, ECO_NOHIDESEL);
        @     ::SendMessage (pWnd->m_hWnd, EM_HIDESELECTION, FALSE, 0);
        @     WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (pWnd->m_hWnd, GWLP_WNDPROC, (LONG_PTR)COutputRichEditMenuHook::Proc);
        @     if (oldProc != NULL)
        @         ::SetProp (pWnd->m_hWnd, kOldProcProp, (HANDLE)oldProc);
        @ }
    }

