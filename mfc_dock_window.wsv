<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序 <注释 = "当前项目专用的MFC停靠窗口封装.普通窗口可使用停靠窗口管理器做边缘布局."
        注释 = "VS停靠窗口基于mfc_ui_mdi中的MDI子窗口/CDockablePane,用于可拖拽、浮动、自动隐藏、标签化的MFC停靠窗."
        @视窗.需求系统头文件 = "afxwin.h | 当前 Visual Studio 本地编译环境未安装 MFC ,需要首先将其安装才能进行编译.">

# @ <global>
# @ <include>
# @ #include <vector>
# @ #include <afxcontrolbars.h>
# @ #include <commctrl.h>
# @ #include <windowsx.h>
# @ #include <richedit.h>
# @ #include <tchar.h>
# @
# @ #ifndef ECO_NOHIDESEL
# @ #define ECO_NOHIDESEL 0x00000100
# @ #endif
# @ #ifndef ES_NOHIDESEL
# @ #define ES_NOHIDESEL 0x00000100
# @ #endif
# @ #ifndef CCIDE_DOCK_DEBUG
# @ #define CCIDE_DOCK_DEBUG 0
# @ #endif
# @ #if !CCIDE_DOCK_DEBUG
# @ #define DebugTrace(...) ((void)0)
# @ #endif
# @
# @ class CCcIdeDockTabCtrlHook
# @ {
# @ public:
# @     static void Install (CMFCBaseTabCtrl* pTabWnd)
# @     {
# @         if (pTabWnd == NULL || pTabWnd->GetSafeHwnd () == NULL)
# @             return;
# @         HWND hWnd = pTabWnd->GetSafeHwnd ();
# @         if (::GetProp (hWnd, OldProcProp ()) != NULL)
# @             return;
# @         WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)CCcIdeDockTabCtrlHook::Proc);
# @         if (oldProc != NULL)
# @             ::SetProp (hWnd, OldProcProp (), (HANDLE)oldProc);
# @         ::SetProp (hWnd, TabCtrlProp (), (HANDLE)pTabWnd);
# @     }
# @
# @ private:
# @     static const TCHAR* OldProcProp ()
# @     {
# @         return _T ("ccide_mfc_dock_tab_old_proc");
# @     }
# @
# @     static const TCHAR* TabCtrlProp ()
# @     {
# @         return _T ("ccide_mfc_dock_tab_ctrl");
# @     }
# @
# @     static void ActivateTabAtPoint (HWND hWnd, LPARAM lParam)
# @     {
# @         CMFCBaseTabCtrl* pTabWnd = (CMFCBaseTabCtrl*)::GetProp (hWnd, TabCtrlProp ());
# @         if (pTabWnd == NULL || pTabWnd->GetSafeHwnd () == NULL)
# @             return;
# @         CPoint point (GET_X_LPARAM (lParam), GET_Y_LPARAM (lParam));
# @         INT nTab = pTabWnd->GetTabFromPoint (point);
# @         if (nTab < 0)
# @             return;
# @         pTabWnd->SetActiveTab (nTab);
# @         pTabWnd->EnsureVisible (nTab);
# @         CWnd* pActiveWnd = pTabWnd->GetTabWnd (nTab);
# @         if (pActiveWnd != NULL && pActiveWnd->GetSafeHwnd () != NULL)
# @         {
# @             pActiveWnd->ShowWindow (SW_SHOW);
# @             pActiveWnd->BringWindowToTop ();
# @             pActiveWnd->RedrawWindow (NULL, NULL, RDW_INVALIDATE | RDW_UPDATENOW | RDW_ALLCHILDREN);
# @         }
# @         pTabWnd->Invalidate ();
# @     }
# @
# @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
# @     {
# @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, OldProcProp ());
# @         if (uMsg == WM_LBUTTONDOWN || uMsg == WM_LBUTTONUP)
# @         {
# @             LRESULT lr = oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam);
# @             ActivateTabAtPoint (hWnd, lParam);
# @             return lr;
# @         }
# @         if (uMsg == WM_NCDESTROY)
# @         {
# @             if (oldProc != NULL)
# @             {
# @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
# @                 ::RemoveProp (hWnd, OldProcProp ());
# @                 ::RemoveProp (hWnd, TabCtrlProp ());
# @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
# @             }
# @         }
# @         return oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam);
# @     }
# @ };
# @
# @ class CCcIdeDockScrollTrack
# @ {
# @ public:
# @     static BOOL Start (HWND hWnd, INT nBar, POINT ptScreen)
# @     {
# @         if (hWnd == NULL || !::IsWindow (hWnd) || (nBar != SB_VERT && nBar != SB_HORZ))
# @             return FALSE;
# @         SCROLLINFO si;
# @         ZeroMemory (&si, sizeof (si));
# @         si.cbSize = sizeof (si);
# @         si.fMask = SIF_RANGE | SIF_PAGE | SIF_POS;
# @         if (!::GetScrollInfo (hWnd, nBar, &si))
# @             return FALSE;
# @         LONG nMaxPos = si.nMax - (LONG)si.nPage + 1;
# @         if (nMaxPos < si.nMin)
# @             nMaxPos = si.nMin;
# @         TrackWnd () = hWnd;
# @         TrackBar () = nBar;
# @         ::SetCapture (hWnd);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_SCROLL_TRACK_START"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), nBar);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
# @         Update (ptScreen, TRUE);
# @         return TRUE;
# @     }
# @
# @     static BOOL HandleMouseHook (UINT uMsg, POINT ptScreen)
# @     {
# @         HWND hWnd = TrackWnd ();
# @         if (hWnd == NULL || !::IsWindow (hWnd))
# @             return FALSE;
# @         if (uMsg == WM_MOUSEMOVE)
# @         {
# @             Update (ptScreen, TRUE);
# @             return TRUE;
# @         }
# @         if (uMsg == WM_LBUTTONUP)
# @         {
# @             Update (ptScreen, FALSE);
# @             ::SendMessage (hWnd, TrackBar () == SB_VERT ? WM_VSCROLL : WM_HSCROLL, MAKELONG (SB_ENDSCROLL, 0), 0);
# @             if (::GetCapture () == hWnd)
# @                 ::ReleaseCapture ();
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_SCROLL_TRACK_END"));
# @             DebugTrace (FALSE, 0, 0, _T ("n"), TrackBar ());
# @             TrackWnd () = NULL;
# @             TrackBar () = SB_VERT;
# @             return TRUE;
# @         }
# @         return FALSE;
# @     }
# @
# @ private:
# @     static HWND& TrackWnd ()
# @     {
# @         static HWND s_hWnd = NULL;
# @         return s_hWnd;
# @     }
# @
# @     static INT& TrackBar ()
# @     {
# @         static INT s_nBar = SB_VERT;
# @         return s_nBar;
# @     }
# @
# @     static LONG CalcPos (HWND hWnd, INT nBar, POINT ptScreen, const SCROLLINFO& si)
# @     {
# @         RECT rcWindow;
# @         ::GetWindowRect (hWnd, &rcWindow);
# @         const int cxScroll = ::GetSystemMetrics (SM_CXVSCROLL);
# @         const int cyScroll = ::GetSystemMetrics (SM_CYHSCROLL);
# @         LONG nMaxPos = si.nMax - (LONG)si.nPage + 1;
# @         if (nMaxPos < si.nMin)
# @             nMaxPos = si.nMin;
# @         LONG nTrackStart = 0;
# @         LONG nTrackEnd = 0;
# @         LONG nCoord = 0;
# @         if (nBar == SB_VERT)
# @         {
# @             nTrackStart = rcWindow.top + cyScroll;
# @             nTrackEnd = rcWindow.bottom - cyScroll;
# @             nCoord = ptScreen.y;
# @         }
# @         else
# @         {
# @             nTrackStart = rcWindow.left + cxScroll;
# @             nTrackEnd = rcWindow.right - cxScroll;
# @             nCoord = ptScreen.x;
# @         }
# @         if (nTrackEnd <= nTrackStart)
# @             return si.nPos;
# @         if (nCoord < nTrackStart)
# @             nCoord = nTrackStart;
# @         if (nCoord > nTrackEnd)
# @             nCoord = nTrackEnd;
# @         return si.nMin + (LONG)((__int64)(nCoord - nTrackStart) * (nMaxPos - si.nMin) / (nTrackEnd - nTrackStart));
# @     }
# @
# @     static void Update (POINT ptScreen, BOOL bTrack)
# @     {
# @         HWND hWnd = TrackWnd ();
# @         INT nBar = TrackBar ();
# @         SCROLLINFO si;
# @         ZeroMemory (&si, sizeof (si));
# @         si.cbSize = sizeof (si);
# @         si.fMask = SIF_RANGE | SIF_PAGE | SIF_POS;
# @         if (!::GetScrollInfo (hWnd, nBar, &si))
# @             return;
# @         LONG nPos = CalcPos (hWnd, nBar, ptScreen, si);
# @         UINT uMsg = nBar == SB_VERT ? WM_VSCROLL : WM_HSCROLL;
# @         UINT uCode = bTrack ? SB_THUMBTRACK : SB_THUMBPOSITION;
# @         ::SendMessage (hWnd, uMsg, MAKELONG (uCode, (WORD)nPos), 0);
# @         si.fMask = SIF_POS;
# @         si.nPos = nPos;
# @         ::SetScrollInfo (hWnd, nBar, &si, TRUE);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), bTrack ? _T ("CCIDE_SCROLL_TRACK_MOVE") : _T ("CCIDE_SCROLL_TRACK_POS"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), nBar);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), nPos);
# @     }
# @ };
# @
# @ class CCcIdeDockTabbedBarHook
# @ {
# @ public:
# @     static void Install (CBaseTabbedPane* pTabbedPane, CMFCBaseTabCtrl* pTabWnd)
# @     {
# @         if (pTabbedPane == NULL || pTabbedPane->GetSafeHwnd () == NULL || pTabWnd == NULL)
# @             return;
# @         HWND hWnd = pTabbedPane->GetSafeHwnd ();
# @         for (int i = 0; i < 4 && hWnd != NULL && ::IsWindow (hWnd); ++i)
# @         {
# @             InstallWindow (hWnd, pTabWnd);
# @             hWnd = ::GetParent (hWnd);
# @         }
# @     }
# @
# @     static BOOL ForwardMouseFromHook (HWND hWnd, UINT uMsg, WPARAM wParam, POINT ptScreen)
# @     {
# @         if (hWnd == NULL || !::IsWindow (hWnd) || ::GetProp (hWnd, TabCtrlProp ()) == NULL)
# @             return FALSE;
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_HOOK_FORWARD"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)uMsg);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
# @         return ForwardScreenPointToActivePaneChild (hWnd, uMsg, wParam, ptScreen);
# @     }
# @
# @ private:
# @     static void InstallWindow (HWND hWnd, CMFCBaseTabCtrl* pTabWnd)
# @     {
# @         if (hWnd == NULL || !::IsWindow (hWnd))
# @             return;
# @         if (::GetProp (hWnd, OldProcProp ()) != NULL)
# @             return;
# @         WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)CCcIdeDockTabbedBarHook::Proc);
# @         if (oldProc != NULL)
# @             ::SetProp (hWnd, OldProcProp (), (HANDLE)oldProc);
# @         ::SetProp (hWnd, TabCtrlProp (), (HANDLE)pTabWnd);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_HOOK_INSTALLED"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
# @     }
# @
# @     static const TCHAR* OldProcProp ()
# @     {
# @         return _T ("ccide_tabbed_bar_old_proc");
# @     }
# @
# @     static const TCHAR* TabCtrlProp ()
# @     {
# @         return _T ("ccide_tabbed_bar_tab_ctrl");
# @     }
# @
# @     static HWND DeepChildFromScreenPoint (HWND hRoot, POINT ptScreen)
# @     {
# @         HWND hPointWnd = ::WindowFromPoint (ptScreen);
# @         if (hPointWnd != NULL && ::IsWindow (hPointWnd) && (hPointWnd == hRoot || ::IsChild (hRoot, hPointWnd)))
# @             return hPointWnd;
# @         HWND hCurrent = hRoot;
# @         for (int i = 0; i < 12 && hCurrent != NULL && ::IsWindow (hCurrent); ++i)
# @         {
# @             POINT ptClient = ptScreen;
# @             ::ScreenToClient (hCurrent, &ptClient);
# @             HWND hChild = ::ChildWindowFromPointEx (hCurrent, ptClient, CWP_SKIPINVISIBLE | CWP_SKIPDISABLED | CWP_SKIPTRANSPARENT);
# @             if (hChild == NULL || hChild == hCurrent)
# @                 return hCurrent;
# @             hCurrent = hChild;
# @         }
# @         return hCurrent;
# @     }
# @
# @     static BOOL ForwardNonClientScrollMouse (HWND hChild, UINT uMsg, POINT ptScreen)
# @     {
# @         if (uMsg != WM_LBUTTONDOWN || hChild == NULL || !::IsWindow (hChild))
# @             return FALSE;
# @         RECT rcWindow;
# @         ::GetWindowRect (hChild, &rcWindow);
# @         if (!::PtInRect (&rcWindow, ptScreen))
# @             return FALSE;
# @         POINT ptClient = ptScreen;
# @         ::ScreenToClient (hChild, &ptClient);
# @         RECT rcClient;
# @         ::GetClientRect (hChild, &rcClient);
# @         if (::PtInRect (&rcClient, ptClient))
# @             return FALSE;
# @         LRESULT nHit = ::SendMessage (hChild, WM_NCHITTEST, 0, MAKELPARAM (ptScreen.x, ptScreen.y));
# @         if (nHit != HTHSCROLL && nHit != HTVSCROLL)
# @         {
# @             const int cxScroll = ::GetSystemMetrics (SM_CXVSCROLL);
# @             const int cyScroll = ::GetSystemMetrics (SM_CYHSCROLL);
# @             if (ptScreen.y >= rcWindow.bottom - cyScroll && ptScreen.y < rcWindow.bottom)
# @                 nHit = HTHSCROLL;
# @             else if (ptScreen.x >= rcWindow.right - cxScroll && ptScreen.x < rcWindow.right)
# @                 nHit = HTVSCROLL;
# @         }
# @         if (nHit != HTHSCROLL && nHit != HTVSCROLL)
# @             return FALSE;
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_CHILD_NCSCROLL"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)nHit);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hChild);
# @         ::SetFocus (hChild);
# @         return CCcIdeDockScrollTrack::Start (hChild, nHit == HTVSCROLL ? SB_VERT : SB_HORZ, ptScreen);
# @     }
# @
# @     static BOOL IsPointInTabCtrl (CMFCBaseTabCtrl* pTabWnd, POINT ptScreen)
# @     {
# @         if (pTabWnd == NULL || pTabWnd->GetSafeHwnd () == NULL)
# @             return FALSE;
# @         CPoint ptTab = ptScreen;
# @         pTabWnd->ScreenToClient (&ptTab);
# @         INT nHitTab = pTabWnd->GetTabFromPoint (ptTab);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_HITTEST"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), nHitTab);
# @         return nHitTab >= 0;
# @     }
# @
# @     static BOOL ForwardToTabCtrl (CMFCBaseTabCtrl* pTabWnd, UINT uMsg, WPARAM wParam, POINT ptScreen)
# @     {
# @         if (pTabWnd == NULL || pTabWnd->GetSafeHwnd () == NULL)
# @             return FALSE;
# @         if (uMsg != WM_LBUTTONDOWN && uMsg != WM_LBUTTONUP && uMsg != WM_LBUTTONDBLCLK &&
# @                 uMsg != WM_RBUTTONDOWN && uMsg != WM_RBUTTONUP)
# @             return FALSE;
# @         HWND hTab = pTabWnd->GetSafeHwnd ();
# @         POINT ptTab = ptScreen;
# @         ::ScreenToClient (hTab, &ptTab);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_FORWARD_TAB"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)uMsg);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hTab);
# @         ::SetFocus (hTab);
# @         ::SendMessage (hTab, uMsg, wParam, MAKELPARAM (ptTab.x, ptTab.y));
# @         return TRUE;
# @     }
# @
# @     static BOOL ForwardToActivePaneChild (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
# @     {
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_FORWARD_ENTER"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)uMsg);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
# @         POINT ptScreen;
# @         ptScreen.x = GET_X_LPARAM (lParam);
# @         ptScreen.y = GET_Y_LPARAM (lParam);
# @         ::ClientToScreen (hWnd, &ptScreen);
# @         return ForwardScreenPointToActivePaneChild (hWnd, uMsg, wParam, ptScreen);
# @     }
# @
# @     static BOOL ForwardScreenPointToActivePaneChild (HWND hWnd, UINT uMsg, WPARAM wParam, POINT ptScreen)
# @     {
# @         CMFCBaseTabCtrl* pTabWnd = (CMFCBaseTabCtrl*)::GetProp (hWnd, TabCtrlProp ());
# @         if (pTabWnd == NULL || pTabWnd->GetSafeHwnd () == NULL)
# @         {
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_NO_TABCTRL"));
# @             return FALSE;
# @         }
# @         if (IsPointInTabCtrl (pTabWnd, ptScreen))
# @         {
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_IN_TABCTRL"));
# @             return ForwardToTabCtrl (pTabWnd, uMsg, wParam, ptScreen);
# @         }
# @         INT nActive = pTabWnd->GetActiveTab ();
# @         CWnd* pActivePane = nActive < 0 ? NULL : pTabWnd->GetTabWnd (nActive);
# @         HWND hPane = pActivePane == NULL ? NULL : pActivePane->GetSafeHwnd ();
# @         if (hPane == NULL || !::IsWindow (hPane))
# @             return FALSE;
# @         RECT rcPaneClient;
# @         ::GetClientRect (hPane, &rcPaneClient);
# @         POINT ptClientLt;
# @         POINT ptClientRb;
# @         ptClientLt.x = rcPaneClient.left;
# @         ptClientLt.y = rcPaneClient.top;
# @         ptClientRb.x = rcPaneClient.right;
# @         ptClientRb.y = rcPaneClient.bottom;
# @         ::ClientToScreen (hPane, &ptClientLt);
# @         ::ClientToScreen (hPane, &ptClientRb);
# @         rcPaneClient.left = ptClientLt.x;
# @         rcPaneClient.top = ptClientLt.y;
# @         rcPaneClient.right = ptClientRb.x;
# @         rcPaneClient.bottom = ptClientRb.y;
# @         if (!::PtInRect (&rcPaneClient, ptScreen))
# @         {
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_OUTSIDE_PANE"));
# @             return FALSE;
# @         }
# @         HWND hUserWnd = (HWND)::GetProp (hPane, _T ("ccide_dock_pane_user_wnd"));
# @         if (hUserWnd != NULL && ::IsWindow (hUserWnd))
# @         {
# @             RECT rcUserWnd;
# @             ::GetWindowRect (hUserWnd, &rcUserWnd);
# @             if (!::PtInRect (&rcUserWnd, ptScreen))
# @             {
# @                 DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_OUTSIDE_USER"));
# @                 return FALSE;
# @             }
# @         }
# @         HWND hChild = DeepChildFromScreenPoint (hPane, ptScreen);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_MOUSE"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)uMsg);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)nActive);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hPane);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hChild);
# @         if (hChild == NULL || hChild == hWnd || !::IsWindow (hChild))
# @             return FALSE;
# @         if (ForwardNonClientScrollMouse (hChild, uMsg, ptScreen))
# @             return TRUE;
# @         POINT ptChild = ptScreen;
# @         ::ScreenToClient (hChild, &ptChild);
# @         ::SetFocus (hChild);
# @         if (uMsg == WM_CONTEXTMENU)
# @             ::SendMessage (hChild, uMsg, (WPARAM)hChild, MAKELPARAM (ptScreen.x, ptScreen.y));
# @         else
# @             ::SendMessage (hChild, uMsg, wParam, MAKELPARAM (ptChild.x, ptChild.y));
# @         return TRUE;
# @     }
# @
# @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
# @     {
# @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, OldProcProp ());
# @         switch (uMsg)
# @         {
# @         case WM_MOUSEACTIVATE:
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_MOUSEACTIVATE"));
# @             return MA_ACTIVATE;
# @         case WM_CONTEXTMENU:
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_TABBED_BAR_SUPPRESS_CONTEXT_MENU"));
# @             {
# @                 POINT ptScreen;
# @                 if (lParam != (LPARAM)-1)
# @                 {
# @                     ptScreen.x = GET_X_LPARAM (lParam);
# @                     ptScreen.y = GET_Y_LPARAM (lParam);
# @                 }
# @                 else
# @                 {
# @                     ::GetCursorPos (&ptScreen);
# @                 }
# @                 ForwardScreenPointToActivePaneChild (hWnd, uMsg, wParam, ptScreen);
# @             }
# @             return 0;
# @         case WM_LBUTTONDOWN:
# @         case WM_LBUTTONUP:
# @         case WM_LBUTTONDBLCLK:
# @         case WM_RBUTTONDOWN:
# @         case WM_RBUTTONUP:
# @             if (ForwardToActivePaneChild (hWnd, uMsg, wParam, lParam))
# @                 return 0;
# @             break;
# @         case WM_NCDESTROY:
# @             if (oldProc != NULL)
# @             {
# @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
# @                 ::RemoveProp (hWnd, OldProcProp ());
# @                 ::RemoveProp (hWnd, TabCtrlProp ());
# @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
# @             }
# @             break;
# @         }
# @         return oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam);
# @     }
# @ };
# @
# @ class CCcIdeDockMouseTraceHook
# @ {
# @ public:
# @     static void Install ()
# @     {
# @         if (HookHandle () != NULL)
# @             return;
# @         HookHandle () = ::SetWindowsHookEx (WH_MOUSE, CCcIdeDockMouseTraceHook::Proc, NULL, ::GetCurrentThreadId ());
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_MOUSE_HOOK_INSTALLED"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)HookHandle ());
# @     }
# @
# @ private:
# @     static HHOOK& HookHandle ()
# @     {
# @         static HHOOK s_hHook = NULL;
# @         return s_hHook;
# @     }
# @
# @     static BOOL IsMouseButtonMessage (WPARAM wParam)
# @     {
# @         if (wParam == WM_MOUSEMOVE)
# @             return (::GetKeyState (VK_LBUTTON) & 0x8000) != 0;
# @         return wParam == WM_LBUTTONDOWN || wParam == WM_LBUTTONUP ||
# @             wParam == WM_LBUTTONDBLCLK || wParam == WM_RBUTTONDOWN ||
# @             wParam == WM_RBUTTONUP;
# @     }
# @
# @     static WPARAM CurrentMouseKeyState (WPARAM message)
# @     {
# @         WPARAM state = 0;
# @         if ((::GetKeyState (VK_LBUTTON) & 0x8000) != 0 || message == WM_LBUTTONDOWN || message == WM_LBUTTONDBLCLK)
# @             state |= MK_LBUTTON;
# @         if ((::GetKeyState (VK_RBUTTON) & 0x8000) != 0 || message == WM_RBUTTONDOWN)
# @             state |= MK_RBUTTON;
# @         if ((::GetKeyState (VK_MBUTTON) & 0x8000) != 0)
# @             state |= MK_MBUTTON;
# @         if ((::GetKeyState (VK_CONTROL) & 0x8000) != 0)
# @             state |= MK_CONTROL;
# @         if ((::GetKeyState (VK_SHIFT) & 0x8000) != 0)
# @             state |= MK_SHIFT;
# @         return state;
# @     }
# @
# @     static BOOL IsOutputRichEdit (HWND hWnd)
# @     {
# @         if (hWnd == NULL || !::IsWindow (hWnd) || ::GetProp (hWnd, _T ("ccide_output_old_proc")) == NULL)
# @             return FALSE;
# @         TCHAR szClass[64];
# @         ZeroMemory (szClass, sizeof (szClass));
# @         ::GetClassName (hWnd, szClass, 63);
# @         return _tcsicmp (szClass, _T ("RichEdit20W")) == 0 || _tcsicmp (szClass, _T ("RICHEDIT50W")) == 0 ||
# @             _tcsicmp (szClass, _T ("RichEdit20A")) == 0 || _tcsicmp (szClass, _T ("RICHEDIT50A")) == 0;
# @     }
# @
# @     static LONG OutputCharFromScreenPoint (HWND hWnd, POINT ptScreen)
# @     {
# @         POINT ptClient = ptScreen;
# @         ::ScreenToClient (hWnd, &ptClient);
# @         POINTL pt;
# @         pt.x = ptClient.x;
# @         pt.y = ptClient.y;
# @         LRESULT result = ::SendMessage (hWnd, EM_CHARFROMPOS, 0, (LPARAM)&pt);
# @         if (result < 0)
# @             result = 0;
# @         return (LONG)result;
# @     }
# @
# @     static void SetOutputSelectionRange (HWND hWnd, LONG nAnchor, LONG nChar)
# @     {
# @         CHARRANGE cr;
# @         ZERO_MEM (&cr, sizeof (cr));
# @         if (nAnchor <= nChar)
# @         {
# @             cr.cpMin = nAnchor;
# @             cr.cpMax = nChar;
# @         }
# @         else
# @         {
# @             cr.cpMin = nChar;
# @             cr.cpMax = nAnchor;
# @         }
# @         if (cr.cpMax > cr.cpMin)
# @             cr.cpMax++;
# @         ::SetFocus (hWnd);
# @         ::SendMessage (hWnd, EM_EXSETSEL, 0, (LPARAM)&cr);
# @         ::SendMessage (hWnd, EM_HIDESELECTION, FALSE, 0);
# @         ::RedrawWindow (hWnd, NULL, NULL, RDW_INVALIDATE | RDW_UPDATENOW);
# @     }
# @
# @     static BOOL HandleOutputSelectionFromHook (HWND hWnd, UINT uMsg, POINT ptScreen)
# @     {
# @         if (!IsOutputRichEdit (hWnd) || ::GetProp (hWnd, _T ("ccide_output_selecting")) == NULL)
# @             return FALSE;
# @         if (uMsg == WM_MOUSEMOVE && (::GetKeyState (VK_LBUTTON) & 0x8000) != 0)
# @         {
# @             LONG nAnchor = (LONG)((INT_PTR)::GetProp (hWnd, _T ("ccide_output_select_anchor")) - 1);
# @             LONG nChar = OutputCharFromScreenPoint (hWnd, ptScreen);
# @             if (nAnchor < 0)
# @                 nAnchor = nChar;
# @             SetOutputSelectionRange (hWnd, nAnchor, nChar);
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_SELECT_MOVE_HOOK"));
# @             DebugTrace (FALSE, 0, 0, _T ("n"), nAnchor);
# @             DebugTrace (FALSE, 0, 0, _T ("n"), nChar);
# @             return TRUE;
# @         }
# @         if (uMsg == WM_LBUTTONUP)
# @         {
# @             LONG nAnchor = (LONG)((INT_PTR)::GetProp (hWnd, _T ("ccide_output_select_anchor")) - 1);
# @             LONG nChar = OutputCharFromScreenPoint (hWnd, ptScreen);
# @             if (nAnchor >= 0)
# @                 SetOutputSelectionRange (hWnd, nAnchor, nChar);
# @             ::RemoveProp (hWnd, _T ("ccide_output_selecting"));
# @             ::RemoveProp (hWnd, _T ("ccide_output_select_anchor"));
# @             if (::GetCapture () == hWnd)
# @                 ::ReleaseCapture ();
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_OUTPUT_SELECT_END_HOOK"));
# @             DebugTrace (FALSE, 0, 0, _T ("n"), nChar);
# @             return TRUE;
# @         }
# @         return FALSE;
# @     }
# @
# @     static HWND FindInternalTabOwner (HWND hStart, HWND& hTab)
# @     {
# @         hTab = NULL;
# @         HWND hCur = hStart;
# @         for (int i = 0; i < 12 && hCur != NULL && ::IsWindow (hCur); ++i)
# @         {
# @             hTab = (HWND)::GetProp (hCur, _T ("ccide_output_tab_hwnd"));
# @             if (hTab != NULL && ::IsWindow (hTab))
# @                 return hCur;
# @             hTab = (HWND)::GetProp (hCur, _T ("ccide_solution_tab_hwnd"));
# @             if (hTab != NULL && ::IsWindow (hTab))
# @                 return hCur;
# @             hCur = ::GetParent (hCur);
# @         }
# @         return NULL;
# @     }
# @
# @     static INT HitInternalTab (HWND hTab, POINT ptScreen)
# @     {
# @         if (hTab == NULL || !::IsWindow (hTab))
# @             return -1;
# @         POINT ptTab = ptScreen;
# @         ::ScreenToClient (hTab, &ptTab);
# @         RECT rcTab;
# @         if (!::GetClientRect (hTab, &rcTab))
# @             return -1;
# @         if (ptTab.x < 0 || ptTab.x >= rcTab.right || ptTab.y < 0 || ptTab.y >= rcTab.bottom)
# @             return -1;
# @         TCHITTESTINFO hit;
# @         ZeroMemory (&hit, sizeof (hit));
# @         hit.pt = ptTab;
# @         INT nIndex = (INT)::SendMessage (hTab, TCM_HITTEST, 0, (LPARAM)&hit);
# @         if (nIndex >= 0)
# @             return nIndex;
# @         if (ptTab.y < rcTab.bottom - 42 || ptTab.y >= rcTab.bottom)
# @             return -1;
# @         INT nCount = (INT)::SendMessage (hTab, TCM_GETITEMCOUNT, 0, 0);
# @         for (INT i = 0; i < nCount; ++i)
# @         {
# @             RECT rcItem;
# @             ZeroMemory (&rcItem, sizeof (rcItem));
# @             if (::SendMessage (hTab, TCM_GETITEMRECT, i, (LPARAM)&rcItem))
# @             {
# @                 ::InflateRect (&rcItem, 8, 8);
# @                 if (ptTab.x >= rcItem.left && ptTab.x < rcItem.right && ptTab.y >= rcItem.top && ptTab.y < rcItem.bottom)
# @                     return i;
# @             }
# @         }
# @         return -1;
# @     }
# @
# @     static void ShowInternalTabPage (HWND hTab, INT nIndex)
# @     {
# @         HWND hTip = (HWND)::GetProp (hTab, _T ("ccide_output_tab_tip"));
# @         HWND hOutput = (HWND)::GetProp (hTab, _T ("ccide_output_tab_output"));
# @         if (::IsWindow (hTip) || ::IsWindow (hOutput))
# @         {
# @             if (::IsWindow (hTip)) ::ShowWindow (hTip, nIndex == 0 ? SW_SHOW : SW_HIDE);
# @             if (::IsWindow (hOutput)) ::ShowWindow (hOutput, nIndex == 1 ? SW_SHOW : SW_HIDE);
# @             return;
# @         }
# @         HWND hDoc = (HWND)::GetProp (hTab, _T ("ccide_solution_tab_doc"));
# @         HWND hLib = (HWND)::GetProp (hTab, _T ("ccide_solution_tab_lib"));
# @         HWND hProp = (HWND)::GetProp (hTab, _T ("ccide_solution_tab_prop"));
# @         if (::IsWindow (hDoc)) ::ShowWindow (hDoc, nIndex == 0 ? SW_SHOW : SW_HIDE);
# @         if (::IsWindow (hLib)) ::ShowWindow (hLib, nIndex == 1 ? SW_SHOW : SW_HIDE);
# @         if (::IsWindow (hProp)) ::ShowWindow (hProp, nIndex == 2 ? SW_SHOW : SW_HIDE);
# @     }
# @
# @     static BOOL HandleInternalTabSwitchFromHook (HWND hTarget, UINT uMsg, POINT ptScreen)
# @     {
# @         if (uMsg != WM_LBUTTONDOWN)
# @             return FALSE;
# @         HWND hTab = NULL;
# @         HWND hOwner = FindInternalTabOwner (hTarget, hTab);
# @         if (hOwner == NULL || hTab == NULL)
# @             return FALSE;
# @         INT nIndex = HitInternalTab (hTab, ptScreen);
# @         if (nIndex < 0)
# @             return FALSE;
# @         ::SendMessage (hTab, TCM_SETCURSEL, nIndex, 0);
# @         ShowInternalTabPage (hTab, nIndex);
# @         ::InvalidateRect (hTab, NULL, TRUE);
# @         ::InvalidateRect (hOwner, NULL, TRUE);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_INTERNAL_TAB_SWITCH"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), nIndex);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hTab);
# @         return TRUE;
# @     }
# @
# @     static LRESULT CALLBACK Proc (int nCode, WPARAM wParam, LPARAM lParam)
# @     {
# @         if (nCode >= 0 && IsMouseButtonMessage (wParam))
# @         {
# @             MOUSEHOOKSTRUCT* pMouse = (MOUSEHOOKSTRUCT*)lParam;
# @             HWND hTarget = pMouse == NULL ? NULL : pMouse->hwnd;
# @             HWND hParent = hTarget == NULL ? NULL : ::GetParent (hTarget);
# @             TCHAR szClass[128];
# @             ZeroMemory (szClass, sizeof (szClass));
# @             if (hTarget != NULL && ::IsWindow (hTarget))
# @                 ::GetClassName (hTarget, szClass, 127);
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_MOUSE_HOOK"));
# @             DebugTrace (FALSE, 0, 0, _T ("n"), (INT)wParam);
# @             DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hTarget);
# @             DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hParent);
# @             DebugTrace (FALSE, 0, 0, _T ("S"), szClass);
# @             if (pMouse != NULL && CCcIdeDockScrollTrack::HandleMouseHook ((UINT)wParam, pMouse->pt))
# @                 return 1;
# @             if (pMouse != NULL && HandleOutputSelectionFromHook (hTarget, (UINT)wParam, pMouse->pt))
# @                 return 1;
# @             if (pMouse != NULL && HandleInternalTabSwitchFromHook (hTarget, (UINT)wParam, pMouse->pt))
# @                 return 1;
# @             if (wParam != WM_MOUSEMOVE && CCcIdeDockTabbedBarHook::ForwardMouseFromHook (hTarget, (UINT)wParam, CurrentMouseKeyState (wParam), pMouse->pt))
# @                 return 1;
# @         }
# @         return ::CallNextHookEx (HookHandle (), nCode, wParam, lParam);
# @     }
# @ };
# @
# @ class CCcIdeDockUserWndHook
# @ {
# @ public:
# @     static void Install (HWND hUserWnd)
# @     {
# @         if (hUserWnd == NULL || !::IsWindow (hUserWnd))
# @             return;
# @         if (::GetProp (hUserWnd, OldProcProp ()) != NULL)
# @             return;
# @         WNDPROC oldProc = (WNDPROC)::SetWindowLongPtr (hUserWnd, GWLP_WNDPROC, (LONG_PTR)CCcIdeDockUserWndHook::Proc);
# @         if (oldProc != NULL)
# @             ::SetProp (hUserWnd, OldProcProp (), (HANDLE)oldProc);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_USER_HOOK_INSTALLED"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hUserWnd);
# @     }
# @
# @     static BOOL ForwardMouse (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
# @     {
# @         return ForwardMouseToChild (hWnd, uMsg, wParam, lParam);
# @     }
# @
# @ private:
# @     static const TCHAR* OldProcProp ()
# @     {
# @         return _T ("ccide_dock_user_old_proc");
# @     }
# @
# @     static HWND DeepChildFromPoint (HWND hParent, POINT ptParent)
# @     {
# @         POINT ptScreen = ptParent;
# @         ::ClientToScreen (hParent, &ptScreen);
# @         HWND hPointWnd = ::WindowFromPoint (ptScreen);
# @         if (hPointWnd != NULL && ::IsWindow (hPointWnd) && (hPointWnd == hParent || ::IsChild (hParent, hPointWnd)))
# @             return hPointWnd;
# @         HWND hCurrent = hParent;
# @         POINT pt = ptParent;
# @         for (int i = 0; i < 8 && hCurrent != NULL && ::IsWindow (hCurrent); ++i)
# @         {
# @             HWND hChild = ::ChildWindowFromPointEx (hCurrent, pt, CWP_SKIPINVISIBLE | CWP_SKIPDISABLED | CWP_SKIPTRANSPARENT);
# @             if (hChild == NULL || hChild == hCurrent)
# @                 return hCurrent;
# @             ::MapWindowPoints (hCurrent, hChild, &pt, 1);
# @             hCurrent = hChild;
# @         }
# @         return hCurrent;
# @     }
# @
# @     static BOOL ForwardNonClientScrollMouse (HWND hParent, HWND hChild, UINT uMsg, POINT ptParent)
# @     {
# @         if (uMsg != WM_LBUTTONDOWN || hChild == NULL || !::IsWindow (hChild))
# @             return FALSE;
# @         POINT ptChild = ptParent;
# @         ::MapWindowPoints (hParent, hChild, &ptChild, 1);
# @         RECT rcClient;
# @         ::GetClientRect (hChild, &rcClient);
# @         if (::PtInRect (&rcClient, ptChild))
# @             return FALSE;
# @         POINT ptScreen = ptParent;
# @         ::ClientToScreen (hParent, &ptScreen);
# @         RECT rcWindow;
# @         ::GetWindowRect (hChild, &rcWindow);
# @         LRESULT nHit = ::SendMessage (hChild, WM_NCHITTEST, 0, MAKELPARAM (ptScreen.x, ptScreen.y));
# @         if (nHit != HTHSCROLL && nHit != HTVSCROLL)
# @         {
# @             const int cxScroll = ::GetSystemMetrics (SM_CXVSCROLL);
# @             const int cyScroll = ::GetSystemMetrics (SM_CYHSCROLL);
# @             if (ptScreen.y >= rcWindow.bottom - cyScroll && ptScreen.y < rcWindow.bottom)
# @                 nHit = HTHSCROLL;
# @             else if (ptScreen.x >= rcWindow.right - cxScroll && ptScreen.x < rcWindow.right)
# @                 nHit = HTVSCROLL;
# @         }
# @         if (nHit != HTHSCROLL && nHit != HTVSCROLL)
# @             return FALSE;
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_CHILD_NCSCROLL"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)nHit);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hChild);
# @         ::SetFocus (hChild);
# @         return CCcIdeDockScrollTrack::Start (hChild, nHit == HTVSCROLL ? SB_VERT : SB_HORZ, ptScreen);
# @     }
# @
# @     static BOOL ForwardMouseToChild (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
# @     {
# @         POINT pt;
# @         POINT ptScreen;
# @         if (uMsg == WM_CONTEXTMENU)
# @         {
# @             ::GetCursorPos (&ptScreen);
# @             pt = ptScreen;
# @             ::ScreenToClient (hWnd, &pt);
# @         }
# @         else
# @         {
# @             pt.x = GET_X_LPARAM (lParam);
# @             pt.y = GET_Y_LPARAM (lParam);
# @             ptScreen = pt;
# @             ::ClientToScreen (hWnd, &ptScreen);
# @         }
# @         HWND hChild = DeepChildFromPoint (hWnd, pt);
# @         DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_USER_MOUSE"));
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT)uMsg);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hWnd);
# @         DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)hChild);
# @         if (hChild == NULL || hChild == hWnd || !::IsWindow (hChild))
# @             return FALSE;
# @         if (ForwardNonClientScrollMouse (hWnd, hChild, uMsg, pt))
# @             return TRUE;
# @         POINT ptChild = pt;
# @         ::MapWindowPoints (hWnd, hChild, &ptChild, 1);
# @         ::SetFocus (hChild);
# @         if (uMsg == WM_CONTEXTMENU)
# @             ::SendMessage (hChild, uMsg, (WPARAM)hChild, MAKELPARAM (ptScreen.x, ptScreen.y));
# @         else
# @             ::SendMessage (hChild, uMsg, wParam, MAKELPARAM (ptChild.x, ptChild.y));
# @         return TRUE;
# @     }
# @
# @     static LRESULT CALLBACK Proc (HWND hWnd, UINT uMsg, WPARAM wParam, LPARAM lParam)
# @     {
# @         WNDPROC oldProc = (WNDPROC)::GetProp (hWnd, OldProcProp ());
# @         switch (uMsg)
# @         {
# @         case WM_MOUSEACTIVATE:
# @             DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_USER_MOUSEACTIVATE"));
# @             return MA_ACTIVATE;
# @         case WM_LBUTTONDOWN:
# @         case WM_LBUTTONDBLCLK:
# @         case WM_CONTEXTMENU:
# @         case WM_RBUTTONDOWN:
# @         case WM_RBUTTONUP:
# @             if (ForwardMouseToChild (hWnd, uMsg, wParam, lParam))
# @                 return 0;
# @             break;
# @         case WM_NCDESTROY:
# @             if (oldProc != NULL)
# @             {
# @                 ::SetWindowLongPtr (hWnd, GWLP_WNDPROC, (LONG_PTR)oldProc);
# @                 ::RemoveProp (hWnd, OldProcProp ());
# @                 return ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam);
# @             }
# @             break;
# @         }
# @         return oldProc != NULL ? ::CallWindowProc (oldProc, hWnd, uMsg, wParam, lParam) : ::DefWindowProc (hWnd, uMsg, wParam, lParam);
# @     }
# @ };
# @
# @ class CCcIdeDockLayoutManager
# @ {
# @ public:
# @     struct Pane
# @     {
# @         HWND hWnd;
# @         int dock;
# @         int size;
# @         int minSize;
# @         BOOL visible;
# @     };
# @
# @     CCcIdeDockLayoutManager () : m_hParent (NULL) {}
# @
# @     BOOL Init (CWnd* pParent)
# @     {
# @         m_hParent = (pParent == NULL ? NULL : pParent->GetSafeHwnd ());
# @         return ::IsWindow (m_hParent);
# @     }
# @
# @     void Clear ()
# @     {
# @         m_panes.clear ();
# @     }
# @
# @     int AddPane (CWnd* pWnd, int dock, int size, int minSize, BOOL visible)
# @     {
# @         if (pWnd == NULL || !::IsWindow (pWnd->GetSafeHwnd ()))
# @             return 0;
# @         if (dock < 1 || dock > 5)
# @             return 0;
# @         Pane pane;
# @         pane.hWnd = pWnd->GetSafeHwnd ();
# @         pane.dock = dock;
# @         pane.size = size;
# @         pane.minSize = minSize;
# @         pane.visible = visible;
# @         m_panes.push_back (pane);
# @         ::ShowWindow (pane.hWnd, visible ? SW_SHOW : SW_HIDE);
# @         return (int)m_panes.size ();
# @     }
# @
# @     BOOL SetPaneVisible (int id, BOOL visible)
# @     {
# @         Pane* pane = GetPane (id);
# @         if (pane == NULL)
# @             return FALSE;
# @         pane->visible = visible;
# @         if (::IsWindow (pane->hWnd))
# @             ::ShowWindow (pane->hWnd, visible ? SW_SHOW : SW_HIDE);
# @         return TRUE;
# @     }
# @
# @     BOOL SetPaneSize (int id, int size)
# @     {
# @         Pane* pane = GetPane (id);
# @         if (pane == NULL)
# @             return FALSE;
# @         pane->size = size;
# @         return TRUE;
# @     }
# @
# @     int GetPaneCount () const
# @     {
# @         return (int)m_panes.size ();
# @     }
# @
# @     BOOL Layout (int left, int top, int width, int height)
# @     {
# @         if (!::IsWindow (m_hParent))
# @             return FALSE;
# @
# @         CRect rc;
# @         if (width <= 0 || height <= 0)
# @         {
# @             ::GetClientRect (m_hParent, &rc);
# @         }
# @         else
# @         {
# @             rc.SetRect (left, top, left + width, top + height);
# @         }
# @
# @         for (size_t i = 0; i < m_panes.size (); ++i)
# @         {
# @             Pane& pane = m_panes [i];
# @             if (!pane.visible || !::IsWindow (pane.hWnd))
# @                 continue;
# @
# @             CRect paneRc (rc);
# @             const int minSize = (pane.minSize < 0 ? 0 : pane.minSize);
# @             int size = pane.size;
# @             if (size < minSize)
# @                 size = minSize;
# @
# @             switch (pane.dock)
# @             {
# @             case 1:
# @                 if (size > rc.Width ()) size = rc.Width ();
# @                 paneRc.right = paneRc.left + size;
# @                 rc.left = paneRc.right;
# @                 break;
# @             case 2:
# @                 if (size > rc.Height ()) size = rc.Height ();
# @                 paneRc.bottom = paneRc.top + size;
# @                 rc.top = paneRc.bottom;
# @                 break;
# @             case 3:
# @                 if (size > rc.Width ()) size = rc.Width ();
# @                 paneRc.left = paneRc.right - size;
# @                 rc.right = paneRc.left;
# @                 break;
# @             case 4:
# @                 if (size > rc.Height ()) size = rc.Height ();
# @                 paneRc.top = paneRc.bottom - size;
# @                 rc.bottom = paneRc.top;
# @                 break;
# @             default:
# @                 paneRc = rc;
# @                 break;
# @             }
# @
# @             if (paneRc.Width () < 0) paneRc.right = paneRc.left;
# @             if (paneRc.Height () < 0) paneRc.bottom = paneRc.top;
# @             ::SetWindowPos (pane.hWnd, NULL, paneRc.left, paneRc.top, paneRc.Width (), paneRc.Height (),
# @                 SWP_NOZORDER | SWP_NOACTIVATE | SWP_SHOWWINDOW);
# @         }
# @         return TRUE;
# @     }
# @
# @ private:
# @     Pane* GetPane (int id)
# @     {
# @         if (id <= 0 || id > (int)m_panes.size ())
# @             return NULL;
# @         return &m_panes [(size_t)id - 1];
# @     }
# @
# @     HWND m_hParent;
# @     std::vector<Pane> m_panes;
# @ };
# @
# @ enum CCcIdeDockPaneEvent
# @ {
# @     CCIDE_DOCK_EVT_VISIBLE_CHANGED = 1,
# @     CCIDE_DOCK_EVT_SIZE_CHANGED = 2,
# @     CCIDE_DOCK_EVT_POSITION_CHANGED = 3,
# @     CCIDE_DOCK_EVT_FLOAT_CHANGED = 4,
# @     CCIDE_DOCK_EVT_AUTO_HIDE_CHANGED = 5,
# @     CCIDE_DOCK_EVT_DOCK_ALIGN_CHANGED = 6,
# @     CCIDE_DOCK_EVT_TITLE_CHANGED = 7,
# @     CCIDE_DOCK_EVT_FOCUS = 8,
# @     CCIDE_DOCK_EVT_CLOSING = 9,
# @     CCIDE_DOCK_EVT_DESTROYING = 10,
# @     CCIDE_DOCK_EVT_MIN_SIZE_CHANGED = 11,
# @     CCIDE_DOCK_EVT_DOCK_ENABLE_CHANGED = 12,
# @     CCIDE_DOCK_EVT_CONTROL_STYLE_CHANGED = 13,
# @     CCIDE_DOCK_EVT_GRIPPER_CHANGED = 14
# @ };
# @
# @ class ICcIdeDockPaneSink
# @ {
# @ public:
# @     virtual HWND OnCreateChildWnd (INT nLeft, INT nTop, INT nWidth, INT nHeight) = 0;
# @     virtual void OnDockPaneEvent (INT nEvent, INT nValue1, INT nValue2, INT nValue3, INT nValue4) = 0;
# @ };
# @
# @ enum CCcIdeScrollContainerEvent
# @ {
# @     CCIDE_SCROLL_EVT_POS_CHANGED = 1,
# @     CCIDE_SCROLL_EVT_CONTENT_SIZE_CHANGED = 2,
# @     CCIDE_SCROLL_EVT_VIEW_SIZE_CHANGED = 3,
# @     CCIDE_SCROLL_EVT_MOUSE_WHEEL = 4,
# @     CCIDE_SCROLL_EVT_DESTROYING = 5
# @ };
# @
# @ class ICcIdeScrollContainerSink
# @ {
# @ public:
# @     virtual HWND OnCreateScrollContent (INT nLeft, INT nTop, INT nWidth, INT nHeight) = 0;
# @     virtual void OnScrollContainerEvent (INT nEvent, INT nValue1, INT nValue2, INT nValue3, INT nValue4) = 0;
# @ };
# @
# @ class CCcIdeScrollContainer : public CWnd
# @ {
# @ public:
# @     CCcIdeScrollContainer () : m_pSink (NULL), m_hContentWnd (NULL), m_nVirtualWidth (0), m_nVirtualHeight (0),
# @         m_nScrollX (0), m_nScrollY (0), m_nLineStepX (24), m_nLineStepY (24), m_blpEnableH (TRUE), m_blpEnableV (TRUE) {}
# @
# @     BOOL CreateContainer (ICcIdeScrollContainerSink* pSink, CWnd* pParentWnd, const RECT& rect, UINT nID,
# @             INT nVirtualWidth, INT nVirtualHeight, BOOL bEnableHorz, BOOL bEnableVert)
# @     {
# @         if (pSink == NULL || pParentWnd == NULL || pParentWnd->GetSafeHwnd () == NULL || GetSafeHwnd () != NULL)
# @             return FALSE;
# @
# @         m_pSink = pSink;
# @         m_blpEnableH = bEnableHorz;
# @         m_blpEnableV = bEnableVert;
# @         m_nVirtualWidth = (nVirtualWidth < 0 ? 0 : nVirtualWidth);
# @         m_nVirtualHeight = (nVirtualHeight < 0 ? 0 : nVirtualHeight);
# @
# @         LPCTSTR lpszClassName = AfxRegisterWndClass (CS_DBLCLKS, ::LoadCursor (NULL, IDC_ARROW),
# @             (HBRUSH)(COLOR_WINDOW + 1), NULL);
# @         DWORD dwStyle = WS_CHILD | WS_VISIBLE | WS_CLIPSIBLINGS | WS_CLIPCHILDREN;
# @         if (m_blpEnableH)
# @             dwStyle |= WS_HSCROLL;
# @         if (m_blpEnableV)
# @             dwStyle |= WS_VSCROLL;
# @
# @         if (!CWnd::Create (lpszClassName, _T (""), dwStyle, rect, pParentWnd, nID))
# @             return FALSE;
# @
# @         m_hContentWnd = m_pSink->OnCreateScrollContent (0, 0, m_nVirtualWidth, m_nVirtualHeight);
# @         if (m_hContentWnd == NULL)
# @         {
# @             DestroyWindow ();
# @             return FALSE;
# @         }
# @
# @         UpdateContentWindow ();
# @         UpdateScrollBars ();
# @         return TRUE;
# @     }
# @
# @     HWND GetContentWnd () const
# @     {
# @         return m_hContentWnd;
# @     }
# @
# @     INT GetVirtualWidth () const
# @     {
# @         return m_nVirtualWidth;
# @     }
# @
# @     INT GetVirtualHeight () const
# @     {
# @         return m_nVirtualHeight;
# @     }
# @
# @     INT GetScrollX () const
# @     {
# @         return m_nScrollX;
# @     }
# @
# @     INT GetScrollY () const
# @     {
# @         return m_nScrollY;
# @     }
# @
# @     BOOL IsHorzScrollEnabled () const
# @     {
# @         return m_blpEnableH;
# @     }
# @
# @     BOOL IsVertScrollEnabled () const
# @     {
# @         return m_blpEnableV;
# @     }
# @
# @     INT GetViewWidth ()
# @     {
# @         CRect rectClient;
# @         if (GetSafeHwnd () == NULL)
# @             return 0;
# @         GetClientRect (&rectClient);
# @         return rectClient.Width ();
# @     }
# @
# @     INT GetViewHeight ()
# @     {
# @         CRect rectClient;
# @         if (GetSafeHwnd () == NULL)
# @             return 0;
# @         GetClientRect (&rectClient);
# @         return rectClient.Height ();
# @     }
# @
# @     BOOL SetVirtualSize (INT nWidth, INT nHeight)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         m_nVirtualWidth = (nWidth < 0 ? 0 : nWidth);
# @         m_nVirtualHeight = (nHeight < 0 ? 0 : nHeight);
# @         ClampScrollPos ();
# @         UpdateContentWindow ();
# @         UpdateScrollBars ();
# @         Notify (CCIDE_SCROLL_EVT_CONTENT_SIZE_CHANGED, m_nVirtualWidth, m_nVirtualHeight, 0, 0);
# @         Notify (CCIDE_SCROLL_EVT_POS_CHANGED, m_nScrollX, m_nScrollY, 4, 0);
# @         return TRUE;
# @     }
# @
# @     BOOL SetScrollEnable (BOOL bEnableHorz, BOOL bEnableVert)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         m_blpEnableH = bEnableHorz;
# @         m_blpEnableV = bEnableVert;
# @         ModifyStyle (WS_HSCROLL | WS_VSCROLL, (m_blpEnableH ? WS_HSCROLL : 0) | (m_blpEnableV ? WS_VSCROLL : 0));
# @         if (!m_blpEnableH)
# @             m_nScrollX = 0;
# @         if (!m_blpEnableV)
# @             m_nScrollY = 0;
# @         ClampScrollPos ();
# @         UpdateContentWindow ();
# @         UpdateScrollBars ();
# @         Notify (CCIDE_SCROLL_EVT_POS_CHANGED, m_nScrollX, m_nScrollY, 4, 0);
# @         return TRUE;
# @     }
# @
# @     BOOL SetScrollStep (INT nLineStepX, INT nLineStepY)
# @     {
# @         m_nLineStepX = (nLineStepX <= 0 ? 1 : nLineStepX);
# @         m_nLineStepY = (nLineStepY <= 0 ? 1 : nLineStepY);
# @         return TRUE;
# @     }
# @
# @     BOOL SetScrollPosValue (INT nX, INT nY, INT nSource)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         const INT nOldX = m_nScrollX;
# @         const INT nOldY = m_nScrollY;
# @         m_nScrollX = nX;
# @         m_nScrollY = nY;
# @         ClampScrollPos ();
# @         UpdateContentWindow ();
# @         UpdateScrollBars ();
# @         if (nOldX != m_nScrollX || nOldY != m_nScrollY)
# @             Notify (CCIDE_SCROLL_EVT_POS_CHANGED, m_nScrollX, m_nScrollY, nSource, 0);
# @         return TRUE;
# @     }
# @
# @     BOOL ScrollBy (INT nDeltaX, INT nDeltaY, INT nSource)
# @     {
# @         return SetScrollPosValue (m_nScrollX + nDeltaX, m_nScrollY + nDeltaY, nSource);
# @     }
# @
# @     BOOL RecalcScroll ()
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         ClampScrollPos ();
# @         UpdateContentWindow ();
# @         UpdateScrollBars ();
# @         return TRUE;
# @     }
# @
# @     BOOL MoveContainer (INT nLeft, INT nTop, INT nWidth, INT nHeight)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         if (nWidth < 0)
# @             nWidth = 0;
# @         if (nHeight < 0)
# @             nHeight = 0;
# @         MoveWindow (nLeft, nTop, nWidth, nHeight, TRUE);
# @         ClampScrollPos ();
# @         UpdateContentWindow ();
# @         UpdateScrollBars ();
# @         return TRUE;
# @     }
# @
# @ protected:
# @     virtual LRESULT WindowProc (UINT message, WPARAM wParam, LPARAM lParam) override
# @     {
# @         switch (message)
# @         {
# @         case WM_SIZE:
# @             {
# @                 LRESULT lResult = CWnd::WindowProc (message, wParam, lParam);
# @                 ClampScrollPos ();
# @                 UpdateContentWindow ();
# @                 UpdateScrollBars ();
# @                 Notify (CCIDE_SCROLL_EVT_VIEW_SIZE_CHANGED, LOWORD (lParam), HIWORD (lParam), (INT)wParam, 0);
# @                 return lResult;
# @             }
# @         case WM_HSCROLL:
# @             HandleScroll (SB_HORZ, LOWORD (wParam), HIWORD (wParam));
# @             return 0;
# @         case WM_VSCROLL:
# @             HandleScroll (SB_VERT, LOWORD (wParam), HIWORD (wParam));
# @             return 0;
# @         case WM_MOUSEWHEEL:
# @             {
# @                 const INT nDelta = (short)HIWORD (wParam);
# @                 Notify (CCIDE_SCROLL_EVT_MOUSE_WHEEL, nDelta, m_nScrollX, m_nScrollY, 0);
# @                 if (m_blpEnableV)
# @                     SetScrollPosValue (m_nScrollX, m_nScrollY - (nDelta / WHEEL_DELTA) * m_nLineStepY * 3, 3);
# @                 else if (m_blpEnableH)
# @                     SetScrollPosValue (m_nScrollX - (nDelta / WHEEL_DELTA) * m_nLineStepX * 3, m_nScrollY, 3);
# @                 return 0;
# @             }
# @         case WM_DESTROY:
# @             Notify (CCIDE_SCROLL_EVT_DESTROYING, 0, 0, 0, 0);
# @             break;
# @         }
# @         return CWnd::WindowProc (message, wParam, lParam);
# @     }
# @
# @     void HandleScroll (INT nBar, INT nCode, INT nTrackPos)
# @     {
# @         INT nNewX = m_nScrollX;
# @         INT nNewY = m_nScrollY;
# @         CRect rectClient;
# @         GetClientRect (&rectClient);
# @
# @         if (nBar == SB_HORZ)
# @         {
# @             switch (nCode)
# @             {
# @             case SB_LINELEFT:      nNewX -= m_nLineStepX; break;
# @             case SB_LINERIGHT:     nNewX += m_nLineStepX; break;
# @             case SB_PAGELEFT:      nNewX -= rectClient.Width (); break;
# @             case SB_PAGERIGHT:     nNewX += rectClient.Width (); break;
# @             case SB_THUMBTRACK:
# @             case SB_THUMBPOSITION: nNewX = nTrackPos; break;
# @             case SB_LEFT:          nNewX = 0; break;
# @             case SB_RIGHT:         nNewX = MaxScrollX (); break;
# @             default: return;
# @             }
# @         }
# @         else
# @         {
# @             switch (nCode)
# @             {
# @             case SB_LINEUP:        nNewY -= m_nLineStepY; break;
# @             case SB_LINEDOWN:      nNewY += m_nLineStepY; break;
# @             case SB_PAGEUP:        nNewY -= rectClient.Height (); break;
# @             case SB_PAGEDOWN:      nNewY += rectClient.Height (); break;
# @             case SB_THUMBTRACK:
# @             case SB_THUMBPOSITION: nNewY = nTrackPos; break;
# @             case SB_TOP:           nNewY = 0; break;
# @             case SB_BOTTOM:        nNewY = MaxScrollY (); break;
# @             default: return;
# @             }
# @         }
# @
# @         SetScrollPosValue (nNewX, nNewY, (nBar == SB_HORZ ? 1 : 2));
# @     }
# @
# @     INT MaxScrollX ()
# @     {
# @         CRect rectClient;
# @         if (GetSafeHwnd () == NULL || !m_blpEnableH)
# @             return 0;
# @         GetClientRect (&rectClient);
# @         const INT nMax = m_nVirtualWidth - rectClient.Width ();
# @         return (nMax > 0 ? nMax : 0);
# @     }
# @
# @     INT MaxScrollY ()
# @     {
# @         CRect rectClient;
# @         if (GetSafeHwnd () == NULL || !m_blpEnableV)
# @             return 0;
# @         GetClientRect (&rectClient);
# @         const INT nMax = m_nVirtualHeight - rectClient.Height ();
# @         return (nMax > 0 ? nMax : 0);
# @     }
# @
# @     void ClampScrollPos ()
# @     {
# @         const INT nMaxX = MaxScrollX ();
# @         const INT nMaxY = MaxScrollY ();
# @         if (m_nScrollX < 0) m_nScrollX = 0;
# @         if (m_nScrollY < 0) m_nScrollY = 0;
# @         if (m_nScrollX > nMaxX) m_nScrollX = nMaxX;
# @         if (m_nScrollY > nMaxY) m_nScrollY = nMaxY;
# @     }
# @
# @     void UpdateScrollBars ()
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return;
# @
# @         CRect rectClient;
# @         GetClientRect (&rectClient);
# @
# @         SCROLLINFO si;
# @         ZeroMemory (&si, sizeof (si));
# @         si.cbSize = sizeof (si);
# @         si.fMask = SIF_RANGE | SIF_PAGE | SIF_POS;
# @
# @         si.nMin = 0;
# @         si.nMax = (m_nVirtualWidth > 0 ? m_nVirtualWidth - 1 : 0);
# @         si.nPage = (UINT)(rectClient.Width () > 0 ? rectClient.Width () : 0);
# @         si.nPos = m_nScrollX;
# @         ::SetScrollInfo (m_hWnd, SB_HORZ, &si, TRUE);
# @         ShowScrollBar (SB_HORZ, m_blpEnableH && MaxScrollX () > 0);
# @
# @         si.nMin = 0;
# @         si.nMax = (m_nVirtualHeight > 0 ? m_nVirtualHeight - 1 : 0);
# @         si.nPage = (UINT)(rectClient.Height () > 0 ? rectClient.Height () : 0);
# @         si.nPos = m_nScrollY;
# @         ::SetScrollInfo (m_hWnd, SB_VERT, &si, TRUE);
# @         ShowScrollBar (SB_VERT, m_blpEnableV && MaxScrollY () > 0);
# @     }
# @
# @     void UpdateContentWindow ()
# @     {
# @         if (m_hContentWnd == NULL || !::IsWindow (m_hContentWnd))
# @             return;
# @
# @         CRect rectClient;
# @         GetClientRect (&rectClient);
# @         const INT nContentWidth = (m_nVirtualWidth > rectClient.Width () ? m_nVirtualWidth : rectClient.Width ());
# @         const INT nContentHeight = (m_nVirtualHeight > rectClient.Height () ? m_nVirtualHeight : rectClient.Height ());
# @         ::SetWindowPos (m_hContentWnd, NULL, -m_nScrollX, -m_nScrollY, nContentWidth, nContentHeight,
# @             SWP_NOZORDER | SWP_NOACTIVATE | SWP_SHOWWINDOW);
# @     }
# @
# @     void Notify (INT nEvent, INT nValue1, INT nValue2, INT nValue3, INT nValue4)
# @     {
# @         if (m_pSink != NULL)
# @             m_pSink->OnScrollContainerEvent (nEvent, nValue1, nValue2, nValue3, nValue4);
# @     }
# @
# @ protected:
# @     ICcIdeScrollContainerSink* m_pSink;
# @     HWND m_hContentWnd;
# @     INT m_nVirtualWidth;
# @     INT m_nVirtualHeight;
# @     INT m_nScrollX;
# @     INT m_nScrollY;
# @     INT m_nLineStepX;
# @     INT m_nLineStepY;
# @     BOOL m_blpEnableH;
# @     BOOL m_blpEnableV;
# @ };
# @
# @ class CCcIdeWndBarEx : public CDockablePane
# @ {
# @ public:
# @     CCcIdeWndBarEx () : m_pSink (NULL), m_hUserWnd (NULL), m_blpLastVisible (FALSE),
# @         m_blpLastFloating (FALSE), m_blpLastAutoHide (FALSE), m_blpHasGripper (FALSE),
# @         m_dwLastAlignment (0) {}
# @
# @     HWND GetUserWnd () const
# @     {
# @         return m_hUserWnd;
# @     }
# @
# @     void Redraw ()
# @     {
# @         if (m_hUserWnd != NULL)
# @             ::InvalidateRect (m_hUserWnd, NULL, TRUE);
# @     }
# @
# @     BOOL CreateVolBar (ICcIdeDockPaneSink* pSink, LPCTSTR lpszCaption, CWnd* pParentWnd, const RECT& rect,
# @             BOOL bHasGripper, UINT nID, DWORD dwStyle)
# @     {
# @         ASSERT (pSink != NULL && m_hUserWnd == NULL);
# @         CCcIdeDockMouseTraceHook::Install ();
# @         m_pSink = pSink;
# @         m_blpHasGripper = bHasGripper;
# @
# @         if (CDockablePane::Create (_T (""), pParentWnd, rect, bHasGripper, nID, dwStyle))
# @         {
# @             if (lpszCaption != NULL && lpszCaption [0] != 0)
# @                 SetWindowText (lpszCaption);
# @             CRect rtClient;
# @             GetClientRect (&rtClient);
# @             m_hUserWnd = m_pSink->OnCreateChildWnd (rtClient.left, rtClient.top, rtClient.Width (), rtClient.Height ());
# @             if (m_hUserWnd == NULL)
# @                 DestroyWindow ();
# @             else
# @             {
# @                 CCcIdeDockUserWndHook::Install (m_hUserWnd);
# @                 ::SetProp (GetSafeHwnd (), _T ("ccide_dock_pane_user_wnd"), (HANDLE)m_hUserWnd);
# @                 DebugTrace (FALSE, 0, 0, _T ("S"), _T ("CCIDE_DOCK_CREATE_USER_HWND"));
# @                 DebugTrace (FALSE, 0, 0, _T ("n"), (INT_P)m_hUserWnd);
# @                 RememberState ();
# @             }
# @         }
# @
# @         return (m_hUserWnd != NULL);
# @     }
# @
# @     BOOL SetVisibleState (BOOL bVisible)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         CFrameWndEx* pFrame = DYNAMIC_DOWNCAST (CFrameWndEx, GetDockSiteFrameWnd ());
# @         if (pFrame == NULL)
# @             pFrame = DYNAMIC_DOWNCAST (CFrameWndEx, GetTopLevelFrame ());
# @         if (pFrame != NULL)
# @             pFrame->ShowPane (this, bVisible, FALSE, FALSE);
# @         else
# @             ShowPane (bVisible, FALSE, FALSE);
# @         CheckStateChange ();
# @         return TRUE;
# @     }
# @
# @     BOOL SetAutoHideState (BOOL bAutoHide, DWORD dwAlignment)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         if ((dwAlignment & CBRS_ALIGN_ANY) == 0)
# @             dwAlignment = GetCurrentAlignment ();
# @         if ((dwAlignment & CBRS_ALIGN_ANY) == 0)
# @             dwAlignment = CBRS_ALIGN_LEFT;
# @         SetAutoHideMode (bAutoHide, dwAlignment);
# @         CheckStateChange ();
# @         return TRUE;
# @     }
# @
# @     BOOL DockToCurrentFrame (DWORD dwAlignment)
# @     {
# @         CMDIFrameWndEx* pFrame = DYNAMIC_DOWNCAST (CMDIFrameWndEx, GetDockSiteFrameWnd ());
# @         if (pFrame == NULL)
# @             pFrame = DYNAMIC_DOWNCAST (CMDIFrameWndEx, GetTopLevelFrame ());
# @         return DockToFrame (pFrame, dwAlignment);
# @     }
# @
# @     BOOL FloatAt (INT nLeft, INT nTop, INT nWidth, INT nHeight)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         if (nWidth <= 0)
# @             nWidth = 320;
# @         if (nHeight <= 0)
# @             nHeight = 240;
# @         CRect rectFloat (nLeft, nTop, nLeft + nWidth, nTop + nHeight);
# @         const BOOL bOK = FloatPane (rectFloat, DM_SHOW, true);
# @         CheckStateChange ();
# @         return bOK;
# @     }
# @
# @     BOOL MoveFloatingRect (INT nLeft, INT nTop, INT nWidth, INT nHeight)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         CRect rectNew (nLeft, nTop, nLeft + nWidth, nTop + nHeight);
# @         SetWindowPos (NULL, rectNew.left, rectNew.top, rectNew.Width (), rectNew.Height (),
# @             SWP_NOZORDER | SWP_NOACTIVATE);
# @         CheckStateChange ();
# @         return TRUE;
# @     }
# @
# @     BOOL DockNextToPane (CCcIdeWndBarEx* pTargetPane, DWORD dwAlignment)
# @     {
# @         if (GetSafeHwnd () == NULL || pTargetPane == NULL || pTargetPane->GetSafeHwnd () == NULL)
# @             return FALSE;
# @         const BOOL bOK = DockToWindow (pTargetPane, dwAlignment, NULL);
# @         CheckStateChange ();
# @         pTargetPane->CheckStateChange ();
# @         return bOK;
# @     }
# @
# @     BOOL AttachAsTabToPane (CCcIdeWndBarEx* pTargetPane, BOOL bSetActive)
# @     {
# @         if (GetSafeHwnd () == NULL || pTargetPane == NULL || pTargetPane->GetSafeHwnd () == NULL)
# @             return FALSE;
# @         CDockablePane* pTabbedBar = pTargetPane;
# @         CDockablePane* pResult = AttachToTabWnd (pTargetPane, DM_SHOW, bSetActive, &pTabbedBar);
# @         InstallTabbedPaneClickHook ();
# @         pTargetPane->InstallTabbedPaneClickHook ();
# @         if (bSetActive)
# @             ActivatePaneTab ();
# @         else
# @             pTargetPane->ActivatePaneTab ();
# @         CheckStateChange ();
# @         pTargetPane->CheckStateChange ();
# @         return (pResult != NULL);
# @     }
# @
# @     BOOL ActivatePaneTab ()
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @
# @         ShowPane (TRUE, FALSE, TRUE);
# @         CBaseTabbedPane* pTabbedPane = GetParentTabbedPane ();
# @         if (pTabbedPane != NULL)
# @         {
# @             pTabbedPane->ShowTab (this, TRUE, FALSE, TRUE);
# @             CMFCBaseTabCtrl* pTabWnd = pTabbedPane->GetUnderlyingWindow ();
# @             if (pTabWnd != NULL)
# @             {
# @                 CCcIdeDockTabCtrlHook::Install (pTabWnd);
# @                 CCcIdeDockTabbedBarHook::Install (pTabbedPane, pTabWnd);
# @                 INT nTab = pTabWnd->GetTabFromHwnd (GetSafeHwnd ());
# @                 if (nTab >= 0)
# @                 {
# @                     pTabWnd->ShowTab (nTab, TRUE, TRUE, TRUE);
# @                     pTabWnd->SetActiveTab (nTab);
# @                     pTabWnd->EnsureVisible (nTab);
# @                     pTabWnd->Invalidate ();
# @                 }
# @             }
# @         }
# @         SetFocus ();
# @         BringWindowToTop ();
# @         RedrawWindow (NULL, NULL, RDW_INVALIDATE | RDW_UPDATENOW | RDW_ALLCHILDREN);
# @         return TRUE;
# @     }
# @
# @     void InstallTabbedPaneClickHook ()
# @     {
# @         CBaseTabbedPane* pTabbedPane = GetParentTabbedPane ();
# @         if (pTabbedPane == NULL)
# @             return;
# @         CMFCBaseTabCtrl* pTabWnd = pTabbedPane->GetUnderlyingWindow ();
# @         CCcIdeDockTabCtrlHook::Install (pTabWnd);
# @         CCcIdeDockTabbedBarHook::Install (pTabbedPane, pTabWnd);
# @     }
# @
# @     BOOL UndockFromFrame (BOOL bDelay)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         UndockPane (bDelay);
# @         CheckStateChange ();
# @         return TRUE;
# @     }
# @
# @     BOOL SavePaneState (LPCTSTR lpszProfileName, INT nIndex, UINT nID)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         return SaveState (lpszProfileName, nIndex, nID);
# @     }
# @
# @     BOOL LoadPaneState (LPCTSTR lpszProfileName, INT nIndex, UINT nID)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         const BOOL bOK = LoadState (lpszProfileName, nIndex, nID);
# @         CheckStateChange ();
# @         return bOK;
# @     }
# @
# @     BOOL DockToFrame (CMDIFrameWndEx* pParentFrame, DWORD dwAlignment)
# @     {
# @         if (GetSafeHwnd () == NULL || pParentFrame == NULL || pParentFrame->GetSafeHwnd () == NULL)
# @             return FALSE;
# @
# @         UINT nDockBarID = AFX_IDW_DOCKBAR_LEFT;
# @         if ((dwAlignment & CBRS_ALIGN_RIGHT) != 0)
# @             nDockBarID = AFX_IDW_DOCKBAR_RIGHT;
# @         else if ((dwAlignment & CBRS_ALIGN_TOP) != 0)
# @             nDockBarID = AFX_IDW_DOCKBAR_TOP;
# @         else if ((dwAlignment & CBRS_ALIGN_BOTTOM) != 0)
# @             nDockBarID = AFX_IDW_DOCKBAR_BOTTOM;
# @
# @         pParentFrame->DockPane (this, nDockBarID, NULL);
# @         CheckStateChange ();
# @         return TRUE;
# @     }
# @
# @     BOOL SetDockEnable (DWORD dwAlignment)
# @     {
# @         if (GetSafeHwnd () == NULL)
# @             return FALSE;
# @         EnableDocking (dwAlignment);
