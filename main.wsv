    {
        变量 结果文本 <类型 = 文本型>
        变量 换行文本 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        换行文本 = "\n"
        结果文本 = "[解决方案]" + 换行文本
        结果文本 = 结果文本 + "名称=" + 解决方案名称 + 换行文本
        结果文本 = 结果文本 + "启动项目索引=" + 到文本 (启动项目索引) + 换行文本
        结果文本 = 结果文本 + "项目数=" + 到文本 (解决方案项目文件组.取成员数 ()) + 换行文本
        结果文本 = 结果文本 + 换行文本
        结果文本 = 结果文本 + "[项目列表]" + 换行文本
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 解决方案项目文件组.取成员数 ())
            {
                跳出循环
            }
            结果文本 = 结果文本 + "项目" + 到文本 (索引) + "=" + 解决方案项目文件组.取成员 (索引) + 换行文本
            结果文本 = 结果文本 + "项目名称" + 到文本 (索引) + "=" + 项目名称组.取成员 (索引) + 换行文本
            结果文本 = 结果文本 + "项目类型" + 到文本 (索引) + "=" + 项目类型组.取成员 (索引) + 换行文本
            结果文本 = 结果文本 + "核心模块" + 到文本 (索引) + "=" + 选择 (索引 < 项目核心模块组.取成员数 (), 项目核心模块组.取成员 (索引), 取默认核心模块列表文本 (项目类型组.取成员 (索引))) + 换行文本
            结果文本 = 结果文本 + "用户模块" + 到文本 (索引) + "=" + 选择 (索引 < 项目用户模块组.取成员数 (), 项目用户模块组.取成员 (索引), "") + 换行文本
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 解决方案项目文件组.取成员数 ())
        返回 (结果文本)
    }

