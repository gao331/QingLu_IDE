    方法 生成属性文本 <公开 类型 = 文本型>
    {
        变量 文本 <类型 = 文本型>
        变量 换行文本 <类型 = 文本型>
        换行文本 = "\n"
        文本 = "[常规]" + 换行文本
        文本 = 文本 + "C++语言标准=" + 取Cxx标准文本 () + 换行文本
        文本 = 文本 + "C语言标准=" + 取C标准文本 () + 换行文本
        文本 = 文本 + "配置类型=" + 取配置类型文本 () + 换行文本
        文本 = 文本 + "字符集=" + 取字符集文本 () + 换行文本
        文本 = 文本 + "MFC使用=" + 取MFC文本 () + 换行文本
        文本 = 文本 + 换行文本 + "[C++]" + 换行文本
        文本 = 文本 + "附加包含目录=" + 包含目录编辑框.内容 + 换行文本
        文本 = 文本 + "警告等级=" + 取警告等级文本 () + 换行文本
        文本 = 文本 + "将警告视为错误=" + 选择 (警告错误框.现行选中项 == 1, "真", "假") + 换行文本
        文本 = 文本 + 换行文本 + "[预处理器]" + 换行文本
        文本 = 文本 + "预处理器定义=" + 预处理器编辑框.内容 + 换行文本
        文本 = 文本 + 换行文本 + "[代码生成]" + 换行文本
        文本 = 文本 + "运行库=" + 取运行库文本 () + 换行文本
        文本 = 文本 + 换行文本 + "[链接器]" + 换行文本
        文本 = 文本 + "附加库目录=" + 库目录编辑框.内容 + 换行文本
        文本 = 文本 + "附加依赖项=" + 依赖项编辑框.内容 + 换行文本
        文本 = 文本 + "生成调试信息=" + 取调试信息文本 () + 换行文本
        文本 = 文本 + "子系统=" + 取子系统文本 () + 换行文本
        返回 (文本)
    }

    方法 按钮_被单击 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 分类常规)
        {
            切换属性分类 (0)
        }
        否则 (来源对象 == 分类编译)
        {
            切换属性分类 (1)
        }
        否则 (来源对象 == 分类预处理)
        {
            切换属性分类 (2)
        }
        否则 (来源对象 == 分类代码生成)
        {
            切换属性分类 (3)
        }
        否则 (来源对象 == 分类链接器)
        {
            切换属性分类 (4)
        }
        否则 (来源对象 == 确定按钮)
        {
            结果属性文本 = 生成属性文本 ()
            关闭窗口 (1)
        }
        否则 (来源对象 == 取消按钮)
        {
            关闭窗口 (0)
        }
        返回 (0)
    }
}

类 IDE设置对话框 <基础类 = 窗口 标题 = "设置" 位置 = 居中 @视窗.布局 = "client_size = \"820, 600\"">
{
    变量 左侧标题 <类型 = 标签 @视窗.布局 = "id = 1270\r\npos = \"14, 14, 150, 24\"" 标题 = "设置分类">
    变量 分类编译器 <类型 = 按钮 @视窗.布局 = "id = 1271\r\npos = \"18, 48, 140, 28\"" 标题 = "编译器">
    变量 分类表格尺寸 <类型 = 按钮 @视窗.布局 = "id = 1272\r\npos = \"18, 82, 140, 28\"" 标题 = "表格尺寸">
    变量 分类外观绘制 <类型 = 按钮 @视窗.布局 = "id = 1273\r\npos = \"18, 116, 140, 28\"" 标题 = "外观与绘制">

    变量 页面标题 <类型 = 标签 @视窗.布局 = "id = 1274\r\npos = \"184, 14, 590, 24\"" 标题 = "编译器">
    变量 编译器路径标签 <类型 = 标签 @视窗.布局 = "id = 1275\r\npos = \"196, 52, 150, 24\"" 标题 = "编译器路径:">
    变量 编译器路径编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1276\r\npos = \"360, 48, 350, 24\"">
    变量 浏览编译器按钮 <类型 = 按钮 @视窗.布局 = "id = 1277\r\npos = \"720, 46, 54, 28\"" 标题 = "...">
    变量 编译器类型标签 <类型 = 标签 @视窗.布局 = "id = 1278\r\npos = \"196, 88, 150, 24\"" 标题 = "编译器类型:">
    变量 编译器类型值标签 <类型 = 标签 @视窗.布局 = "id = 1279\r\npos = \"360, 88, 350, 24\"" 标题 = "未设置">

    变量 标签横向间距 <类型 = 标签 @视窗.布局 = "id = 1280\r\npos = \"196, 52, 210, 24\"" 标题 = "单元格横向间距:">
    变量 横向间距编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1281\r\npos = \"430, 48, 180, 24\"">
    变量 标签纵向间距 <类型 = 标签 @视窗.布局 = "id = 1282\r\npos = \"196, 86, 210, 24\"" 标题 = "单元格纵向间距:">
    变量 纵向间距编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1283\r\npos = \"430, 82, 180, 24\"">
    变量 标签顶层间距 <类型 = 标签 @视窗.布局 = "id = 1284\r\npos = \"196, 120, 210, 24\"" 标题 = "命名空间顶层间距:">
    变量 顶层间距编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1285\r\npos = \"430, 116, 180, 24\"">
    变量 标签命名空间行距 <类型 = 标签 @视窗.布局 = "id = 1286\r\npos = \"196, 154, 210, 24\"" 标题 = "命名空间成员行间距:">
    变量 命名空间行距编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1287\r\npos = \"430, 150, 180, 24\"">
    变量 标签类成员行距 <类型 = 标签 @视窗.布局 = "id = 1288\r\npos = \"196, 188, 210, 24\"" 标题 = "类成员行间距:">
    变量 类成员行距编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1289\r\npos = \"430, 184, 180, 24\"">
    变量 标签方法成员行距 <类型 = 标签 @视窗.布局 = "id = 1290\r\npos = \"196, 222, 210, 24\"" 标题 = "方法成员行间距:">
    变量 方法成员行距编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1291\r\npos = \"430, 218, 180, 24\"">
    变量 标签类成员缩进 <类型 = 标签 @视窗.布局 = "id = 1292\r\npos = \"196, 256, 210, 24\"" 标题 = "类成员缩进宽度:">
    变量 类成员缩进编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1293\r\npos = \"430, 252, 180, 24\"">

    变量 字体标签 <类型 = 标签 @视窗.布局 = "id = 1294\r\npos = \"196, 52, 150, 24\"" 标题 = "字体:">
    变量 字体编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1295\r\npos = \"360, 48, 350, 24\"">
    变量 浏览字体按钮 <类型 = 按钮 @视窗.布局 = "id = 1296\r\npos = \"720, 46, 54, 28\"" 标题 = "...">
    变量 缓冲绘制标签 <类型 = 标签 @视窗.布局 = "id = 1297\r\npos = \"196, 88, 150, 24\"" 标题 = "缓冲绘制表格:">
    变量 缓冲绘制框 <类型 = 组合框 @视窗.布局 = "id = 1298\r\npos = \"360, 84, 220, 24\"" "类型" = 不可编辑下拉式 列表项目 = "真\n假" 现行选中项 = 0>
    变量 流程线样式标签 <类型 = 标签 @视窗.布局 = "id = 1299\r\npos = \"196, 124, 150, 24\"" 标题 = "语句块绘制线样式:">
    变量 流程线样式框 <类型 = 组合框 @视窗.布局 = "id = 1300\r\npos = \"360, 120, 260, 24\"" "类型" = 不可编辑下拉式 列表项目 = "标准直角线\n加粗直角线\n仅垂直层级线" 现行选中项 = 0>
    变量 字体对话框 <类型 = 通用对话框>

    变量 确定按钮 <类型 = 按钮 @视窗.布局 = "id = 1301\r\npos = \"590, 554, 104, 28\"" 标题 = "确定(O)">
    变量 取消按钮 <类型 = 按钮 @视窗.布局 = "id = 1302\r\npos = \"704, 554, 104, 28\"" 标题 = "取消(C)">
    变量 初始编译器路径 <类型 = 文本型>
    变量 初始编译器类型 <类型 = 文本型>
    变量 结果编译器路径 <公开 类型 = 文本型>
    变量 结果编译器类型 <公开 类型 = 文本型>

    方法 初始化数据 <公开>
    参数 编译器路径 <类型 = 文本型>
    参数 编译器类型 <类型 = 文本型>
    {
        初始编译器路径 = 编译器路径
        初始编译器类型 = 编译器类型
        结果编译器路径 = 编译器路径
        结果编译器类型 = 编译器类型
    }

    方法 IDE设置对话框_创建完毕 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE设置对话框>
    参数 标记值 <类型 = 整数>
    {
        变量 配置路径 <类型 = 文本型>
        配置路径 = 环境存取类.取运行目录 () + "\\ide_config.ini"
        横向间距编辑框.输入方式 = 编辑框输入方式.整数文本输入
        纵向间距编辑框.输入方式 = 编辑框输入方式.整数文本输入
        顶层间距编辑框.输入方式 = 编辑框输入方式.整数文本输入
        命名空间行距编辑框.输入方式 = 编辑框输入方式.整数文本输入
        类成员行距编辑框.输入方式 = 编辑框输入方式.整数文本输入
        方法成员行距编辑框.输入方式 = 编辑框输入方式.整数文本输入
        类成员缩进编辑框.输入方式 = 编辑框输入方式.整数文本输入
        字体编辑框.输入方式 = 编辑框输入方式.只读方式
        编译器路径编辑框.内容 = 初始编译器路径
        横向间距编辑框.内容 = "5"
        纵向间距编辑框.内容 = "5"
        如果 (常用功能类.读配置项 (配置路径, "表格编辑器", "单元格间距版本", "") == "2")
        {
            横向间距编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "单元格横向间距", "5")
            纵向间距编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "单元格纵向间距", "5")
        }
        顶层间距编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "命名空间顶层间距", "8")
        命名空间行距编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "命名空间成员行间距", "20")
        类成员行距编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "类成员行间距", "20")
        方法成员行距编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "方法成员行间距", "20")
        类成员缩进编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "类成员缩进宽度", "12")
        字体编辑框.内容 = 常用功能类.读配置项 (配置路径, "表格编辑器", "字体", "Consolas, 10")
        如果 (常用功能类.读配置项 (配置路径, "表格编辑器", "缓冲绘制表格", "真") == "假")
        {
            缓冲绘制框.现行选中项 = 1
        }
        流程线样式框.现行选中项 = 文本到整数 (常用功能类.读配置项 (配置路径, "表格编辑器", "语句块绘制线样式", "0"))
        如果 (流程线样式框.现行选中项 < 0 || 流程线样式框.现行选中项 > 2)
        {
            流程线样式框.现行选中项 = 0
        }
        刷新编译器类型 ()
        切换设置分类 (0)
        调整设置下拉高度 ()
        返回 (0)
    }

    方法 调整设置下拉高度 <公开 @禁止流程检查 = 真>
    {
        @ #ifndef CB_SETMINVISIBLE
        @ #define CB_SETMINVISIBLE 0x1701
        @ #endif
        @ CComboBox* pBuffer = (CComboBox*)@<缓冲绘制框>.GetMfcWndPtrWithValidHWnd ();
        @ CComboBox* pFlow = (CComboBox*)@<流程线样式框>.GetMfcWndPtrWithValidHWnd ();
        @ CComboBox* combos[] = { pBuffer, pFlow };
        @ const INT itemCounts[] = { 2, 3 };
        @ for (INT i = 0; i < 2; ++i)
        @ {
        @     CComboBox* pCombo = combos[i];
        @     if (pCombo == NULL || pCombo->m_hWnd == NULL)
        @         continue;
        @     CRect rc;
        @     pCombo->GetWindowRect (&rc);
        @     CWnd* pParent = pCombo->GetParent ();
        @     if (pParent != NULL && pParent->m_hWnd != NULL)
        @         pParent->ScreenToClient (&rc);
        @     INT itemHeight = (INT)pCombo->SendMessage (CB_GETITEMHEIGHT, 0, 0);
        @     if (itemHeight < 18)
        @         itemHeight = 18;
        @     pCombo->MoveWindow (rc.left, rc.top, rc.Width (), 28 + itemHeight * itemCounts[i], TRUE);
        @     pCombo->SetDroppedWidth (rc.Width ());
        @     pCombo->SendMessage (CB_SETMINVISIBLE, itemCounts[i], 0);
        @ }
    }

    方法 置编译器页可视 <公开>
    参数 是否可视 <类型 = 逻辑型>
    {
        编译器路径标签.可视 = 是否可视
        编译器路径编辑框.可视 = 是否可视
        浏览编译器按钮.可视 = 是否可视
        编译器类型标签.可视 = 是否可视
        编译器类型值标签.可视 = 是否可视
    }

    方法 置尺寸页可视 <公开>
    参数 是否可视 <类型 = 逻辑型>
    {
        标签横向间距.可视 = 是否可视
        横向间距编辑框.可视 = 是否可视
        标签纵向间距.可视 = 是否可视
        纵向间距编辑框.可视 = 是否可视
        标签顶层间距.可视 = 是否可视
        顶层间距编辑框.可视 = 是否可视
        标签命名空间行距.可视 = 是否可视
        命名空间行距编辑框.可视 = 是否可视
        标签类成员行距.可视 = 是否可视
        类成员行距编辑框.可视 = 是否可视
        标签方法成员行距.可视 = 是否可视
        方法成员行距编辑框.可视 = 是否可视
        标签类成员缩进.可视 = 是否可视
        类成员缩进编辑框.可视 = 是否可视
