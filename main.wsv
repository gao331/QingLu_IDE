            模板源码 = 模板源码 + "    {" + 换行文本
            模板源码 = 模板源码 + "        主窗口对象.创建主窗口 ()" + 换行文本
            模板源码 = 模板源码 + "        返回 (1)" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
            模板源码 = 模板源码 + 换行文本
            模板源码 = 模板源码 + "类 主窗口类 <基础类 = 窗口 标题 = \"窗口程序\">" + 换行文本
            模板源码 = 模板源码 + "{" + 换行文本
            模板源码 = 模板源码 + "    方法 主窗口类_创建完毕 <公开>" + 换行文本
            模板源码 = 模板源码 + "    {" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + 换行文本
            模板源码 = 模板源码 + "    方法 主窗口类_尺寸被改变 <公开>" + 换行文本
            模板源码 = 模板源码 + "    {" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + 换行文本
            模板源码 = 模板源码 + "    方法 主窗口类_将被关闭 <公开>" + 换行文本
            模板源码 = 模板源码 + "    {" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
            返回 (模板源码)
        }
        如果 (项目类型 == "empty")
        {
            模板源码 = "包 " + 项目名称 + ".程序" + 换行文本
            模板源码 = 模板源码 + 换行文本
            模板源码 = 模板源码 + "类 启动类 <公开>" + 换行文本
            模板源码 = 模板源码 + "{" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
            返回 (模板源码)
        }
        如果 (项目类型 == "dll")
        {
            模板源码 = "包 " + 项目名称 + ".模块" + 换行文本
            模板源码 = 模板源码 + 换行文本
            模板源码 = 模板源码 + "类 导出类 <公开>" + 换行文本
            模板源码 = 模板源码 + "{" + 换行文本
            模板源码 = 模板源码 + "    方法 初始化 <公开 类型 = 整数>" + 换行文本
            模板源码 = 模板源码 + "    {" + 换行文本
            模板源码 = 模板源码 + "        返回 (1)" + 换行文本
            模板源码 = 模板源码 + "    }" + 换行文本
            模板源码 = 模板源码 + "}" + 换行文本
            返回 (模板源码)
        }
        模板源码 = "包 控制台.程序" + 换行文本
        模板源码 = 模板源码 + "类 程序入口类 <公开>" + 换行文本
        模板源码 = 模板源码 + "{" + 换行文本
        模板源码 = 模板源码 + "    方法 项目入口 <公开 静态 类型 = 整数>" + 换行文本
        模板源码 = 模板源码 + "    {" + 换行文本
        模板源码 = 模板源码 + "        返回 (0)" + 换行文本
        模板源码 = 模板源码 + "    }" + 换行文本
        模板源码 = 模板源码 + "}" + 换行文本
        返回 (模板源码)
    }

