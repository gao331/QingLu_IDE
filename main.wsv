    方法 重建属性下拉项 <公开 @禁止流程检查 = 真>
    {
        @ #ifndef CB_SETMINVISIBLE
        @ #define CB_SETMINVISIBLE 0x1701
        @ #endif
        @ CComboBox* pCxx = (CComboBox*)@<Cxx标准框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pCxx != NULL)
        @ {
        @     pCxx->ResetContent ();
        @     pCxx->AddString (_T ("默认(ISO C++14标准)"));
        @     pCxx->AddString (_T ("ISO C++14标准 (/std:c++14)"));
        @     pCxx->AddString (_T ("ISO C++17 标准 (/std:c++17)"));
        @     pCxx->AddString (_T ("ISO C++20 标准 (/std:c++20)"));
        @ }
        @ CComboBox* pC = (CComboBox*)@<C标准框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pC != NULL)
        @ {
        @     pC->ResetContent ();
        @     pC->AddString (_T ("默认(旧MSVC)"));
        @     pC->AddString (_T ("ISO C11 标准 (/std:c11)"));
        @     pC->AddString (_T ("ISO C17 (2018)标准 (/std:c17)"));
        @ }
        @ CComboBox* pConfig = (CComboBox*)@<配置类型框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pConfig != NULL)
        @ {
        @     pConfig->ResetContent ();
        @     pConfig->AddString (_T ("应用程序(.exe)"));
        @     pConfig->AddString (_T ("动态库(.dll)"));
        @     pConfig->AddString (_T ("静态库(.lib)"));
        @ }
        @ CComboBox* pCharset = (CComboBox*)@<字符集框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pCharset != NULL)
        @ {
        @     pCharset->ResetContent ();
        @     pCharset->AddString (_T ("使用 Unicode 字符集"));
        @     pCharset->AddString (_T ("使用多字节字符集"));
        @ }
        @ CComboBox* pMfc = (CComboBox*)@<MFC框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pMfc != NULL)
        @ {
        @     pMfc->ResetContent ();
        @     pMfc->AddString (_T ("使用标准Windows库"));
        @     pMfc->AddString (_T ("在静态库中使用MFC"));
        @     pMfc->AddString (_T ("在共享DLL中使用MFC"));
        @ }
        @ CComboBox* pWarn = (CComboBox*)@<警告等级框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pWarn != NULL)
        @ {
        @     pWarn->ResetContent ();
        @     pWarn->AddString (_T ("默认"));
        @     pWarn->AddString (_T ("等级1 (/W1)"));
        @     pWarn->AddString (_T ("等级2 (/W2)"));
        @     pWarn->AddString (_T ("等级3 (/W3)"));
        @     pWarn->AddString (_T ("等级4 (/W4)"));
        @ }
        @ CComboBox* pWarnErr = (CComboBox*)@<警告错误框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pWarnErr != NULL)
        @ {
        @     pWarnErr->ResetContent ();
        @     pWarnErr->AddString (_T ("假"));
        @     pWarnErr->AddString (_T ("真"));
        @ }
        @ CComboBox* pRuntime = (CComboBox*)@<运行库框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pRuntime != NULL)
        @ {
        @     pRuntime->ResetContent ();
        @     pRuntime->AddString (_T ("多线程 (/MT)"));
        @     pRuntime->AddString (_T ("多线程调试 (/MTd)"));
        @     pRuntime->AddString (_T ("多线程 DLL (/MD)"));
        @     pRuntime->AddString (_T ("多线程调试 DLL (/MDd)"));
        @ }
        @ CComboBox* pDebug = (CComboBox*)@<调试信息框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pDebug != NULL)
        @ {
        @     pDebug->ResetContent ();
        @     pDebug->AddString (_T ("生成调试信息 (/DEBUG)"));
        @     pDebug->AddString (_T ("生成经过优化以使链接更快的调试信息 (/DEBUG:FASTLINK)"));
        @     pDebug->AddString (_T ("生成经过优化以共享和发布的调试信息 (/DEBUG:FULL)"));
        @ }
        @ CComboBox* pSub = (CComboBox*)@<子系统框>.GetMfcWndPtrWithValidHWnd ();
        @ if (pSub != NULL)
        @ {
        @     pSub->ResetContent ();
        @     pSub->AddString (_T ("控制台 (/SUBSYSTEM:CONSOLE)"));
        @     pSub->AddString (_T ("窗口 (/SUBSYSTEM:WINDOWS)"));
        @     pSub->AddString (_T ("本机 (/SUBSYSTEM:NATIVE)"));
        @     pSub->AddString (_T ("EFI应用程序 (/SUBSYSTEM:EFI_APPLICATION)"));
        @     pSub->AddString (_T ("EFI 启动服务驱动程序 (/SUBSYSTEM:EFI_BOOT_SERVICE_DRIVER)"));
        @     pSub->AddString (_T ("EFI ROM (/SUBSYSTEM:EFI_ROM)"));
        @     pSub->AddString (_T ("EFI 运行时 (/SUBSYSTEM:EFI_RUNTIME_DRIVER)"));
        @     pSub->AddString (_T ("POSIX (/SUBSYSTEM:POSIX)"));
        @ }
        @ CComboBox* combos[] = { pCxx, pC, pConfig, pCharset, pMfc, pWarn, pWarnErr, pRuntime, pDebug, pSub };
        @ const INT comboCount = sizeof (combos) / sizeof (combos[0]);
        @ for (INT i = 0; i < comboCount; ++i)
        @ {
        @     if (combos[i] != NULL && combos[i]->m_hWnd != NULL)
        @     {
        @         combos[i]->SetDroppedWidth (420);
        @         combos[i]->SendMessage (CB_SETMINVISIBLE, 8, 0);
        @     }
        @ }
    }

    方法 调整属性下拉高度 <公开 @禁止流程检查 = 真>
    {
        @ #ifndef CB_SETMINVISIBLE
        @ #define CB_SETMINVISIBLE 0x1701
        @ #endif
        @ struct CcIdeComboDropSizer
        @ {
        @     static void Apply (CComboBox* pCombo, INT nVisibleItems)
        @     {
        @         if (pCombo == NULL || pCombo->m_hWnd == NULL)
        @             return;
        @         CRect rc;
        @         pCombo->GetWindowRect (&rc);
        @         CWnd* pParent = pCombo->GetParent ();
        @         if (pParent != NULL && pParent->m_hWnd != NULL)
        @             pParent->ScreenToClient (&rc);
        @         const INT nClosedHeight = 26;
        @         INT nItemHeight = (INT)pCombo->SendMessage (CB_GETITEMHEIGHT, 0, 0);
        @         if (nItemHeight < 18)
        @             nItemHeight = 18;
        @         const INT nDropHeight = nClosedHeight + nItemHeight * nVisibleItems + 8;
        @         pCombo->MoveWindow (rc.left, rc.top, rc.Width (), nDropHeight, TRUE);
        @         INT nDropWidth = rc.Width ();
        @         if (nDropWidth < 420)
        @             nDropWidth = 420;
        @         pCombo->SetDroppedWidth (nDropWidth);
        @         pCombo->SendMessage (CB_SETMINVISIBLE, nVisibleItems, 0);
        @     }
        @ };
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<Cxx标准框>.GetMfcWndPtrWithValidHWnd (), 4);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<C标准框>.GetMfcWndPtrWithValidHWnd (), 3);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<配置类型框>.GetMfcWndPtrWithValidHWnd (), 3);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<字符集框>.GetMfcWndPtrWithValidHWnd (), 2);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<MFC框>.GetMfcWndPtrWithValidHWnd (), 3);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<警告等级框>.GetMfcWndPtrWithValidHWnd (), 5);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<警告错误框>.GetMfcWndPtrWithValidHWnd (), 2);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<运行库框>.GetMfcWndPtrWithValidHWnd (), 4);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<调试信息框>.GetMfcWndPtrWithValidHWnd (), 3);
        @ CcIdeComboDropSizer::Apply ((CComboBox*)@<子系统框>.GetMfcWndPtrWithValidHWnd (), 8);
    }

