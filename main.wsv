    方法 置外观页可视 <公开>
    参数 是否可视 <类型 = 逻辑型>
    {
        字体标签.可视 = 是否可视
        字体编辑框.可视 = 是否可视
        浏览字体按钮.可视 = 是否可视
        缓冲绘制标签.可视 = 是否可视
        缓冲绘制框.可视 = 是否可视
        流程线样式标签.可视 = 是否可视
        流程线样式框.可视 = 是否可视
    }

    方法 切换设置分类 <公开>
    参数 分类索引 <类型 = 整数>
    {
        置编译器页可视 (分类索引 == 0)
        置尺寸页可视 (分类索引 == 1)
        置外观页可视 (分类索引 == 2)
        如果 (分类索引 == 0)
        {
            页面标题.标题 = "编译器"
        }
        否则 (分类索引 == 1)
        {
            页面标题.标题 = "表格尺寸"
        }
        否则
        {
            页面标题.标题 = "外观与绘制"
        }
    }

    方法 识别编译器类型 <公开 类型 = 文本型>
    参数 编译器路径 <类型 = 文本型>
    {
        如果 (编译器路径 == "")
        {
            返回 ("未设置")
        }
        如果 (文本类.寻找文本 (编译器路径, "cl.exe", 0, 真) >= 0)
        {
            返回 ("msvc")
        }
        否则 (文本类.寻找文本 (编译器路径, "g++", 0, 真) >= 0 || 文本类.寻找文本 (编译器路径, "gcc", 0, 真) >= 0)
        {
            返回 ("gcc")
        }
        否则 (文本类.寻找文本 (编译器路径, "clang++", 0, 真) >= 0 || 文本类.寻找文本 (编译器路径, "clang", 0, 真) >= 0)
        {
            返回 ("gcc")
        }
        如果 (初始编译器类型 != "")
        {
            返回 (初始编译器类型)
        }
        返回 ("gcc")
    }

    方法 刷新编译器类型 <公开>
    {
        结果编译器类型 = 识别编译器类型 (编译器路径编辑框.内容)
        编译器类型值标签.标题 = 结果编译器类型
    }

    方法 取字体名称 <公开 类型 = 文本型>
    参数 字体描述 <类型 = 文本型>
    {
        变量 逗号位置 <类型 = 整数>
        逗号位置 = 文本类.寻找文本 (字体描述, ",", 0, 真)
        如果 (逗号位置 < 0)
        {
            返回 (字体描述)
        }
        返回 (文本类.取文本左边 (字体描述, 逗号位置))
    }

    方法 取字体大小 <公开 类型 = 整数>
    参数 字体描述 <类型 = 文本型>
    {
        变量 逗号位置 <类型 = 整数>
        变量 后续文本 <类型 = 文本型>
        变量 第二逗号 <类型 = 整数>
        变量 字体大小值 <类型 = 整数>
        逗号位置 = 文本类.寻找文本 (字体描述, ",", 0, 真)
        如果 (逗号位置 < 0)
        {
            返回 (10)
        }
        后续文本 = 文本类.取文本右边 (字体描述, 文本类.取文本长度 (字体描述) - 逗号位置 - 1)
        第二逗号 = 文本类.寻找文本 (后续文本, ",", 0, 真)
        如果 (第二逗号 >= 0)
        {
            后续文本 = 文本类.取文本左边 (后续文本, 第二逗号)
        }
        字体大小值 = 文本到整数 (后续文本)
        如果 (字体大小值 < 6 || 字体大小值 > 72)
        {
            返回 (10)
        }
        返回 (字体大小值)
    }

    方法 取字体逻辑属性 <公开 类型 = 逻辑型>
    参数 字体描述 <类型 = 文本型>
    参数 属性索引 <类型 = 整数>
    {
        变量 字体属性组 <类型 = 文本数组类>
        分割文本 (字体描述, ",", 字体属性组, 真, 假)
        如果 (属性索引 < 0 || 属性索引 >= 字体属性组.取成员数 ())
        {
            返回 (假)
        }
        返回 (文本到整数 (字体属性组.取成员 (属性索引)) == 1)
    }

    方法 取逻辑数值文本 <公开 类型 = 文本型>
    参数 逻辑值 <类型 = 逻辑型>
    {
        如果 (逻辑值)
        {
            返回 ("1")
        }
        返回 ("0")
    }

    方法 尺寸输入有效 <公开 类型 = 逻辑型>
    {
        如果 (是否整数输入文本 (横向间距编辑框.内容) == 假 || 是否整数输入文本 (纵向间距编辑框.内容) == 假 || 是否整数输入文本 (顶层间距编辑框.内容) == 假 || 是否整数输入文本 (命名空间行距编辑框.内容) == 假 || 是否整数输入文本 (类成员行距编辑框.内容) == 假 || 是否整数输入文本 (方法成员行距编辑框.内容) == 假 || 是否整数输入文本 (类成员缩进编辑框.内容) == 假)
        {
            返回 (假)
        }
        返回 (文本到整数 (横向间距编辑框.内容) >= 0 && 文本到整数 (横向间距编辑框.内容) <= 32 && 文本到整数 (纵向间距编辑框.内容) >= 0 && 文本到整数 (纵向间距编辑框.内容) <= 32 && 文本到整数 (顶层间距编辑框.内容) >= 0 && 文本到整数 (顶层间距编辑框.内容) <= 200 && 文本到整数 (命名空间行距编辑框.内容) >= 1 && 文本到整数 (命名空间行距编辑框.内容) <= 100 && 文本到整数 (类成员行距编辑框.内容) >= 1 && 文本到整数 (类成员行距编辑框.内容) <= 100 && 文本到整数 (方法成员行距编辑框.内容) >= 1 && 文本到整数 (方法成员行距编辑框.内容) <= 100 && 文本到整数 (类成员缩进编辑框.内容) >= 4 && 文本到整数 (类成员缩进编辑框.内容) <= 64)
    }

    方法 是否整数输入文本 <公开 类型 = 逻辑型>
    参数 输入文本 <类型 = 文本型>
    {
        如果 (输入文本 == "")
        {
            返回 (假)
        }
        返回 (到文本 (文本到整数 (输入文本)) == 输入文本)
    }

    方法 保存编辑器设置 <公开>
    {
        变量 配置路径 <类型 = 文本型>
        配置路径 = 环境存取类.取运行目录 () + "\\ide_config.ini"
        常用功能类.写配置项 (配置路径, "表格编辑器", "单元格横向间距", 横向间距编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "单元格纵向间距", 纵向间距编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "单元格间距版本", "2")
        常用功能类.写配置项 (配置路径, "表格编辑器", "命名空间顶层间距", 顶层间距编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "命名空间成员行间距", 命名空间行距编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "类成员行间距", 类成员行距编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "方法成员行间距", 方法成员行距编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "类成员缩进宽度", 类成员缩进编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "字体", 字体编辑框.内容)
        常用功能类.写配置项 (配置路径, "表格编辑器", "字体大小", 到文本 (取字体大小 (字体编辑框.内容)))
        如果 (缓冲绘制框.现行选中项 == 0)
        {
            常用功能类.写配置项 (配置路径, "表格编辑器", "缓冲绘制表格", "真")
        }
        否则
        {
            常用功能类.写配置项 (配置路径, "表格编辑器", "缓冲绘制表格", "假")
        }
        常用功能类.写配置项 (配置路径, "表格编辑器", "语句块绘制线样式", 到文本 (流程线样式框.现行选中项))
    }

    方法 按钮_被单击 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 分类编译器)
        {
            切换设置分类 (0)
        }
        否则 (来源对象 == 分类表格尺寸)
        {
            切换设置分类 (1)
        }
        否则 (来源对象 == 分类外观绘制)
        {
            切换设置分类 (2)
        }
        否则 (来源对象 == 浏览编译器按钮)
        {
            变量 选中文件 <类型 = 文本型>
            选中文件 = 快速文件对话框.选择文件 (本对象, "选择编译器可执行文件", "可执行文件(*.exe)|*.exe|所有文件(*.*)|*.*", "exe", "", 假, 真, 假)
            如果 (选中文件 != "")
            {
                编译器路径编辑框.内容 = 选中文件
                刷新编译器类型 ()
            }
        }
        否则 (来源对象 == 浏览字体按钮)
        {
            字体对话框.类型 = 通用对话框类型.字体选择
            字体对话框.字体名称 = 取字体名称 (字体编辑框.内容)
            字体对话框.字体大小 = 取字体大小 (字体编辑框.内容)
            字体对话框.加粗 = 取字体逻辑属性 (字体编辑框.内容, 2)
            字体对话框.倾斜 = 取字体逻辑属性 (字体编辑框.内容, 3)
            字体对话框.下划线 = 取字体逻辑属性 (字体编辑框.内容, 4)
            字体对话框.删除线 = 取字体逻辑属性 (字体编辑框.内容, 5)
            如果 (字体对话框.打开 (本对象))
            {
                字体编辑框.内容 = 字体对话框.字体名称 + ", " + 到文本 (字体对话框.字体大小) + ", " + 取逻辑数值文本 (字体对话框.加粗) + ", " + 取逻辑数值文本 (字体对话框.倾斜) + ", " + 取逻辑数值文本 (字体对话框.下划线) + ", " + 取逻辑数值文本 (字体对话框.删除线)
            }
        }
        否则 (来源对象 == 确定按钮)
        {
            如果 (尺寸输入有效 () == 假)
            {
                信息框 ("表格尺寸输入无效，请检查数值范围。", 信息框按钮.确认钮, "设置")
                返回 (0)
            }
            结果编译器路径 = 编译器路径编辑框.内容
            刷新编译器类型 ()
            保存编辑器设置 ()
            关闭窗口 (1)
        }
        否则 (来源对象 == 取消按钮)
        {
            关闭窗口 (0)
        }
        返回 (0)
    }
}

类 创建模块对话框 <基础类 = 窗口 标题 = "创建模块" 位置 = 居中 @视窗.布局 = "client_size = \"520, 250\"">
{
    变量 名称标签 <类型 = 标签 @视窗.布局 = "id = 1501\r\npos = \"24, 28, 120, 24\"" 标题 = "模块名称:">
    变量 名称编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1502\r\npos = \"152, 24, 336, 28\"" 提示横幅 = "例如: 网络请求">
    变量 形态标签 <类型 = 标签 @视窗.布局 = "id = 1503\r\npos = \"24, 76, 120, 24\"" 标题 = "文件形态:">
    变量 形态选择框 <类型 = 组合框 @视窗.布局 = "id = 1504\r\npos = \"152, 72, 336, 28\"" "类型" = 不可编辑下拉式 列表项目 = "仅头文件(.h)\n头文件加源码(.h + .cpp)\n仅源码(.cpp)" 现行选中项 = 1>
    变量 路径说明 <类型 = 标签 @视窗.布局 = "id = 1505\r\npos = \"24, 120, 464, 44\"" 标题 = "模块将保存到 modules\\user，并生成模块.json、接口.json 和文档.md。">
    变量 确定按钮 <类型 = 按钮 @视窗.布局 = "id = 1506\r\npos = \"320, 194, 80, 32\"" 标题 = "确定">
    变量 取消按钮 <类型 = 按钮 @视窗.布局 = "id = 1507\r\npos = \"408, 194, 80, 32\"" 标题 = "取消">
    变量 结果模块名称 <公开 类型 = 文本型>
    变量 结果文件形态 <公开 类型 = 整数>

    方法 按钮_被单击 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 确定按钮)
        {
            如果 (名称编辑框.内容 == "")
            {
                信息框 ("请输入模块名称。", 信息框按钮.确认钮, "创建模块")
                返回 (0)
            }
            结果模块名称 = 名称编辑框.内容
            结果文件形态 = 形态选择框.现行选中项 + 1
            关闭窗口 (1)
        }
        否则 (来源对象 == 取消按钮)
        {
            关闭窗口 (0)
        }
        返回 (0)
    }
}

类 项目模块配置对话框 <基础类 = 窗口 标题 = "配置项目模块" 位置 = 居中 @视窗.布局 = "client_size = \"760, 520\"">
{
    变量 搜索标签 <类型 = 标签 @视窗.布局 = "id = 1521\r\npos = \"20, 20, 72, 24\"" 标题 = "搜索:">
    变量 搜索编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1522\r\npos = \"92, 16, 636, 28\"" 提示横幅 = "输入模块名称或标识">
    变量 模块列表框 <类型 = 选择列表框 @视窗.布局 = "id = 1523\r\npos = \"20, 60, 360, 388\"" 单选 = 假 行间距 = 4>
    变量 模块说明框 <类型 = 编辑框 @视窗.布局 = "id = 1524\r\npos = \"396, 60, 332, 388\"" 是否允许多行 = 真 输入方式 = 只读方式 滚动条 = 纵向滚动条>
    变量 确定按钮 <类型 = 按钮 @视窗.布局 = "id = 1525\r\npos = \"552, 468, 80, 32\"" 标题 = "确定">
    变量 取消按钮 <类型 = 按钮 @视窗.布局 = "id = 1526\r\npos = \"648, 468, 80, 32\"" 标题 = "取消">
    变量 全部模块标识组 <类型 = 文本数组类>
    变量 全部模块目录组 <类型 = 文本数组类>
    变量 核心模块组 <类型 = 文本数组类>
    变量 已选模块组 <类型 = 文本数组类>
    变量 可视模块标识组 <类型 = 文本数组类>
    变量 模块解析器 <类型 = 构建引擎>
    变量 正在刷新 <类型 = 逻辑型>
    变量 结果用户模块文本 <公开 类型 = 文本型>

    方法 文本组包含 <公开 类型 = 逻辑型>
    参数 文本组 <类型 = 文本数组类>
    参数 文本值 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        索引 = 0
        判断循环 (索引 < 文本组.取成员数 ())
        {
            如果 (到小写 (文本组.取成员 (索引)) == 到小写 (文本值))
            {
                返回 (真)
            }
            索引 = 索引 + 1
        }
        返回 (假)
    }

    方法 加入唯一模块 <公开>
    参数 文本组 <类型 = 文本数组类>
    参数 模块标识 <类型 = 文本型>
    {
        如果 (模块标识 != "" && 文本组包含 (文本组, 模块标识) == 假)
        {
            文本组.加入成员 (模块标识)
        }
    }

    方法 删除模块 <公开>
    参数 文本组 <类型 = 文本数组类>
    参数 模块标识 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        索引 = 0
        判断循环 (索引 < 文本组.取成员数 ())
        {
            如果 (到小写 (文本组.取成员 (索引)) == 到小写 (模块标识))
            {
                文本组.删除成员 (索引, 1)
                返回
            }
            索引 = 索引 + 1
        }
    }

    方法 初始化数据 <公开>
    参数 模块标识组 <类型 = 文本数组类>
    参数 模块目录组 <类型 = 文本数组类>
    参数 核心模块文本 <类型 = 文本型>
    参数 用户模块文本 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        变量 临时组 <类型 = 文本数组类>
        全部模块标识组.删除所有成员 ()
        全部模块目录组.删除所有成员 ()
        索引 = 0
        判断循环 (索引 < 模块标识组.取成员数 ())
        {
            全部模块标识组.加入成员 (模块标识组.取成员 (索引))
            如果 (索引 < 模块目录组.取成员数 ())
            {
                全部模块目录组.加入成员 (模块目录组.取成员 (索引))
            }
            否则
            {
                全部模块目录组.加入成员 ("")
            }
            索引 = 索引 + 1
        }
        核心模块组 = 模块解析器.拆分列表文本 (核心模块文本)
        已选模块组.删除所有成员 ()
        索引 = 0
        判断循环 (索引 < 核心模块组.取成员数 ())
        {
            加入唯一模块 (已选模块组, 核心模块组.取成员 (索引))
            如果 (文本组包含 (全部模块标识组, 核心模块组.取成员 (索引)) == 假)
            {
                全部模块标识组.加入成员 (核心模块组.取成员 (索引))
                全部模块目录组.加入成员 ("")
            }
            索引 = 索引 + 1
        }
        临时组 = 模块解析器.拆分列表文本 (用户模块文本)
        索引 = 0
        判断循环 (索引 < 临时组.取成员数 ())
        {
            加入唯一模块 (已选模块组, 临时组.取成员 (索引))
            如果 (文本组包含 (全部模块标识组, 临时组.取成员 (索引)) == 假)
            {
                全部模块标识组.加入成员 (临时组.取成员 (索引))
                全部模块目录组.加入成员 ("")
            }
            索引 = 索引 + 1
        }
    }

    方法 项目模块配置对话框_创建完毕 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 项目模块配置对话框>
    参数 标记值 <类型 = 整数>
    {
        刷新模块列表 ()
        返回 (0)
    }

    方法 保存当前可见选择 <公开>
    {
        如果 (正在刷新)
        {
            返回
        }
        变量 索引 <类型 = 整数>
        变量 模块标识 <类型 = 文本型>
        索引 = 0
        判断循环 (索引 < 可视模块标识组.取成员数 () && 索引 < 模块列表框.取项目数 ())
        {
            模块标识 = 可视模块标识组.取成员 (索引)
            如果 (文本组包含 (核心模块组, 模块标识) == 假)
            {
                如果 (模块列表框.是否被选中 (索引))
                {
                    加入唯一模块 (已选模块组, 模块标识)
                }
                否则
                {
                    删除模块 (已选模块组, 模块标识)
                }
            }
            索引 = 索引 + 1
        }
    }

    方法 刷新模块列表 <公开>
    {
        变量 索引 <类型 = 整数>
        变量 列表索引 <类型 = 整数>
        变量 模块标识 <类型 = 文本型>
        变量 搜索文本 <类型 = 文本型>
        正在刷新 = 真
        模块列表框.清空 ()
        可视模块标识组.删除所有成员 ()
        搜索文本 = 到小写 (搜索编辑框.内容)
        索引 = 0
        判断循环 (索引 < 全部模块标识组.取成员数 ())
        {
            模块标识 = 全部模块标识组.取成员 (索引)
            如果 (搜索文本 == "" || 文本类.寻找文本 (到小写 (模块标识), 搜索文本, 0, 真) >= 0)
            {
                模块列表框.加入项目 (模块标识)
                列表索引 = 可视模块标识组.加入成员 (模块标识)
                如果 (文本组包含 (已选模块组, 模块标识))
                {
                    模块列表框.选中项目 (列表索引, 真)
                }
                如果 (文本组包含 (核心模块组, 模块标识))
                {
                    模块列表框.允许 (列表索引, 假)
                }
            }
            索引 = 索引 + 1
        }
        模块说明框.内容 = "可用模块: " + 到文本 (全部模块标识组.取成员数 ()) + "\n已选模块: " + 到文本 (已选模块组.取成员数 ()) + "\n\n系统核心模块由项目模板管理，不能取消。"
        正在刷新 = 假
    }

    方法 编辑框_内容被改变 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 编辑框>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 搜索编辑框)
        {
            保存当前可见选择 ()
            刷新模块列表 ()
        }
        返回 (0)
    }

    方法 查找模块索引 <公开 类型 = 整数>
    参数 模块标识 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        索引 = 0
        判断循环 (索引 < 全部模块标识组.取成员数 ())
        {
            如果 (到小写 (全部模块标识组.取成员 (索引)) == 到小写 (模块标识))
            {
                返回 (索引)
            }
            索引 = 索引 + 1
        }
        返回 (-1)
    }

    方法 补全依赖模块 <公开>
    {
        变量 选中索引 <类型 = 整数>
        变量 模块索引 <类型 = 整数>
        变量 配置文本 <类型 = 文本型>
        变量 依赖组 <类型 = 文本数组类>
        变量 依赖索引 <类型 = 整数>
        选中索引 = 0
        判断循环 (选中索引 < 已选模块组.取成员数 ())
        {
            模块索引 = 查找模块索引 (已选模块组.取成员 (选中索引))
            如果 (模块索引 >= 0 && 模块索引 < 全部模块目录组.取成员数 () && 全部模块目录组.取成员 (模块索引) != "")
            {
                如果 (读入文本文件2 (配置文本, 全部模块目录组.取成员 (模块索引) + "\\模块.json", -1, 文本编码类型.UTF8))
                {
                    依赖组 = 模块解析器.取JSON字符串数组 (配置文本, "依赖模块")
                    依赖索引 = 0
                    判断循环 (依赖索引 < 依赖组.取成员数 ())
                    {
                        加入唯一模块 (已选模块组, 依赖组.取成员 (依赖索引))
                        依赖索引 = 依赖索引 + 1
                    }
                }
            }
            选中索引 = 选中索引 + 1
        }
    }

    方法 生成用户模块结果 <公开 类型 = 文本型>
    {
        变量 结果文本 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        变量 模块标识 <类型 = 文本型>
        索引 = 0
        判断循环 (索引 < 已选模块组.取成员数 ())
        {
            模块标识 = 已选模块组.取成员 (索引)
            如果 (文本组包含 (核心模块组, 模块标识) == 假)
            {
                如果 (结果文本 != "")
                {
                    结果文本 = 结果文本 + "|"
                }
                结果文本 = 结果文本 + 模块标识
            }
            索引 = 索引 + 1
        }
        返回 (结果文本)
    }

    方法 按钮_被单击 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 确定按钮)
        {
            保存当前可见选择 ()
            补全依赖模块 ()
            结果用户模块文本 = 生成用户模块结果 ()
            关闭窗口 (1)
        }
        否则 (来源对象 == 取消按钮)
        {
            关闭窗口 (0)
        }
        返回 (0)
    }
}

