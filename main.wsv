        变量 结果文本 <类型 = 文本型>
        原列表 = 主构建引擎.拆分列表文本 (项目用户模块组.取成员 (项目索引))
        索引 = 0
        判断循环 (索引 < 原列表.取成员数 ())
        {
            当前标识 = 原列表.取成员 (索引)
            如果 (到小写 (当前标识) == 到小写 (原模块标识))
            {
                当前标识 = 新模块标识
            }
            如果 (当前标识 != "" && 文本类.寻找文本 ("|" + 到小写 (结果文本) + "|", "|" + 到小写 (当前标识) + "|", 0, 真) < 0)
            {
                如果 (结果文本 != "")
                {
                    结果文本 = 结果文本 + "|"
                }
                结果文本 = 结果文本 + 当前标识
            }
            索引 = 索引 + 1
        }
        项目用户模块组.置成员值 (项目索引, 结果文本)
    }

    方法 替换模块文本 <公开 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    参数 查找文本 <类型 = 文本型>
    参数 替换文本 <类型 = 文本型>
    {
        如果 (查找文本 == "")
        {
            返回 (原文本)
        }
        变量 结果文本 <类型 = 文本型>
        变量 剩余文本 <类型 = 文本型>
        变量 查找位置 <类型 = 整数>
        剩余文本 = 原文本
        循环判断首 ()
        {
            查找位置 = 文本类.寻找文本 (剩余文本, 查找文本, 0, 真)
            如果 (查找位置 < 0)
            {
                结果文本 = 结果文本 + 剩余文本
                跳出循环
            }
            结果文本 = 结果文本 + 文本类.取文本左边 (剩余文本, 查找位置) + 替换文本
            剩余文本 = 文本类.取文本右边 (剩余文本, 文本类.取文本长度 (剩余文本) - 查找位置 - 文本类.取文本长度 (查找文本))
        }
        循环判断尾 (真)
        返回 (结果文本)
    }

