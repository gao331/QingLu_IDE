    方法 执行删除文件 <公开>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回
        }
        变量 节点值 <类型 = 整数>
        节点值 = 解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)
        变量 路径 <类型 = 文本型>
        路径 = 取节点路径 (节点值)
        变量 节点类型 <类型 = 文本型>
        节点类型 = 取节点类型 (节点值)
        变量 项目索引 <类型 = 整数>
        变量 模块标识 <类型 = 文本型>
        项目索引 = 取节点项目索引 (节点值)
        如果 (路径 == "" || 节点类型 == "solution")
        {
            返回
        }
        如果 (节点类型 == "module")
        {
            模块标识 = 取模块标识_按目录 (路径)
            如果 (文本类.取文本左边 (到小写 (模块标识), 4) == "sys.")
            {
                警告信息框 ("系统核心模块不能删除。", "删除模块")
                返回
            }
            如果 (模块目录属于项目 (项目索引, 路径) == 假)
            {
                如果 (信息框 ("确定从当前项目移除全局模块引用吗？\n" + 模块标识, 信息框按钮.是否钮, "移除模块引用") == 返回按钮类型.是钮)
                {
                    更新项目用户模块标识 (项目索引, 模块标识, "")
                    保存解决方案 ()
                    重建文件树 ()
                    置状态文本 ("已移除模块引用: " + 模块标识)
                }
                返回
            }
        }
        如果 (节点类型 == "window")
        {
            变量 设计文本 <类型 = 文本型>
            变量 设计文档 <类型 = 窗口设计文档>
            变量 关联代码路径 <类型 = 文本型>
            如果 (读入文本文件2 (设计文本, 路径, -1, 文本编码类型.UTF8) == 假 || 设计文档.载入设计文本 (设计文本) == 假)
            {
                警告信息框 ("窗口设计文件无法读取。", "删除窗口")
                返回
            }
            如果 (设计文档.是否启动窗口)
            {
                警告信息框 ("启动窗口不能直接删除，请先把另一个窗口设为启动窗口。", "删除窗口")
                返回
            }
            关联代码路径 = 取窗口设计关联代码路径 (项目索引, 路径)
            如果 (信息框 ("确定删除窗口设计及其关联代码吗？\n" + 路径 + "\n" + 关联代码路径, 信息框按钮.是否钮, "删除窗口") != 返回按钮类型.是钮)
            {
                返回
            }
            如果 (磁盘操作类.删除文件 (路径) == 假)
            {
                警告信息框 ("窗口设计文件删除失败。", "删除窗口")
                返回
            }
            如果 (关联代码路径 != "" && 磁盘操作类.取文件属性 (关联代码路径) != -1)
            {
                磁盘操作类.删除文件 (关联代码路径)
            }
            重建文件树 ()
            置状态文本 ("已删除窗口: " + 设计文档.窗口名称)
            返回
        }
        如果 (信息框 ("确定要删除文件/文件夹吗？\n" + 路径, 信息框按钮.是否钮, "确认删除") != 返回按钮类型.是钮)
        {
            返回
        }
        如果 (节点类型 == "project")
        {
            如果 (磁盘操作类.删除目录 (路径, 目录删除模式.全部删除))
            {
                解决方案项目文件组.删除成员 (项目索引, 1)
                项目名称组.删除成员 (项目索引, 1)
                项目目录组.删除成员 (项目索引, 1)
                项目文件组.删除成员 (项目索引, 1)
                项目类型组.删除成员 (项目索引, 1)
                项目主文件组.删除成员 (项目索引, 1)
                项目核心模块组.删除成员 (项目索引, 1)
                项目用户模块组.删除成员 (项目索引, 1)
                如果 (启动项目索引 == 项目索引)
                {
                    如果 (项目名称组.取成员数 () > 0)
                    {
                        启动项目索引 = 0
                    }
                    否则
                    {
                        启动项目索引 = -1
                    }
                }
                否则 (启动项目索引 > 项目索引)
                {
                    启动项目索引 = 启动项目索引 - 1
                }
                保存解决方案 ()
                重建文件树 ()
            }
            返回
        }
        如果 (位与 (磁盘操作类.取文件属性 (路径), 文件属性.子目录) != 0)
        {
            如果 (磁盘操作类.删除目录 (路径, 目录删除模式.全部删除))
            {
                如果 (节点类型 == "module")
                {
                    更新项目用户模块标识 (项目索引, 模块标识, "")
                    保存解决方案 ()
                }
                重建文件树 ()
            }
        }
        否则
        {
            如果 (磁盘操作类.删除文件 (路径))
            {
                重建文件树 ()
            }
        }
    }

