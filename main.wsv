    方法 生成默认项目属性文本 <公开 类型 = 文本型>
    参数 项目索引 <类型 = 整数>
    {
        变量 项目类型 <类型 = 文本型>
        变量 子系统 <类型 = 文本型>
        变量 配置类型 <类型 = 文本型>
        变量 换行文本 <类型 = 文本型>
        如果 (项目索引 < 0 || 项目索引 >= 项目类型组.取成员数 ())
        {
            返回 ("")
        }
        项目类型 = 项目类型组.取成员 (项目索引)
        配置类型 = "应用程序(.exe)"
        子系统 = "控制台 (/SUBSYSTEM:CONSOLE)"
        如果 (项目类型 == "window")
        {
            子系统 = "窗口 (/SUBSYSTEM:WINDOWS)"
        }
        如果 (项目类型 == "dll")
        {
            配置类型 = "动态库(.dll)"
            子系统 = "窗口 (/SUBSYSTEM:WINDOWS)"
        }
        换行文本 = "\n"
        变量 文本 <类型 = 文本型>
        文本 = "[常规]" + 换行文本
        文本 = 文本 + "C++语言标准=默认(ISO C++14标准)" + 换行文本
        文本 = 文本 + "C语言标准=默认(旧MSVC)" + 换行文本
        文本 = 文本 + "配置类型=" + 配置类型 + 换行文本
        文本 = 文本 + "字符集=使用 Unicode 字符集" + 换行文本
        文本 = 文本 + "MFC使用=使用标准Windows库" + 换行文本
        文本 = 文本 + 换行文本 + "[C++]" + 换行文本
        文本 = 文本 + "附加包含目录=" + 换行文本
        文本 = 文本 + "警告等级=默认" + 换行文本
        文本 = 文本 + "将警告视为错误=假" + 换行文本
        文本 = 文本 + 换行文本 + "[预处理器]" + 换行文本
        文本 = 文本 + "预处理器定义=" + 换行文本
        文本 = 文本 + 换行文本 + "[代码生成]" + 换行文本
        文本 = 文本 + "运行库=多线程调试 DLL (/MDd)" + 换行文本
        文本 = 文本 + 换行文本 + "[链接器]" + 换行文本
        文本 = 文本 + "附加库目录=" + 换行文本
        文本 = 文本 + "附加依赖项=" + 换行文本
        文本 = 文本 + "生成调试信息=生成调试信息 (/DEBUG)" + 换行文本
        文本 = 文本 + "子系统=" + 子系统 + 换行文本
        返回 (文本)
    }

