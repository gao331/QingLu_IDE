    方法 载入解决方案 <公开>
    参数 解决方案文件路径 <类型 = 文本型>
    {
        变量 解决方案文本 <类型 = 文本型>
        变量 读取成功 <类型 = 逻辑型>
        清空解决方案数据 ()
        解决方案路径 = 解决方案文件路径
        解决方案目录 = 磁盘操作类.取文件名路径 (解决方案文件路径)
        读取成功 = 读入文本文件2 (解决方案文本, 解决方案文件路径, -1, 文本编码类型.UTF8)
        如果 (读取成功)
        {
            解决方案名称 = 取解决方案配置值 (解决方案文本, "解决方案", "名称")
        }
        否则
        {
            解决方案名称 = ""
        }
        如果 (解决方案名称 == "")
        {
            解决方案名称 = 常用功能类.读配置项 (解决方案文件路径, "解决方案", "名称", "")
            如果 (解决方案名称 == "")
            {
                解决方案名称 = 磁盘操作类.取文件名无路径部分 (解决方案文件路径)
            }
        }
        如果 (读取成功)
        {
            启动项目索引 = 文本到整数 (选择 (取解决方案配置值 (解决方案文本, "解决方案", "启动项目索引") != "", 取解决方案配置值 (解决方案文本, "解决方案", "启动项目索引"), "-1"))
        }
        否则
        {
            启动项目索引 = -1
        }
        如果 (启动项目索引 < -1)
        {
            启动项目索引 = -1
        }
        如果 (读取成功 == 假 || 启动项目索引 == -1 && 常用功能类.读配置项 (解决方案文件路径, "解决方案", "启动项目索引", "") != "")
        {
            启动项目索引 = 文本到整数 (常用功能类.读配置项 (解决方案文件路径, "解决方案", "启动项目索引", 到文本 (启动项目索引)))
        }
        变量 项目数 <类型 = 整数>
        如果 (读取成功)
        {
            项目数 = 文本到整数 (选择 (取解决方案配置值 (解决方案文本, "解决方案", "项目数") != "", 取解决方案配置值 (解决方案文本, "解决方案", "项目数"), "0"))
        }
        否则
        {
            项目数 = 0
        }
        如果 (项目数 <= 0)
        {
            项目数 = 文本到整数 (常用功能类.读配置项 (解决方案文件路径, "解决方案", "项目数", "0"))
        }
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目数)
            {
                跳出循环
            }
            变量 相对项目文件 <类型 = 文本型>
            如果 (读取成功)
            {
                相对项目文件 = 取解决方案配置值 (解决方案文本, "项目列表", "项目" + 到文本 (索引))
            }
            否则
            {
                相对项目文件 = ""
            }
            如果 (相对项目文件 == "")
            {
                变量 临时项目键 <类型 = 文本型>
                临时项目键 = "项目" + 到文本 (索引)
                相对项目文件 = 常用功能类.读配置项 (解决方案文件路径, "项目列表", 临时项目键, "")
            }
            如果 (相对项目文件 != "")
            {
                变量 项目文件路径 <类型 = 文本型>
                项目文件路径 = 解决方案目录 + "\\" + 相对项目文件
                变量 项目目录 <类型 = 文本型>
                项目目录 = 取项目根目录_按项目文件 (项目文件路径)
                解决方案项目文件组.加入成员 (相对项目文件)
                项目文件组.加入成员 (项目文件路径)
                项目目录组.加入成员 (项目目录)
                变量 项目名称文本 <类型 = 文本型>
                变量 项目类型文本 <类型 = 文本型>
                如果 (读取成功)
                {
                    项目名称文本 = 取解决方案配置值 (解决方案文本, "项目列表", "项目名称" + 到文本 (索引))
                    项目类型文本 = 取解决方案配置值 (解决方案文本, "项目列表", "项目类型" + 到文本 (索引))
                }
                否则
                {
                    项目名称文本 = ""
                    项目类型文本 = ""
                }
                如果 (项目名称文本 == "")
                {
                    变量 临时名称键 <类型 = 文本型>
                    临时名称键 = "项目名称" + 到文本 (索引)
                    项目名称文本 = 常用功能类.读配置项 (解决方案文件路径, "项目列表", 临时名称键, "")
                }
                如果 (项目类型文本 == "")
                {
                    变量 临时类型键 <类型 = 文本型>
                    临时类型键 = "项目类型" + 到文本 (索引)
                    项目类型文本 = 常用功能类.读配置项 (解决方案文件路径, "项目列表", 临时类型键, "")
                }
                如果 (项目名称文本 == "")
                {
                    变量 临时项目名称 <类型 = 文本型>
                    临时项目名称 = "项目" + 到文本 (索引 + 1)
                    项目名称文本 = 常用功能类.读配置项 (项目文件路径, "项目", "名称", 临时项目名称)
                }
                如果 (项目类型文本 == "")
                {
                    项目类型文本 = 常用功能类.读配置项 (项目文件路径, "项目", "类型", "console")
                }
                项目名称组.加入成员 (项目名称文本)
                项目类型组.加入成员 (项目类型文本)
                变量 核心模块文本 <类型 = 文本型>
                变量 用户模块文本 <类型 = 文本型>
                如果 (读取成功)
                {
                    核心模块文本 = 取解决方案配置值 (解决方案文本, "项目列表", "核心模块" + 到文本 (索引))
                    用户模块文本 = 取解决方案配置值 (解决方案文本, "项目列表", "用户模块" + 到文本 (索引))
                }
                否则
                {
                    核心模块文本 = ""
                    用户模块文本 = ""
                }
                如果 (核心模块文本 == "")
                {
                    变量 临时核心键 <类型 = 文本型>
                    临时核心键 = "核心模块" + 到文本 (索引)
                    变量 默认核心 <类型 = 文本型>
                    默认核心 = 取默认核心模块列表文本 (项目类型文本)
                    核心模块文本 = 常用功能类.读配置项 (解决方案文件路径, "项目列表", 临时核心键, 默认核心)
                }
                如果 (用户模块文本 == "")
                {
                    变量 临时用户键 <类型 = 文本型>
                    临时用户键 = "用户模块" + 到文本 (索引)
                    用户模块文本 = 常用功能类.读配置项 (解决方案文件路径, "项目列表", 临时用户键, "")
                }
                项目核心模块组.加入成员 (规范模块列表文本 (核心模块文本))
                项目用户模块组.加入成员 (规范模块列表文本 (用户模块文本))
                变量 旧主文件相对路径 <类型 = 文本型>
                旧主文件相对路径 = 常用功能类.读配置项 (项目文件路径, "项目", "主文件", "")
                如果 (旧主文件相对路径 != "")
                {
                    项目主文件组.加入成员 (项目目录 + "\\" + 旧主文件相对路径)
                }
                否则
                {
                    项目主文件组.加入成员 (项目文件路径)
                }
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目数)
        重建文件树 ()
        更新状态栏 ()
        如果 (项目文件组.取成员数 () > 0)
        {
            如果 (启动项目索引 >= 0 && 启动项目索引 < 项目文件组.取成员数 ())
            {
                如果 (项目类型组.取成员 (启动项目索引) == "window")
                {
                    确保项目窗口设计文件 (启动项目索引)
                    打开指定文件 (取窗口设计目录 (启动项目索引) + "\\主程序窗口.wui")
                }
                否则
                {
                    打开指定文件 (项目文件组.取成员 (启动项目索引))
                }
            }
            否则
            {
                如果 (项目类型组.取成员 (0) == "window")
                {
                    确保项目窗口设计文件 (0)
                    打开指定文件 (取窗口设计目录 (0) + "\\主程序窗口.wui")
                }
                否则
                {
                    打开指定文件 (项目文件组.取成员 (0))
                }
            }
        }
    }

    方法 新建项目 <公开>
    {
        变量 新建对话框 <类型 = 新建项目对话框>
        变量 项目名称 <类型 = 文本型>
        变量 模板类型 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        变量 方案根目录 <类型 = 文本型>
        变量 对话框结果 <类型 = 整数>

        新建对话框 = 新建对象 (新建项目对话框)
        如果 (解决方案路径 == "")
        {
            新建对话框.初始化数据 (假, "MySolution", "", "MyProject")
        }
        否则
        {
            方案根目录 = 磁盘操作类.取文件名路径 (解决方案目录)
            新建对话框.初始化数据 (真, 解决方案名称, 方案根目录, "MyProject")
        }
        对话框结果 = 新建对话框.创建对话框 ()
        如果 (对话框结果 != 1)
        {
            返回
        }
        项目名称 = 新建对话框.结果项目名称
        模板类型 = 新建对话框.结果项目类型

        如果 (解决方案路径 == "")
        {
            变量 新解决方案名称 <类型 = 文本型>
            新解决方案名称 = 新建对话框.结果解决方案名称
            方案根目录 = 新建对话框.结果方案根目录
            清空解决方案数据 ()
            解决方案名称 = 新解决方案名称
            解决方案目录 = 方案根目录 + "\\" + 解决方案名称
            如果 (磁盘操作类.取文件属性 (解决方案目录) != -1)
            {
                警告信息框 ("解决方案目录已存在，请重新选择名称或目录。", "新建解决方案")
                返回
            }
            磁盘操作类.创建目录 (解决方案目录)
            解决方案路径 = 解决方案目录 + "\\" + 解决方案名称 + ".hsln"
        }
        如果 (项目名称 == "")
        {
            返回
        }
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目名称组.取成员数 ())
            {
                跳出循环
            }
            如果 (项目名称组.取成员 (索引) == 项目名称)
            {
                警告信息框 ("已存在同名项目。", "新建项目")
                返回
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目名称组.取成员数 ())

        变量 项目目录 <类型 = 文本型>
        项目目录 = 解决方案目录 + "\\" + 项目名称
        如果 (磁盘操作类.取文件属性 (项目目录) != -1)
        {
            警告信息框 ("项目目录已存在，请更换项目名称。", "新建项目")
            返回
        }
        磁盘操作类.创建目录 (项目目录)
        变量 项目文件路径 <类型 = 文本型>
        磁盘操作类.创建目录 (项目目录 + "\\代码")
        磁盘操作类.创建目录 (项目目录 + "\\modules")
        项目文件路径 = 项目目录 + "\\代码\\" + 取默认项目文件名 (模板类型)
        写出文本文件 (生成项目模板源码 (项目名称, 模板类型), 项目文件路径, -1, 文本编码类型.UTF8)
        如果 (模板类型 == "window")
        {
            磁盘操作类.创建目录 (项目目录 + "\\窗口")
            写出文本文件 (生成窗口设计文件文本 ("主程序窗口", "主窗口类", "代码\\" + 取默认项目文件名 (模板类型), 真), 项目目录 + "\\窗口\\主程序窗口.wui", -1, 文本编码类型.UTF8)
        }

        项目名称组.加入成员 (项目名称)
        项目目录组.加入成员 (项目目录)
        项目文件组.加入成员 (项目文件路径)
        项目类型组.加入成员 (模板类型)
        项目主文件组.加入成员 (项目文件路径)
        项目核心模块组.加入成员 (取默认核心模块列表文本 (模板类型))
        项目用户模块组.加入成员 ("")
        解决方案项目文件组.加入成员 (取相对项目文件路径 (项目名称, 模板类型))

        索引 = 项目名称组.取成员数 () - 1
        写出文本文件 (生成默认项目属性文本 (索引), 取项目属性文件路径 (索引), -1, 文本编码类型.UTF8)
        保存项目文件 (索引)
        如果 (启动项目索引 < 0)
        {
            启动项目索引 = 0
        }
        保存解决方案 ()
        重建文件树 ()
        如果 (模板类型 == "window")
        {
            打开指定文件 (项目目录 + "\\窗口\\主程序窗口.wui")
        }
        否则
        {
            打开指定文件 (项目文件路径)
        }
        置状态文本 ("已创建项目: " + 项目名称)
        刷新工具条状态 ()
    }

