    方法 文件基础名是否合法 <公开 类型 = 逻辑型>
    参数 文件基础名 <类型 = 文本型>
    {
        如果 (文件基础名 == "")
        {
            返回 (假)
        }
        如果 (文本类.寻找文本 (文件基础名, "\\", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, "/", 0, 真) >= 0)
        {
            返回 (假)
        }
        如果 (文本类.寻找文本 (文件基础名, ":", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, "*", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, "?", 0, 真) >= 0)
        {
            返回 (假)
        }
        如果 (文本类.寻找文本 (文件基础名, "\"", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, "<", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, ">", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, "|", 0, 真) >= 0)
        {
            返回 (假)
        }
        如果 (文本类.寻找文本 (文件基础名, " ", 0, 真) >= 0 || 文本类.寻找文本 (文件基础名, ".", 0, 真) >= 0)
        {
            返回 (假)
        }
        返回 (真)
    }

