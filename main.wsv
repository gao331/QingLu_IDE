    方法 收集模块根目录下模块 <公开>
    参数 模块根目录 <类型 = 文本型>
    参数 模块目录组 <类型 = 文本数组类>
    {
        变量 查找器 <类型 = 文件查找类>
        变量 子查找器 <类型 = 文件查找类>
        变量 目录名 <类型 = 文本型>
        变量 子目录名 <类型 = 文本型>
        变量 当前目录 <类型 = 文本型>
        目录名 = 查找器.寻找文件 (模块根目录 + "\\*", 文件属性.子目录)
        循环判断首 ()
        {
            如果 (目录名 == "")
            {
                跳出循环
            }
            如果 (目录名 != "." && 目录名 != "..")
            {
                当前目录 = 模块根目录 + "\\" + 目录名
                如果 (磁盘操作类.取文件属性 (当前目录 + "\\模块.json") != -1)
                {
                    附加唯一文本 (模块目录组, 当前目录)
                }
                否则
                {
                    子目录名 = 子查找器.寻找文件 (当前目录 + "\\*", 文件属性.子目录)
                    判断循环 (子目录名 != "")
                    {
                        如果 (子目录名 != "." && 子目录名 != ".." && 磁盘操作类.取文件属性 (当前目录 + "\\" + 子目录名 + "\\模块.json") != -1)
                        {
                            附加唯一文本 (模块目录组, 当前目录 + "\\" + 子目录名)
                        }
                        子目录名 = 子查找器.寻找文件 ("", 文件属性.子目录)
                    }
                    子查找器.停止寻找文件 ()
                }
            }
            目录名 = 查找器.寻找文件 ("", 文件属性.子目录)
        }
        循环判断尾 (目录名 != "")
        查找器.停止寻找文件 ()
    }

