    方法 文本数组包含 <公开 类型 = 逻辑型>
    参数 文本组 <类型 = 文本数组类>
    参数 欲查文本 <类型 = 文本型>
    {
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 文本组.取成员数 ())
            {
                跳出循环
            }
            如果 (文本组.取成员 (索引) == 欲查文本)
            {
                返回 (真)
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 文本组.取成员数 ())
        返回 (假)
    }

