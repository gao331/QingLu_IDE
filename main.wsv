        选中文件 = 快速文件对话框.选择文件 (本对象, "选择编译器可执行文件", "可执行文件(*.exe)|*.exe|所有文件(*.*)|*.*", "exe", 取对话框初始目录 (), 假, 真, 假)
        如果 (选中文件 != "")
        {
            主构建引擎.成员_编译器路径 = 选中文件
            变量 选中路径 <类型 = 文本型>
            选中路径 = 选中文件
            如果 (文本类.寻找文本 (选中路径, "cl.exe", 0, 真) >= 0)
            {
                主构建引擎.成员_编译器类型 = "msvc"
            }
            否则 (文本类.寻找文本 (选中路径, "g++", 0, 真) >= 0 || 文本类.寻找文本 (选中路径, "gcc", 0, 真) >= 0)
            {
                主构建引擎.成员_编译器类型 = "gcc"
            }
            否则 (文本类.寻找文本 (选中路径, "clang++", 0, 真) >= 0 || 文本类.寻找文本 (选中路径, "clang", 0, 真) >= 0)
            {
                主构建引擎.成员_编译器类型 = "gcc"
            }
            主构建引擎.保存配置 ()
            置状态文本 ("编译器已设置: " + 主构建引擎.取编译器信息 ())
        }
    }

    方法 选择输出目录 <公开>
    {
        变量 选中目录 <类型 = 文本型>
        选中目录 = 快速文件对话框.选择目录 (本对象, "选择输出目录", 取对话框初始目录 ())
        如果 (选中目录 != "")
        {
            主构建引擎.成员_输出目录 = 选中目录
            置状态文本 ("输出目录: " + 选中目录)
        }
    }

    方法 取当前树节点项目索引 <公开 类型 = 整数>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回 (-1)
        }
        返回 (取节点项目索引 (解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)))
    }

    方法 执行新建窗口文件 <公开>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回
        }
        变量 节点值 <类型 = 整数>
        变量 节点类型 <类型 = 文本型>
        变量 项目索引 <类型 = 整数>
        节点值 = 解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)
        节点类型 = 取节点类型 (节点值)
        项目索引 = 取节点项目索引 (节点值)
        如果 (节点类型 != "code_folder")
        {
            信息框 ("请在“代码”节点上新建窗口。", 信息框按钮.确认钮, "新建窗口")
            返回
        }
        如果 (项目索引 < 0 || 项目索引 >= 项目名称组.取成员数 ())
        {
            返回
        }
        如果 (项目类型组.取成员 (项目索引) != "window")
        {
            信息框 ("当前项目模板不是窗口程序，暂不创建窗口。", 信息框按钮.确认钮, "新建窗口")
            返回
        }
        变量 窗口名称 <类型 = 文本型>
        窗口名称 = 取默认新窗口名称 (项目索引)
        如果 (输入框 (窗口名称, "请输入窗口名称", "新建窗口", 窗口名称) == 假)
        {
            返回
        }
        窗口名称 = 取源文件基础名 (窗口名称)
        如果 (文件基础名是否合法 (窗口名称) == 假)
        {
            警告信息框 ("窗口名称不能为空，且不能包含空格、点号或文件名非法字符。", "新建窗口")
            返回
        }
        变量 文件路径 <类型 = 文本型>
        变量 设计文件路径 <类型 = 文本型>
        文件路径 = 项目目录组.取成员 (项目索引) + "\\代码\\" + 窗口名称 + ".n"
        设计文件路径 = 取窗口设计目录 (项目索引) + "\\" + 窗口名称 + ".wui"
        如果 (磁盘操作类.取文件属性 (文件路径) != -1 || 磁盘操作类.取文件属性 (设计文件路径) != -1)
        {
            警告信息框 ("已存在同名窗口文件。", "新建窗口")
            返回
        }
        如果 (写出文本文件 (生成窗口文件源码 (窗口名称), 文件路径, -1, 文本编码类型.UTF8) == 假)
        {
            警告信息框 ("窗口文件创建失败。", "新建窗口")
            返回
        }
        磁盘操作类.创建目录 (取窗口设计目录 (项目索引))
        如果 (写出文本文件 (生成窗口设计文件文本 (窗口名称, 窗口名称 + "类", "代码\\" + 窗口名称 + ".n", 假), 设计文件路径, -1, 文本编码类型.UTF8) == 假)
        {
            磁盘操作类.删除文件 (文件路径)
            警告信息框 ("窗口设计文件创建失败。", "新建窗口")
            返回
        }
        重建文件树 ()
        打开指定文件 (设计文件路径)
        置状态文本 ("已创建窗口: " + 窗口名称)
    }

    方法 执行重命名节点 <公开>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回
        }
        变量 节点值 <类型 = 整数>
        变量 节点类型 <类型 = 文本型>
        变量 路径 <类型 = 文本型>
        变量 项目索引 <类型 = 整数>
        节点值 = 解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)
        节点类型 = 取节点类型 (节点值)
        路径 = 取节点路径 (节点值)
        项目索引 = 取节点项目索引 (节点值)
        如果 (路径 == "" || 项目索引 < 0)
        {
            返回
        }
        如果 (节点类型 == "window")
        {
            变量 新窗口名称 <类型 = 文本型>
            变量 新设计路径 <类型 = 文本型>
            变量 原代码路径 <类型 = 文本型>
            变量 新代码路径 <类型 = 文本型>
            变量 设计文本 <类型 = 文本型>
            变量 设计文档 <类型 = 窗口设计文档>
            变量 原窗口名称 <类型 = 文本型>
            变量 原窗口类名 <类型 = 文本型>
            变量 新窗口类名 <类型 = 文本型>
            变量 代码文件文本 <类型 = 文本型>
            新窗口名称 = 取窗口设计标题 (路径)
            如果 (输入框 (新窗口名称, "请输入新的窗口名称", "重命名窗口", 新窗口名称) == 假)
            {
                返回
            }
            新窗口名称 = 取源文件基础名 (新窗口名称)
            如果 (文件基础名是否合法 (新窗口名称) == 假)
            {
                警告信息框 ("窗口名称不能为空，且不能包含空格、点号或文件名非法字符。", "重命名窗口")
                返回
            }
            新设计路径 = 磁盘操作类.取文件名路径 (路径) + "\\" + 新窗口名称 + ".wui"
            原代码路径 = 取窗口设计关联代码路径 (项目索引, 路径)
            新代码路径 = 项目目录组.取成员 (项目索引) + "\\代码\\" + 新窗口名称 + ".n"
            如果 (新设计路径 == 路径)
            {
                返回
            }
            如果 (磁盘操作类.取文件属性 (新设计路径) != -1 || 原代码路径 != "" && 原代码路径 != 新代码路径 && 磁盘操作类.取文件属性 (新代码路径) != -1)
            {
                警告信息框 ("目标窗口或代码文件已存在。", "重命名窗口")
                返回
            }
            如果 (读入文本文件2 (设计文本, 路径, -1, 文本编码类型.UTF8) == 假 || 设计文档.载入设计文本 (设计文本) == 假)
            {
                警告信息框 ("窗口设计文件无法读取。", "重命名窗口")
                返回
            }
            原窗口名称 = 设计文档.窗口名称
            原窗口类名 = 设计文档.窗口类名
            新窗口类名 = 新窗口名称 + "类"
            如果 (原代码路径 != "" && 磁盘操作类.取文件属性 (原代码路径) != -1 && 读入文本文件2 (代码文件文本, 原代码路径, -1, 文本编码类型.UTF8) == 假)
            {
                警告信息框 ("关联代码文件无法读取。", "重命名窗口")
                返回
            }
            如果 (原代码路径 != "" && 原代码路径 != 新代码路径 && 磁盘操作类.取文件属性 (原代码路径) != -1)
            {
                如果 (磁盘操作类.文件更名 (原代码路径, 新代码路径) == 假)
                {
                    警告信息框 ("关联代码文件重命名失败。", "重命名窗口")
                    返回
                }
            }
            如果 (磁盘操作类.文件更名 (路径, 新设计路径) == 假)
            {
                如果 (原代码路径 != "" && 原代码路径 != 新代码路径 && 磁盘操作类.取文件属性 (新代码路径) != -1)
                {
                    磁盘操作类.文件更名 (新代码路径, 原代码路径)
                }
                警告信息框 ("窗口设计文件重命名失败。", "重命名窗口")
                返回
            }
            设计文档.窗口名称 = 新窗口名称
            设计文档.窗口类名 = 新窗口类名
            如果 (设计文档.窗口标题 == 原窗口名称)
            {
                设计文档.窗口标题 = 新窗口名称
            }
            如果 (设计文档.创建完毕事件 == 原窗口类名 + "_创建完毕")
            {
                设计文档.创建完毕事件 = 新窗口类名 + "_创建完毕"
            }
            如果 (设计文档.尺寸改变事件 == 原窗口类名 + "_尺寸被改变")
            {
                设计文档.尺寸改变事件 = 新窗口类名 + "_尺寸被改变"
            }
            如果 (设计文档.关闭事件 == 原窗口类名 + "_将被关闭")
            {
                设计文档.关闭事件 = 新窗口类名 + "_将被关闭"
            }
            设计文档.关联代码文件 = "代码\\" + 新窗口名称 + ".n"
            如果 (写出文本文件 (设计文档.取设计文本 (), 新设计路径, -1, 文本编码类型.UTF8) == 假)
            {
                警告信息框 ("窗口设计文件内容更新失败。", "重命名窗口")
                返回
            }
            如果 (代码文件文本 != "" && 原窗口类名 != "")
            {
                代码文件文本 = 替换模块文本 (代码文件文本, "标题 = \"" + 原窗口名称 + "\"", "标题 = \"" + 新窗口名称 + "\"")
                代码文件文本 = 替换模块文本 (代码文件文本, 原窗口类名, 新窗口类名)
                如果 (写出文本文件 (代码文件文本, 新代码路径, -1, 文本编码类型.UTF8) == 假)
                {
                    警告信息框 ("关联代码中的类名更新失败。", "重命名窗口")
                    返回
                }
            }
            同步项目入口文件路径 (项目索引, 原代码路径, 新代码路径)
            保存解决方案 ()
            重建文件树 ()
            置状态文本 ("已重命名窗口: " + 新窗口名称)
            返回
        }
        如果 (节点类型 == "file")
        {
            变量 新名称 <类型 = 文本型>
            变量 新路径 <类型 = 文本型>
            新名称 = 取源文件标题 (路径)
            如果 (输入框 (新名称, "请输入新的源文件名称", "重命名", 新名称) == 假)
            {
                返回
            }
            新名称 = 取源文件基础名 (新名称)
            如果 (文件基础名是否合法 (新名称) == 假)
            {
                警告信息框 ("名称不能为空，且不能包含空格、点号或文件名非法字符。", "重命名")
                返回
            }
            新路径 = 磁盘操作类.取文件名路径 (路径) + "\\" + 新名称 + ".n"
            如果 (新路径 == 路径)
            {
                返回
            }
            如果 (磁盘操作类.取文件属性 (新路径) != -1)
            {
                警告信息框 ("目标文件已存在。", "重命名")
                返回
            }
            如果 (磁盘操作类.文件更名 (路径, 新路径) == 假)
            {
                警告信息框 ("重命名失败。", "重命名")
                返回
            }
            同步项目入口文件路径 (项目索引, 路径, 新路径)
            保存解决方案 ()
            重建文件树 ()
            置状态文本 ("已重命名: " + 新名称)
            返回
        }
        如果 (节点类型 == "module")
        {
            变量 新模块名称 <类型 = 文本型>
            变量 新模块路径 <类型 = 文本型>
            变量 原模块名称 <类型 = 文本型>
            变量 原模块标识 <类型 = 文本型>
            变量 新模块标识 <类型 = 文本型>
            原模块名称 = 取文件名无路径部分 (路径)
            原模块标识 = 取模块标识_按目录 (路径)
            如果 (模块目录属于项目 (项目索引, 路径) == 假)
            {
                警告信息框 ("全局模块不能在项目中重命名，请在全局模块目录中维护它。", "重命名模块")
                返回
            }
            如果 (文本类.取文本左边 (到小写 (原模块标识), 4) == "sys.")
            {
                警告信息框 ("系统核心模块不能重命名。", "重命名模块")
                返回
            }
            新模块名称 = 原模块名称
            如果 (输入框 (新模块名称, "请输入新的模块名称", "重命名模块", 新模块名称) == 假)
            {
                返回
            }
            新模块名称 = 取源文件基础名 (新模块名称)
            如果 (文件基础名是否合法 (新模块名称) == 假)
            {
                警告信息框 ("模块名称不能为空，且不能包含空格、点号或文件名非法字符。", "重命名模块")
                返回
            }
            新模块路径 = 磁盘操作类.取文件名路径 (路径) + "\\" + 新模块名称
            如果 (新模块路径 == 路径)
            {
                返回
            }
            如果 (磁盘操作类.取文件属性 (新模块路径) != -1)
            {
                警告信息框 ("目标模块已存在。", "重命名模块")
                返回
            }
            如果 (磁盘操作类.文件更名 (路径, 新模块路径) == 假)
            {
                警告信息框 ("模块目录重命名失败。", "重命名模块")
                返回
            }
            新模块标识 = 生成重命名模块标识 (原模块标识, 新模块名称)
            更新模块身份文件 (新模块路径, 原模块名称, 新模块名称, 原模块标识, 新模块标识)
            更新项目用户模块标识 (项目索引, 原模块标识, 新模块标识)
            保存解决方案 ()
            重建文件树 ()
            置状态文本 ("已重命名模块: " + 原模块标识 + " -> " + 新模块标识)
            返回
        }
        如果 (节点类型 == "project")
        {
            变量 新项目名称 <类型 = 文本型>
            变量 新项目目录 <类型 = 文本型>
            变量 旧项目目录 <类型 = 文本型>
            新项目名称 = 项目名称组.取成员 (项目索引)
            如果 (输入框 (新项目名称, "请输入新的项目名称", "重命名项目", 新项目名称) == 假)
            {
                返回
            }
            新项目名称 = 取源文件基础名 (新项目名称)
            如果 (文件基础名是否合法 (新项目名称) == 假)
            {
                警告信息框 ("项目名称不能为空，且不能包含空格、点号或文件名非法字符。", "重命名项目")
                返回
            }
            旧项目目录 = 路径
            新项目目录 = 解决方案目录 + "\\" + 新项目名称
            如果 (新项目目录 == 旧项目目录)
            {
                返回
            }
            如果 (磁盘操作类.取文件属性 (新项目目录) != -1)
            {
                警告信息框 ("目标项目目录已存在。", "重命名项目")
                返回
            }
            如果 (磁盘操作类.文件更名 (旧项目目录, 新项目目录) == 假)
            {
                警告信息框 ("项目目录重命名失败。", "重命名项目")
                返回
            }
            项目名称组.置成员值 (项目索引, 新项目名称)
            项目目录组.置成员值 (项目索引, 新项目目录)
            项目文件组.置成员值 (项目索引, 新项目目录 + "\\代码\\" + 取文件名无路径部分 (项目文件组.取成员 (项目索引)))
            项目主文件组.置成员值 (项目索引, 新项目目录 + "\\代码\\" + 取文件名无路径部分 (项目主文件组.取成员 (项目索引)))
            解决方案项目文件组.置成员值 (项目索引, 取项目文件相对路径 (项目文件组.取成员 (项目索引)))
            保存解决方案 ()
            重建文件树 ()
            置状态文本 ("已重命名项目: " + 新项目名称)
            返回
        }
        信息框 ("该节点暂不支持重命名。", 信息框按钮.确认钮, "重命名")
    }

    方法 取当前树节点类型 <公开 类型 = 文本型>
    {
        如果 (解决方案窗口.文件树.现行选中项 == -1)
        {
            返回 ("")
        }
        变量 节点值 <类型 = 整数>
        节点值 = 解决方案窗口.文件树.取项目数值 (解决方案窗口.文件树.现行选中项)
        返回 (取节点类型 (节点值))
