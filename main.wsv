    方法 IDE编辑视图_请求打开关联代码文件 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = IDE编辑视图>
    参数 标记值 <类型 = 整数>
    参数 设计文件路径 <类型 = 文本型>
    参数 关联代码路径 <类型 = 文本型>
    {
        变量 完整代码路径 <类型 = 文本型>
        变量 所属项目索引 <类型 = 整数>
        变量 设计目录 <类型 = 文本型>
        如果 (关联代码路径 == "")
        {
            警告信息框 ("当前窗口没有配置关联代码文件。", "窗口设计器")
            返回 (0)
        }
        如果 (文本类.寻找文本 (关联代码路径, ":\\", 0, 真) >= 0)
        {
            完整代码路径 = 关联代码路径
        }
        否则
        {
            所属项目索引 = 取项目索引_按文件路径 (设计文件路径)
            如果 (所属项目索引 >= 0 && 所属项目索引 < 项目目录组.取成员数 ())
            {
                完整代码路径 = 项目目录组.取成员 (所属项目索引) + "\\" + 关联代码路径
            }
            否则
            {
                设计目录 = 磁盘操作类.取文件名路径 (设计文件路径)
                完整代码路径 = 磁盘操作类.取文件名路径 (设计目录) + "\\" + 关联代码路径
            }
        }
        如果 (磁盘操作类.取文件属性 (完整代码路径) == -1)
        {
            警告信息框 ("关联代码文件不存在：\n" + 完整代码路径, "窗口设计器")
            返回 (0)
        }
        打开指定文件 (完整代码路径)
        返回 (0)
    }

    方法 寻找最后子文本 <公开 类型 = 整数>
    参数 原文本 <类型 = 文本型>
    参数 欲找文本 <类型 = 文本型>
    参数 截止位置 <类型 = 整数>
    {
        变量 索引 <类型 = 整数>
        变量 最后位置 <类型 = 整数>
        变量 原长度 <类型 = 整数>
        变量 查找长度 <类型 = 整数>
        原长度 = 文本类.取文本长度 (原文本)
        查找长度 = 文本类.取文本长度 (欲找文本)
        如果 (查找长度 <= 0)
        {
            返回 (-1)
        }
        如果 (截止位置 < 0 || 截止位置 > 原长度)
        {
            截止位置 = 原长度
        }
        最后位置 = -1
        索引 = 0
        判断循环 (索引 + 查找长度 <= 截止位置)
        {
            如果 (文本类.取文本中间 (原文本, 索引, 查找长度) == 欲找文本)
            {
                最后位置 = 索引
            }
            索引 = 索引 + 1
        }
        返回 (最后位置)
    }

    方法 文本是否正整数 <公开 类型 = 逻辑型>
    参数 原文本 <类型 = 文本型>
    {
        变量 文本 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        变量 数字字符 <类型 = 文本型>
        文本 = 取裁剪文本 (原文本)
        如果 (文本 == "")
        {
            返回 (假)
        }
        索引 = 0
        判断循环 (索引 < 文本类.取文本长度 (文本))
        {
            数字字符 = 文本类.取文本中间 (文本, 索引, 1)
            如果 (文本类.寻找文本 ("0123456789", 数字字符, 0, 真) < 0)
            {
                返回 (假)
            }
            索引 = 索引 + 1
        }
        返回 (文本到整数 (文本) > 0)
    }

    方法 规范诊断文件路径 <公开 类型 = 文本型>
    参数 原路径 <类型 = 文本型>
    {
        变量 路径 <类型 = 文本型>
        变量 项目索引 <类型 = 整数>
        变量 候选路径 <类型 = 文本型>
        路径 = 取裁剪文本 (原路径)
        路径 = 替换模块文本 (路径, "\"", "")
        路径 = 替换模块文本 (路径, "/", "\\")
        如果 (文本类.取文本左边 (路径, 2) == ".\\")
        {
            路径 = 文本类.取文本右边 (路径, 文本类.取文本长度 (路径) - 2)
        }
        如果 (磁盘操作类.取文件属性 (路径) != -1)
        {
            返回 (路径)
        }
        项目索引 = 取当前项目索引 ()
        如果 (项目索引 >= 0 && 项目索引 < 项目目录组.取成员数 () && 文本类.寻找文本 (路径, ":\\", 0, 真) < 0)
        {
            候选路径 = 项目目录组.取成员 (项目索引) + "\\" + 路径
            如果 (磁盘操作类.取文件属性 (候选路径) != -1)
            {
                返回 (候选路径)
            }
        }
        返回 (路径)
    }

    方法 解析编译诊断行 <公开 类型 = 逻辑型>
    参数 行文本 <类型 = 文本型>
    参数 诊断 <类型 = 编译诊断信息>
    {
        变量 文本 <类型 = 文本型>
        变量 左括位置 <类型 = 整数>
        变量 右括位置 <类型 = 整数>
        变量 逗号位置 <类型 = 整数>
        变量 位置1 <类型 = 整数>
        变量 位置2 <类型 = 整数>
        变量 严重位置 <类型 = 整数>
        变量 严重标记 <类型 = 文本型>
        变量 位置文本 <类型 = 文本型>
        变量 行号文本 <类型 = 文本型>
        变量 列号文本 <类型 = 文本型>
        变量 前缀文本 <类型 = 文本型>
        变量 前段文本 <类型 = 文本型>
        诊断.清空 ()
        文本 = 取裁剪文本 (行文本)
        文本 = 替换模块文本 (文本, "\r", "")
        文本 = 替换模块文本 (文本, "\n", "")
        诊断.原始文本 = 文本
        如果 (文本类.取文本左边 (文本, 5) == "[错误] ")
        {
            文本 = 文本类.取文本右边 (文本, 文本类.取文本长度 (文本) - 5)
        }

        右括位置 = 寻找最后子文本 (文本, "):", -1)
        如果 (右括位置 > 0)
        {
            左括位置 = 寻找最后子文本 (文本, "(", 右括位置)
            如果 (左括位置 > 0)
            {
                位置文本 = 文本类.取文本中间 (文本, 左括位置 + 1, 右括位置 - 左括位置 - 1)
                逗号位置 = 文本类.寻找文本 (位置文本, ",", 0, 真)
                如果 (逗号位置 >= 0)
                {
                    行号文本 = 取裁剪文本 (文本类.取文本左边 (位置文本, 逗号位置))
                    列号文本 = 取裁剪文本 (文本类.取文本右边 (位置文本, 文本类.取文本长度 (位置文本) - 逗号位置 - 1))
                }
                否则
                {
                    行号文本 = 取裁剪文本 (位置文本)
                    列号文本 = ""
                }
                如果 (文本是否正整数 (行号文本))
                {
                    诊断.文件路径 = 规范诊断文件路径 (文本类.取文本左边 (文本, 左括位置))
                    诊断.行号 = 文本到整数 (行号文本)
                    如果 (文本是否正整数 (列号文本))
                    {
                        诊断.列号 = 文本到整数 (列号文本)
                    }
                    诊断.消息 = 取裁剪文本 (文本类.取文本右边 (文本, 文本类.取文本长度 (文本) - 右括位置 - 2))
                    如果 (文本类.寻找文本 (到小写 (诊断.消息), "warning", 0, 真) >= 0 || 文本类.寻找文本 (诊断.消息, "警告", 0, 真) >= 0)
                    {
                        诊断.等级 = "警告"
                    }
                    否则 (文本类.寻找文本 (到小写 (诊断.消息), "note", 0, 真) >= 0 || 文本类.寻找文本 (诊断.消息, "提示", 0, 真) >= 0)
                    {
                        诊断.等级 = "提示"
                    }
                    否则
                    {
                        诊断.等级 = "错误"
                    }
                    返回 (诊断.文件路径 != "")
                }
            }
        }

        严重标记 = ": fatal error:"
        严重位置 = 文本类.寻找文本 (到小写 (文本), 严重标记, 0, 真)
        诊断.等级 = "错误"
        如果 (严重位置 < 0)
        {
            严重标记 = ": error:"
            严重位置 = 文本类.寻找文本 (到小写 (文本), 严重标记, 0, 真)
        }
        如果 (严重位置 < 0)
        {
            严重标记 = ": warning:"
            严重位置 = 文本类.寻找文本 (到小写 (文本), 严重标记, 0, 真)
            诊断.等级 = "警告"
        }
        如果 (严重位置 < 0)
        {
            严重标记 = ": note:"
            严重位置 = 文本类.寻找文本 (到小写 (文本), 严重标记, 0, 真)
            诊断.等级 = "提示"
        }
        如果 (严重位置 < 0)
        {
            返回 (假)
        }
        前缀文本 = 文本类.取文本左边 (文本, 严重位置)
        位置1 = 寻找最后子文本 (前缀文本, ":", -1)
        如果 (位置1 < 0)
        {
            返回 (假)
        }
        列号文本 = 取裁剪文本 (文本类.取文本右边 (前缀文本, 文本类.取文本长度 (前缀文本) - 位置1 - 1))
        前段文本 = 文本类.取文本左边 (前缀文本, 位置1)
        位置2 = 寻找最后子文本 (前段文本, ":", -1)
        如果 (位置2 >= 0 && 文本是否正整数 (列号文本))
        {
            行号文本 = 取裁剪文本 (文本类.取文本右边 (前段文本, 文本类.取文本长度 (前段文本) - 位置2 - 1))
            如果 (文本是否正整数 (行号文本))
            {
                诊断.文件路径 = 规范诊断文件路径 (文本类.取文本左边 (前段文本, 位置2))
                诊断.行号 = 文本到整数 (行号文本)
                诊断.列号 = 文本到整数 (列号文本)
            }
            否则
            {
                诊断.文件路径 = 规范诊断文件路径 (前段文本)
                诊断.行号 = 文本到整数 (列号文本)
            }
        }
        否则 (文本是否正整数 (列号文本))
        {
            诊断.文件路径 = 规范诊断文件路径 (前段文本)
            诊断.行号 = 文本到整数 (列号文本)
        }
        诊断.消息 = 取裁剪文本 (文本类.取文本右边 (文本, 文本类.取文本长度 (文本) - 严重位置 - 文本类.取文本长度 (严重标记)))
        返回 (诊断.文件路径 != "" && 诊断.行号 > 0)
    }

    方法 映射诊断文件到项目源码 <公开 类型 = 文本型>
    参数 诊断路径 <类型 = 文本型>
    {
        变量 路径 <类型 = 文本型>
        变量 项目索引 <类型 = 整数>
        变量 诊断文件名 <类型 = 文本型>
        变量 诊断基础名 <类型 = 文本型>
        变量 点位置 <类型 = 整数>
        变量 源文件组 <类型 = 文本数组类>
        变量 索引 <类型 = 整数>
        变量 源文件名 <类型 = 文本型>
        变量 源基础名 <类型 = 文本型>
        路径 = 规范诊断文件路径 (诊断路径)
        项目索引 = 取当前项目索引 ()
        如果 (项目索引 >= 0 && 项目索引 < 项目目录组.取成员数 () && 文本类.寻找文本 (到小写 (路径), "\\build\\", 0, 真) >= 0)
        {
            诊断文件名 = 取文件名无路径部分 (路径)
            点位置 = 寻找最后子文本 (诊断文件名, ".", -1)
            诊断基础名 = 选择 (点位置 > 0, 文本类.取文本左边 (诊断文件名, 点位置), 诊断文件名)
            收集项目代码文件 (项目索引, 源文件组)
            索引 = 0
            判断循环 (索引 < 源文件组.取成员数 ())
            {
                源文件名 = 取文件名无路径部分 (源文件组.取成员 (索引))
                点位置 = 寻找最后子文本 (源文件名, ".", -1)
                源基础名 = 选择 (点位置 > 0, 文本类.取文本左边 (源文件名, 点位置), 源文件名)
                如果 (到小写 (源基础名) == 到小写 (诊断基础名))
                {
                    返回 (源文件组.取成员 (索引))
                }
                索引 = 索引 + 1
            }
        }
        返回 (路径)
    }

    方法 处理编译诊断双击 <公开>
    参数 行文本 <类型 = 文本型>
    {
        变量 诊断 <类型 = 编译诊断信息>
