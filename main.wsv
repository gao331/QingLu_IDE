    方法 重建文件树 <公开>
    {
        节点路径组.删除所有成员 ()
        节点类型组.删除所有成员 ()
        节点项目索引组.删除所有成员 ()
        解决方案窗口.文件树.清空 ()
        如果 (解决方案名称 == "")
        {
            解决方案窗口.文件树.加入项目 (-1, "未打开解决方案", 2, -1, 0, 假)
            刷新解决方案辅助页 ()
            返回
        }
        变量 根节点索引 <类型 = 整数>
        根节点索引 = 记录节点 (解决方案路径, "solution", -1)
        变量 根项目句柄 <类型 = 变整数>
        根项目句柄 = 解决方案窗口.文件树.加入项目 (-1, "解决方案“" + 解决方案名称 + "”（" + 到文本 (项目名称组.取成员数 ()) + " 个项目）", 0, 1, 根节点索引 + 1, 真)
        变量 索引 <类型 = 整数>
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 项目名称组.取成员数 ())
            {
                跳出循环
            }
            变量 项目标题 <类型 = 文本型>
            项目标题 = 项目名称组.取成员 (索引)
            如果 (索引 == 启动项目索引)
            {
                项目标题 = 项目标题 + " [启动]"
            }
            变量 项目节点索引 <类型 = 整数>
            项目节点索引 = 记录节点 (项目目录组.取成员 (索引), "project", 索引)
            变量 项目句柄 <类型 = 变整数>
            项目句柄 = 解决方案窗口.文件树.加入项目 (根项目句柄, 项目标题, 4, 4, 项目节点索引 + 1, 真)

            变量 代码夹句柄 <类型 = 变整数>
            变量 代码夹节点索引 <类型 = 整数>
            代码夹节点索引 = 记录节点 (项目目录组.取成员 (索引) + "\\代码", "code_folder", 索引)
            代码夹句柄 = 解决方案窗口.文件树.加入项目 (项目句柄, "代码", 5, 5, 代码夹节点索引 + 1, 真)

            变量 项目文件路径 <类型 = 文本型>
            项目文件路径 = 项目文件组.取成员 (索引)
            变量 源文件组 <类型 = 文本数组类>
            变量 源文件索引 <类型 = 整数>
            收集项目代码文件 (索引, 源文件组)
            源文件索引 = 0
            循环判断首 ()
            {
                如果 (源文件索引 >= 源文件组.取成员数 ())
                {
                    跳出循环
                }
                变量 当前源文件 <类型 = 文本型>
                变量 文件节点索引 <类型 = 整数>
                当前源文件 = 源文件组.取成员 (源文件索引)
                文件节点索引 = 记录节点 (当前源文件, "file", 索引)
                解决方案窗口.文件树.加入项目 (代码夹句柄, 取文件名无路径部分 (当前源文件), 2, 2, 文件节点索引 + 1, 假)
                源文件索引 = 源文件索引 + 1
            }
            循环判断尾 (源文件索引 < 源文件组.取成员数 ())

            如果 (项目类型组.取成员 (索引) == "window")
            {
                变量 窗口夹句柄 <类型 = 变整数>
                变量 窗口夹节点索引 <类型 = 整数>
                窗口夹节点索引 = 记录节点 (项目目录组.取成员 (索引) + "\\窗口", "window_folder", 索引)
                窗口夹句柄 = 解决方案窗口.文件树.加入项目 (项目句柄, "窗口", 5, 5, 窗口夹节点索引 + 1, 真)
                变量 窗口设计文件组 <类型 = 文本数组类>
                收集项目窗口设计文件 (索引, 窗口设计文件组)
                源文件索引 = 0
                循环判断首 ()
                {
                    如果 (源文件索引 >= 窗口设计文件组.取成员数 ())
                    {
                        跳出循环
                    }
                    变量 当前窗口文件 <类型 = 文本型>
                    变量 窗口标题 <类型 = 文本型>
                    变量 窗口节点索引 <类型 = 整数>
                    当前窗口文件 = 窗口设计文件组.取成员 (源文件索引)
                    窗口标题 = 取窗口设计标题 (当前窗口文件)
                    窗口节点索引 = 记录节点 (当前窗口文件, "window", 索引)
                    解决方案窗口.文件树.加入项目 (窗口夹句柄, 窗口标题, 2, 2, 窗口节点索引 + 1, 假)
                    源文件索引 = 源文件索引 + 1
                }
                循环判断尾 (源文件索引 < 窗口设计文件组.取成员数 ())
                解决方案窗口.文件树.扩展 (窗口夹句柄)
            }

            变量 模块夹句柄 <类型 = 变整数>
            变量 模块夹节点索引 <类型 = 整数>
            模块夹节点索引 = 记录节点 (项目目录组.取成员 (索引) + "\\modules", "modules_folder", 索引)
            模块夹句柄 = 解决方案窗口.文件树.加入项目 (项目句柄, "模块", 5, 5, 模块夹节点索引 + 1, 假)
            变量 模块标识组 <类型 = 文本数组类>
            变量 模块目录组 <类型 = 文本数组类>
            变量 模块索引 <类型 = 整数>
            收集项目树模块信息 (索引, 模块标识组, 模块目录组)
            模块索引 = 0
            循环判断首 ()
            {
                如果 (模块索引 >= 模块目录组.取成员数 ())
                {
                    跳出循环
                }
                变量 模块节点索引 <类型 = 整数>
                变量 模块目录 <类型 = 文本型>
                模块目录 = 模块目录组.取成员 (模块索引)
                模块节点索引 = 记录节点 (模块目录, "module", 索引)
                解决方案窗口.文件树.加入项目 (模块夹句柄, 模块标识组.取成员 (模块索引), 5, 5, 模块节点索引 + 1, 假)
                模块索引 = 模块索引 + 1
            }
            循环判断尾 (模块索引 < 模块目录组.取成员数 ())

            变量 属性节点索引 <类型 = 整数>
            属性节点索引 = 记录节点 (项目目录组.取成员 (索引), "properties", 索引)
            解决方案窗口.文件树.加入项目 (项目句柄, "属性", 2, 2, 属性节点索引 + 1, 假)

            解决方案窗口.文件树.扩展 (项目句柄)
            解决方案窗口.文件树.扩展 (代码夹句柄)
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 项目名称组.取成员数 ())
        解决方案窗口.文件树.扩展 (根项目句柄)
        刷新解决方案辅助页 ()
    }

    方法 刷新解决方案辅助页 <公开>
    {
        支持库窗口.支持库树.清空 ()
        如果 (解决方案名称 == "")
        {
            属性窗口.属性编辑框.内容 = ""
            刷新输出辅助页 ()
            返回
        }

        刷新解决方案属性页 ()
        刷新输出辅助页 ()
    }

    方法 刷新解决方案属性页 <公开>
    {
        属性窗口.属性编辑框.内容 = ""
    }

    方法 刷新输出辅助页 <公开>
    {
        变量 提示文本 <类型 = 文本型>
        提示文本 = "提示\n\n"
        如果 (解决方案名称 == "")
        {
            提示文本 = 提示文本 + "未打开解决方案。\n"
            提示文本 = 提示文本 + "可通过“新建项目”或“打开解决方案”开始。"
        }
        否则
        {
            提示文本 = 提示文本 + "当前解决方案: " + 解决方案名称 + "\n"
            提示文本 = 提示文本 + "项目数: " + 到文本 (项目名称组.取成员数 ()) + "\n"
            提示文本 = 提示文本 + "平台/配置: " + 主构建引擎.成员_平台 + " / " + 主构建引擎.成员_配置 + "\n"
            如果 (启动项目索引 >= 0 && 启动项目索引 < 项目名称组.取成员数 ())
            {
                提示文本 = 提示文本 + "启动项目: " + 项目名称组.取成员 (启动项目索引) + "\n"
            }
            否则
            {
                提示文本 = 提示文本 + "启动项目: 未设置\n"
            }
            提示文本 = 提示文本 + "\n生成日志会写入“输出”页。"
        }
        提示窗口.提示编辑框.内容 = 提示文本
        如果 (输出窗口.输出编辑框.取文本长度 () <= 0)
        {
            输出窗口.输出编辑框.内容 = "输出面板已就绪，请先新建项目或打开解决方案。"
        }
    }

    方法 取节点路径 <公开 类型 = 文本型>
    参数 项目数值 <类型 = 整数>
    {
        如果 (项目数值 == 0)
        {
            返回 ("")
        }
        变量 实际索引 <类型 = 整数>
        实际索引 = 项目数值 - 1
        如果 (实际索引 < 0 || 实际索引 >= 节点路径组.取成员数 ())
        {
            返回 ("")
        }
        返回 (节点路径组.取成员 (实际索引))
    }

    方法 取节点类型 <公开 类型 = 文本型>
    参数 项目数值 <类型 = 整数>
    {
        变量 实际索引 <类型 = 整数>
        实际索引 = 项目数值 - 1
        如果 (实际索引 < 0 || 实际索引 >= 节点类型组.取成员数 ())
        {
            返回 ("")
        }
        返回 (节点类型组.取成员 (实际索引))
    }

    方法 取节点项目索引 <公开 类型 = 整数>
    参数 项目数值 <类型 = 整数>
    {
        变量 实际索引 <类型 = 整数>
        实际索引 = 项目数值 - 1
        如果 (实际索引 < 0 || 实际索引 >= 节点路径组.取成员数 ())
        {
            返回 (-1)
        }
        返回 (节点项目索引组.取成员 (实际索引))
    }
}

类 IDE输出回调 <基础类 = 构建输出回调类>
{
    变量 目标编辑框 <类型 = 超级编辑框>

    方法 初始化 <公开>
    参数 编辑框 <类型 = 超级编辑框>
    {
        目标编辑框 = 编辑框
    }

    方法 输出文本 <公开 类型 = 整数 @虚拟方法 = 可覆盖>
    参数 文本 <类型 = 文本型>
    {
        如果 (目标编辑框.取文本长度 () > 0)
        {
            目标编辑框.加入文本行 (文本)
        }
        否则
        {
            目标编辑框.内容 = 文本 + "\n"
        }
        返回 (0)
    }

    方法 输出错误 <公开 类型 = 整数 @虚拟方法 = 可覆盖>
    参数 文本 <类型 = 文本型>
    {
        如果 (目标编辑框.取文本长度 () > 0)
        {
            目标编辑框.加入文本行 ("[错误] " + 文本)
        }
        否则
        {
            目标编辑框.内容 = "[错误] " + 文本 + "\n"
        }
        返回 (0)
    }
}
