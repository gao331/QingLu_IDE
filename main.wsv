    方法 生成模块JSON文本 <公开 类型 = 文本型>
    参数 模块名称 <类型 = 文本型>
    参数 模块标识 <类型 = 文本型>
    参数 文件形态 <类型 = 整数>
    {
        变量 换行文本 <类型 = 文本型>
        变量 文本 <类型 = 文本型>
        换行文本 = "\n"
        文本 = "{" + 换行文本
        文本 = 文本 + "  \"模块名称\": \"" + 模块名称 + "\"," + 换行文本
        文本 = 文本 + "  \"模块标识\": \"" + 模块标识 + "\"," + 换行文本
        文本 = 文本 + "  \"模块类型\": \"用户模块\"," + 换行文本
        文本 = 文本 + "  \"目标平台\": \"Windows\"," + 换行文本
        文本 = 文本 + "  \"依赖模块\": []," + 换行文本
        如果 (文件形态 == AI模块文件形态.仅头文件 || 文件形态 == AI模块文件形态.头文件加源码)
        {
            文本 = 文本 + "  \"包含目录\": [\"include\"]," + 换行文本
        }
        否则
        {
            文本 = 文本 + "  \"包含目录\": []," + 换行文本
        }
        文本 = 文本 + "  \"库目录\": []," + 换行文本
        文本 = 文本 + "  \"链接库\": []," + 换行文本
        如果 (文件形态 == AI模块文件形态.仅源码 || 文件形态 == AI模块文件形态.头文件加源码)
        {
            文本 = 文本 + "  \"源码文件\": [\"src/" + 模块名称 + ".cpp\"]," + 换行文本
        }
        否则
        {
            文本 = 文本 + "  \"源码文件\": []," + 换行文本
        }
        文本 = 文本 + "  \"预处理器定义\": []" + 换行文本
        文本 = 文本 + "}" + 换行文本
        返回 (文本)
    }

