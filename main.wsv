    方法 切换属性分类 <公开>
    参数 分类索引 <类型 = 整数>
    {
        当前分类索引 = 分类索引
        定位属性页控件 (分类索引)
        置常规项可视 (分类索引 == 0)
        置编译项可视 (分类索引 == 1)
        置预处理项可视 (分类索引 == 2)
        置代码生成项可视 (分类索引 == 3)
        置链接器项可视 (分类索引 == 4)
        调整属性下拉高度 ()
    }

    方法 定位属性页控件 <公开>
    参数 分类索引 <类型 = 整数>
    {
        如果 (分类索引 == 0)
        {
            标题常规.移动 (184, 14, 590, 24)
            标签Cxx标准.移动 (196, 48, 150, 24)
            Cxx标准框.移动 (360, 44, 410, 24)
            标签C标准.移动 (196, 80, 150, 24)
            C标准框.移动 (360, 76, 410, 24)
            标签配置类型.移动 (196, 112, 150, 24)
            配置类型框.移动 (360, 108, 410, 24)
            标签字符集.移动 (196, 144, 150, 24)
            字符集框.移动 (360, 140, 410, 24)
            标签MFC.移动 (196, 176, 150, 24)
            MFC框.移动 (360, 172, 410, 24)
        }
        否则 (分类索引 == 1)
        {
            标题编译.移动 (184, 14, 590, 24)
            标签包含目录.移动 (196, 48, 150, 24)
            包含目录编辑框.移动 (360, 44, 410, 24)
            标签警告等级.移动 (196, 80, 150, 24)
            警告等级框.移动 (360, 76, 410, 24)
            标签警告错误.移动 (196, 112, 150, 24)
            警告错误框.移动 (360, 108, 410, 24)
        }
        否则 (分类索引 == 2)
        {
            标签预处理器.移动 (196, 48, 150, 24)
            预处理器编辑框.移动 (360, 44, 410, 24)
        }
        否则 (分类索引 == 3)
        {
            标签运行库.移动 (196, 48, 150, 24)
            运行库框.移动 (360, 44, 410, 24)
        }
        否则 (分类索引 == 4)
        {
            标题链接器.移动 (184, 14, 590, 24)
            标签库目录.移动 (196, 48, 150, 24)
            库目录编辑框.移动 (360, 44, 410, 24)
            标签依赖项.移动 (196, 80, 150, 24)
            依赖项编辑框.移动 (360, 76, 410, 24)
            标签调试信息.移动 (196, 112, 150, 24)
            调试信息框.移动 (360, 108, 410, 24)
            标签子系统.移动 (196, 144, 150, 24)
            子系统框.移动 (360, 140, 410, 24)
        }
    }

    方法 载入属性文本 <公开>
    参数 属性文本 <类型 = 文本型>
    {
        设置Cxx标准 (取属性行值 (属性文本, "C++语言标准", "默认(ISO C++14标准)"))
        设置C标准 (取属性行值 (属性文本, "C语言标准", "默认(旧MSVC)"))
        设置配置类型 (取属性行值 (属性文本, "配置类型", "应用程序(.exe)"))
        设置字符集 (取属性行值 (属性文本, "字符集", "使用 Unicode 字符集"))
        设置MFC (取属性行值 (属性文本, "MFC使用", "使用标准Windows库"))
        包含目录编辑框.内容 = 取属性行值 (属性文本, "附加包含目录", "")
        设置警告等级 (取属性行值 (属性文本, "警告等级", "默认"))
        设置警告错误 (取属性行值 (属性文本, "将警告视为错误", "假"))
        预处理器编辑框.内容 = 取属性行值 (属性文本, "预处理器定义", "")
        设置运行库 (取属性行值 (属性文本, "运行库", "多线程调试 DLL (/MDd)"))
        库目录编辑框.内容 = 取属性行值 (属性文本, "附加库目录", "")
        依赖项编辑框.内容 = 取属性行值 (属性文本, "附加依赖项", "")
        设置调试信息 (取属性行值 (属性文本, "生成调试信息", "生成调试信息 (/DEBUG)"))
        设置子系统 (取属性行值 (属性文本, "子系统", "控制台 (/SUBSYSTEM:CONSOLE)"))
    }

    方法 裁剪文本 <公开 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 文本 <类型 = 文本型>
        文本 = 原文本
        判断循环 (文本类.取文本长度 (文本) > 0 && (文本类.取文本左边 (文本, 1) == " " || 文本类.取文本左边 (文本, 1) == "\t"))
        {
            文本 = 文本类.取文本右边 (文本, 文本类.取文本长度 (文本) - 1)
        }
        判断循环 (文本类.取文本长度 (文本) > 0 && (文本类.取文本右边 (文本, 1) == " " || 文本类.取文本右边 (文本, 1) == "\t" || 文本类.取文本右边 (文本, 1) == "\r"))
        {
            文本 = 文本类.取文本左边 (文本, 文本类.取文本长度 (文本) - 1)
        }
        返回 (文本)
    }

    方法 取属性行值 <公开 类型 = 文本型>
    参数 属性文本 <类型 = 文本型>
    参数 键名 <类型 = 文本型>
    参数 默认值 <类型 = 文本型>
    {
        变量 行数组 <类型 = 文本数组类>
        变量 索引 <类型 = 整数>
        变量 行文本 <类型 = 文本型>
        变量 等号位置 <类型 = 整数>
        文本类.分割子文本 (属性文本, "\n", 行数组, 假, 假)
        索引 = 0
        循环判断首 ()
        {
            如果 (索引 >= 行数组.取成员数 ())
            {
                跳出循环
            }
            行文本 = 行数组.取成员 (索引)
            等号位置 = 文本类.寻找文本 (行文本, "=", 0, 真)
            如果 (等号位置 >= 0 && 裁剪文本 (文本类.取文本左边 (行文本, 等号位置)) == 键名)
            {
                返回 (裁剪文本 (文本类.取文本右边 (行文本, 文本类.取文本长度 (行文本) - 等号位置 - 1)))
            }
            索引 = 索引 + 1
        }
        循环判断尾 (索引 < 行数组.取成员数 ())
        返回 (默认值)
    }

    方法 设置Cxx标准 <公开>
    参数 属性值 <类型 = 文本型>
    {
        如果 (文本类.寻找文本 (属性值, "c++20", 0, 真) >= 0 || 文本类.寻找文本 (属性值, "C++20", 0, 真) >= 0)
        {
            Cxx标准框.现行选中项 = 3
        }
        否则 (文本类.寻找文本 (属性值, "c++17", 0, 真) >= 0 || 文本类.寻找文本 (属性值, "C++17", 0, 真) >= 0)
        {
            Cxx标准框.现行选中项 = 2
        }
        否则 (文本类.寻找文本 (属性值, "/std:c++14", 0, 真) >= 0)
        {
            Cxx标准框.现行选中项 = 1
        }
        否则
        {
            Cxx标准框.现行选中项 = 0
        }
    }

