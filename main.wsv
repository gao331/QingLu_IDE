类 编辑页布局器 <基础类 = 组件布局器 @视窗.布局 = "client_size = \"800, 600\"">
{
    变量 页面编辑器 <公开 类型 = 代码表格编辑器 @视窗.布局 = "id = 201\r\npos = \"0, 0, 800, 600\"">

    方法 编辑页布局器_尺寸被改变 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 编辑页布局器>
    参数 标记值 <类型 = 整数>
    {
        页面编辑器.宽度 = 宽度
        页面编辑器.高度 = 高度
        返回 (0)
    }
}

类 文件树布局器 <基础类 = 组件布局器 @视窗.布局 = "client_size = \"220, 750\"">
{
    变量 内部文件树 <公开 类型 = 增强树形框 @视窗.布局 = "id = 105\r\npos = \"0, 0, 220, 750\"" 显示加减框 = 真 显示连线 = 真 显示根部线 = 真 始终显示选择项 = 真
            图片组文件 = "..\\Assets\\tree_icons.bmp" 字体 = "微软雅黑, 11">

    方法 文件树布局器_尺寸被改变 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 文件树布局器>
    参数 标记值 <类型 = 整数>
    {
        内部文件树.宽度 = 宽度
        内部文件树.高度 = 高度
        返回 (0)
    }
}

类 新建项目对话框 <基础类 = 窗口 标题 = "新建项目:" 位置 = 居中 @视窗.布局 = "client_size = \"760, 560\"">
{
    变量 模板画板 <类型 = 画板 @视窗.布局 = "id = 1201\r\npos = \"8, 8, 744, 360\"" 画板背景色 = 颜色类.白色 自动重画 = 真>
    变量 模板选择框 <类型 = 组合框 @视窗.布局 = "id = 1206\r\npos = \"16, 520, 180, 24\"" "类型" = 不可编辑下拉式 列表项目 = "控制台程序\n空白视窗项目\n窗口程序\n空项目\n动态库"
            现行选中项 = 0 可视 = 假>
    变量 项目名称标签 <类型 = 标签 @视窗.布局 = "id = 1212\r\npos = \"14, 388, 104, 24\"" 标题 = "项目名称:">
    变量 项目名称编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1213\r\npos = \"170, 384, 580, 24\"">
    变量 保存路径标签 <类型 = 标签 @视窗.布局 = "id = 1214\r\npos = \"14, 420, 104, 24\"" 标题 = "所在位置:">
    变量 保存路径编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1215\r\npos = \"170, 416, 544, 24\"">
    变量 浏览路径按钮 <类型 = 按钮 @视窗.布局 = "id = 1216\r\npos = \"720, 414, 30, 28\"" 标题 = "...">
    变量 解决方案模式标签 <类型 = 标签 @视窗.布局 = "id = 1217\r\npos = \"14, 452, 120, 24\"" 标题 = "所在解决方案:">
    变量 解决方案模式框 <类型 = 组合框 @视窗.布局 = "id = 1218\r\npos = \"170, 448, 580, 24\"" "类型" = 不可编辑下拉式 列表项目 = "现行解决方案-集成开发环境\n创建新的解决方案"
            现行选中项 = 0>
    变量 解决方案名称标签 <类型 = 标签 @视窗.布局 = "id = 1219\r\npos = \"14, 484, 120, 24\"" 标题 = "解决方案名称:">
    变量 解决方案名称编辑框 <类型 = 编辑框 @视窗.布局 = "id = 1220\r\npos = \"170, 480, 580, 24\"">
    变量 模式说明标签 <类型 = 标签 @视窗.布局 = "id = 1221\r\npos = \"14, 526, 470, 24\"" 标题 = "注: 可以在“解决方案”工作夹中对项目显示名称重新命名。" 是否自动折行 = 真>
    变量 确定按钮 <类型 = 按钮 @视窗.布局 = "id = 1222\r\npos = \"532, 518, 104, 32\"" 标题 = "确定(O)">
    变量 取消按钮 <类型 = 按钮 @视窗.布局 = "id = 1223\r\npos = \"646, 518, 104, 32\"" 标题 = "取消(C)">
    变量 已关联解决方案 <类型 = 逻辑型>
    变量 当前模板索引 <类型 = 整数>
    变量 当前平台索引 <类型 = 整数>
    变量 模板画板已创建 <类型 = 逻辑型>
    变量 结果项目名称 <公开 类型 = 文本型>
    变量 结果项目类型 <公开 类型 = 文本型>
    变量 结果解决方案名称 <公开 类型 = 文本型>
    变量 结果方案根目录 <公开 类型 = 文本型>

    方法 初始化数据 <公开>
    参数 是否已有解决方案 <类型 = 逻辑型>
    参数 默认解决方案名称 <类型 = 文本型>
    参数 默认方案根目录 <类型 = 文本型>
    参数 默认项目名称 <类型 = 文本型>
    {
        已关联解决方案 = 是否已有解决方案
        当前平台索引 = 0
        模板画板已创建 = 假
        模板选择框.可视 = 假
        选择模板 (0)
        项目名称编辑框.内容 = 默认项目名称
        如果 (默认解决方案名称 == "")
        {
            默认解决方案名称 = 默认项目名称
        }
        解决方案名称编辑框.内容 = 默认解决方案名称
        保存路径编辑框.内容 = 默认方案根目录
        如果 (已关联解决方案)
        {
            解决方案名称编辑框.输入方式 = 编辑框输入方式.只读方式
            保存路径编辑框.输入方式 = 编辑框输入方式.只读方式
            浏览路径按钮.可视 = 假
            解决方案模式框.现行选中项 = 0
            模式说明标签.标题 = "注: 当前将项目添加到已打开的解决方案中，解决方案名称和位置不可修改。"
        }
        否则
        {
            解决方案名称编辑框.输入方式 = 编辑框输入方式.通常方式
            保存路径编辑框.输入方式 = 编辑框输入方式.通常方式
            浏览路径按钮.可视 = 真
            解决方案模式框.现行选中项 = 1
            模式说明标签.标题 = "注: 可以在“解决方案”工作夹中对项目显示名称重新命名。"
        }
        更新模板说明 ()
    }

    方法 新建项目对话框_创建完毕 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 新建项目对话框>
    参数 标记值 <类型 = 整数>
    {
        模板画板已创建 = 真
        如果 (已关联解决方案)
        {
            解决方案模式框.现行选中项 = 0
        }
        否则
        {
            解决方案模式框.现行选中项 = 1
        }
        绘制模板区域 ()
        返回 (0)
    }

    方法 选择模板 <公开>
    参数 模板索引 <类型 = 整数>
    {
        当前模板索引 = 模板索引
        模板选择框.现行选中项 = 模板索引
        更新模板说明 ()
        如果 (模板画板已创建)
        {
            绘制模板区域 ()
        }
    }

    方法 更新模板说明 <公开>
    {
        如果 (当前模板索引 == 1 || 当前模板索引 == 2)
        {
            结果项目类型 = "window"
        }
        否则 (当前模板索引 == 3)
        {
            结果项目类型 = "empty"
        }
        否则 (当前模板索引 == 4)
        {
            结果项目类型 = "dll"
        }
        否则
        {
            结果项目类型 = "console"
        }
    }

    方法 取当前模板标题 <类型 = 文本型>
    {
        如果 (当前模板索引 == 1)
        {
            返回 ("空白视窗项目")
        }
        否则 (当前模板索引 == 2)
        {
            返回 ("窗口程序")
        }
        否则 (当前模板索引 == 3)
        {
            返回 ("空项目")
        }
        否则 (当前模板索引 == 4)
        {
            返回 ("动态链接库")
        }
        返回 ("控制台程序")
    }

    方法 取当前模板说明 <类型 = 文本型>
    {
        如果 (当前模板索引 == 1)
        {
            返回 ("建立默认的空白视窗项目，适合创建带界面的火山视窗程序。")
        }
        否则 (当前模板索引 == 2)
        {
            返回 ("创建窗口程序入口和默认主窗口模板。")
        }
        否则 (当前模板索引 == 3)
        {
            返回 ("只创建包和空启动类，适合手动组织目录、模块和入口。")
        }
        否则 (当前模板索引 == 4)
        {
            返回 ("创建导出类入口，适合封装库、模块或可复用组件。")
        }
        返回 ("创建火山控制台程序表格代码模板，适合命令行工具和快速测试。")
    }

    方法 绘制模板行 <公开>
    参数 模板索引 <类型 = 整数>
    参数 顶边 <类型 = 整数>
    参数 图标文本 <类型 = 文本型>
    参数 标题文本 <类型 = 文本型>
    参数 说明文本 <类型 = 文本型>
    {
        变量 选中 <类型 = 逻辑型>
        选中 = 当前模板索引 == 模板索引
        如果 (选中)
        {
            模板画板.画笔颜色 = 0x00D77800
            模板画板.刷子颜色 = 0x00D77800
            模板画板.画矩形 (186, 顶边, 726, 顶边 + 42)
            模板画板.文本颜色 = 颜色类.白色
            模板画板.文本背景颜色 = 0x00D77800
        }
        否则
        {
            模板画板.画笔颜色 = 颜色类.白色
            模板画板.刷子颜色 = 颜色类.白色
            模板画板.画矩形 (186, 顶边, 726, 顶边 + 42)
            模板画板.文本颜色 = 颜色类.黑色
            模板画板.文本背景颜色 = 颜色类.白色
        }
        模板画板.画笔颜色 = 0x00A0A0A0
        模板画板.刷子颜色 = 0x00F5F5F5
        模板画板.画矩形 (194, 顶边 + 8, 224, 顶边 + 36)
        模板画板.定位写出 (200, 顶边 + 14, 图标文本)
        如果 (选中)
        {
            模板画板.文本颜色 = 颜色类.白色
            模板画板.文本背景颜色 = 0x00D77800
        }
        否则
        {
            模板画板.文本颜色 = 颜色类.黑色
            模板画板.文本背景颜色 = 颜色类.白色
        }
        模板画板.定位写出 (234, 顶边 + 8, 标题文本)
        如果 (选中)
        {
            模板画板.文本颜色 = 颜色类.白色
            模板画板.文本背景颜色 = 0x00D77800
        }
        否则
        {
            模板画板.文本颜色 = 0x00808080
            模板画板.文本背景颜色 = 颜色类.白色
        }
        模板画板.定位写出 (234, 顶边 + 25, 说明文本)
    }

    方法 绘制模板区域 <公开>
    {
        模板画板.清除 (0, 0, 模板画板.画板宽度, 模板画板.画板高度)
        模板画板.画笔颜色 = 0x00A0A0A0
        模板画板.刷子颜色 = 颜色类.白色
        模板画板.画矩形 (0, 0, 170, 358)
        模板画板.画矩形 (178, 0, 736, 220)
        模板画板.画矩形 (178, 224, 736, 358)
        模板画板.文本背景颜色 = 颜色类.白色
        模板画板.文本颜色 = 颜色类.黑色
        模板画板.定位写出 (8, 8, "已安装项目模板")
        模板画板.画笔颜色 = 0x00D77800
        模板画板.刷子颜色 = 0x00D77800
        模板画板.画矩形 (8, 38, 160, 66)
        模板画板.文本颜色 = 颜色类.白色
        模板画板.文本背景颜色 = 0x00D77800
        模板画板.定位写出 (28, 45, "视窗")
        绘制模板行 (1, 8, "APP", "空白视窗项目", "建立默认的空白视窗工程")
        绘制模板行 (2, 50, "WIN", "窗口程序", "创建窗口程序入口和默认主窗口")
        绘制模板行 (4, 92, "DLL", "动态链接库", "生成导出类与库项目入口")
        绘制模板行 (0, 134, ">_", "控制台程序", "创建中文项目入口与命令行模板")
        绘制模板行 (3, 176, "...", "空项目", "只创建最小包与启动类")
        模板画板.画笔颜色 = 0x00A0A0A0
        模板画板.刷子颜色 = 颜色类.白色
        模板画板.画矩形 (720, 16, 728, 134)
        模板画板.刷子颜色 = 0x00808080
        模板画板.画矩形 (721, 22, 727, 84)
        模板画板.文本背景颜色 = 颜色类.白色
        模板画板.文本颜色 = 颜色类.黑色
        模板画板.定位写出 (186, 234, 取当前模板标题 ())
        模板画板.文本颜色 = 0x00555555
        模板画板.定位写出 (186, 260, 取当前模板说明 ())
    }

    方法 组合框_列表项被选择 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 组合框>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 模板选择框)
        {
            选择模板 (模板选择框.现行选中项)
        }
        否则 (来源对象 == 解决方案模式框)
        {
            如果 (已关联解决方案)
            {
                解决方案模式框.现行选中项 = 0
            }
            否则
            {
                解决方案模式框.现行选中项 = 1
            }
        }
        返回 (0)
    }

    方法 画板_鼠标左键被按下 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 模板画板)
        {
            如果 (横向位置 >= 8 && 横向位置 <= 160 && 纵向位置 >= 38 && 纵向位置 <= 66)
            {
                当前平台索引 = 0
                绘制模板区域 ()
            }
            否则 (横向位置 >= 186 && 横向位置 <= 726)
            {
                如果 (纵向位置 >= 8 && 纵向位置 <= 50)
                {
                    选择模板 (1)
                }
                否则 (纵向位置 >= 50 && 纵向位置 <= 92)
                {
                    选择模板 (2)
                }
                否则 (纵向位置 >= 92 && 纵向位置 <= 134)
                {
                    选择模板 (4)
                }
                否则 (纵向位置 >= 134 && 纵向位置 <= 176)
                {
                    选择模板 (0)
                }
                否则 (纵向位置 >= 176 && 纵向位置 <= 218)
                {
                    选择模板 (3)
                }
            }
        }
        返回 (0)
    }

    方法 按钮_被单击 <公开 接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 浏览路径按钮)
        {
            变量 新路径 <类型 = 文本型>
            新路径 = 快速文件对话框.选择目录 (本对象, "选择解决方案保存位置", 保存路径编辑框.内容)
            如果 (新路径 != "")
            {
                保存路径编辑框.内容 = 新路径
            }
        }
        否则 (来源对象 == 确定按钮)
        {
            如果 (项目名称编辑框.内容 == "")
            {
                警告信息框 ("请输入项目名称。", "新建项目")
                返回 (0)
            }
            如果 (已关联解决方案 == 假 && 解决方案名称编辑框.内容 == "")
            {
                警告信息框 ("请输入解决方案名称。", "新建项目")
                返回 (0)
            }
            如果 (已关联解决方案 == 假 && 保存路径编辑框.内容 == "")
            {
                警告信息框 ("请选择解决方案保存位置。", "新建项目")
                返回 (0)
            }
            结果项目名称 = 项目名称编辑框.内容
            结果解决方案名称 = 解决方案名称编辑框.内容
            结果方案根目录 = 保存路径编辑框.内容
            更新模板说明 ()
            关闭窗口 (1)
        }
        否则 (来源对象 == 取消按钮)
        {
            关闭窗口 (0)
        }
        返回 (0)
    }
}

类 项目属性对话框 <基础类 = 窗口 标题 = "项目属性" 位置 = 居中 @视窗.布局 = "client_size = \"820, 640\"">
{
    变量 左侧标题 <类型 = 标签 @视窗.布局 = "id = 1230\r\npos = \"14, 14, 150, 24\"" 标题 = "配置分类">
    变量 分类常规 <类型 = 按钮 @视窗.布局 = "id = 1231\r\npos = \"18, 48, 140, 28\"" 标题 = "常规">
    变量 分类编译 <类型 = 按钮 @视窗.布局 = "id = 1232\r\npos = \"18, 82, 140, 28\"" 标题 = "C/C++">
    变量 分类预处理 <类型 = 按钮 @视窗.布局 = "id = 1233\r\npos = \"18, 116, 140, 28\"" 标题 = "预处理器">
    变量 分类代码生成 <类型 = 按钮 @视窗.布局 = "id = 1234\r\npos = \"18, 150, 140, 28\"" 标题 = "代码生成">
    变量 分类链接器 <类型 = 按钮 @视窗.布局 = "id = 1235\r\npos = \"18, 184, 140, 28\"" 标题 = "链接器">

    变量 标题常规 <类型 = 标签 @视窗.布局 = "id = 1236\r\npos = \"184, 14, 590, 24\"" 标题 = "常规">
    变量 标签Cxx标准 <类型 = 标签 @视窗.布局 = "id = 1237\r\npos = \"196, 48, 150, 24\"" 标题 = "C++语言标准:">
    变量 Cxx标准框 <类型 = 组合框 @视窗.布局 = "id = 1238\r\npos = \"360, 44, 410, 24\"" "类型" = 不可编辑下拉式 列表项目 = "默认(ISO C++14标准)\nISO C++14标准 (/std:c++14)\nISO C++17 标准 (/std:c++17)\nISO C++20 标准 (/std:c++20)" 现行选中项 = 0>
    变量 标签C标准 <类型 = 标签 @视窗.布局 = "id = 1239\r\npos = \"196, 80, 150, 24\"" 标题 = "C语言标准:">
    变量 C标准框 <类型 = 组合框 @视窗.布局 = "id = 1240\r\npos = \"360, 76, 410, 24\"" "类型" = 不可编辑下拉式 列表项目 = "默认(旧MSVC)\nISO C11 标准 (/std:c11)\nISO C17 (2018)标准 (/std:c17)" 现行选中项 = 0>
