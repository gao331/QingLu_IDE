<火山程序 类型 = "通常" 版本 = 1 />

包 火山.程序

类 窗口设计控件 <公开>
{
    变量 标识 <公开 类型 = 整数>
    变量 控件类型 <公开 类型 = 文本型>
    变量 名称 <公开 类型 = 文本型>
    变量 标题 <公开 类型 = 文本型>
    变量 左边 <公开 类型 = 整数>
    变量 顶边 <公开 类型 = 整数>
    变量 宽度 <公开 类型 = 整数>
    变量 高度 <公开 类型 = 整数>
    变量 可视 <公开 类型 = 逻辑型>
    变量 允许 <公开 类型 = 逻辑型>
    变量 单击事件 <公开 类型 = 文本型>
    变量 内容改变事件 <公开 类型 = 文本型>

    方法 初始化 <公开>
    参数 类型文本 <类型 = 文本型>
    参数 序号 <类型 = 整数>
    参数 控件标识 <类型 = 整数>
    {
        标识 = 控件标识
        控件类型 = 类型文本
        名称 = 取类型显示名称 () + 到文本 (序号)
        标题 = 名称
        左边 = 24 + (序号 - 1) * 10
        顶边 = 24 + (序号 - 1) * 10
        宽度 = 112
        高度 = 30
        可视 = 真
        允许 = 真
        单击事件 = ""
        内容改变事件 = ""
        如果 (控件类型 == "label")
        {
            宽度 = 96
            高度 = 24
        }
        否则 (控件类型 == "edit")
        {
            宽度 = 180
            高度 = 26
        }
        否则 (控件类型 == "checkbox")
        {
            宽度 = 132
            高度 = 24
        }
        如果 (控件类型 == "button" || 控件类型 == "checkbox")
        {
            单击事件 = 名称 + "_被单击"
        }
        如果 (控件类型 == "edit")
        {
            内容改变事件 = 名称 + "_内容被改变"
        }
    }

    方法 取类型显示名称 <公开 类型 = 文本型>
    {
        如果 (控件类型 == "button")
        {
            返回 ("按钮")
        }
        如果 (控件类型 == "label")
        {
            返回 ("标签")
        }
        如果 (控件类型 == "edit")
        {
            返回 ("编辑框")
        }
        如果 (控件类型 == "checkbox")
        {
            返回 ("选择框")
        }
        返回 ("控件")
    }
}

类 窗口设计控件数组类 <基础类 = 对象数组模板类 @模板实现类 = "窗口设计控件">

类 窗口设计文档 <公开>
{
    变量 格式版本 <公开 类型 = 整数 值 = 1>
    变量 窗口名称 <公开 类型 = 文本型>
    变量 窗口类名 <公开 类型 = 文本型>
    变量 窗口标题 <公开 类型 = 文本型>
    变量 关联代码文件 <公开 类型 = 文本型>
    变量 窗口宽度 <公开 类型 = 整数 值 = 800>
    变量 窗口高度 <公开 类型 = 整数 值 = 560>
    变量 背景颜色 <公开 类型 = 整数 值 = 16777215>
    变量 是否启动窗口 <公开 类型 = 逻辑型>
    变量 创建完毕事件 <公开 类型 = 文本型>
    变量 尺寸改变事件 <公开 类型 = 文本型>
    变量 关闭事件 <公开 类型 = 文本型>
    变量 控件组 <公开 类型 = 窗口设计控件数组类>

    方法 创建默认文档 <公开>
    参数 名称文本 <类型 = 文本型>
    参数 类名文本 <类型 = 文本型>
    参数 代码文件文本 <类型 = 文本型>
    参数 启动窗口 <类型 = 逻辑型>
    {
        格式版本 = 1
        窗口名称 = 名称文本
        窗口类名 = 类名文本
        窗口标题 = 名称文本
        关联代码文件 = 代码文件文本
        窗口宽度 = 800
        窗口高度 = 560
        背景颜色 = 16777215
        是否启动窗口 = 启动窗口
        创建完毕事件 = 窗口类名 + "_创建完毕"
        尺寸改变事件 = 窗口类名 + "_尺寸被改变"
        关闭事件 = 窗口类名 + "_将被关闭"
        控件组.删除所有成员 ()
    }

    方法 取裁剪文本 <公开 静态 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 起始 <类型 = 整数>
        变量 结束 <类型 = 整数>
        变量 当前字符 <类型 = 文本型>
        变量 文本长度 <类型 = 整数>
        文本长度 = 文本类.取文本长度 (原文本)
        起始 = 0
        结束 = 文本长度 - 1
        判断循环 (起始 < 文本长度)
        {
            当前字符 = 文本类.取文本中间 (原文本, 起始, 1)
            如果 (当前字符 != " " && 当前字符 != "\t" && 当前字符 != "\r" && 当前字符 != "\n")
            {
                跳出循环
            }
            起始 = 起始 + 1
        }
        判断循环 (结束 >= 起始)
        {
            当前字符 = 文本类.取文本中间 (原文本, 结束, 1)
            如果 (当前字符 != " " && 当前字符 != "\t" && 当前字符 != "\r" && 当前字符 != "\n")
            {
                跳出循环
            }
            结束 = 结束 - 1
        }
        如果 (结束 < 起始)
        {
            返回 ("")
        }
        返回 (文本类.取文本中间 (原文本, 起始, 结束 - 起始 + 1))
    }

    方法 规范字段值 <公开 静态 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 结果 <类型 = 文本型>
        变量 当前字符 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        索引 = 0
        判断循环 (索引 < 文本类.取文本长度 (原文本))
        {
            当前字符 = 文本类.取文本中间 (原文本, 索引, 1)
            如果 (当前字符 == "\r" || 当前字符 == "\n" || 当前字符 == "\t")
            {
                结果 = 结果 + " "
            }
            否则
            {
                结果 = 结果 + 当前字符
            }
            索引 = 索引 + 1
        }
        返回 (取裁剪文本 (结果))
    }

    方法 取配置值 <公开 静态 类型 = 文本型>
    参数 配置文本 <类型 = 文本型>
    参数 节名称 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 默认值 <类型 = 文本型>
    {
        变量 行组 <类型 = 文本数组类>
        变量 当前节 <类型 = 文本型>
        变量 行文本 <类型 = 文本型>
        变量 等号位置 <类型 = 整数>
        变量 索引 <类型 = 整数>
        分割文本 (配置文本, "\n", 行组, 真, 假)
        索引 = 0
        判断循环 (索引 < 行组.取成员数 ())
        {
            行文本 = 取裁剪文本 (行组.取成员 (索引))
            如果 (文本类.取文本长度 (行文本) >= 2 && 文本类.取文本左边 (行文本, 1) == "[" && 文本类.取文本右边 (行文本, 1) == "]")
            {
                当前节 = 文本类.取文本中间 (行文本, 1, 文本类.取文本长度 (行文本) - 2)
            }
            否则 (当前节 == 节名称)
            {
                等号位置 = 文本类.寻找文本 (行文本, "=", 0, 真)
                如果 (等号位置 > 0 && 取裁剪文本 (文本类.取文本左边 (行文本, 等号位置)) == 键名称)
                {
                    返回 (取裁剪文本 (文本类.取文本右边 (行文本, 文本类.取文本长度 (行文本) - 等号位置 - 1)))
                }
            }
            索引 = 索引 + 1
        }
        返回 (默认值)
    }

    方法 取逻辑配置值 <公开 静态 类型 = 逻辑型>
    参数 配置文本 <类型 = 文本型>
    参数 节名称 <类型 = 文本型>
    参数 键名称 <类型 = 文本型>
    参数 默认值 <类型 = 逻辑型>
    {
        变量 文本值 <类型 = 文本型>
        文本值 = 到小写 (取配置值 (配置文本, 节名称, 键名称, 选择 (默认值, "true", "false")))
        返回 (文本值 == "true" || 文本值 == "1" || 文本值 == "真")
    }

    方法 载入设计文本 <公开 类型 = 逻辑型>
    参数 设计文本 <类型 = 文本型>
    {
        变量 控件数 <类型 = 整数>
        变量 索引 <类型 = 整数>
        变量 节名称 <类型 = 文本型>
        变量 当前控件 <类型 = 窗口设计控件>
        如果 (取配置值 (设计文本, "designer", "format", "") != "ccide-window")
        {
            返回 (假)
        }
        格式版本 = 文本到整数 (取配置值 (设计文本, "designer", "version", "1"))
        如果 (格式版本 != 1)
        {
            返回 (假)
        }
        窗口名称 = 取配置值 (设计文本, "window", "name", "窗口")
        窗口类名 = 取配置值 (设计文本, "window", "class", 窗口名称 + "类")
        窗口标题 = 取配置值 (设计文本, "window", "title", 窗口名称)
        关联代码文件 = 取配置值 (设计文本, "window", "code_file", "")
        窗口宽度 = 文本到整数 (取配置值 (设计文本, "window", "width", "800"))
        窗口高度 = 文本到整数 (取配置值 (设计文本, "window", "height", "560"))
        背景颜色 = 文本到整数 (取配置值 (设计文本, "window", "background", "16777215"))
        是否启动窗口 = 取逻辑配置值 (设计文本, "window", "startup", 假)
        创建完毕事件 = 取配置值 (设计文本, "events", "created", 窗口类名 + "_创建完毕")
        尺寸改变事件 = 取配置值 (设计文本, "events", "resized", 窗口类名 + "_尺寸被改变")
        关闭事件 = 取配置值 (设计文本, "events", "closing", 窗口类名 + "_将被关闭")
        如果 (窗口宽度 < 240)
        {
            窗口宽度 = 240
        }
        如果 (窗口高度 < 160)
        {
            窗口高度 = 160
        }
        控件组.删除所有成员 ()
        控件数 = 文本到整数 (取配置值 (设计文本, "designer", "control_count", "0"))
        如果 (控件数 < 0 || 控件数 > 4096)
        {
            返回 (假)
        }
        索引 = 0
        判断循环 (索引 < 控件数)
        {
            节名称 = "control." + 到文本 (索引)
            当前控件.初始化 (取配置值 (设计文本, 节名称, "type", "button"), 索引 + 1, 文本到整数 (取配置值 (设计文本, 节名称, "id", 到文本 (1000 + 索引))))
            如果 (当前控件.控件类型 != "button" && 当前控件.控件类型 != "label" && 当前控件.控件类型 != "edit" && 当前控件.控件类型 != "checkbox")
            {
                返回 (假)
            }
            如果 (当前控件.标识 <= 0)
            {
                返回 (假)
            }
            变量 已有索引 <类型 = 整数>
            已有索引 = 0
            判断循环 (已有索引 < 控件组.取成员数 ())
            {
                如果 (控件组.取成员 (已有索引).标识 == 当前控件.标识)
                {
                    返回 (假)
                }
                已有索引 = 已有索引 + 1
            }
            当前控件.名称 = 取配置值 (设计文本, 节名称, "name", 当前控件.名称)
            当前控件.标题 = 取配置值 (设计文本, 节名称, "title", 当前控件.标题)
            当前控件.左边 = 文本到整数 (取配置值 (设计文本, 节名称, "x", "20"))
            当前控件.顶边 = 文本到整数 (取配置值 (设计文本, 节名称, "y", "20"))
            当前控件.宽度 = 文本到整数 (取配置值 (设计文本, 节名称, "width", "100"))
            当前控件.高度 = 文本到整数 (取配置值 (设计文本, 节名称, "height", "28"))
            如果 (当前控件.左边 < 0)
            {
                当前控件.左边 = 0
            }
            如果 (当前控件.顶边 < 0)
            {
                当前控件.顶边 = 0
            }
            如果 (当前控件.宽度 < 8)
            {
                当前控件.宽度 = 8
            }
            如果 (当前控件.高度 < 8)
            {
                当前控件.高度 = 8
            }
            当前控件.可视 = 取逻辑配置值 (设计文本, 节名称, "visible", 真)
            当前控件.允许 = 取逻辑配置值 (设计文本, 节名称, "enabled", 真)
            当前控件.单击事件 = 取配置值 (设计文本, 节名称, "event.click", 当前控件.单击事件)
            当前控件.内容改变事件 = 取配置值 (设计文本, 节名称, "event.change", 当前控件.内容改变事件)
            控件组.加入成员 (当前控件)
            索引 = 索引 + 1
        }
        返回 (真)
    }

    方法 取设计文本 <公开 类型 = 文本型>
    {
        变量 文本 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        变量 当前控件 <类型 = 窗口设计控件>
        文本 = "[designer]\n"
        文本 = 文本 + "format=ccide-window\n"
        文本 = 文本 + "version=" + 到文本 (格式版本) + "\n"
        文本 = 文本 + "control_count=" + 到文本 (控件组.取成员数 ()) + "\n\n"
        文本 = 文本 + "[window]\n"
        文本 = 文本 + "name=" + 规范字段值 (窗口名称) + "\n"
        文本 = 文本 + "class=" + 规范字段值 (窗口类名) + "\n"
        文本 = 文本 + "title=" + 规范字段值 (窗口标题) + "\n"
        文本 = 文本 + "code_file=" + 规范字段值 (关联代码文件) + "\n"
        文本 = 文本 + "width=" + 到文本 (窗口宽度) + "\n"
        文本 = 文本 + "height=" + 到文本 (窗口高度) + "\n"
        文本 = 文本 + "background=" + 到文本 (背景颜色) + "\n"
        文本 = 文本 + "startup=" + 选择 (是否启动窗口, "true", "false") + "\n\n"
        文本 = 文本 + "[events]\n"
        文本 = 文本 + "created=" + 规范字段值 (创建完毕事件) + "\n"
        文本 = 文本 + "resized=" + 规范字段值 (尺寸改变事件) + "\n"
        文本 = 文本 + "closing=" + 规范字段值 (关闭事件) + "\n"
        索引 = 0
        判断循环 (索引 < 控件组.取成员数 ())
        {
            当前控件 = 控件组.取成员 (索引)
            文本 = 文本 + "\n[control." + 到文本 (索引) + "]\n"
            文本 = 文本 + "id=" + 到文本 (当前控件.标识) + "\n"
            文本 = 文本 + "type=" + 规范字段值 (当前控件.控件类型) + "\n"
            文本 = 文本 + "name=" + 规范字段值 (当前控件.名称) + "\n"
            文本 = 文本 + "title=" + 规范字段值 (当前控件.标题) + "\n"
            文本 = 文本 + "x=" + 到文本 (当前控件.左边) + "\n"
            文本 = 文本 + "y=" + 到文本 (当前控件.顶边) + "\n"
            文本 = 文本 + "width=" + 到文本 (当前控件.宽度) + "\n"
            文本 = 文本 + "height=" + 到文本 (当前控件.高度) + "\n"
            文本 = 文本 + "visible=" + 选择 (当前控件.可视, "true", "false") + "\n"
            文本 = 文本 + "enabled=" + 选择 (当前控件.允许, "true", "false") + "\n"
            文本 = 文本 + "event.click=" + 规范字段值 (当前控件.单击事件) + "\n"
            文本 = 文本 + "event.change=" + 规范字段值 (当前控件.内容改变事件) + "\n"
            索引 = 索引 + 1
        }
        返回 (文本)
    }

    方法 转义C加加文本 <公开 静态 类型 = 文本型>
    参数 原文本 <类型 = 文本型>
    {
        变量 结果 <类型 = 文本型>
        变量 当前字符 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        索引 = 0
        判断循环 (索引 < 文本类.取文本长度 (原文本))
        {
            当前字符 = 文本类.取文本中间 (原文本, 索引, 1)
            如果 (当前字符 == "\\")
            {
                结果 = 结果 + "\\\\"
            }
            否则 (当前字符 == "\"")
            {
                结果 = 结果 + "\\\""
            }
            否则 (当前字符 == "\r")
            {
                结果 = 结果 + "\\r"
            }
            否则 (当前字符 == "\n")
            {
                结果 = 结果 + "\\n"
            }
            否则
            {
                结果 = 结果 + 当前字符
            }
            索引 = 索引 + 1
        }
        返回 (结果)
    }

    方法 生成Win32运行时头 <公开 静态 类型 = 文本型>
    {
        返回 ("#ifndef UNICODE\r\n#define UNICODE\r\n#endif\r\n#ifndef _UNICODE\r\n#define _UNICODE\r\n#endif\r\n#include <windows.h>\r\n#include <commctrl.h>\r\n\r\ntypedef void (*CCIDE_WindowEventCallback)(const wchar_t* eventName, HWND windowHandle, int sourceId, int detail);\r\nstatic CCIDE_WindowEventCallback CCIDE_CurrentWindowEventCallback = NULL;\r\n\r\nextern \"C\" void CCIDE_SetWindowEventCallback(CCIDE_WindowEventCallback callback)\r\n{\r\n    CCIDE_CurrentWindowEventCallback = callback;\r\n}\r\n\r\nstatic void CCIDE_RaiseWindowEvent(const wchar_t* eventName, HWND windowHandle, int sourceId, int detail)\r\n{\r\n    if (CCIDE_CurrentWindowEventCallback != NULL && eventName != NULL && eventName[0] != L'\\0')\r\n    {\r\n        CCIDE_CurrentWindowEventCallback(eventName, windowHandle, sourceId, detail);\r\n    }\r\n}\r\n\r\n")
    }

    方法 生成Win32窗口代码 <公开 类型 = 文本型>
    参数 窗口序号 <类型 = 整数>
    参数 启动窗口 <类型 = 逻辑型>
    {
        变量 代码 <类型 = 文本型>
        变量 索引 <类型 = 整数>
        变量 当前控件 <类型 = 窗口设计控件>
        变量 样式文本 <类型 = 文本型>
        变量 原生类名 <类型 = 文本型>
        原生类名 = "CCIDE_DESIGN_WINDOW_" + 到文本 (窗口序号)
        代码 = "static void CCIDE_DispatchEvent_" + 到文本 (窗口序号) + "(HWND hwnd, int controlId, int notifyCode)\r\n{\r\n    (void)hwnd;\r\n    (void)notifyCode;\r\n    switch (controlId)\r\n    {\r\n"
        索引 = 0
        判断循环 (索引 < 控件组.取成员数 ())
        {
            当前控件 = 控件组.取成员 (索引)
            代码 = 代码 + "    case " + 到文本 (当前控件.标识) + ":"
            如果 (当前控件.单击事件 != "")
            {
                代码 = 代码 + " if (notifyCode == BN_CLICKED) CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (当前控件.单击事件) + "\", hwnd, controlId, notifyCode);"
            }
            如果 (当前控件.内容改变事件 != "")
            {
                代码 = 代码 + " if (notifyCode == EN_CHANGE) CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (当前控件.内容改变事件) + "\", hwnd, controlId, notifyCode);"
            }
            代码 = 代码 + " break;\r\n"
            索引 = 索引 + 1
        }
        代码 = 代码 + "    default: break;\r\n    }\r\n}\r\n\r\n"
        代码 = 代码 + "static LRESULT CALLBACK CCIDE_WindowProc_" + 到文本 (窗口序号) + "(HWND hwnd, UINT message, WPARAM wParam, LPARAM lParam)\r\n{\r\n    switch (message)\r\n    {\r\n    case WM_COMMAND:\r\n        CCIDE_DispatchEvent_" + 到文本 (窗口序号) + "(hwnd, LOWORD(wParam), HIWORD(wParam));\r\n        return 0;\r\n    case WM_SIZE:\r\n"
        如果 (尺寸改变事件 != "")
        {
            代码 = 代码 + "        CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (尺寸改变事件) + "\", hwnd, LOWORD(lParam), HIWORD(lParam));\r\n"
        }
        代码 = 代码 + "        return 0;\r\n    case WM_CLOSE:\r\n"
        如果 (关闭事件 != "")
        {
            代码 = 代码 + "        CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (关闭事件) + "\", hwnd, 0, 0);\r\n"
        }
        代码 = 代码 + "        DestroyWindow(hwnd);\r\n        return 0;\r\n    case WM_DESTROY:\r\n"
        如果 (启动窗口)
        {
            代码 = 代码 + "        PostQuitMessage(0);\r\n"
        }
        代码 = 代码 + "        return 0;\r\n    }\r\n    return DefWindowProcW(hwnd, message, wParam, lParam);\r\n}\r\n\r\n"
        代码 = 代码 + "static HWND CCIDE_CreateWindow_" + 到文本 (窗口序号) + "(HINSTANCE instance, int showCommand)\r\n{\r\n    const wchar_t* className = L\"" + 原生类名 + "\";\r\n    WNDCLASSEXW windowClass = {};\r\n    windowClass.cbSize = sizeof(windowClass);\r\n    windowClass.lpfnWndProc = CCIDE_WindowProc_" + 到文本 (窗口序号) + ";\r\n    windowClass.hInstance = instance;\r\n    windowClass.hCursor = LoadCursorW(NULL, IDC_ARROW);\r\n    windowClass.hbrBackground = CreateSolidBrush((COLORREF)" + 到文本 (背景颜色) + ");\r\n    windowClass.lpszClassName = className;\r\n    RegisterClassExW(&windowClass);\r\n    RECT windowRectangle = { 0, 0, " + 到文本 (窗口宽度) + ", " + 到文本 (窗口高度) + " };\r\n    AdjustWindowRectEx(&windowRectangle, WS_OVERLAPPEDWINDOW, FALSE, 0);\r\n    HWND hwnd = CreateWindowExW(0, className, L\"" + 转义C加加文本 (窗口标题) + "\", WS_OVERLAPPEDWINDOW, CW_USEDEFAULT, CW_USEDEFAULT, windowRectangle.right - windowRectangle.left, windowRectangle.bottom - windowRectangle.top, NULL, NULL, instance, NULL);\r\n    if (hwnd == NULL) return NULL;\r\n"
        索引 = 0
        判断循环 (索引 < 控件组.取成员数 ())
        {
            当前控件 = 控件组.取成员 (索引)
            样式文本 = "WS_CHILD | WS_TABSTOP"
            如果 (当前控件.可视)
            {
                样式文本 = 样式文本 + " | WS_VISIBLE"
            }
            如果 (当前控件.控件类型 == "button")
            {
                样式文本 = 样式文本 + " | BS_PUSHBUTTON"
                代码 = 代码 + "    HWND control" + 到文本 (索引) + " = CreateWindowExW(0, L\"BUTTON\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            否则 (当前控件.控件类型 == "label")
            {
                样式文本 = "WS_CHILD | SS_LEFT" + 选择 (当前控件.可视, " | WS_VISIBLE", "")
                代码 = 代码 + "    HWND control" + 到文本 (索引) + " = CreateWindowExW(0, L\"STATIC\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            否则 (当前控件.控件类型 == "edit")
            {
                样式文本 = 样式文本 + " | WS_BORDER | ES_AUTOHSCROLL"
                代码 = 代码 + "    HWND control" + 到文本 (索引) + " = CreateWindowExW(WS_EX_CLIENTEDGE, L\"EDIT\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            否则
            {
                样式文本 = 样式文本 + " | BS_AUTOCHECKBOX"
                代码 = 代码 + "    HWND control" + 到文本 (索引) + " = CreateWindowExW(0, L\"BUTTON\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            代码 = 代码 + 到文本 (当前控件.左边) + ", " + 到文本 (当前控件.顶边) + ", " + 到文本 (当前控件.宽度) + ", " + 到文本 (当前控件.高度) + ", hwnd, (HMENU)(INT_PTR)" + 到文本 (当前控件.标识) + ", instance, NULL);\r\n"
            如果 (当前控件.允许 == 假)
            {
                代码 = 代码 + "    EnableWindow(control" + 到文本 (索引) + ", FALSE);\r\n"
            }
            索引 = 索引 + 1
        }
        如果 (创建完毕事件 != "")
        {
            代码 = 代码 + "    CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (创建完毕事件) + "\", hwnd, 0, 0);\r\n"
        }
        代码 = 代码 + "    ShowWindow(hwnd, showCommand);\r\n    UpdateWindow(hwnd);\r\n    return hwnd;\r\n}\r\n\r\n"
        返回 (代码)
    }

    方法 生成Win32入口代码 <公开 静态 类型 = 文本型>
    参数 启动窗口序号 <类型 = 整数>
    {
        变量 代码 <类型 = 文本型>
        代码 = "int WINAPI WinMain(HINSTANCE instance, HINSTANCE previousInstance, LPSTR commandLine, int showCommand)\r\n{\r\n    (void)previousInstance;\r\n    (void)commandLine;\r\n    INITCOMMONCONTROLSEX commonControls = {};\r\n    commonControls.dwSize = sizeof(commonControls);\r\n    commonControls.dwICC = ICC_WIN95_CLASSES;\r\n    InitCommonControlsEx(&commonControls);\r\n    HWND mainWindow = CCIDE_CreateWindow_" + 到文本 (启动窗口序号) + "(instance, showCommand);\r\n    if (mainWindow == NULL) return 1;\r\n    MSG message = {};\r\n    while (GetMessageW(&message, NULL, 0, 0) > 0)\r\n    {\r\n        TranslateMessage(&message);\r\n        DispatchMessageW(&message);\r\n    }\r\n    return (int)message.wParam;\r\n}\r\n"
        返回 (代码)
    }

    方法 生成MFC运行时头 <公开 静态 类型 = 文本型>
    {
        返回 ("#include <afxwin.h>\r\n#include <afxcmn.h>\r\n\r\ntypedef void (*CCIDE_WindowEventCallback)(const wchar_t* eventName, HWND windowHandle, int sourceId, int detail);\r\nstatic CCIDE_WindowEventCallback CCIDE_CurrentWindowEventCallback = NULL;\r\n\r\nextern \"C\" void CCIDE_SetWindowEventCallback(CCIDE_WindowEventCallback callback)\r\n{\r\n    CCIDE_CurrentWindowEventCallback = callback;\r\n}\r\n\r\nstatic void CCIDE_RaiseWindowEvent(const wchar_t* eventName, HWND windowHandle, int sourceId, int detail)\r\n{\r\n    if (CCIDE_CurrentWindowEventCallback != NULL && eventName != NULL && eventName[0] != L'\\0')\r\n    {\r\n        CCIDE_CurrentWindowEventCallback(eventName, windowHandle, sourceId, detail);\r\n    }\r\n}\r\n\r\n")
    }

