        代码 = "class CCIDE_GeneratedApplication : public CWinApp\r\n{\r\npublic:\r\n    virtual BOOL InitInstance()\r\n    {\r\n        INITCOMMONCONTROLSEX commonControls = {};\r\n        commonControls.dwSize = sizeof(commonControls);\r\n        commonControls.dwICC = ICC_WIN95_CLASSES;\r\n        InitCommonControlsEx(&commonControls);\r\n        if (!CWinApp::InitInstance()) return FALSE;\r\n        AfxEnableControlContainer();\r\n        CFrameWnd* mainWindow = CCIDE_CreateMfcWindow_" + 到文本 (启动窗口序号) + "(m_nCmdShow);\r\n        if (mainWindow == NULL) return FALSE;\r\n        m_pMainWnd = mainWindow;\r\n        return TRUE;\r\n    }\r\n};\r\n\r\nCCIDE_GeneratedApplication CCIDE_ApplicationInstance;\r\n"
        返回 (代码)
    }
}

类 CCIDE窗口设计器 <公开 基础类 = 组件布局器 @视窗.布局 = "client_size = \"1100, 720\"">
{
    变量 选择工具按钮 <类型 = 按钮 @视窗.布局 = "id = 1701\r\npos = \"8, 6, 70, 28\"" 标题 = "选择" 可视 = 假>
    变量 添加按钮控件 <类型 = 按钮 @视窗.布局 = "id = 1702\r\npos = \"84, 6, 70, 28\"" 标题 = "按钮" 可视 = 假>
    变量 添加标签控件 <类型 = 按钮 @视窗.布局 = "id = 1703\r\npos = \"160, 6, 70, 28\"" 标题 = "标签" 可视 = 假>
    变量 添加编辑框控件 <类型 = 按钮 @视窗.布局 = "id = 1704\r\npos = \"236, 6, 78, 28\"" 标题 = "编辑框" 可视 = 假>
    变量 添加选择框控件 <类型 = 按钮 @视窗.布局 = "id = 1705\r\npos = \"320, 6, 78, 28\"" 标题 = "选择框" 可视 = 假>
    变量 删除控件按钮 <类型 = 按钮 @视窗.布局 = "id = 1706\r\npos = \"404, 6, 70, 28\"" 标题 = "删除">
    变量 打开代码按钮 <类型 = 按钮 @视窗.布局 = "id = 1707\r\npos = \"480, 6, 86, 28\"" 标题 = "打开代码">
    变量 控件树标题 <类型 = 标签 @视窗.布局 = "id = 1708\r\npos = \"8, 44, 198, 22\"" 标题 = "控件树" 可视 = 假>
    变量 控件树 <类型 = 增强树形框 @视窗.布局 = "id = 1709\r\npos = \"8, 68, 198, 640\"" 显示加减框 = 真 显示连线 = 真 显示根部线 = 真 始终显示选择项 = 真 行高 = 24 可视 = 假>
    变量 设计画板 <类型 = 画板 @视窗.布局 = "id = 1710\r\npos = \"214, 44, 576, 664\"" 画板背景色 = 0x00D8D8D8 自动重画 = 真 字体 = "微软雅黑, 9">
    变量 属性标题 <类型 = 标签 @视窗.布局 = "id = 1711\r\npos = \"798, 44, 294, 22\"" 标题 = "属性与事件" 可视 = 假>
    变量 属性表 <类型 = 属性表格 @视窗.布局 = "id = 1712\r\npos = \"798, 68, 294, 640\"" 左列宽度 = 42 显示描述栏 = 真 描述栏行数 = 3>
    变量 组件箱标题 <类型 = 标签 @视窗.布局 = "id = 1713\r\npos = \"8, 10, 198, 24\"" 标题 = "组件箱">
    变量 组件箱 <类型 = 增强树形框 @视窗.布局 = "id = 1714\r\npos = \"8, 44, 198, 664\"" 显示加减框 = 真 显示连线 = 真 显示根部线 = 真 始终显示选择项 = 真 行高 = 26>
    变量 控件树页按钮 <类型 = 按钮 @视窗.布局 = "id = 1715\r\npos = \"798, 8, 142, 28\"" 标题 = "控件树">
    变量 属性页按钮 <类型 = 按钮 @视窗.布局 = "id = 1716\r\npos = \"946, 8, 146, 28\"" 标题 = "属性">

    变量 设计文档 <公开 类型 = 窗口设计文档>
    变量 当前设计文件 <公开 类型 = 文本型>
    变量 当前选中控件 <类型 = 整数 值 = -1>
    变量 下一个控件标识 <类型 = 整数 值 = 1001>
    变量 正在刷新属性 <类型 = 逻辑型>
    变量 正在拖动 <类型 = 逻辑型>
    变量 拖动已改变 <类型 = 逻辑型>
    变量 拖动偏移横向 <类型 = 整数>
    变量 拖动偏移纵向 <类型 = 整数>
    变量 窗口绘制左边 <类型 = 整数>
    变量 窗口绘制顶边 <类型 = 整数>
    变量 客户区绘制左边 <类型 = 整数>
    变量 客户区绘制顶边 <类型 = 整数>
    变量 保存点文本 <类型 = 文本型>
    变量 当前工具类型 <类型 = 文本型>
    变量 当前右侧面板 <类型 = 整数 值 = 1>
    变量 组件箱指针项目 <类型 = 变整数>

    方法 设计内容被修改 <公开 定义事件 类型 = 整数>

    方法 请求打开代码文件 <公开 定义事件 类型 = 整数>
    参数 代码文件 <类型 = 文本型>

    方法 取当前内容 <公开 类型 = 文本型>
    {
        返回 (设计文档.取设计文本 ())
    }

    方法 置为保存点 <公开>
    {
        保存点文本 = 取当前内容 ()
    }

    方法 是否已修改 <公开 类型 = 逻辑型>
    {
        返回 (取当前内容 () != 保存点文本)
    }

    方法 载入设计内容 <公开 类型 = 逻辑型>
    参数 设计文本 <类型 = 文本型>
    参数 设计文件路径 <类型 = 文本型>
    {
        如果 (设计文档.载入设计文本 (设计文本) == 假)
        {
            返回 (假)
        }
        当前设计文件 = 设计文件路径
        当前选中控件 = -1
        计算下一个控件标识 ()
        重建控件树 ()
        刷新属性表 ()
        置为保存点 ()
        设计画板.重画 ()
        返回 (真)
    }

    方法 创建默认设计 <公开>
    参数 窗口名称 <类型 = 文本型>
    参数 窗口类名 <类型 = 文本型>
    参数 代码文件 <类型 = 文本型>
    参数 是否启动 <类型 = 逻辑型>
    {
        设计文档.创建默认文档 (窗口名称, 窗口类名, 代码文件, 是否启动)
        当前选中控件 = -1
        下一个控件标识 = 1001
        重建控件树 ()
        刷新属性表 ()
        置为保存点 ()
        设计画板.重画 ()
    }

    方法 计算下一个控件标识 <公开>
    {
        变量 索引 <类型 = 整数>
        下一个控件标识 = 1001
        索引 = 0
        判断循环 (索引 < 设计文档.控件组.取成员数 ())
        {
            如果 (设计文档.控件组.取成员 (索引).标识 >= 下一个控件标识)
            {
                下一个控件标识 = 设计文档.控件组.取成员 (索引).标识 + 1
            }
            索引 = 索引 + 1
        }
    }

    方法 标记设计被修改 <公开>
    {
        设计内容被修改 ()
    }

    方法 初始化组件箱 <公开>
    {
        变量 常规分类 <类型 = 变整数>
        变量 标准控件分类 <类型 = 变整数>
        组件箱.清空 ()
        常规分类 = 组件箱.加入项目 (-1, "常规", 0, -1, 0, 真)
        组件箱指针项目 = 组件箱.加入项目 (常规分类, "指针", 0, -1, 1, 假)
        标准控件分类 = 组件箱.加入项目 (-1, "标准控件", 0, -1, 0, 真)
        组件箱.加入项目 (标准控件分类, "按钮", 0, -1, 2, 假)
        组件箱.加入项目 (标准控件分类, "标签", 0, -1, 3, 假)
        组件箱.加入项目 (标准控件分类, "编辑框", 0, -1, 4, 假)
        组件箱.加入项目 (标准控件分类, "选择框", 0, -1, 5, 假)
        组件箱.扩展 (常规分类)
        组件箱.扩展 (标准控件分类)
        选择指针工具 ()
    }

    方法 选择指针工具 <公开>
    {
        当前工具类型 = ""
        如果 (组件箱指针项目 != -1)
        {
            组件箱.现行选中项 = 组件箱指针项目
        }
    }

    方法 切换右侧面板 <公开>
    参数 面板类型 <类型 = 整数>
    {
        当前右侧面板 = 选择 (面板类型 == 0, 0, 1)
        控件树.可视 = 当前右侧面板 == 0
        属性表.可视 = 当前右侧面板 == 1
        控件树页按钮.禁止 = 当前右侧面板 == 0
        属性页按钮.禁止 = 当前右侧面板 == 1
    }

    方法 添加控件到位置 <公开>
    参数 控件类型 <类型 = 文本型>
    参数 中心横向位置 <类型 = 整数>
    参数 中心纵向位置 <类型 = 整数>
    {
        变量 新控件 <类型 = 窗口设计控件>
        变量 新左边 <类型 = 整数>
        变量 新顶边 <类型 = 整数>
        新控件.初始化 (控件类型, 设计文档.控件组.取成员数 () + 1, 下一个控件标识)
        下一个控件标识 = 下一个控件标识 + 1
        如果 (中心横向位置 < 0 || 中心纵向位置 < 0)
        {
            中心横向位置 = 设计文档.窗口宽度 / 2
            中心纵向位置 = 设计文档.窗口高度 / 2
        }
        新左边 = 中心横向位置 - 新控件.宽度 / 2
        新顶边 = 中心纵向位置 - 新控件.高度 / 2
        新左边 = (新左边 / 5) * 5
        新顶边 = (新顶边 / 5) * 5
        新控件.左边 = 限制数值 (新左边, 0, 设计文档.窗口宽度 - 新控件.宽度)
        新控件.顶边 = 限制数值 (新顶边, 0, 设计文档.窗口高度 - 新控件.高度)
        设计文档.控件组.加入成员 (新控件)
        当前选中控件 = 设计文档.控件组.取成员数 () - 1
        重建控件树 ()
        刷新属性表 ()
        设计画板.重画 ()
        标记设计被修改 ()
    }

    方法 添加控件 <公开>
    参数 控件类型 <类型 = 文本型>
    {
        添加控件到位置 (控件类型, -1, -1)
    }

    方法 删除当前控件 <公开>
    {
        如果 (当前选中控件 < 0 || 当前选中控件 >= 设计文档.控件组.取成员数 ())
        {
            返回
        }
        设计文档.控件组.删除成员 (当前选中控件, 1)
        当前选中控件 = -1
        重建控件树 ()
        刷新属性表 ()
        设计画板.重画 ()
        标记设计被修改 ()
    }

    方法 重建控件树 <公开>
    {
        变量 根项目 <类型 = 变整数>
        变量 当前项目 <类型 = 变整数>
        变量 索引 <类型 = 整数>
        控件树.清空 ()
        根项目 = 控件树.加入项目 (-1, 设计文档.窗口名称 + " (" + 设计文档.窗口类名 + ")", 0, -1, 0, 真)
        如果 (当前选中控件 < 0)
        {
            控件树.现行选中项 = 根项目
        }
        索引 = 0
        判断循环 (索引 < 设计文档.控件组.取成员数 ())
        {
            当前项目 = 控件树.加入项目 (根项目, 设计文档.控件组.取成员 (索引).名称 + " : " + 设计文档.控件组.取成员 (索引).取类型显示名称 (), 0, -1, 索引 + 1, 假)
            如果 (索引 == 当前选中控件)
            {
                控件树.现行选中项 = 当前项目
            }
            索引 = 索引 + 1
        }
        控件树.扩展 (根项目)
    }

    方法 刷新属性表 <公开>
    {
        变量 外观分组 <类型 = 变整数>
        变量 布局分组 <类型 = 变整数>
        变量 事件分组 <类型 = 变整数>
        变量 属性句柄 <类型 = 变整数>
        正在刷新属性 = 真
        属性表.修改后立即刷新 = 假
        属性表.清空 ()
        如果 (当前选中控件 < 0 || 当前选中控件 >= 设计文档.控件组.取成员数 ())
        {
            外观分组 = 属性表.加入分组属性 ("窗口")
            属性表.加入文本属性 ("名称", 设计文档.窗口名称, 外观分组, "窗口设计文件中的显示名称", 1)
            属性表.加入文本属性 ("类名", 设计文档.窗口类名, 外观分组, "生成代码时使用的窗口类名称", 2)
            属性表.加入文本属性 ("标题", 设计文档.窗口标题, 外观分组, "运行时窗口标题", 3)
            属性句柄 = 属性表.加入文本属性 ("代码文件", 设计文档.关联代码文件, 外观分组, "与该设计器关联的 .n 代码文件", 4)
            属性表.禁止编辑属性 (属性句柄, 真)
            属性表.加入逻辑属性 ("启动窗口", 选择 (设计文档.是否启动窗口, "1", "0"), 外观分组, "程序启动时首先创建的窗口", 5)
            布局分组 = 属性表.加入分组属性 ("布局")
            属性表.加入整数属性 ("宽度", 到文本 (设计文档.窗口宽度), 布局分组, "窗口客户区宽度", 6)
            属性表.加入整数属性 ("高度", 到文本 (设计文档.窗口高度), 布局分组, "窗口客户区高度", 7)
            属性表.加入整数属性 ("背景颜色", 到文本 (设计文档.背景颜色), 布局分组, "窗口客户区颜色值", 8)
            事件分组 = 属性表.加入分组属性 ("事件")
            属性表.加入文本属性 ("创建完毕", 设计文档.创建完毕事件, 事件分组, "窗口创建完成后绑定的方法", 20)
            属性表.加入文本属性 ("尺寸改变", 设计文档.尺寸改变事件, 事件分组, "窗口客户区尺寸改变后绑定的方法", 21)
            属性表.加入文本属性 ("关闭", 设计文档.关闭事件, 事件分组, "窗口关闭前绑定的方法", 22)
        }
        否则
        {
            外观分组 = 属性表.加入分组属性 ("控件")
            属性表.加入文本属性 ("名称", 设计文档.控件组.取成员 (当前选中控件).名称, 外观分组, "控件变量名称", 101)
            属性句柄 = 属性表.加入文本属性 ("类型", 设计文档.控件组.取成员 (当前选中控件).取类型显示名称 (), 外观分组, "控件类型", 102)
            属性表.禁止编辑属性 (属性句柄, 真)
            属性表.加入文本属性 ("标题", 设计文档.控件组.取成员 (当前选中控件).标题, 外观分组, "控件显示文本", 103)
            属性表.加入逻辑属性 ("可视", 选择 (设计文档.控件组.取成员 (当前选中控件).可视, "1", "0"), 外观分组, "运行时是否显示", 108)
            属性表.加入逻辑属性 ("允许", 选择 (设计文档.控件组.取成员 (当前选中控件).允许, "1", "0"), 外观分组, "运行时是否允许操作", 109)
            布局分组 = 属性表.加入分组属性 ("布局")
            属性表.加入整数属性 ("左边", 到文本 (设计文档.控件组.取成员 (当前选中控件).左边), 布局分组, "相对窗口客户区的横向位置", 104)
            属性表.加入整数属性 ("顶边", 到文本 (设计文档.控件组.取成员 (当前选中控件).顶边), 布局分组, "相对窗口客户区的纵向位置", 105)
            属性表.加入整数属性 ("宽度", 到文本 (设计文档.控件组.取成员 (当前选中控件).宽度), 布局分组, "控件宽度", 106)
            属性表.加入整数属性 ("高度", 到文本 (设计文档.控件组.取成员 (当前选中控件).高度), 布局分组, "控件高度", 107)
            事件分组 = 属性表.加入分组属性 ("事件")
            如果 (设计文档.控件组.取成员 (当前选中控件).控件类型 == "button" || 设计文档.控件组.取成员 (当前选中控件).控件类型 == "checkbox")
            {
                属性表.加入文本属性 ("单击", 设计文档.控件组.取成员 (当前选中控件).单击事件, 事件分组, "单击后绑定的方法名称", 120)
            }
            如果 (设计文档.控件组.取成员 (当前选中控件).控件类型 == "edit")
            {
                属性表.加入文本属性 ("内容改变", 设计文档.控件组.取成员 (当前选中控件).内容改变事件, 事件分组, "内容改变后绑定的方法名称", 121)
            }
        }
        属性表.修改后立即刷新 = 真
        属性表.全部展开 ()
        正在刷新属性 = 假
    }

    方法 限制数值 <公开 类型 = 整数>
    参数 数值 <类型 = 整数>
    参数 最小值 <类型 = 整数>
    参数 最大值 <类型 = 整数>
    {
        如果 (数值 < 最小值)
        {
            返回 (最小值)
        }
        如果 (数值 > 最大值)
        {
            返回 (最大值)
        }
        返回 (数值)
    }

    方法 计算窗口绘制位置 <公开>
    {
        窗口绘制左边 = (设计画板.画板宽度 - 设计文档.窗口宽度 - 12) / 2
        如果 (窗口绘制左边 < 24)
        {
            窗口绘制左边 = 24
        }
        窗口绘制顶边 = 28
        客户区绘制左边 = 窗口绘制左边 + 6
        客户区绘制顶边 = 窗口绘制顶边 + 36
    }

    方法 绘制选择框 <公开>
    参数 左 <类型 = 整数>
    参数 顶 <类型 = 整数>
    参数 宽 <类型 = 整数>
    参数 高 <类型 = 整数>
    {
        设计画板.画笔颜色 = 0x00D97706
        设计画板.刷子颜色 = 颜色类.透明色
        设计画板.画矩形 (左 - 2, 顶 - 2, 左 + 宽 + 2, 顶 + 高 + 2)
        设计画板.刷子颜色 = 0x00FFFFFF
        设计画板.画矩形 (左 - 5, 顶 - 5, 左 + 1, 顶 + 1)
        设计画板.画矩形 (左 + 宽 - 1, 顶 - 5, 左 + 宽 + 5, 顶 + 1)
        设计画板.画矩形 (左 - 5, 顶 + 高 - 1, 左 + 1, 顶 + 高 + 5)
        设计画板.画矩形 (左 + 宽 - 1, 顶 + 高 - 1, 左 + 宽 + 5, 顶 + 高 + 5)
    }

    方法 绘制设计内容 <公开>
    {
        变量 索引 <类型 = 整数>
        变量 当前控件 <类型 = 窗口设计控件>
        变量 控件左 <类型 = 整数>
        变量 控件顶 <类型 = 整数>
        变量 窗口右边 <类型 = 整数>
        变量 窗口底边 <类型 = 整数>
        变量 标题栏顶边 <类型 = 整数>
        变量 标题栏底边 <类型 = 整数>
        变量 关闭按钮左边 <类型 = 整数>
        变量 最大化按钮左边 <类型 = 整数>
        变量 最小化按钮左边 <类型 = 整数>
        变量 文字左边 <类型 = 整数>
        变量 文字顶边 <类型 = 整数>
        设计画板.清除 (0, 0, 设计画板.画板宽度, 设计画板.画板高度)
        设计画板.画笔颜色 = 0x00D8D8D8
        设计画板.刷子颜色 = 0x00D8D8D8
        设计画板.画矩形 (0, 0, 设计画板.画板宽度, 设计画板.画板高度)
        计算窗口绘制位置 ()
        窗口右边 = 窗口绘制左边 + 设计文档.窗口宽度 + 12
        窗口底边 = 窗口绘制顶边 + 设计文档.窗口高度 + 42
        标题栏顶边 = 窗口绘制顶边 + 6
        标题栏底边 = 客户区绘制顶边
        关闭按钮左边 = 窗口右边 - 46
        最大化按钮左边 = 关闭按钮左边 - 46
        最小化按钮左边 = 最大化按钮左边 - 46

        设计画板.画笔颜色 = 0x00989898
        设计画板.刷子颜色 = 0x00A8A8A8
        设计画板.画矩形 (窗口绘制左边 + 6, 窗口绘制顶边 + 8, 窗口右边 + 6, 窗口底边 + 8)
        设计画板.画笔颜色 = 0x00606060
        设计画板.刷子颜色 = 0x00D77800
        设计画板.画矩形 (窗口绘制左边, 窗口绘制顶边, 窗口右边, 窗口底边)
        设计画板.画笔颜色 = 0x00D77800
        设计画板.刷子颜色 = 0x00D77800
        设计画板.画矩形 (窗口绘制左边 + 6, 标题栏顶边, 窗口右边 - 6, 标题栏底边)
        设计画板.文本背景颜色 = 颜色类.透明色
        设计画板.文本颜色 = 0x00FFFFFF
        设计画板.画笔颜色 = 0x00FFFFFF
        设计画板.刷子颜色 = 0x00FFFFFF
        设计画板.画矩形 (窗口绘制左边 + 12, 标题栏顶边 + 7, 窗口绘制左边 + 28, 标题栏顶边 + 23)
        设计画板.画笔颜色 = 0x00D77800
        设计画板.画直线 (窗口绘制左边 + 15, 标题栏顶边 + 12, 窗口绘制左边 + 25, 标题栏顶边 + 12)
        设计画板.画直线 (窗口绘制左边 + 15, 标题栏顶边 + 16, 窗口绘制左边 + 25, 标题栏顶边 + 16)
        设计画板.定位写出 (窗口绘制左边 + 34, 标题栏顶边 + 7, 设计文档.窗口标题)

        设计画板.画笔颜色 = 0x00B45F00
        设计画板.画直线 (最小化按钮左边, 标题栏顶边, 最小化按钮左边, 标题栏底边)
        设计画板.画直线 (最大化按钮左边, 标题栏顶边, 最大化按钮左边, 标题栏底边)
        设计画板.画直线 (关闭按钮左边, 标题栏顶边, 关闭按钮左边, 标题栏底边)
        设计画板.画笔颜色 = 0x00FFFFFF
        设计画板.画直线 (最小化按钮左边 + 17, 标题栏顶边 + 20, 最小化按钮左边 + 29, 标题栏顶边 + 20)
        设计画板.画矩形 (最大化按钮左边 + 17, 标题栏顶边 + 9, 最大化按钮左边 + 29, 标题栏顶边 + 21)
        设计画板.画直线 (关闭按钮左边 + 17, 标题栏顶边 + 9, 关闭按钮左边 + 29, 标题栏顶边 + 21)
        设计画板.画直线 (关闭按钮左边 + 29, 标题栏顶边 + 9, 关闭按钮左边 + 17, 标题栏顶边 + 21)

        设计画板.画笔颜色 = 0x00707070
        设计画板.刷子颜色 = 设计文档.背景颜色
        设计画板.画矩形 (客户区绘制左边, 客户区绘制顶边, 客户区绘制左边 + 设计文档.窗口宽度, 客户区绘制顶边 + 设计文档.窗口高度)
        索引 = 0
        判断循环 (索引 < 设计文档.控件组.取成员数 ())
        {
            当前控件 = 设计文档.控件组.取成员 (索引)
            控件左 = 客户区绘制左边 + 当前控件.左边
            控件顶 = 客户区绘制顶边 + 当前控件.顶边
            设计画板.文本背景颜色 = 颜色类.透明色
            设计画板.文本颜色 = 选择 (当前控件.允许, 0x00202020, 0x00888888)
            文字顶边 = 控件顶 + (当前控件.高度 - 16) / 2
            如果 (文字顶边 < 控件顶 + 2)
            {
                文字顶边 = 控件顶 + 2
            }
            如果 (当前控件.控件类型 == "label")
            {
                设计画板.定位写出 (控件左 + 2, 文字顶边, 当前控件.标题)
            }
            否则 (当前控件.控件类型 == "edit")
            {
                设计画板.画笔颜色 = 0x007A7A7A
                设计画板.刷子颜色 = 0x00FFFFFF
                设计画板.画矩形 (控件左, 控件顶, 控件左 + 当前控件.宽度, 控件顶 + 当前控件.高度)
                设计画板.画笔颜色 = 0x00D0D0D0
                设计画板.画直线 (控件左 + 1, 控件顶 + 1, 控件左 + 当前控件.宽度 - 1, 控件顶 + 1)
                设计画板.画直线 (控件左 + 1, 控件顶 + 1, 控件左 + 1, 控件顶 + 当前控件.高度 - 1)
                设计画板.定位写出 (控件左 + 5, 文字顶边, 当前控件.标题)
            }
            否则 (当前控件.控件类型 == "checkbox")
            {
                设计画板.画笔颜色 = 0x00686868
                设计画板.刷子颜色 = 0x00FFFFFF
                设计画板.画矩形 (控件左, 控件顶 + 4, 控件左 + 14, 控件顶 + 18)
                设计画板.定位写出 (控件左 + 20, 文字顶边, 当前控件.标题)
            }
            否则
            {
                设计画板.画笔颜色 = 0x00707070
                设计画板.刷子颜色 = 选择 (当前控件.允许, 0x00F0F0F0, 0x00DDDDDD)
                设计画板.画矩形 (控件左, 控件顶, 控件左 + 当前控件.宽度, 控件顶 + 当前控件.高度)
                设计画板.画笔颜色 = 0x00FFFFFF
                设计画板.画直线 (控件左 + 1, 控件顶 + 1, 控件左 + 当前控件.宽度 - 1, 控件顶 + 1)
                设计画板.画直线 (控件左 + 1, 控件顶 + 1, 控件左 + 1, 控件顶 + 当前控件.高度 - 1)
                设计画板.画笔颜色 = 0x00A0A0A0
                设计画板.画直线 (控件左 + 1, 控件顶 + 当前控件.高度 - 1, 控件左 + 当前控件.宽度 - 1, 控件顶 + 当前控件.高度 - 1)
                设计画板.画直线 (控件左 + 当前控件.宽度 - 1, 控件顶 + 1, 控件左 + 当前控件.宽度 - 1, 控件顶 + 当前控件.高度 - 1)
                文字左边 = 控件左 + (当前控件.宽度 - 文本类.取文本长度 (当前控件.标题) * 12) / 2
                如果 (文字左边 < 控件左 + 4)
                {
                    文字左边 = 控件左 + 4
                }
                设计画板.定位写出 (文字左边, 文字顶边, 当前控件.标题)
            }
            如果 (索引 == 当前选中控件)
            {
                绘制选择框 (控件左, 控件顶, 当前控件.宽度, 当前控件.高度)
            }
            索引 = 索引 + 1
        }
        如果 (当前选中控件 < 0)
        {
            绘制选择框 (窗口绘制左边, 窗口绘制顶边, 设计文档.窗口宽度 + 12, 设计文档.窗口高度 + 42)
        }
    }

    方法 命中控件 <公开 类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    {
        变量 索引 <类型 = 整数>
        变量 本地横向 <类型 = 整数>
        变量 本地纵向 <类型 = 整数>
        本地横向 = 横向位置 - 客户区绘制左边
        本地纵向 = 纵向位置 - 客户区绘制顶边
        索引 = 设计文档.控件组.取成员数 () - 1
        判断循环 (索引 >= 0)
        {
            如果 (本地横向 >= 设计文档.控件组.取成员 (索引).左边 && 本地横向 <= 设计文档.控件组.取成员 (索引).左边 + 设计文档.控件组.取成员 (索引).宽度 && 本地纵向 >= 设计文档.控件组.取成员 (索引).顶边 && 本地纵向 <= 设计文档.控件组.取成员 (索引).顶边 + 设计文档.控件组.取成员 (索引).高度)
            {
                返回 (索引)
            }
            索引 = 索引 - 1
        }
        返回 (-1)
    }

    方法 调整设计器布局 <公开>
    {
        变量 组件箱宽度 <类型 = 整数>
        变量 右侧宽度 <类型 = 整数>
        变量 内容高度 <类型 = 整数>
        变量 画布宽度 <类型 = 整数>
        变量 画布左边 <类型 = 整数>
        变量 右侧左边 <类型 = 整数>
        变量 右侧实际宽度 <类型 = 整数>
        变量 页按钮宽度 <类型 = 整数>
        组件箱宽度 = 220
        右侧宽度 = 312
        如果 (宽度 < 920)
        {
            组件箱宽度 = 184
            右侧宽度 = 264
        }
        内容高度 = 高度 - 52
        画布左边 = 组件箱宽度 + 8
        右侧左边 = 宽度 - 右侧宽度
        画布宽度 = 右侧左边 - 画布左边 - 8
        右侧实际宽度 = 宽度 - 右侧左边 - 8
        页按钮宽度 = (右侧实际宽度 - 6) / 2
        如果 (内容高度 < 80)
        {
            内容高度 = 80
        }
        如果 (画布宽度 < 200)
        {
            画布宽度 = 200
        }
        选择工具按钮.可视 = 假
        添加按钮控件.可视 = 假
        添加标签控件.可视 = 假
        添加编辑框控件.可视 = 假
        添加选择框控件.可视 = 假
        控件树标题.可视 = 假
        属性标题.可视 = 假
        组件箱标题.移动 (8, 10, 组件箱宽度 - 12, 24)
        组件箱.移动 (8, 44, 组件箱宽度 - 12, 内容高度)
        删除控件按钮.移动 (画布左边, 8, 72, 28)
        打开代码按钮.移动 (画布左边 + 80, 8, 92, 28)
        设计画板.移动 (画布左边, 44, 画布宽度, 内容高度)
        控件树页按钮.移动 (右侧左边, 8, 页按钮宽度, 28)
        属性页按钮.移动 (右侧左边 + 页按钮宽度 + 6, 8, 页按钮宽度, 28)
        控件树.移动 (右侧左边, 44, 右侧实际宽度, 内容高度)
        属性表.移动 (右侧左边, 44, 右侧实际宽度, 内容高度)
        切换右侧面板 (当前右侧面板)
        设计画板.重画 ()
    }

    方法 聚焦设计器 <公开>
    {
        设计画板.获取焦点 ()
    }

    方法 CCIDE窗口设计器_创建完毕 <接收事件 类型 = 整数>
