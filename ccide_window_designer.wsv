    方法 按钮_被单击 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 按钮>
    参数 标记值 <类型 = 整数>
    {
        如果 (来源对象 == 添加按钮控件)
        {
            添加控件 ("button")
        }
        否则 (来源对象 == 添加标签控件)
        {
            添加控件 ("label")
        }
        否则 (来源对象 == 添加编辑框控件)
        {
            添加控件 ("edit")
        }
        否则 (来源对象 == 添加选择框控件)
        {
            添加控件 ("checkbox")
        }
        否则 (来源对象 == 删除控件按钮)
        {
            删除当前控件 ()
        }
        否则 (来源对象 == 打开代码按钮)
        {
            请求打开代码文件 (设计文档.关联代码文件)
        }
        否则 (来源对象 == 控件树页按钮)
        {
            切换右侧面板 (0)
        }
        否则 (来源对象 == 属性页按钮)
        {
            切换右侧面板 (1)
        }
        否则 (来源对象 == 选择工具按钮)
        {
            选择指针工具 ()
        }
        返回 (0)
    }

    方法 增强树形框_项目被选择 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 增强树形框>
    参数 标记值 <类型 = 整数>
    参数 选择方式 <类型 = 整数>
    {
        如果 (来源对象 == 控件树 && 控件树.现行选中项 != -1)
        {
            当前选中控件 = 控件树.取项目数值 (控件树.现行选中项) - 1
            刷新属性表 ()
            设计画板.重画 ()
        }
        否则 (来源对象 == 组件箱 && 组件箱.现行选中项 != -1)
        {
            变量 组件类型值 <类型 = 整数>
            组件类型值 = 组件箱.取项目数值 (组件箱.现行选中项)
            如果 (组件类型值 == 1)
            {
                当前工具类型 = ""
            }
            否则 (组件类型值 == 2)
            {
                当前工具类型 = "button"
            }
            否则 (组件类型值 == 3)
            {
                当前工具类型 = "label"
            }
            否则 (组件类型值 == 4)
            {
                当前工具类型 = "edit"
            }
            否则 (组件类型值 == 5)
            {
                当前工具类型 = "checkbox"
            }
            否则
            {
                当前工具类型 = ""
            }
        }
        返回 (0)
    }

    方法 增强树形框_双击项目 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 增强树形框>
