            }
            代码 = 代码 + " break;\r\n"
            索引 = 索引 + 1
        }
        代码 = 代码 + "    default: break;\r\n    }\r\n}\r\n\r\n"
        代码 = 代码 + "class " + 原生类名 + " : public CFrameWnd\r\n{\r\npublic:\r\n    " + 原生类名 + "()\r\n    {\r\n        CRect windowRectangle(0, 0, " + 到文本 (窗口宽度) + ", " + 到文本 (窗口高度) + ");\r\n        ::AdjustWindowRectEx(&windowRectangle, WS_OVERLAPPEDWINDOW, FALSE, 0);\r\n        windowRectangle.OffsetRect(100 - windowRectangle.left, 100 - windowRectangle.top);\r\n        if (!Create(NULL, L\"" + 转义C加加文本 (窗口标题) + "\", WS_OVERLAPPEDWINDOW, windowRectangle)) return;\r\n        HWND hwnd = GetSafeHwnd();\r\n"
        索引 = 0
        判断循环 (索引 < 控件组.取成员数 ())
        {
            当前控件 = 控件组.取成员 (索引)
            样式文本 = "WS_CHILD | WS_TABSTOP"
            如果 (当前控件.可视)
            {
                样式文本 = 样式文本 + " | WS_VISIBLE"
            }
            如果 (当前控件.控件类型 == "button")
            {
                样式文本 = 样式文本 + " | BS_PUSHBUTTON"
                代码 = 代码 + "        HWND control" + 到文本 (索引) + " = CreateWindowExW(0, L\"BUTTON\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            否则 (当前控件.控件类型 == "label")
            {
                样式文本 = "WS_CHILD | SS_LEFT" + 选择 (当前控件.可视, " | WS_VISIBLE", "")
                代码 = 代码 + "        HWND control" + 到文本 (索引) + " = CreateWindowExW(0, L\"STATIC\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            否则 (当前控件.控件类型 == "edit")
            {
                样式文本 = 样式文本 + " | WS_BORDER | ES_AUTOHSCROLL"
                代码 = 代码 + "        HWND control" + 到文本 (索引) + " = CreateWindowExW(WS_EX_CLIENTEDGE, L\"EDIT\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            否则
            {
                样式文本 = 样式文本 + " | BS_AUTOCHECKBOX"
                代码 = 代码 + "        HWND control" + 到文本 (索引) + " = CreateWindowExW(0, L\"BUTTON\", L\"" + 转义C加加文本 (当前控件.标题) + "\", " + 样式文本 + ", "
            }
            代码 = 代码 + 到文本 (当前控件.左边) + ", " + 到文本 (当前控件.顶边) + ", " + 到文本 (当前控件.宽度) + ", " + 到文本 (当前控件.高度) + ", hwnd, (HMENU)(INT_PTR)" + 到文本 (当前控件.标识) + ", AfxGetInstanceHandle(), NULL);\r\n"
            如果 (当前控件.允许 == 假)
            {
                代码 = 代码 + "        EnableWindow(control" + 到文本 (索引) + ", FALSE);\r\n"
            }
            索引 = 索引 + 1
        }
        如果 (创建完毕事件 != "")
        {
            代码 = 代码 + "        CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (创建完毕事件) + "\", hwnd, 0, 0);\r\n"
        }
        代码 = 代码 + "    }\r\n\r\nprotected:\r\n    virtual BOOL OnCommand(WPARAM wParam, LPARAM lParam)\r\n    {\r\n        CCIDE_DispatchMfcEvent_" + 到文本 (窗口序号) + "(GetSafeHwnd(), LOWORD(wParam), HIWORD(wParam));\r\n        return CFrameWnd::OnCommand(wParam, lParam);\r\n    }\r\n\r\n    afx_msg void OnSize(UINT sizeType, int width, int height)\r\n    {\r\n        CFrameWnd::OnSize(sizeType, width, height);\r\n"
        如果 (尺寸改变事件 != "")
