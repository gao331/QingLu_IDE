        }
        代码 = 代码 + "    }\r\n\r\n    afx_msg void OnClose()\r\n    {\r\n"
        如果 (关闭事件 != "")
        {
            代码 = 代码 + "        CCIDE_RaiseWindowEvent(L\"" + 转义C加加文本 (关闭事件) + "\", GetSafeHwnd(), 0, 0);\r\n"
        }
        代码 = 代码 + "        CFrameWnd::OnClose();\r\n    }\r\n\r\n    afx_msg BOOL OnEraseBkgnd(CDC* deviceContext)\r\n    {\r\n        CRect clientArea;\r\n        GetClientRect(&clientArea);\r\n        deviceContext->FillSolidRect(&clientArea, (COLORREF)" + 到文本 (背景颜色) + ");\r\n        return TRUE;\r\n    }\r\n\r\n    DECLARE_MESSAGE_MAP()\r\n};\r\n\r\nBEGIN_MESSAGE_MAP(" + 原生类名 + ", CFrameWnd)\r\n    ON_WM_SIZE()\r\n    ON_WM_CLOSE()\r\n    ON_WM_ERASEBKGND()\r\nEND_MESSAGE_MAP()\r\n\r\nstatic CFrameWnd* CCIDE_CreateMfcWindow_" + 到文本 (窗口序号) + "(int showCommand)\r\n{\r\n    " + 原生类名 + "* window = new " + 原生类名 + "();\r\n    if (!::IsWindow(window->GetSafeHwnd()))\r\n    {\r\n        delete window;\r\n        return NULL;\r\n    }\r\n    window->ShowWindow(showCommand);\r\n    window->UpdateWindow();\r\n    return window;\r\n}\r\n\r\n"
        返回 (代码)
    }

    方法 生成MFC入口代码 <公开 静态 类型 = 文本型>
