        原生类名 = "CCIDE_MfcWindow_" + 到文本 (窗口序号)
        代码 = "static void CCIDE_DispatchMfcEvent_" + 到文本 (窗口序号) + "(HWND hwnd, int controlId, int notifyCode)\r\n{\r\n    switch (controlId)\r\n    {\r\n"
        索引 = 0
