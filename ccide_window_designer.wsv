    参数 重画区 <类型 = 矩形类>
    {
        如果 (来源对象 == 设计画板)
        {
            绘制设计内容 ()
        }
        返回 (0)
    }

    方法 画板_鼠标左键被按下 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        变量 命中索引 <类型 = 整数>
        变量 本地横向 <类型 = 整数>
        变量 本地纵向 <类型 = 整数>
        如果 (来源对象 != 设计画板)
        {
            返回 (0)
        }
        计算窗口绘制位置 ()
        如果 (当前工具类型 != "")
        {
            本地横向 = 横向位置 - 客户区绘制左边
            本地纵向 = 纵向位置 - 客户区绘制顶边
            如果 (本地横向 >= 0 && 本地横向 <= 设计文档.窗口宽度 && 本地纵向 >= 0 && 本地纵向 <= 设计文档.窗口高度)
            {
                添加控件到位置 (当前工具类型, 本地横向, 本地纵向)
                选择指针工具 ()
                返回 (0)
            }
        }
        命中索引 = 命中控件 (横向位置, 纵向位置)
        当前选中控件 = 命中索引
        正在拖动 = 命中索引 >= 0
        拖动已改变 = 假
        如果 (正在拖动)
        {
            本地横向 = 横向位置 - 客户区绘制左边
            本地纵向 = 纵向位置 - 客户区绘制顶边
            拖动偏移横向 = 本地横向 - 设计文档.控件组.取成员 (当前选中控件).左边
            拖动偏移纵向 = 本地纵向 - 设计文档.控件组.取成员 (当前选中控件).顶边
        }
        重建控件树 ()
        刷新属性表 ()
        设计画板.重画 ()
        返回 (0)
    }

    方法 画板_鼠标位置被移动 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        变量 新左边 <类型 = 整数>
        变量 新顶边 <类型 = 整数>
        如果 (来源对象 != 设计画板 || 正在拖动 == 假 || 当前选中控件 < 0)
        {
            返回 (0)
        }
        新左边 = 横向位置 - 客户区绘制左边 - 拖动偏移横向
        新顶边 = 纵向位置 - 客户区绘制顶边 - 拖动偏移纵向
        新左边 = (新左边 / 5) * 5
        新顶边 = (新顶边 / 5) * 5
        新左边 = 限制数值 (新左边, 0, 设计文档.窗口宽度 - 设计文档.控件组.取成员 (当前选中控件).宽度)
        新顶边 = 限制数值 (新顶边, 0, 设计文档.窗口高度 - 设计文档.控件组.取成员 (当前选中控件).高度)
        如果 (新左边 != 设计文档.控件组.取成员 (当前选中控件).左边 || 新顶边 != 设计文档.控件组.取成员 (当前选中控件).顶边)
        {
            设计文档.控件组.取成员 (当前选中控件).左边 = 新左边
            设计文档.控件组.取成员 (当前选中控件).顶边 = 新顶边
            拖动已改变 = 真
            设计画板.重画 ()
        }
        返回 (0)
    }

    方法 画板_鼠标左键被放开 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
    参数 标记值 <类型 = 整数>
    参数 横向位置 <类型 = 整数>
    参数 纵向位置 <类型 = 整数>
    参数 辅助键状态 <类型 = 整数>
    {
        如果 (来源对象 == 设计画板)
        {
            正在拖动 = 假
            如果 (拖动已改变)
            {
                刷新属性表 ()
                标记设计被修改 ()
            }
            拖动已改变 = 假
        }
        返回 (0)
    }
}
