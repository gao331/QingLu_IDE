        {
            添加控件 (当前工具类型)
            选择指针工具 ()
        }
        否则 (来源对象 == 控件树)
        {
            切换右侧面板 (1)
        }
        返回 (0)
    }

    方法 属性表格_属性值被改变 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 属性表格>
    参数 标记值 <类型 = 整数>
    参数 属性标识值 <类型 = 变整数>
    参数 属性值 <类型 = 文本型>
    {
        变量 用户数值 <类型 = 变整数>
        变量 数值 <类型 = 整数>
        如果 (来源对象 != 属性表 || 正在刷新属性)
        {
            返回 (0)
        }
        用户数值 = 属性表.取用户数值 (属性标识值)
        如果 (当前选中控件 < 0)
        {
            如果 (用户数值 == 1)
            {
                设计文档.窗口名称 = 窗口设计文档.规范字段值 (属性值)
            }
            否则 (用户数值 == 2)
            {
                设计文档.窗口类名 = 窗口设计文档.规范字段值 (属性值)
            }
            否则 (用户数值 == 3)
            {
                设计文档.窗口标题 = 属性值
            }
            否则 (用户数值 == 5)
            {
                设计文档.是否启动窗口 = 属性值 == "1"
            }
            否则 (用户数值 == 6)
            {
                数值 = 限制数值 (文本到整数 (属性值), 240, 2400)
                设计文档.窗口宽度 = 数值
                属性表.置属性值 (属性标识值, 到文本 (数值))
            }
            否则 (用户数值 == 7)
            {
                数值 = 限制数值 (文本到整数 (属性值), 160, 1600)
                设计文档.窗口高度 = 数值
                属性表.置属性值 (属性标识值, 到文本 (数值))
            }
            否则 (用户数值 == 8)
            {
                数值 = 限制数值 (文本到整数 (属性值), 0, 16777215)
                设计文档.背景颜色 = 数值
                属性表.置属性值 (属性标识值, 到文本 (数值))
            }
            否则 (用户数值 == 20)
            {
                设计文档.创建完毕事件 = 属性值
            }
            否则 (用户数值 == 21)
            {
                设计文档.尺寸改变事件 = 属性值
            }
            否则 (用户数值 == 22)
            {
                设计文档.关闭事件 = 属性值
            }
        }
        否则 (当前选中控件 < 设计文档.控件组.取成员数 ())
        {
            如果 (用户数值 == 101)
            {
                设计文档.控件组.取成员 (当前选中控件).名称 = 窗口设计文档.规范字段值 (属性值)
            }
            否则 (用户数值 == 103)
            {
                设计文档.控件组.取成员 (当前选中控件).标题 = 属性值
            }
            否则 (用户数值 == 104)
            {
                设计文档.控件组.取成员 (当前选中控件).左边 = 限制数值 (文本到整数 (属性值), 0, 4000)
            }
            否则 (用户数值 == 105)
            {
                设计文档.控件组.取成员 (当前选中控件).顶边 = 限制数值 (文本到整数 (属性值), 0, 4000)
            }
            否则 (用户数值 == 106)
            {
                设计文档.控件组.取成员 (当前选中控件).宽度 = 限制数值 (文本到整数 (属性值), 8, 2000)
            }
            否则 (用户数值 == 107)
            {
                设计文档.控件组.取成员 (当前选中控件).高度 = 限制数值 (文本到整数 (属性值), 8, 1200)
            }
            否则 (用户数值 == 108)
            {
                设计文档.控件组.取成员 (当前选中控件).可视 = 属性值 == "1"
            }
            否则 (用户数值 == 109)
            {
                设计文档.控件组.取成员 (当前选中控件).允许 = 属性值 == "1"
            }
            否则 (用户数值 == 120)
            {
                设计文档.控件组.取成员 (当前选中控件).单击事件 = 属性值
            }
            否则 (用户数值 == 121)
            {
                设计文档.控件组.取成员 (当前选中控件).内容改变事件 = 属性值
            }
        }
        重建控件树 ()
        设计画板.重画 ()
        标记设计被修改 ()
        返回 (0)
    }

    方法 画板_绘画 <接收事件 类型 = 整数>
    参数 来源对象 <类型 = 画板>
