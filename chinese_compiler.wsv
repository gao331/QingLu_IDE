        }
        如果 (文本类.寻找文本 (代码, "unordered_set", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<unordered_set>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <unordered_set>\n"
        }
        如果 (文本类.寻找文本 (代码, "set", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<set>", 0, 假) < 0 && 文本类.寻找文本 (代码, "unordered_set", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <set>\n"
        }
        如果 (文本类.寻找文本 (代码, "list", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<list>", 0, 假) < 0)
        {
