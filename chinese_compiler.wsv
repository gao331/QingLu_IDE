    方法 取块注释结束位置 <公开 类型 = 整数>
    参数 源码 <类型 = 文本型>
    参数 起始位置 <类型 = 整数>
    {
        变量 局位置 <类型 = 整数>
        局位置 = 起始位置 + 2
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (源码)
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局源码长度 + 10)
            {
                跳出循环 ()
            }
            如果 (局位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (源码, 局位置 - 1))
            如果 (局当前代码 == 42 && 局位置 < 局源码长度)
            {
                变量 局下一代码 <类型 = 整数>
                局下一代码 = 无符号字符到整数 (取字符 (源码, 局位置))
                如果 (局下一代码 == 47)
                {
                    返回 (局位置 + 2)
                }
            }
            局位置 = 局位置 + 1
        }
        循环判断尾 (局位置 <= 局源码长度)
        返回 (局位置)
    }

    方法 查找中文关键字 <公开 类型 = 文本型>
