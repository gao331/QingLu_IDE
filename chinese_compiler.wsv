    方法 智能替换 <公开 类型 = 文本型>
    参数 源码 <类型 = 文本型>
    参数 中文转英文 <类型 = 逻辑型>
    {
        变量 局结果 <类型 = 文本型>
        局结果 = ""
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (源码)
        变量 局位置 <类型 = 整数>
        局位置 = 1
        变量 局计数 <类型 = 整数>
        局计数 = 成员_中文关键字组.取成员数 ()
        变量 局安全计数 <类型 = 整数>
        局安全计数 = 0
        循环判断首 ()
        {
            局安全计数 = 局安全计数 + 1
            如果 (局安全计数 > 局源码长度 + 100)
            {
                跳出循环 ()
            }
            如果 (局位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (源码, 局位置 - 1))
            如果 (局当前代码 == 34)
            {
                变量 局串内容 <类型 = 文本型>
                变量 局串结束 <类型 = 整数>
                局串内容 = 提取字符串 (源码, 局位置)
                局串结束 = 取字符串结束位置 (源码, 局位置)
                局结果 = 局结果 + 局串内容
                局位置 = 局串结束
            }
            否则 (局当前代码 == 47 && 局位置 < 局源码长度)
            {
                变量 局下一代码 <类型 = 整数>
                局下一代码 = 无符号字符到整数 (取字符 (源码, 局位置))
                如果 (局下一代码 == 47)
                {
                    变量 局注释内容 <类型 = 文本型>
                    变量 局注释结束 <类型 = 整数>
                    局注释内容 = 提取行注释 (源码, 局位置)
                    局注释结束 = 取行注释结束位置 (源码, 局位置)
                    局结果 = 局结果 + 局注释内容
                    局位置 = 局注释结束
                }
                否则 (局下一代码 == 42)
                {
                    变量 局块注释内容 <类型 = 文本型>
                    变量 局块注释结束 <类型 = 整数>
                    局块注释内容 = 提取块注释 (源码, 局位置)
                    局块注释结束 = 取块注释结束位置 (源码, 局位置)
                    局结果 = 局结果 + 局块注释内容
                    局位置 = 局块注释结束
                }
                否则
                {
                    变量 局匹配长度 <类型 = 整数>
                    变量 局替换文本 <类型 = 文本型>
                    局匹配长度 = 尝试替换关键字 (源码, 局位置, 局计数, 中文转英文, 局替换文本)
                    局结果 = 局结果 + 局替换文本
                    局位置 = 局位置 + 局匹配长度
                }
            }
            否则
            {
                变量 局匹配长度2 <类型 = 整数>
                变量 局替换文本2 <类型 = 文本型>
                局匹配长度2 = 尝试替换关键字 (源码, 局位置, 局计数, 中文转英文, 局替换文本2)
                局结果 = 局结果 + 局替换文本2
                局位置 = 局位置 + 局匹配长度2
            }
        }
        循环判断尾 (局位置 <= 局源码长度)
        返回 (局结果)
    }

    方法 尝试替换关键字 <公开 类型 = 整数>
    参数 源码 <类型 = 文本型>
    参数 位置 <类型 = 整数>
    参数 计数 <类型 = 整数>
    参数 中文转英文 <类型 = 逻辑型>
    参数 输出替换文本 <类型 = 文本型>
    {
        变量 局索引 <类型 = 整数>
        循环 (局索引 = 0; 局索引 < 计数; 局索引++)
        {
            变量 局源关键字 <类型 = 文本型>
            变量 局目标关键字 <类型 = 文本型>
            如果 (中文转英文)
            {
                局源关键字 = 成员_中文关键字组.取成员 (局索引)
                局目标关键字 = 成员_英文关键字组.取成员 (局索引)
            }
            否则
            {
                局源关键字 = 成员_英文关键字组.取成员 (局索引)
                局目标关键字 = 成员_中文关键字组.取成员 (局索引)
            }
            变量 局关键字长度 <类型 = 整数>
            局关键字长度 = 取文本长度 (局源关键字)
            如果 (位置 + 局关键字长度 - 1 <= 取文本长度 (源码))
            {
                变量 局截取文本 <类型 = 文本型>
                局截取文本 = 取文本中间 (源码, 位置 - 1, 局关键字长度)
                如果 (文本比较 (局截取文本, 局源关键字, 真) == 0)
                {
                    如果 (是否为完整词 (源码, 位置, 局关键字长度))
                    {
                        输出替换文本 = 局目标关键字
                        返回 (局关键字长度)
                    }
                }
            }
        }
        输出替换文本 = 取文本中间 (源码, 位置 - 1, 1)
        返回 (1)
    }

    方法 是否为完整词 <公开 类型 = 逻辑型>
    参数 源码 <类型 = 文本型>
    参数 位置 <类型 = 整数>
    参数 长度 <类型 = 整数>
    {
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (源码)
        如果 (位置 > 1)
        {
            变量 局前一代码 <类型 = 整数>
            局前一代码 = 无符号字符到整数 (取字符 (源码, 位置 - 2))
            如果 (是否为标识符字符 (局前一代码))
            {
                返回 (假)
            }
        }
        变量 局后位置 <类型 = 整数>
        局后位置 = 位置 + 长度
        如果 (局后位置 <= 局源码长度)
        {
            变量 局后一代码 <类型 = 整数>
            局后一代码 = 无符号字符到整数 (取字符 (源码, 局后位置 - 1))
            如果 (是否为标识符字符 (局后一代码))
            {
                返回 (假)
            }
        }
        返回 (真)
    }

    方法 是否为标识符字符 <公开 类型 = 逻辑型>
    参数 字符代码 <类型 = 整数>
    {
        如果 (字符代码 >= 48 && 字符代码 <= 57)
