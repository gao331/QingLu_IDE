    方法 添加所需头文件 <公开 类型 = 文本型>
    参数 代码 <类型 = 文本型>
    {
        变量 需加头文件 <类型 = 文本型>
        需加头文件 = ""
        如果 ((文本类.寻找文本 (代码, "cout", 0, 假) >= 0 || 文本类.寻找文本 (代码, "cin", 0, 假) >= 0 || 文本类.寻找文本 (代码, "endl", 0, 假) >= 0) && 文本类.寻找文本 (代码, "<iostream>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <iostream>\n"
        }
        如果 (文本类.寻找文本 (代码, "vector", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<vector>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <vector>\n"
        }
        如果 (文本类.寻找文本 (代码, "string", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<string>", 0, 假) < 0 && 文本类.寻找文本 (代码, "stringstream", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <string>\n"
        }
        如果 (文本类.寻找文本 (代码, "unordered_map", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<unordered_map>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <unordered_map>\n"
        }
        如果 (文本类.寻找文本 (代码, "map", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<map>", 0, 假) < 0 && 文本类.寻找文本 (代码, "unordered_map", 0, 假) < 0)
        {
