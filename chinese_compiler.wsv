    方法 添加缺失分号 <公开 类型 = 文本型>
    参数 代码 <类型 = 文本型>
    {
        变量 行组 <类型 = 文本数组类>
        文本类.分割子文本 (代码, "\n", 行组, 假, 假)
        变量 局结果 <类型 = 文本型>
        局结果 = ""
        变量 局行数 <类型 = 整数>
        局行数 = 行组.取成员数 ()
        变量 局索引 <类型 = 整数>
        循环 (局索引 = 0; 局索引 < 局行数; 局索引++)
        {
            变量 当前行 <类型 = 文本型>
            当前行 = 行组.取成员 (局索引)
            如果 (取文本长度 (当前行) > 0)
            {
                变量 尾字符2 <类型 = 文本型>
                尾字符2 = 文本类.取文本右边 (当前行, 1)
                如果 (尾字符2 == "\r")
                {
                    当前行 = 文本类.取文本左边 (当前行, 取文本长度 (当前行) - 1)
                }
            }
            变量 去尾行 <类型 = 文本型>
            去尾行 = 文本类.删首尾空 (当前行)
            如果 (去尾行 == "")
            {
                局结果 = 局结果 + 当前行
            }
            否则 (文本类.寻找文本 (去尾行, "//", 0, 真) == 0)
            {
                局结果 = 局结果 + 当前行
            }
            否则 (文本类.寻找文本 (去尾行, "#", 0, 真) == 0)
            {
                局结果 = 局结果 + 当前行
            }
            否则
            {
                变量 尾字符 <类型 = 文本型>
                尾字符 = 文本类.取文本右边 (去尾行, 1)
                如果 (尾字符 == ";" || 尾字符 == "{" || 尾字符 == "}" || 尾字符 == "," || 尾字符 == ":" || 尾字符 == "\\")
                {
                    局结果 = 局结果 + 当前行
                }
                否则 (尾字符 == ")")
                {
                    变量 下行有花括号 <类型 = 逻辑型>
                    下行有花括号 = 假
                    变量 下行索引 <类型 = 整数>
                    下行索引 = 局索引 + 1
                    循环判断首 ()
                    {
                        如果 (下行索引 >= 局行数)
                        {
                            跳出循环 ()
                        }
                        变量 下行 <类型 = 文本型>
                        下行 = 文本类.删首尾空 (行组.取成员 (下行索引))
                        如果 (下行 != "")
                        {
                            如果 (文本类.取文本右边 (下行, 1) == "\r")
                            {
                                下行 = 文本类.取文本左边 (下行, 取文本长度 (下行) - 1)
                                下行 = 文本类.删首尾空 (下行)
                            }
                            如果 (下行 == "{" || 文本类.寻找文本 (下行, "{", 0, 真) == 0)
                            {
                                下行有花括号 = 真
                            }
                            跳出循环 ()
                        }
                        下行索引 = 下行索引 + 1
                    }
                    循环判断尾 (下行索引 < 局行数)
                    如果 (下行有花括号)
                    {
                        局结果 = 局结果 + 当前行
                    }
                    否则
                    {
                        局结果 = 局结果 + 当前行 + ";"
                    }
                }
                否则
                {
                    局结果 = 局结果 + 当前行 + ";"
                }
            }
            如果 (局索引 < 局行数 - 1)
            {
                局结果 = 局结果 + "\n"
            }
        }
        返回 (局结果)
    }

    方法 转换中文标识符 <公开 类型 = 文本型>
    参数 代码 <类型 = 文本型>
    {
        变量 局标识名组 <类型 = 文本数组类>
        变量 局替换名组 <类型 = 文本数组类>
        变量 局编号 <类型 = 整数>
        局编号 = 0
        变量 局结果 <类型 = 文本型>
        局结果 = ""
        变量 局位置 <类型 = 整数>
        局位置 = 1
        变量 局长度 <类型 = 整数>
        局长度 = 取文本长度 (代码)
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局长度 + 100)
            {
                跳出循环 ()
            }
            如果 (局位置 > 局长度)
            {
                跳出循环 ()
            }
            变量 局当前码 <类型 = 整数>
            局当前码 = 无符号字符到整数 (取字符 (代码, 局位置 - 1))
            如果 (局当前码 == 34)
            {
                变量 局串内容 <类型 = 文本型>
                变量 局串结束 <类型 = 整数>
                局串内容 = 提取字符串 (代码, 局位置)
                局串结束 = 取字符串结束位置 (代码, 局位置)
                局结果 = 局结果 + 局串内容
                局位置 = 局串结束
            }
            否则 (局当前码 == 47 && 局位置 < 局长度)
            {
                变量 局下一码 <类型 = 整数>
                局下一码 = 无符号字符到整数 (取字符 (代码, 局位置))
                如果 (局下一码 == 47)
                {
                    变量 局注释内容 <类型 = 文本型>
                    变量 局注释结束 <类型 = 整数>
                    局注释内容 = 提取行注释 (代码, 局位置)
                    局注释结束 = 取行注释结束位置 (代码, 局位置)
                    局结果 = 局结果 + 局注释内容
                    局位置 = 局注释结束
                }
                否则 (局下一码 == 42)
                {
                    变量 局块注释内容 <类型 = 文本型>
                    变量 局块注释结束 <类型 = 整数>
                    局块注释内容 = 提取块注释 (代码, 局位置)
                    局块注释结束 = 取块注释结束位置 (代码, 局位置)
                    局结果 = 局结果 + 局块注释内容
                    局位置 = 局块注释结束
                }
                否则
                {
                    局结果 = 局结果 + 到文本 ((字符) 局当前码)
                    局位置 = 局位置 + 1
                }
            }
            否则 (局当前码 > 127)
            {
                变量 局中文标识 <类型 = 文本型>
                局中文标识 = ""
                循环判断首 ()
                {
                    如果 (局位置 > 局长度)
                    {
                        跳出循环 ()
                    }
                    变量 局中码 <类型 = 整数>
                    局中码 = 无符号字符到整数 (取字符 (代码, 局位置 - 1))
                    如果 (局中码 > 127 || (局中码 >= 48 && 局中码 <= 57) || (局中码 >= 65 && 局中码 <= 90) || (局中码 >= 97 && 局中码 <= 122) || 局中码 == 95)
                    {
                        局中文标识 = 局中文标识 + 到文本 ((字符) 局中码)
                        局位置 = 局位置 + 1
                    }
                    否则
                    {
                        跳出循环 ()
                    }
                }
                循环判断尾 (局位置 <= 局长度)
                变量 局已存在 <类型 = 逻辑型>
                局已存在 = 假
                变量 局映射索引 <类型 = 整数>
                局映射索引 = 0
                循环 (局映射索引 = 0; 局映射索引 < 局标识名组.取成员数 (); 局映射索引++)
                {
                    如果 (文本比较 (局标识名组.取成员 (局映射索引), 局中文标识, 真) == 0)
                    {
                        局已存在 = 真
                        跳出循环 ()
                    }
                }
                变量 局替换名 <类型 = 文本型>
                如果 (局已存在)
                {
                    局替换名 = 局替换名组.取成员 (局映射索引)
                }
                否则
                {
                    局替换名 = "_z" + 到文本 (局编号)
                    局标识名组.加入成员 (局中文标识)
                    局替换名组.加入成员 (局替换名)
                    局编号 = 局编号 + 1
                }
                局结果 = 局结果 + 局替换名
            }
            否则
            {
                局结果 = 局结果 + 到文本 ((字符) 局当前码)
                局位置 = 局位置 + 1
            }
        }
        循环判断尾 (局位置 <= 局长度)
        返回 (局结果)
    }
}

类 词法分析器 <公开>
{
    变量 成员_源码 <类型 = 文本型>
    变量 成员_位置 <类型 = 整数>
    变量 成员_当前行号 <类型 = 整数>
    变量 成员_Token类型组 <类型 = 文本数组类>
    变量 成员_Token文本组 <类型 = 文本数组类>
    变量 成员_Token行号组 <类型 = 整数数组类>
    变量 成员_错误信息组 <类型 = 文本数组类>
    变量 成员_关键字查找器 <类型 = 中文编译器>

    方法 初始化 <公开>
    参数 输入源码 <类型 = 文本型>
    {
        成员_源码 = 输入源码
        成员_位置 = 1
        成员_当前行号 = 1
        成员_Token类型组.删除所有成员 ()
        成员_Token文本组.删除所有成员 ()
        成员_Token行号组.删除所有成员 ()
        成员_错误信息组.删除所有成员 ()
        成员_关键字查找器.初始化 ()
    }

    方法 执行词法分析 <公开>
    {
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局源码长度 + 100)
            {
                跳出循环 ()
            }
            如果 (成员_位置 > 局源码长度)
            {
                跳出循环 ()
            }
            跳过空白和注释 ()
            如果 (成员_位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            如果 (局当前代码 == 34)
            {
                分析字符串 ()
            }
            否则 (局当前代码 == 39)
            {
                分析字符字面量 ()
            }
            否则 (局当前代码 >= 48 && 局当前代码 <= 57)
            {
                分析数字 ()
            }
            否则 (是否为标识符首字符 (局当前代码))
            {
                分析标识符或关键字 ()
            }
            否则 (是否为运算符字符 (局当前代码))
            {
                分析运算符 ()
            }
            否则 (局当前代码 == 35)
            {
                分析预处理指令 ()
            }
            否则
            {
                加入Token ("分隔符", 到文本 ((字符) 局当前代码), 成员_当前行号)
                成员_位置 = 成员_位置 + 1
            }
        }
        循环判断尾 (成员_位置 <= 局源码长度)
        加入Token ("结束", "", 成员_当前行号)
    }

    方法 跳过空白和注释 <公开>
    {
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局源码长度 + 10)
            {
                跳出循环 ()
            }
            如果 (成员_位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            如果 (局当前代码 == 32 || 局当前代码 == 9 || 局当前代码 == 13 || 局当前代码 == 10)
            {
                如果 (局当前代码 == 10)
                {
                    成员_当前行号 = 成员_当前行号 + 1
                }
                成员_位置 = 成员_位置 + 1
            }
            否则 (局当前代码 == 47 && 成员_位置 < 局源码长度)
            {
                变量 局下一代码 <类型 = 整数>
                局下一代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置))
                如果 (局下一代码 == 47)
                {
                    成员_位置 = 成员_位置 + 2
                    循环判断首 ()
                    {
                        如果 (成员_位置 > 局源码长度)
                        {
                            跳出循环 ()
                        }
                        变量 局注释代码 <类型 = 整数>
                        局注释代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
                        如果 (局注释代码 == 10)
                        {
                            成员_当前行号 = 成员_当前行号 + 1
                            成员_位置 = 成员_位置 + 1
                            跳出循环 ()
                        }
                        成员_位置 = 成员_位置 + 1
                    }
                    循环判断尾 (成员_位置 <= 局源码长度)
                }
                否则 (局下一代码 == 42)
                {
                    成员_位置 = 成员_位置 + 2
                    循环判断首 ()
                    {
                        如果 (成员_位置 > 局源码长度)
                        {
                            成员_错误信息组.加入成员 ("第" + 到文本 (成员_当前行号) + "行: 未闭合的块注释")
                            跳出循环 ()
                        }
                        变量 局注释代码2 <类型 = 整数>
                        局注释代码2 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
                        如果 (局注释代码2 == 10)
                        {
                            成员_当前行号 = 成员_当前行号 + 1
                        }
                        否则 (局注释代码2 == 42 && 成员_位置 < 局源码长度)
                        {
                            变量 局再下一代码 <类型 = 整数>
                            局再下一代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置))
                            如果 (局再下一代码 == 47)
                            {
                                成员_位置 = 成员_位置 + 2
                                跳出循环 ()
                            }
                        }
                        成员_位置 = 成员_位置 + 1
                    }
                    循环判断尾 (成员_位置 <= 局源码长度)
                }
                否则
                {
                    跳出循环 ()
                }
            }
            否则
            {
                跳出循环 ()
            }
        }
        循环判断尾 (成员_位置 <= 局源码长度)
    }

    方法 分析字符串 <公开>
    {
        变量 局起始行 <类型 = 整数>
        局起始行 = 成员_当前行号
        变量 局内容 <类型 = 文本型>
        局内容 = "\""
        成员_位置 = 成员_位置 + 1
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局源码长度 + 10)
            {
                跳出循环 ()
            }
            如果 (成员_位置 > 局源码长度)
            {
                成员_错误信息组.加入成员 ("第" + 到文本 (局起始行) + "行: 未闭合的字符串")
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            局内容 = 局内容 + 到文本 ((字符) 局当前代码)
            如果 (局当前代码 == 92 && 成员_位置 < 局源码长度)
            {
                成员_位置 = 成员_位置 + 1
                局内容 = 局内容 + 到文本 (取字符 (成员_源码, 成员_位置 - 1))
            }
            否则 (局当前代码 == 34)
            {
                成员_位置 = 成员_位置 + 1
                跳出循环 ()
            }
            如果 (局当前代码 == 10)
            {
                成员_当前行号 = 成员_当前行号 + 1
            }
            成员_位置 = 成员_位置 + 1
        }
        循环判断尾 (成员_位置 <= 局源码长度)
        加入Token ("字符串", 局内容, 局起始行)
    }

    方法 分析字符字面量 <公开>
    {
        变量 局起始行 <类型 = 整数>
        局起始行 = 成员_当前行号
        变量 局内容 <类型 = 文本型>
        局内容 = "'"
        成员_位置 = 成员_位置 + 1
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        循环判断首 ()
        {
            如果 (成员_位置 > 局源码长度)
            {
                成员_错误信息组.加入成员 ("第" + 到文本 (局起始行) + "行: 未闭合的字符字面量")
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            局内容 = 局内容 + 到文本 ((字符) 局当前代码)
            如果 (局当前代码 == 92 && 成员_位置 < 局源码长度)
            {
                成员_位置 = 成员_位置 + 1
                局内容 = 局内容 + 到文本 (取字符 (成员_源码, 成员_位置 - 1))
            }
            否则 (局当前代码 == 39)
            {
                成员_位置 = 成员_位置 + 1
                跳出循环 ()
            }
            成员_位置 = 成员_位置 + 1
        }
        循环判断尾 (成员_位置 <= 局源码长度)
        加入Token ("字符字面量", 局内容, 局起始行)
    }

    方法 分析数字 <公开>
    {
        变量 局内容 <类型 = 文本型>
        局内容 = ""
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        循环判断首 ()
        {
            如果 (成员_位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            如果 ((局当前代码 >= 48 && 局当前代码 <= 57) || 局当前代码 == 46 || 局当前代码 == 120 || 局当前代码 == 88 || (局当前代码 >= 97 && 局当前代码 <= 102) || (局当前代码 >= 65 && 局当前代码 <= 70))
            {
                局内容 = 局内容 + 到文本 ((字符) 局当前代码)
                成员_位置 = 成员_位置 + 1
            }
            否则
            {
                跳出循环 ()
            }
        }
        循环判断尾 (成员_位置 <= 局源码长度)
        加入Token ("数字", 局内容, 成员_当前行号)
    }

    方法 分析标识符或关键字 <公开>
    {
        变量 局内容 <类型 = 文本型>
        局内容 = ""
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        循环判断首 ()
        {
            如果 (成员_位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            如果 (是否为标识符字符 (局当前代码))
            {
                局内容 = 局内容 + 到文本 ((字符) 局当前代码)
                成员_位置 = 成员_位置 + 1
            }
            否则
            {
                跳出循环 ()
            }
        }
        循环判断尾 (成员_位置 <= 局源码长度)
        变量 局Token类型 <类型 = 文本型>
        局Token类型 = 识别关键字类型 (局内容)
        加入Token (局Token类型, 局内容, 成员_当前行号)
    }

    方法 识别关键字类型 <公开 类型 = 文本型>
    参数 词语文本 <类型 = 文本型>
    {
        变量 局计数 <类型 = 整数>
        局计数 = 成员_关键字查找器.成员_中文关键字组.取成员数 ()
        变量 局索引 <类型 = 整数>
        循环 (局索引 = 0; 局索引 < 局计数; 局索引++)
        {
            如果 (文本比较 (成员_关键字查找器.成员_中文关键字组.取成员 (局索引), 词语文本, 真) == 0)
            {
                返回 ("中文关键字")
            }
            如果 (文本比较 (成员_关键字查找器.成员_英文关键字组.取成员 (局索引), 词语文本, 假) == 0)
            {
                返回 ("英文关键字")
            }
        }
        返回 ("标识符")
    }

    方法 分析运算符 <公开>
    {
        变量 局内容 <类型 = 文本型>
        局内容 = 到文本 (取字符 (成员_源码, 成员_位置 - 1))
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        如果 (成员_位置 < 局源码长度)
        {
            变量 局双字符 <类型 = 文本型>
            局双字符 = 局内容 + 到文本 (取字符 (成员_源码, 成员_位置))
            如果 (是否为双字符运算符 (局双字符))
            {
                局内容 = 局双字符
                成员_位置 = 成员_位置 + 2
                加入Token ("运算符", 局内容, 成员_当前行号)
                返回
            }
        }
        成员_位置 = 成员_位置 + 1
        加入Token ("运算符", 局内容, 成员_当前行号)
    }

    方法 是否为双字符运算符 <公开 类型 = 逻辑型>
    参数 双字符 <类型 = 文本型>
    {
        如果 (双字符 == "==" || 双字符 == "!=" || 双字符 == "<=" || 双字符 == ">=" || 双字符 == "&&" || 双字符 == "||" || 双字符 == "++" || 双字符 == "--" || 双字符 == "+=" || 双字符 == "-=" || 双字符 == "*=" || 双字符 == "/=" || 双字符 == "->" || 双字符 == "::" || 双字符 == "<<" || 双字符 == ">>")
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 分析预处理指令 <公开>
    {
        变量 局内容 <类型 = 文本型>
        局内容 = "#"
        成员_位置 = 成员_位置 + 1
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (成员_源码)
        循环判断首 ()
        {
            如果 (成员_位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (成员_源码, 成员_位置 - 1))
            如果 (局当前代码 == 10)
            {
                跳出循环 ()
            }
            局内容 = 局内容 + 到文本 ((字符) 局当前代码)
            成员_位置 = 成员_位置 + 1
        }
        循环判断尾 (成员_位置 <= 局源码长度)
        加入Token ("预处理", 局内容, 成员_当前行号)
    }

    方法 是否为标识符首字符 <公开 类型 = 逻辑型>
    参数 字符代码 <类型 = 整数>
    {
        如果 (字符代码 >= 65 && 字符代码 <= 90)
        {
            返回 (真)
        }
        如果 (字符代码 >= 97 && 字符代码 <= 122)
        {
            返回 (真)
        }
        如果 (字符代码 == 95)
        {
            返回 (真)
        }
        如果 (字符代码 > 127)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 是否为标识符字符 <公开 类型 = 逻辑型>
    参数 字符代码 <类型 = 整数>
    {
        如果 (是否为标识符首字符 (字符代码))
        {
            返回 (真)
        }
        如果 (字符代码 >= 48 && 字符代码 <= 57)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 是否为运算符字符 <公开 类型 = 逻辑型>
    参数 字符代码 <类型 = 整数>
    {
        如果 (字符代码 == 43 || 字符代码 == 45 || 字符代码 == 42 || 字符代码 == 47 || 字符代码 == 61 || 字符代码 == 60 || 字符代码 == 62 || 字符代码 == 33 || 字符代码 == 38 || 字符代码 == 124 || 字符代码 == 94 || 字符代码 == 37 || 字符代码 == 126)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 加入Token <公开>
    参数 类型 <类型 = 文本型>
    参数 文本 <类型 = 文本型>
    参数 行号 <类型 = 整数>
    {
        成员_Token类型组.加入成员 (类型)
        成员_Token文本组.加入成员 (文本)
        成员_Token行号组.加入成员 (行号)
    }

    方法 取Token数量 <公开 类型 = 整数>
    {
        返回 (成员_Token类型组.取成员数 ())
    }

    方法 取Token类型 <公开 类型 = 文本型>
    参数 索引 <类型 = 整数>
    {
        如果 (索引 < 0 || 索引 >= 成员_Token类型组.取成员数 ())
        {
            返回 ("")
        }
        返回 (成员_Token类型组.取成员 (索引))
    }

    方法 取Token文本 <公开 类型 = 文本型>
    参数 索引 <类型 = 整数>
    {
        如果 (索引 < 0 || 索引 >= 成员_Token文本组.取成员数 ())
        {
            返回 ("")
        }
        返回 (成员_Token文本组.取成员 (索引))
    }

    方法 取Token行号 <公开 类型 = 整数>
    参数 索引 <类型 = 整数>
    {
        如果 (索引 < 0 || 索引 >= 成员_Token行号组.取成员数 ())
        {
            返回 (0)
        }
        返回 (成员_Token行号组.取成员 (索引))
    }

    方法 取错误信息 <公开 类型 = 文本型>
    {
        变量 局结果 <类型 = 文本型>
        局结果 = ""
        变量 局计数 <类型 = 整数>
        局计数 = 成员_错误信息组.取成员数 ()
        变量 局索引 <类型 = 整数>
        循环 (局索引 = 0; 局索引 < 局计数; 局索引++)
        {
            局结果 = 局结果 + 成员_错误信息组.取成员 (局索引) + "\n"
        }
        返回 (局结果)
    }

    方法 是否有错误 <公开 类型 = 逻辑型>
    {
        返回 (成员_错误信息组.取成员数 () > 0)
    }

    方法 取Token列表文本 <公开 类型 = 文本型>
    {
        变量 局结果 <类型 = 文本型>
        局结果 = ""
        变量 局计数 <类型 = 整数>
        局计数 = 成员_Token类型组.取成员数 ()
        变量 局索引 <类型 = 整数>
        循环 (局索引 = 0; 局索引 < 局计数; 局索引++)
        {
            局结果 = 局结果 + "[" + 成员_Token类型组.取成员 (局索引) + "] " + 成员_Token文本组.取成员 (局索引) + "  (行" + 到文本 (成员_Token行号组.取成员 (局索引)) + ")\n"
        }
        返回 (局结果)
    }
}

类 语法分析器 <公开>
{
    变量 成员_词法 <类型 = 词法分析器>
    变量 成员_当前位置 <类型 = 整数>
    变量 成员_错误信息组 <类型 = 文本数组类>
    变量 成员_关键字查找器 <类型 = 中文编译器>

    方法 初始化 <公开>
    {
        成员_词法 = 新建对象 (词法分析器)
        成员_当前位置 = 0
        成员_错误信息组.删除所有成员 ()
        成员_关键字查找器.初始化 ()
    }

    方法 分析源码 <公开 类型 = 文本型>
    参数 源码 <类型 = 文本型>
    {
        成员_词法.初始化 (源码)
        成员_词法.执行词法分析 ()
        成员_当前位置 = 0
        成员_错误信息组.删除所有成员 ()
        如果 (成员_词法.是否有错误 ())
        {
            返回 ("词法分析错误:\n" + 成员_词法.取错误信息 ())
        }
        变量 局结果 <类型 = 文本型>
        局结果 = 生成C加加代码 ()
        如果 (成员_错误信息组.取成员数 () > 0)
        {
            局结果 = 局结果 + "\n\n语法分析警告:\n"
            变量 局索引 <类型 = 整数>
            循环 (局索引 = 0; 局索引 < 成员_错误信息组.取成员数 (); 局索引++)
            {
                局结果 = 局结果 + 成员_错误信息组.取成员 (局索引) + "\n"
            }
        }
        返回 (局结果)
    }

    方法 生成C加加代码 <公开 类型 = 文本型>
    {
        变量 局输出 <类型 = 文本型>
        局输出 = ""
        变量 局Token数量 <类型 = 整数>
        局Token数量 = 成员_词法.取Token数量 ()
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局Token数量 + 10)
            {
                跳出循环 ()
            }
            如果 (成员_当前位置 >= 局Token数量)
            {
                跳出循环 ()
            }
            变量 局类型 <类型 = 文本型>
            局类型 = 成员_词法.取Token类型 (成员_当前位置)
            变量 局文本 <类型 = 文本型>
            局文本 = 成员_词法.取Token文本 (成员_当前位置)
            如果 (局类型 == "中文关键字")
            {
                变量 局英文 <类型 = 文本型>
                局英文 = 成员_关键字查找器.查找英文关键字 (局文本)
                局输出 = 局输出 + 局英文 + " "
            }
            否则 (局类型 == "英文关键字")
            {
                局输出 = 局输出 + 局文本 + " "
            }
            否则 (局类型 == "标识符")
            {
                局输出 = 局输出 + 局文本
            }
            否则 (局类型 == "数字")
            {
                局输出 = 局输出 + 局文本
            }
            否则 (局类型 == "字符串")
            {
                局输出 = 局输出 + 局文本
            }
            否则 (局类型 == "字符字面量")
            {
                局输出 = 局输出 + 局文本
            }
            否则 (局类型 == "运算符")
            {
                局输出 = 局输出 + " " + 局文本 + " "
            }
            否则 (局类型 == "分隔符")
            {
                局输出 = 局输出 + 局文本
                如果 (局文本 == "{" || 局文本 == "}")
                {
                    局输出 = 局输出 + "\n"
                }
                否则 (局文本 == ";")
                {
                    局输出 = 局输出 + "\n"
                }
            }
            否则 (局类型 == "预处理")
            {
                局输出 = 局输出 + 局文本 + "\n"
            }
            否则
            {
                局输出 = 局输出 + 局文本
            }
            成员_当前位置 = 成员_当前位置 + 1
        }
        循环判断尾 (成员_当前位置 < 局Token数量)
        返回 (局输出)
    }

    方法 取Token流文本 <公开 类型 = 文本型>
    {
        返回 (成员_词法.取Token列表文本 ())
    }

    方法 是否有错误 <公开 类型 = 逻辑型>
    {
        如果 (成员_词法.是否有错误 ())
        {
            返回 (真)
        }
        返回 (成员_错误信息组.取成员数 () > 0)
    }

    方法 取错误信息 <公开 类型 = 文本型>
    {
        变量 局结果 <类型 = 文本型>
        局结果 = 成员_词法.取错误信息 ()
        变量 局计数 <类型 = 整数>
        局计数 = 成员_错误信息组.取成员数 ()
        变量 局索引 <类型 = 整数>
        循环 (局索引 = 0; 局索引 < 局计数; 局索引++)
        {
            局结果 = 局结果 + 成员_错误信息组.取成员 (局索引) + "\n"
        }
        返回 (局结果)
    }
}
