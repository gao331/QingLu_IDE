        如果 (文本类.寻找文本 (代码, "queue", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<queue>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <queue>\n"
        }
        如果 (文本类.寻找文本 (代码, "stack", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<stack>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <stack>\n"
        }
        如果 (文本类.寻找文本 (代码, "array", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<array>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <array>\n"
        }
        如果 ((文本类.寻找文本 (代码, "shared_ptr", 0, 假) >= 0 || 文本类.寻找文本 (代码, "unique_ptr", 0, 假) >= 0 || 文本类.寻找文本 (代码, "weak_ptr", 0, 假) >= 0 || 文本类.寻找文本 (代码, "make_shared", 0, 假) >= 0 || 文本类.寻找文本 (代码, "make_unique", 0, 假) >= 0) && 文本类.寻找文本 (代码, "<memory>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <memory>\n"
        }
        如果 (文本类.寻找文本 (代码, "thread", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<thread>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <thread>\n"
        }
        如果 (文本类.寻找文本 (代码, "mutex", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<mutex>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <mutex>\n"
        }
        如果 (文本类.寻找文本 (代码, "atomic", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<atomic>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <atomic>\n"
        }
        如果 (文本类.寻找文本 (代码, "tuple", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<tuple>", 0, 假) < 0)
        {
            需加头文件 = 需加头文件 + "#include <tuple>\n"
        }
        如果 (文本类.寻找文本 (代码, "stringstream", 0, 假) >= 0 && 文本类.寻找文本 (代码, "<sstream>", 0, 假) < 0)
        {
