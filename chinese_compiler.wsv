        }
        如果 (字符代码 >= 65 && 字符代码 <= 90)
        {
            返回 (真)
        }
        如果 (字符代码 >= 97 && 字符代码 <= 122)
        {
            返回 (真)
        }
        如果 (字符代码 == 95)
        {
            返回 (真)
        }
        如果 (字符代码 > 127)
        {
            返回 (真)
        }
        返回 (假)
    }

    方法 提取字符串 <公开 类型 = 文本型>
    参数 源码 <类型 = 文本型>
    参数 起始位置 <类型 = 整数>
    {
        变量 局结果 <类型 = 文本型>
        局结果 = "\""
        变量 局位置 <类型 = 整数>
        局位置 = 起始位置 + 1
        变量 局源码长度 <类型 = 整数>
        局源码长度 = 取文本长度 (源码)
        变量 局安全 <类型 = 整数>
        局安全 = 0
        循环判断首 ()
        {
            局安全 = 局安全 + 1
            如果 (局安全 > 局源码长度 + 10)
            {
                跳出循环 ()
            }
            如果 (局位置 > 局源码长度)
            {
                跳出循环 ()
            }
            变量 局当前代码 <类型 = 整数>
            局当前代码 = 无符号字符到整数 (取字符 (源码, 局位置 - 1))
            局结果 = 局结果 + 到文本 ((字符) 局当前代码)
            如果 (局当前代码 == 92 && 局位置 < 局源码长度)
            {
                局位置 = 局位置 + 1
                局结果 = 局结果 + 到文本 (取字符 (源码, 局位置 - 1))
            }
            否则 (局当前代码 == 34)
            {
                局位置 = 局位置 + 1
                跳出循环 ()
            }
            局位置 = 局位置 + 1
        }
        循环判断尾 (局位置 <= 局源码长度)
        返回 (局结果)
    }

